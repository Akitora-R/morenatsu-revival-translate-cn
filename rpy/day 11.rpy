# game/day 11.rpy:1699
translate chinese_simplified juuichi11_dodge_07fdee82:

    # "Since I have no idea what this 'mas' is,\nI continue to question him."
    # [旧版翻译] 来源: 柔一_s_01.ks (KS 220)
