# game/day 11.rpy:199
translate chinese_simplified torahiko11_7b7fcd54:

    # fn "「Eh?{w} Is that okay, Granpa?」"
    # [旧版翻译] 来源: 11日目.ks (KS 87)
    fn "诶？[l]可以吗？"

# game/day 11.rpy:200
translate chinese_simplified torahiko11_c3755a08:

    # gp "「Ah. You should buy sweets at the candy store\n on your way home.」"
    # [旧版翻译] 来源: 11日目.ks (KS 90)
    gp "嗯。[l]回来的时候可以去糖果店买些点心什么的"

# game/day 11.rpy:201
translate chinese_simplified torahiko11_be06f314:

    # fn "「Wow! Thank you!{w} I'll go now.」"
    # [旧版翻译] 来源: 11日目.ks (KS 93)
    fn "呜哇！[l]谢谢爷爷！[l]"

# game/day 11.rpy:206
translate chinese_simplified torahiko11_b729fa79:

    # "I got an unexpected extra income and somehow I feel the summer heat has been eased a little."
    # [旧版翻译] 来源: 11日目.ks (KS 99)
    "没想到还能得到些临时收入,貌似自身的疲惫感缓和了许多。"

# game/day 11.rpy:207
translate chinese_simplified torahiko11_02b4cd32:

    # "I usually hate the shining sun, but now it seems to be one of the thing that make summer exciting."
    # [旧版翻译] 来源: 11日目.ks (KS 102)
    "虽然总是对那灿烂的阳光抱有着憎恨,但现在却觉得那是使夏季气氛高涨的要素之一了。"

# game/day 11.rpy:208
translate chinese_simplified torahiko11_9e1b5f7d:

    # "Recently, I often go buy junk food near the beach, so my budget was getting tighter and tighter."
    # [旧版翻译] 来源: 11日目.ks (KS 105-106)
    "最近因为去了海边,买了不少东西吃,渐渐地手头就越来越紧了。"

# game/day 11.rpy:213
translate chinese_simplified torahiko11_dfc3e54d:

    # "The village mayor lives in a very far house on the outskirts of the village.{w} When I arrive, I call out in a loud voice."
    # [旧版翻译] 来源: 11日目.ks (KS 111)
    "村长住在村子尽头的豪华房子里。[漏れ]从一块木板刨出来的大门那里试着喊了几下。"

# game/day 11.rpy:214
translate chinese_simplified torahiko11_b26a1d49:

    # fn "「Excuse me!」"
    # [旧版翻译] 来源: 11日目.ks (KS 117)
    fn "不好意思，有人吗？"

# game/day 11.rpy:215
translate chinese_simplified torahiko11_8e36397a:

    # who "「Hmmm?{w} Who are you?」"
    # [旧版翻译] 来源: 11日目.ks (KS 120)
    who "嗯？[l]是哪位啊？"

# game/day 11.rpy:219
translate chinese_simplified torahiko11_e2c89b9a:

    # "I see the village mayor is sitting on the porch."
    # [旧版翻译] 来源: 11日目.ks (KS 124)
    "坐在走廊上的村长注意到了我。"

# game/day 11.rpy:220
translate chinese_simplified torahiko11_e46a91d3:

    # "This is Shigure-san, the mayor of Minasato Village."
    # [旧版翻译] 来源: 11日目.ks (KS 125)
    "这位就是水乡村的村长,时雨村长。"

# game/day 11.rpy:221
translate chinese_simplified torahiko11_f33cc04d:

    # "He's looks like a dog-beastman's grandfather,{w} but while he looks like this, he seems to be a master of martial arts."
    # [旧版翻译] 来源: 11日目.ks (KS 127)
    "别看外表只是一位普通的犬兽人的老爷爷,其实是一位武术高手。"

# game/day 11.rpy:222
translate chinese_simplified torahiko11_a70d56fd:

    # "Tatsu-nii said that even he could be thrown away within a second."
    # [旧版翻译] 来源: 11日目.ks (KS 130)
    "辰兄还说过,就连辰平叔都可以被这个人轻松地扔出去。"

# game/day 11.rpy:223
translate chinese_simplified torahiko11_97fa170b:

    # "「Ah!{w} When I take a closer look at your face, is\n that you?{w} You've grown up.」"
    # [旧版翻译] 来源: 11日目.ks (KS 133-134)
    "哈，仔细一看，这不是博行吗？你已经长大了。"

# game/day 11.rpy:224
translate chinese_simplified torahiko11_74c068fc:

    # fn "「Heh, it's been a long time.{w} But I'm back in\n Minasato only during my summer vacation.」"
    # [旧版翻译] 来源: 11日目.ks (KS 137)
    fn "嘿嘿，好久不见了。[l]"

# game/day 11.rpy:228
translate chinese_simplified torahiko11_76b3b338:

    # sg "「I've heard about the rumors.{w} That the\n worst evil kid in the village is back. Hohoho!」"
    # [旧版翻译] 来源: 11日目.ks (KS 142)
    sg "早就听说了。[l]"

# game/day 11.rpy:229
translate chinese_simplified torahiko11_1fbc76c0:

    # fn "「The worst evil kid in the village...」"
    # [旧版翻译] 来源: 11日目.ks (KS 146)
    fn "村里第一捣蛋鬼……"

# game/day 11.rpy:233
translate chinese_simplified torahiko11_e7ac3e59:

    # sg "「Well, but I was in a position to enjoy watching from\n a long distance.{w} So did you come all the way to say\n hello today?」"
    # [旧版翻译] 来源: 11日目.ks (KS 150)
    sg "哈哈，虽然我只是站在旁边看着乐而已。[l]"

# game/day 11.rpy:234
translate chinese_simplified torahiko11_75d526f9:

    # fn "「Yes, Shigure-san. Moreover, my Grandma pickled the\n plums so I brought them.」"
    # [旧版翻译] 来源: 11日目.ks (KS 154)
    fn "嗯，还有带了些[漏れ]奶奶腌的梅干"

# game/day 11.rpy:235
translate chinese_simplified torahiko11_fd7f0472:

    # sg "「Oh right, those were taken from our plum tree.」"
    # [旧版翻译] 来源: 11日目.ks (KS 157)
    sg "哦，这是从我这的梅树摘的吧"

# game/day 11.rpy:236
translate chinese_simplified torahiko11_82716318:

    # sg "「Your grandmother is the best Umeboshi maker in\n the village.」"
    # [旧版翻译] 来源: 11日目.ks (KS 159-161)
    sg "你的奶奶可是村里最有名的梅干腌制大师。"

# game/day 11.rpy:237
translate chinese_simplified torahiko11_1f6dc276:

    # "The village mayor said while opening the lid of the jar and put a piece of Umeboshi in his mouth."
    # [旧版翻译] 来源: 11日目.ks (KS 163)
    "村长边说着边打开了罐子,并拿出了一颗梅干放进了嘴里。"

# game/day 11.rpy:241
translate chinese_simplified torahiko11_ca8ae588:

    # sg "「Yeah, it's an exquisite pickle.」"
    # [旧版翻译] 来源: 11日目.ks (KS 168)
    sg "嗯，腌制的味道甚是绝妙！"

# game/day 11.rpy:242
translate chinese_simplified torahiko11_86b3a950:

    # "Shigure-san tastes with a smile.{w} After all, as I get older, my taste sensation will probably become less sensitive..."
    # [旧版翻译] 来源: 11日目.ks (KS 170)
    "村长一脸笑容地品尝着。看来一旦老了,味觉就会变得迟钝啊……"

# game/day 11.rpy:246
translate chinese_simplified torahiko11_6b4f9399:

    # sg "「Come here, go to the porch. We'll have some cold\n barley tea.{w} Until then, tell me about the city.」"
    # [旧版翻译] 来源: 11日目.ks (KS 175)
    sg "那，上来坐坐吧。[l]要不要来杯冷麦茶。[l]"

# game/day 11.rpy:247
translate chinese_simplified torahiko11_bd10e487:

    # fn "「Thank you, Shigure-san!」"
    # [旧版翻译] 来源: 11日目.ks (KS 178-179)
    fn "谢谢，时雨村长！"

# game/day 11.rpy:253
translate chinese_simplified torahiko11_561a6b0d:

    # "He let me go up to the porch and talked about my life after moving to the city, while quenching my thirst with some cold barley tea."
    # [旧版翻译] 来源: 11日目.ks (KS 185-188)
    "坐在走廊上,一边喝着冷麦茶滋润着喉咙,一边���着搬到城市后的生活。"

# game/day 11.rpy:254
translate chinese_simplified torahiko11_f9c13b1b:

    # "I'm not a very active person, so I couldn't talk about it so much.{w} However, the village mayor listened to each one of them with a fresh reaction."
    # [旧版翻译] 来源: 11日目.ks (KS 190)
    "因为我不是个很健谈的人,所以讲故事什么的,都说得不是那么有意思。但是村长先生却认真地听着,每次都有不同的反应。"

# game/day 11.rpy:255
translate chinese_simplified torahiko11_9b8fd2a6:

    # sg "「Hohoho.{w} I didn't know such a thing could be so\n popular in the city.」"
    # [旧版翻译] 来源: 11日目.ks (KS 195)
    sg "哈哈。[l]现在城市里居然流行那种东西啊，"

# game/day 11.rpy:259
translate chinese_simplified torahiko11_27629ad4:

    # sg "「That's right.」"
    # [旧版翻译] 来源: 11日目.ks (KS 56)
    sg "啊，对了"

# game/day 11.rpy:260
translate chinese_simplified torahiko11_3ccac1e0:

    # sg "「Have you tasted this pickled plum?」"
    # [旧版翻译] 来源: 11日目.ks (KS 203)
    sg "[博行]也吃了这梅干吗？"

# game/day 11.rpy:261
translate chinese_simplified torahiko11_3bd0a10e:

    # fn "「Yes, I had it for lunch.」"
    # [旧版翻译] 来源: 11日目.ks (KS 206)
    fn "嗯，中午吃饭的时候一起吃了"

# game/day 11.rpy:262
translate chinese_simplified torahiko11_111ef3a6:

    # sg "「Hmm.{w} So did anything strange happened today?」"
    # [旧版翻译] 来源: 11日目.ks (KS 209)
    sg "嗯。[l]除此之外，"

# game/day 11.rpy:263
translate chinese_simplified torahiko11_3080366f:

    # fn "「Eh?{w}... Hmm ...{w} Well, when I left home today, my\n Grandpa gave me some pocket money.」"
    # [旧版翻译] 来源: 11日目.ks (KS 213)
    fn "诶？[l]……嗯……[l]好像出门的时候，"

# game/day 11.rpy:267
translate chinese_simplified torahiko11_4ace5925:

    # sg "「Hohoho, then that was good.」"
    # [旧版翻译] 来源: 11日目.ks (KS 218)
    sg "哈哈，那真是太好了"

# game/day 11.rpy:268
translate chinese_simplified torahiko11_f00793d7:

    # sg "「Actually, there's a legend about the plums of\n this house.」"
    # [旧版翻译] 来源: 11日目.ks (KS 221)
    sg "其实啊，这家的梅树有个传说"

# game/day 11.rpy:269
translate chinese_simplified torahiko11_c3e7cf35:

    # fn "「A legend?」"
    # [旧版翻译] 来源: 11日目.ks (KS 224)
    fn "传说？"

# game/day 11.rpy:270
translate chinese_simplified torahiko11_e15a3d08:

    # sg "「Well, I've heard it from my grandfather...{p} Do you want to hear it?」"
    # [旧版翻译] 来源: 11日目.ks (KS 227)
    sg "我也是从爷爷那听来的。[l]想听吗？"

# game/day 11.rpy:271
translate chinese_simplified torahiko11_7b1ce19f:

    # fn "「Of course, Shigure-san.」"
    # [旧版翻译] 来源: 11日目.ks (KS 227)
    fn "想听"

# game/day 11.rpy:275
translate chinese_simplified torahiko11_b89ddc20:

    # sg "「Once upon a time...」"
    # [旧版翻译] 来源: 11日目.ks (KS 234)
    sg "很～久很久以前……"

# game/day 11.rpy:280
translate chinese_simplified torahiko11_516e688f:

    # "There was a beautiful young woman in a village.{w} One early summer, she fell in love with a fish seller."
    # [旧版翻译] 来源: 11日目.ks (KS 239)
    "有个村子里住着一位年轻漂亮的女人。"

# game/day 11.rpy:281
translate chinese_simplified torahiko11_0b8e0bb0:

    # "The man seemed to have interest in the woman, too.{w} And they soon became close friends."
    # [旧版翻译] 来源: 11日目.ks (KS 241)
    "那个女人在初夏的时候爱上了一个卖鱼的渔夫。"

# game/day 11.rpy:282
translate chinese_simplified torahiko11_e10783fd:

    # "However, the dream between those two did not come true from the beginning.{w} Because the man was from another village."
    # [旧版翻译] 来源: 11日目.ks (KS 243)
    "渔夫好像也很在意女人,他们很快就成为了亲密的关系。"

# game/day 11.rpy:283
translate chinese_simplified torahiko11_4cff5799:

    # "At that time, it was forbidden to marry a man from another village in the village where the woman came from."
    # [旧版翻译] 来源: 11日目.ks (KS 246-248)
    "但是,两个人的恋情从一开始就是不可能的。是因为,那个渔夫是其他村子里的人。"

# game/day 11.rpy:284
translate chinese_simplified torahiko11_de6eda13:

    # "In an era when there used to be much fewer women, it was a struggle to prevent the precious beings that gave birth to children from leaking to other villages."
    # [旧版翻译] 来源: 11日目.ks (KS 250-251)
    "在那个时代,村里的女人跟别的村的男人结婚是被禁止的。"

# game/day 11.rpy:285
translate chinese_simplified torahiko11_01005c79:

    # "So if the people around them know about that relationship, she would surely get into troubles."
    # [旧版翻译] 来源: 11日目.ks (KS 253)
    "在那个女性地位比现在更低的时代,女性作为村子的劳动力的同时,也承担着传宗接代的任务。这种规则是防止劳动力外流到其他村子的苦肉计。"

# game/day 11.rpy:286
translate chinese_simplified torahiko11_36e15446:

    # "Knowing that, the two decided to have a secret signal."
    # [旧版翻译] 来源: 11日目.ks (KS 257)
    "如果这种关系被周围的人知道了,一定会被迫分开。"

# game/day 11.rpy:287
translate chinese_simplified torahiko11_41df4d02:

    # "When a man comes to the village to sell fish, he'll put a pine cone on the rock at the entrance of the village.{w} That's the signal of \"I want to meet you\"."
    # [旧版翻译] 来源: 11日目.ks (KS 259-263)
    "当渔夫来村里卖鱼时，他会在村子入口前的岩石上放一颗松果。[l] 那是\"想见你\"的信号。"

# game/day 11.rpy:288
translate chinese_simplified torahiko11_fc9c22c5:

    # "While the man is selling fish in the village, the woman will replace the pine cones with plum seeds.{w} That is the signal of \"Received\"."
    # [旧版翻译] 来源: 11日目.ks (KS 265-267)
    "当男人在村里卖鱼时，女人会把松果换成梅子的种子。[l] 那是\"知道了\"的信号。"

# game/day 11.rpy:289
translate chinese_simplified torahiko11_a3260ee7:

    # "On the night of the day when the signal was given,{w} they'll meet at a shrine between each other's villages."
    # [旧版翻译] 来源: 11日目.ks (KS 269-270)
    "暗号对上之夜,他们就会在彼此村子间的神社里见面。"

# game/day 11.rpy:290
translate chinese_simplified torahiko11_3c8dce51:

    # "And for a limited time until the dawn, the two will love each other as hard as they could."
    # [旧版翻译] 来源: 11日目.ks (KS 272)
    "在黎明来临之前那有限的时间里,两人竭尽全力地交换着爱。"

# game/day 11.rpy:295
translate chinese_simplified torahiko11_21c702b4:

    # sg "「And...{w} the descendants of the plum trees at that\n time are the plum trees in this house.」"
    # [旧版翻译] 来源: 11日目.ks (KS 279)
    sg "然后……那时的梅树的后代，就是在这里的梅树"

# game/day 11.rpy:299
translate chinese_simplified torahiko11_375e9b9a:

    # sg "「It seems that the offspring of the pine trees are\n also growing well somewhere.」"
    # [旧版翻译] 来源: 11日目.ks (KS 284)
    sg "还有，松树的子孙似乎也在某处茁壮成长"

# game/day 11.rpy:300
translate chinese_simplified torahiko11_109f24c4:

    # fn "「So...{w} What happened to those two?」"
    # [旧版翻译] 来源: 11日目.ks (KS 287)
    fn "嗯……[l]顺便问一下，那两个人最后怎么样了？"

# game/day 11.rpy:301
translate chinese_simplified torahiko11_8d9c0cf4:

    # sg "「According to the legend I've heard, they ran off.」"
    # [旧版翻译] 来源: 11日目.ks (KS 290)
    sg "据我所听到的传说，好像是私奔了"

# game/day 11.rpy:302
translate chinese_simplified torahiko11_4aa1cb29:

    # sg "「Eventually it seems that he pioneered a new land,\n had many children and found a new village.」"
    # [旧版翻译] 来源: 11日目.ks (KS 293)
    sg "并且开拓了新的土地，生了很多孩子，"

# game/day 11.rpy:303
translate chinese_simplified torahiko11_41591518:

    # fn "「Wow, it sounds like a really good story.」"
    # [旧版翻译] 来源: 11日目.ks (KS 297)
    fn "看来是个好故事啊"

# game/day 11.rpy:307
translate chinese_simplified torahiko11_d474c3c3:

    # sg "「Well, I don't know if it really happened.」"
    # [旧版翻译] 来源: 11日目.ks (KS 301)
    sg "不过，我也不知道这故事是不是真的"

# game/day 11.rpy:311
translate chinese_simplified torahiko11_11c0ec1e:

    # sg "「However, it is said that:{w} if you eat the fruit of\n the plum tree in this house because of that story,{p} good things will happen to the person who ate it.」"
    # [旧版翻译] 来源: 11日目.ks (KS 305)
    sg "只是，那个故事的由来是吃这个家的梅树的果实，"

# game/day 11.rpy:312
translate chinese_simplified torahiko11_1e5bd7e9:

    # fn "「Eh?」"
    # [旧版翻译] 来源: 11日目.ks (KS 87)
    fn "诶？"

# game/day 11.rpy:313
translate chinese_simplified torahiko11_0163fe5b:

    # "Unintentionally, I saw a plum tree from the porch.{w} However, it doesn't look like it has such a mysterious power."
    # [旧版翻译] 来源: 11日目.ks (KS 311)
    "我不由自主地望向了梅树。不过,却看不出有什么不可思议的力量。"

# game/day 11.rpy:314
translate chinese_simplified torahiko11_cf70dc3c:

    # sg "「I also don't know if that's true.」"
    # [旧版翻译] 来源: 11日目.ks (KS 316)
    sg "这个也是不知道是不是真的就是了"

# game/day 11.rpy:318
translate chinese_simplified torahiko11_431141f4:

    # sg "「But,{w} looks like you've actually experienced it.」"
    # [旧版翻译] 来源: 11日目.ks (KS 318-319)
    sg "「不过,看起来你实际上已经体验过了」"

# game/day 11.rpy:319
translate chinese_simplified torahiko11_018b93bd:

    # fn "「Wow, that's amazing...」"
    # [旧版翻译] 来源: 11日目.ks (KS 320)
    fn "不过，[博行]好像已经亲身体验过了"

# game/day 11.rpy:320
translate chinese_simplified torahiko11_5e62d0b9:

    # "While it's not a very scientific story, I actually got some pocket money from Grandpa.{w} So good things did happen.{w} I guess I'll have to believe a little."
    # [旧版翻译] 来源: 11日目.ks (KS 323)
    "好，好神奇……"

# game/day 11.rpy:321
translate chinese_simplified torahiko11_b821e9ea:

    # sg "「There's something else good may happen today after\n that. So don't miss your chance.」"
    # [旧版翻译] 来源: 11日目.ks (KS 325-326)
    sg "「那之后啊,还有好事会发生呢。所以不要错过机会哦」"

# game/day 11.rpy:322
translate chinese_simplified torahiko11_a6714476:

    # sg "「Well...{w} Thank you for visiting this old man.{p} It was fun to hear stories about the city.」"
    # [旧版翻译] 来源: 11日目.ks (KS 328-329)
    sg "「……谢谢你来探望我这个老头子。听城里的话题很开心」"

# game/day 11.rpy:323
translate chinese_simplified torahiko11_024aadd6:

    # fn "「Thank you for everything!」"
    # [旧版翻译] 来源: 11日目.ks (KS 331)
    fn "「谢谢村长先生了!」"

# game/day 11.rpy:327
translate chinese_simplified torahiko11_66f3fb0e:

    # sg "「Be careful when you go home!」"
    # [旧版翻译] 来源: 11日目.ks (KS 333)
    sg "「回去的时候小心点哦!」"

# game/day 11.rpy:328
translate chinese_simplified torahiko11_5e560b85:

    # fn "「Sure, Shigure-san!」"
    # [旧版翻译] 来源: 11日目.ks (KS 335)
    fn "「好的,时雨村长!»"

# game/day 11.rpy:333
translate chinese_simplified torahiko11_dca3864c:

    # "I give a light bow to the village mayor and then leave his house."
    # [旧版翻译] 来源: 11日目.ks (KS 337)
    "向村长轻轻鞠了一躬,然后离开了他的家。"

# game/day 11.rpy:334
translate chinese_simplified torahiko11_bdfcb75f:

    # "I walk in the opposite direction on the way I came.{w} Probably I'm going to buy some sweets at the candy store on my way home."
    # [旧版翻译] 来源: 11日目.ks (KS 339-340)
    "沿着来时的路往回走。回去的时候顺便去糖果店买些点心吧。"

# game/day 11.rpy:335
translate chinese_simplified torahiko11_4f567ab6:

    # "....{w} Even so, is the story of that plum tree true?{w} If true, what's the good thing going happen?"
    # [旧版翻译] 来源: 11日目.ks (KS 1177)
    "[虎彦 笑脸][l]【虎彦】[l]「抱歉,抱歉」"

# game/day 11.rpy:336
translate chinese_simplified torahiko11_1f60dc5c:

    # "Will I win something if I buy a Garigari-kun popsicle at the candy store?{w} Well I'd be very happy about that."
    # [旧版翻译] 来源: 11日目.ks (KS 1179)
    "「哈哈」"

# game/day 11.rpy:341
translate chinese_simplified torahiko11_8187d274:

    # "Finally, I arrived at the candy store."
    # [旧版翻译] 来源: 11日目.ks (KS 348)
    "终于到了糖果店。"

# game/day 11.rpy:342
translate chinese_simplified torahiko11_6d6ee12c:

    # "With my pocket money, I buy all kinds of snacks, chocolates, and classic Taiyakis."
    # [旧版翻译] 来源: 11日目.ks (KS 350)
    "我用零花钱买了各种各样的零食、巧克力,还有经典的鲷鱼烧。"

# game/day 11.rpy:343
translate chinese_simplified torahiko11_1c5ac7b9:

    # "It is strange that even if you have no appetite due to the heat stroke,{w} you still want to eat sweets."
    # [旧版翻译] 来源: 11日目.ks (KS 352)
    "真是奇怪,即使因为暑热没有食欲,却还是想吃甜食。"

# game/day 11.rpy:344
translate chinese_simplified torahiko11_8f3eff6a:

    # "And I also bought Garigari-kun popsicle with such a high expectation."
    # [旧版翻译] 来源: 11日目.ks (KS 354)
    "而且我还带着很高的期待买了冰棍。"

# game/day 11.rpy:345
translate chinese_simplified torahiko11_f2fc3840:

    # fn "「I wonder if it will win.」"
    # [旧版翻译] 来源: 11日目.ks (KS 356)
    fn "「不知道能不能中奖呢。」"

# game/day 11.rpy:349
translate chinese_simplified torahiko11_5b7f98fa:

    # "For the time being, I sit at the table outside the store and start eating the popsicle."
    # [旧版翻译] 来源: 11日目.ks (KS 358)
    "暂时坐在店外的桌上,开始吃起冰棍来。"

# game/day 11.rpy:350
translate chinese_simplified torahiko11_7b2ca6ed:

    # "The result is .........."
    # [旧版翻译] 来源: 11日目.ks (KS 360)
    "结果是……"

# game/day 11.rpy:351
translate chinese_simplified torahiko11_b1d60569:

    # "“Better luck next time!”"
    # [旧版翻译] 来源: 11日目.ks (KS 362)
    "「下次再来吧!?」"

# game/day 11.rpy:355
translate chinese_simplified torahiko11_b8344ca3:

    # "I was really expecting a little, but soon became embarrassed.{w} Yeah, I can't help believing in unrealistic powers."
    # [旧版翻译] 来源: 11日目.ks (KS 364-365)
    "虽然稍微有点期待,但马上就很失落了。是的,总是会忍不住去相信不现实的力量。"

# game/day 11.rpy:356
translate chinese_simplified torahiko11_17e43e4d:

    # "I mean in the first place, if the plums have such a power, Grandpa and Grandma, who usually eat it, would have become millionaires by now."
    # [旧版翻译] 来源: 11日目.ks (KS 367-368)
    "我的意思是,如果梅树有这种力量的话,经常吃它的爷爷和奶奶应该已经成为百万富翁了。"

# game/day 11.rpy:357
translate chinese_simplified torahiko11_2437b63a:

    # fn "「Well, that's what reality looks like, isn't it?」"
    # [旧版翻译] 来源: 11日目.ks (KS 370)
    fn "「嗯,就是这就是现实吧?」"

# game/day 11.rpy:358
translate chinese_simplified torahiko11_b523c648:

    # who "「What are you doing here?」"
    # [旧版翻译] 来源: 11日目.ks (KS 372)
    who "「你在这干什么呢?」"

# game/day 11.rpy:359
translate chinese_simplified torahiko11_b7de4bc2:

    # fn "「!!」"
    # [旧版翻译] 来源: 11日目.ks (KS 361)
    fn "再来一个"

# game/day 11.rpy:360
translate chinese_simplified torahiko11_84ce36f7:

    # fn "「... Torahiko!」"
    # [旧版翻译] 来源: 11日目.ks (KS 376)
    fn "「……虎彦!?」"

# game/day 11.rpy:364
translate chinese_simplified torahiko11_42fb3dbd:

    # to "「Well.{w} You look like you've fallen into some kind\n of misanthropy.」"
    # [旧版翻译] 来源: 11日目.ks (KS 378)
    to "会不会中呢？"

# game/day 11.rpy:365
translate chinese_simplified torahiko11_92e269c5:

    # fn "「Hmmm, miracle power is more distrusted rather than\n humans.」"
    # [旧版翻译] 来源: 11日目.ks (KS 381-382)
    fn "「嗯……奇迹的力量比人类更不可信啊」"

# game/day 11.rpy:369
translate chinese_simplified torahiko11_acc0d1eb:

    # to "「What's even that?」"
    # [旧版翻译] 来源: 11日目.ks (KS 384)
    to "「那是什么?」"

# game/day 11.rpy:370
translate chinese_simplified torahiko11_b8f46e73:

    # "Torahiko get off his bicycle and sit next to me."
    # [旧版翻译] 来源: 11日目.ks (KS 386)
    "虎彦从自行车上下来,坐到我的旁边。"

# game/day 11.rpy:374
translate chinese_simplified torahiko11_ba8d51c9:

    # fn "「How's it going, Torahiko?」"
    # [旧版翻译] 来源: 11日目.ks (KS 388)
    fn "「怎么样,虎彦?」"

# game/day 11.rpy:378
translate chinese_simplified torahiko11_68c53b1e:

    # to "「Hahh.{w} It's hard for me everyday to help around the\n house and practice swimming.」"
    # [旧版翻译] 来源: 11日目.ks (KS 390-391)
    to "「哈～啊。每天帮忙做家务和练习游泳都很辛苦呢。」"

# game/day 11.rpy:379
translate chinese_simplified torahiko11_8901a3f3:

    # fn "「It's still that difficult...」"
    # [旧版翻译] 来源: 11日目.ks (KS 393)
    fn "「还是那么辛苦啊……」"

# game/day 11.rpy:383
translate chinese_simplified torahiko11_37d1c7dd:

    # to "「Well, I'm enjoying summer by finding a break.」"
    # [旧版翻译] 来源: 11日目.ks (KS 395)
    to "「嗯,我享受夏天的方式就是找机会休息一下。」"

# game/day 11.rpy:384
translate chinese_simplified torahiko11_00679ac9:

    # "Both of us burst out laughing."
    # [旧版翻译] 来源: 孝之助_m_09.ks (KS 548)
    "两个人都笑出声来。"

# game/day 11.rpy:388
translate chinese_simplified torahiko11_0d31b020:

    # to "「How about you, [fn]?」"
    # [旧版翻译] 来源: 11日目.ks (KS 399)
    to "「你怎么样,[博行]?」"

# game/day 11.rpy:389
translate chinese_simplified torahiko11_1c0ace6c:

    # fn "「I think I'm enjoying it quite a bit.{w} But recently\n I've been feeling like the summer.」"
    # [旧版翻译] 来源: 11日目.ks (KS 401)
    fn "什么也就是这样啊？"

# game/day 11.rpy:393
translate chinese_simplified torahiko11_cd362ff2:

    # to "「Hey, are you okay?{w} In the old days, heat strokes\n have nothing to do with words.」"
    # [旧版翻译] 来源: 10日目.ks (KS 526)
    to "！！"

# game/day 11.rpy:394
translate chinese_simplified torahiko11_1f036914:

    # fn "「You mean the city has driven me crazy?{w} Heh it's\n okay, I just don't have an appetite for\n anything these days.」"
    # [旧版翻译] 来源: 11日目.ks (KS 407)
    fn "……虎彦！"

# game/day 11.rpy:395
translate chinese_simplified torahiko11_e18f486e:

    # fn "Well I just bought some sweets earlier..."
    # [旧版翻译] 来源: 11日目.ks (KS 410)
    fn "不过我刚才买了些甜食……"

# game/day 11.rpy:399
translate chinese_simplified torahiko11_3da30aff:

    # to "「Well!{w} Then I'll cook for you!」"
    # [旧版翻译] 来源: 11日目.ks (KS 412)
    to "嗨。[l]怎么一脸不相信人的表情啊"

# game/day 11.rpy:400
translate chinese_simplified torahiko11_eeb8e3bc:

    # fn "「Eh, really?」"
    # [旧版翻译] 来源: 11日目.ks (KS 414)
    fn "「诶,真的吗?」"

# game/day 11.rpy:401
translate chinese_simplified torahiko11_83f73674:

    # to "「Yes!{w} I'll make whatever you like.」"
    # [旧版翻译] 来源: 11日目.ks (KS 416)
    to "「嗯!?给你做你想吃的」"

# game/day 11.rpy:402
translate chinese_simplified torahiko11_41619e57:

    # fn "「Okay then...{w} Nikujaga!」"
    # [旧版翻译] 来源: 11日目.ks (KS 418)
    fn "「那……土豆炖肉!?」"

# game/day 11.rpy:407
translate chinese_simplified torahiko11_1f7006ed:

    # to "「You really like that dish, don't you...?」"
    # [旧版翻译] 来源: 11日目.ks (KS 420)
    to "「你真的很喜欢那道菜呢……」"

# game/day 11.rpy:408
translate chinese_simplified torahiko11_cd3677e7:

    # fn "「I ate Satoru-san's Nikujaga last time, so I'd like\n to eat yours this time!」"
    # [旧版翻译] 来源: 11日目.ks (KS 422-423)
    fn "「上次吃了辰兄的土豆炖肉,所以这次想吃你做的!?」"

# game/day 11.rpy:412
translate chinese_simplified torahiko11_b70c3402:

    # to "「I see. Then I'll make it for dinner.{w} Let's go to\n my house.」"
    # [旧版翻译] 来源: 11日目.ks (KS 426)
    to "虎彦是去帮家里买东西吗？"

# game/day 11.rpy:413
translate chinese_simplified torahiko11_1d96f6d6:

    # fn "「Alright!」"
    # [旧版翻译] 来源: 11日目.ks (KS 487)
    fn "太好了！"

# game/day 11.rpy:417
translate chinese_simplified torahiko11_3e3821ee:

    # "The two of us get on Torahiko's bicycle and head to the Ooshima's Inn.{w} Since the candy store is not far from the Inn, we arrive almost immediately."
    # [旧版翻译] 来源: 11日目.ks (KS 492)
    "虎彦骑着自行车载着我两人,前往大岛旅馆。因为糖果店离旅馆不远,所以很快就到了。"

# game/day 11.rpy:422
translate chinese_simplified torahiko11_6afedac0:

    # to "「Konnichiwa!」"
    # [旧版翻译] 来源: 11日目.ks (KS 502)
    to "打扰了—"

# game/day 11.rpy:423
translate chinese_simplified torahiko11_7347afb9:

    # takemi "「Oh! You've come over!」"
    # [旧版翻译] 来源: 11日目.ks (KS 505)
    takemi "哎呀！[l]小[博行]，你又来啦"

# game/day 11.rpy:424
translate chinese_simplified torahiko11_d3d0b233:

    # "Takemi-san was at the front door when we arrived."
    # [旧版翻译] 来源: 11日目.ks (KS 507)
    "在玄关，刚好看到竹美阿姨在。"

# game/day 11.rpy:425
translate chinese_simplified torahiko11_da485ab3:

    # fn "「Heheheh, Torahiko will cook for me so I came.」"
    # [旧版翻译] 来源: 11日目.ks (KS 510)
    fn "诶嘿嘿，因为虎彦要做料理，"

# game/day 11.rpy:426
translate chinese_simplified torahiko11_480329e2:

    # takemi "「Well, that's right.{w} He'll make delicious food\n today.」"
    # [旧版翻译] 来源: 11日目.ks (KS 514)
    takemi "嗯，就是啊。[l]他会做一些很美味的东西呢"

# game/day 11.rpy:430
translate chinese_simplified torahiko11_75e3b0c5:

    # to "「Hey hey...」"
    # [旧版翻译] 来源: 11日目.ks (KS 137)
    to "嘿嘿"

# game/day 11.rpy:431
translate chinese_simplified torahiko11_8432fc56:

    # fn "「Oh, and it's not good to come just for dinner, so I'll\n help the around again like before.」"
    # [旧版翻译] 来源: 11日目.ks (KS 521)
    fn "啊，只是为了吃饭就过来挺不好意思的，"

# game/day 11.rpy:432
translate chinese_simplified torahiko11_aeed27c8:

