# game/day 11.rpy:703
translate chinese_simplified torahiko11_ee5e5738:

    # fn "「...!!」"
    # [旧版翻译] 来源: 11日目.ks (KS 992)
    fn "「……!!」"

# game/day 11.rpy:704
translate chinese_simplified torahiko11_7d0b6368:

    # "The devil whispers inside my head.{w} And when I try to reach the bookshelf, the angel tries to stop my hand."
