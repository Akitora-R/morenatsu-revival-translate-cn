    # extend "{w=.5}{nw}"
    extend "{w=.5}{nw}"

# game/day 5.rpy:882
translate chinese_simplified tatsuki05_accept_31d80f5f:

    # fn "「Hey, Tatsu-nii, did you just hear something weird?」"
    fn "「等下，辰兄，刚刚是不是有什么奇怪的声音？」"

# game/day 5.rpy:887
translate chinese_simplified tatsuki05_accept_55a49c38:

    # ta "「Don't worry about it, the car's just old.{p} It's running fine.{p} ...Huh?」{w} {nw}"
    ta "「别担心啦，这家伙破破烂烂的有点顿了吧。\n你看——，提高点速度就没问题了。\n……啊勒？」"

# game/day 5.rpy:891
translate chinese_simplified tatsuki05_accept_22dcbbf6_3:

    # extend "{w=.5}{nw}"
    extend "{w=.5}{nw}"

# game/day 5.rpy:894
translate chinese_simplified tatsuki05_accept_63d66385:

    # extend "{w=.8}{nw}"
    extend "{w=.8}{nw}"

# game/day 5.rpy:897
translate chinese_simplified tatsuki05_accept_22dcbbf6_4:

    # extend "{w=.5}{nw}"
    extend "{w=.5}{nw}"

# game/day 5.rpy:900
translate chinese_simplified tatsuki05_accept_63d66385_1:

    # extend "{w=.8}{nw}"
    extend "{w=.8}{nw}"

# game/day 5.rpy:904
translate chinese_simplified tatsuki05_accept_f8300e95:

    # "The beaten-up frame gave a jolt\nas a weird noise came from the engine."
    "颤动的车体摇晃着，从引擎那边传来奇怪的声音。"

# game/day 5.rpy:905
translate chinese_simplified tatsuki05_accept_ccc14ae9:

    # "The needle in the speedometer dropped,\nand the truck stalled."
    "速度仪的指针也在下降，轻卡车渐渐地变慢了。"

# game/day 5.rpy:906
translate chinese_simplified tatsuki05_accept_345d004e:

    # "It rolled for a while,\nbut in the end, {w=.3}{nw}"
    "虽然这样但也在往前跑着，最后{w=.3}{nw}"

# game/day 5.rpy:909
translate chinese_simplified tatsuki05_accept_6f317e1c:

    # extend "it gave a hiss, {nw}"
    extend "噗哧——{nw}"

# game/day 5.rpy:911
translate chinese_simplified tatsuki05_accept_a87c6c36:

    # extend "{w=.05}{nw}"
    extend "{w=.05}{nw}"

# game/day 5.rpy:916
translate chinese_simplified tatsuki05_accept_7ca49345:

    # extend "and stopped."
    extend "的一声后停了下来。"

# game/day 5.rpy:918
translate chinese_simplified tatsuki05_accept_5525eb5d:

    # fn "「It stopped.」"
    fn "「停下来了呢」"

# game/day 5.rpy:926
translate chinese_simplified tatsuki05_accept_44ed97ac:

    # ta "「Whoops, it looks like it's out of gas.{p} No, wait, I forgot to put any in. Gahahaha!」"
    ta "「麻烦了，汽油用完了呢。\n咿呀咿呀——忘记加油了呢，嘎哈哈哈」"

# game/day 5.rpy:927
translate chinese_simplified tatsuki05_accept_e9de9d56:

    # fn "「What do we do?」"
    fn "「怎么办？」"

# game/day 5.rpy:931
translate chinese_simplified tatsuki05_accept_543e4a07:

    # ta "「Well, there's not much else we can do.{p} I'll get out and push, while you steer.」"
    ta "「既然停下来就没办法了。\n我下车到后面推，\n博行你能帮忙控制方向盘么？」"

# game/day 5.rpy:932
translate chinese_simplified tatsuki05_accept_7edd0eaa:

    # fn "「I don't have my licence.\n Even then, can you really push this thing?」"
    fn "「我没有驾照的哦，\n更重要的是，你真能推得动吗？」"

# game/day 5.rpy:936
translate chinese_simplified tatsuki05_accept_162ac3d3:

    # ta "「You don't need a licence if I'm pushing it.」"
    ta "「只是我在推而已驾照什么的不需要哦」"

# game/day 5.rpy:937
translate chinese_simplified tatsuki05_accept_f58c41bb:

    # ta "「Occasionally, when I run out of gas,\n I just push this back home,\n which is what Pa told me to do.」"
    ta "「偶尔遇上这样没油的时候就推回家去，这是老爸教我的呢」"

# game/day 5.rpy:938
translate chinese_simplified tatsuki05_accept_3858c94e:

    # "The crazy Midoriya father and son..."
    "恐怖的翠屋两父子……"

# game/day 5.rpy:942
translate chinese_simplified tatsuki05_accept_8a0cf9c6:

    # ta "「I know I said I'd drive you,\n but can you come along with me?」"
    ta "「虽然说过送你回去，能不能往我家方向走？」"

# game/day 5.rpy:943
translate chinese_simplified tatsuki05_accept_24619238:

    # fn "「Yeah, there's no helping it.{p} You messed up again, just like you always do.」"
    fn "「嗯，没办法嘛。\n而且辰兄做事失败什么的是常有的事」"

# game/day 5.rpy:947
translate chinese_simplified tatsuki05_accept_5e71fb52:

    # ta "「What was that!?」"
    ta "「你说啥」"

# game/day 5.rpy:951
translate chinese_simplified tatsuki05_accept_2708531a:

    # ta "「No... This is totally my fault.{p} Sorry about that, and thanks for helping, [fn].」"
    ta "「不……这次完全是我的失误呢。\n要你陪着我真是抱歉呢，谢谢啦博行」"

# game/day 5.rpy:952
translate chinese_simplified tatsuki05_accept_184b62ea:

    # fn "「Hey, no problem.」"
    fn "「没关系啦」"

# game/day 5.rpy:956
translate chinese_simplified tatsuki05_accept_46ce0042:

    # ta "「Okay, let's hurry on home.{p} I'll push from behind, and we'll be back soon.{p} You take care of the steering.」"
    ta "「好了，快点回去吧。\n我推的话很快就到家的了。\n方向盘就交给你咯。」"

# game/day 5.rpy:975
translate chinese_simplified juuichi05_bf6547ab:

    # "Heading to where I was meeting Juuichi-san,{w=.3}\nI walk along the embankment in silence.{p}Catching fireflies. That's our plan for today."
    "我朝着和柔一约好的集合地点，{w=.3}一个人在堤防上走着。{p}今天的目的，是要去找萤火虫。"

# game/day 5.rpy:976
translate chinese_simplified juuichi05_e75a7ecf:

    # "After talking to him yesterday,{p}I immediately went looking in the\nshed for something we could use."
    "昨天和柔一道别后，{p}我马上在家里找了找有没有什么能用的东西。"

# game/day 5.rpy:977
translate chinese_simplified juuichi05_40377751:

    # "The bug net I found in the corner looked promising,\nuntil I saw the large hole in the net."
    "在角落发现了放置已久的捕虫网，但上面却破了个大洞，已经不能使用了。"

# game/day 5.rpy:978
translate chinese_simplified juuichi05_76ae79a9:

    # "I even went out to get a brand new\ninsect-catching kit just for this outing,{w=.3}\nbut in the end, all I've got is this flashlight."
    "后来今天还花了一整天想要做一套新的捕虫用具，{w=.3}但结果最后还是只有带了手电筒出门。"

# game/day 5.rpy:979
translate chinese_simplified juuichi05_57152918:

    # "It's quite bright,{w=.3}\nand illuminates the surroundings\nmore than I thought it would."
    "比我想像中照得亮度还要强得多，{w=.3}照亮的范围完全不像是普通的亮度。"

# game/day 5.rpy:980
translate chinese_simplified juuichi05_5451a22a:

    # "The way the light cuts through the dark night\nhas a somewhat reliable feeling to it."
    "简直就像是要把黑夜给切开似的，这道直直往前射去的光线让人觉得莫名的可靠。"

# game/day 5.rpy:981
translate chinese_simplified juuichi05_41075c51:

    # "Although I felt lost in the dark yesterday,{p}I have a completely different impression of it\nnow that I have a light."
    "昨晚因为太暗结果害我吓成那样，{p}没想到有了光线之后给人的感觉会差那么多。"

# game/day 5.rpy:982
translate chinese_simplified juuichi05_a8f60f49:

    # "While I think about that,{w=.3}\nI take a look at my watch.{p}There are still...{w=.3} 15 minutes until the meeting."
    "我一边想着这些，{w=.3}一边用手电筒照了一下手表。{p}距离约好的时间……{w=.3}还有十五分钟啊。"

# game/day 5.rpy:983
translate chinese_simplified juuichi05_e38618d3:

    # "Damn,{w=.3} seems I was a little too early.{p}I'm at a bit of a loss on how to kill time..."
    "糟糕。{w=.3}似乎来得太早了的样子。{p}我正想着在这种地方要怎么打发时间才好的时候……"

# game/day 5.rpy:984
translate chinese_simplified juuichi05_6246ccd3:

    # ju "「Hey,{w=.3} [ln].」"
    ju "「喂，{w=.3}西村。」"

# game/day 5.rpy:989
translate chinese_simplified juuichi05_e656e044:

    # "It's the owner of the physique that dwarfs me.{p}Needless to say, it's the person I'm here to meet?{w=.3}\nthat is, it's Juuichi-san."
    "突然听到有人从背后叫我，害我身体整个震了一下。为了让急速跳动的心脏慢下来，我两手用力压着自己的胸口，接着转头看向出声叫我的人。{p}对方是个体型大到能够完全把我整个人遮住的人。{w=.3}当然不用说，他就是我在这里等的对象——也就是柔一。"

# game/day 5.rpy:990
translate chinese_simplified juuichi05_e3020124:

    # fn "「Oh, Juuichi-san!{w=.3} Good evening.{p} Please stop surprising me from behind...{w=.3}\n It's bad for my heart.」"
    fn "「啊，柔一。{w=.3}晚上好。{p}这样对心脏不好啦，{w=.3}拜托以后不要突然从背后叫我可以吗。」"

# game/day 5.rpy:991
translate chinese_simplified juuichi05_59209f70:

    # "As I greet him, I raise my voice in protest.{p}I guess I'm still twitchy from last night."
    "在打招呼之后，我忍不住马上提出了抗议。{p}被吓到的经验已经非常够啦。"

# game/day 5.rpy:995
translate chinese_simplified juuichi05_680c3746:

    # ju "「Sorry,{w=.3} I didn't mean to scare you.{p} I forgot that humans don't have good night vision.」"
    ju "「抱歉，{w=.3}我没有想要吓你的意思。{p}看来人类的夜视力好像真的不太好。」"

# game/day 5.rpy:996
translate chinese_simplified juuichi05_dc99a88f:

    # "I'm sure that even beastmen who can see fine\nat night would jump if their name was called out\nwhen they weren't expecting it."
    "就算夜晚视力很好的兽人，在这么暗的小路上，完全没有预兆地突然被叫名字的话，肯定也是会被吓到的吧。"

# game/day 5.rpy:997
translate chinese_simplified juuichi05_663bd16c:

    # "...Actually,{w=.3} Juuichi-san would probably just say{w=.3}\n'What do you want, at a time like this?' as though\nnothing was out of the ordinary."
    "……不过，是柔一的话，肯定会完全没事地回答{w=.3}「怎么了吗？这种时间还出门。」之类的吧。"

# game/day 5.rpy:998
translate chinese_simplified juuichi05_e1fd659f:

    # "Hmm.{w=.3} I suppose it depends on who was calling."
    "嗯，{w=.3}这种事每个人的反应都不一样。"

# game/day 5.rpy:999
translate chinese_simplified juuichi05_e3ce1851:

    # fn "「Juuichi-san,{w=.3} you got here pretty fast.{p} And here I was thinking I was too early.」"
    fn "「柔一，{w=.3}你来得真早呢。{p}我才刚想说，是不是来得有点太早了说。」"

# game/day 5.rpy:1003
translate chinese_simplified juuichi05_dc4b901c:

    # ju "「...Really?」"
    ju "「……是吗？」"

# game/day 5.rpy:1004
translate chinese_simplified juuichi05_8cea886d:

    # fn "「Yeah.{w} There are still about 15 minutes\n until the time we were going to meet.」"
    fn "「是啊。{w}离约定的时间还有差不多十五分钟呢。」"

# game/day 5.rpy:1008
translate chinese_simplified juuichi05_412f386c:

    # ju "「15 minutes isn't really that early.」"
    ju "「十五分钟的话，{w=.3}还不算是太早吧。」"

# game/day 5.rpy:1009
translate chinese_simplified juuichi05_c780d319:

    # "Hmm,{w=.3} I don't know about that.{p}I'm the type who likes to\ndo things at the last minute."
    "嗯——{w=.3}可能是那样吧。{p}我基本上都是等差不多时间了才会到的那种类型，所以感觉不一样。"

# game/day 5.rpy:1010
translate chinese_simplified juuichi05_6cbb65b7:

    # "...As expected, Juuichi-san's the leader again.{p}I consider apologising for being late,\nbut I was technically here early."
    "……不过今天是想说特地请柔一来带路了，{p}要是还迟到的话真的很不好意思，所以才特地提早出门的。"

# game/day 5.rpy:1014
translate chinese_simplified juuichi05_41c95071:

    # ju "「...Well,{w=.3} it's better than always being late,\n like a certain someone, right?」"
    ju "「……哎，{w=.3}不管怎样总比每次都迟到的某人好得多了吧？」"

# game/day 5.rpy:1015
translate chinese_simplified juuichi05_a5f105ad:

    # "Juuichi-san speaks with a low growl.{p}...He must be talking about Kounosuke."
    "柔一用喉咙深处的低音说着。{p}……这个，不管怎么想应该都是在说孝之助吧。"

# game/day 5.rpy:1016
translate chinese_simplified juuichi05_c772a8e2:

    # "I suppose he does have a reputation for being late.{p}It's not easy to make Juuichi-san growl.{w=.3}\n...Well, in a bad way."
    "真不愧是以迟到为标准的男人。{p}会被柔一抱怨的事情，{w=.3}通常不会是什么好事。"

# game/day 5.rpy:1017
translate chinese_simplified juuichi05_23a01831:

    # fn "「...Ahem.{p} It's still a little early,{w=.3}\n but why don't we get going?」"
    fn "「……咳嗯。{p}虽然是有点早，{w=.3}不过也差不多可以出发了吧。{p}今天也只有我们两人而已。」"

# game/day 5.rpy:1018
translate chinese_simplified juuichi05_c03ced40:

    # fn "「It's just the two of us today.」"
    fn "「今天也只有我们两人而已。」"

# game/day 5.rpy:1022
translate chinese_simplified juuichi05_ecddcbef:

    # ju "「Yeah,{w=.3} you're right.」"
    ju "「啊啊，{w=.3}这倒是。」"

# game/day 5.rpy:1026
translate chinese_simplified juuichi05_4658bf09:

    # "We set out, with Juuichi-san in front.{p}I follow the beams of light\ncoming from our flashlights with my eyes."
    "以柔一走在前面带路的队形，我们就这么出发了。{p}为了安心，我的眼睛一直盯着手电筒照出的两道光线往前看。"

# game/day 5.rpy:1027
translate chinese_simplified juuichi05_68f13f51:

    # "The large flashlight he's holding looks like it\nwas built for emergency situations.{w=.3}\nIt has a whole bunch of knobs and switches on it."
    "而且柔一带的，是紧急情况下使用的专用超大型手电筒。{w=.3}连调亮度的按钮、光度表等等的上面都有。"

# game/day 5.rpy:1028
translate chinese_simplified juuichi05_b627df44:

    # "From its appearance,{w=.3}\nit must have an inbuilt radio.{p}Curious, I ask him about it."
    "照那个样子看来，{w=.3}恐怕是那种里面还有藏着收音机的类型。{p}想到这一点，{w=.3}我往前多跨两步追上柔一跟他搭话。"

# game/day 5.rpy:1029
translate chinese_simplified juuichi05_aa5cdd60:

    # fn "「Juuichi-san,{w=.3} do you usually listen to the radio\n when you're out walking?」"
    fn "「柔一，{w=.3}平常你在一个人散步的时候，会听收音机吗？」"

# game/day 5.rpy:1033
translate chinese_simplified juuichi05_4559f6f6:

    # ju "「No.」"
    ju "「不。」"

# game/day 5.rpy:1034
translate chinese_simplified juuichi05_aeca2ff7:

    # "He shakes his head."
    "柔一摇了摇头。"

# game/day 5.rpy:1038
translate chinese_simplified juuichi05_735aeb85:

    # ju "「When I'm walking alone,{w=.3}\n I remember that day's practice,\n and try to figure out how to improve.」"
    ju "「一个人的时候，我会回想当天的练习内容，{w=.3}或是在脑海中进行想像重训。{p}完全没有听过收音机。」"

# game/day 5.rpy:1039
translate chinese_simplified juuichi05_e37c969e:

    # ju "「I rarely listen to the radio.」"
    ju "「完全没有听过收音机。」"

# game/day 5.rpy:1043
translate chinese_simplified juuichi05_f678db11:

    # ju "「...Why,{w=.3} is there a program\n you wanted to listen to?」"
    ju "「……怎么了，{w=.3}是现在有什么想要听的节目吗？」"

# game/day 5.rpy:1044
translate chinese_simplified juuichi05_1e8becf6:

    # "I hastily shake my head in response to his question."
    "听了柔一的问题，我连忙摇头。"

# game/day 5.rpy:1045
translate chinese_simplified juuichi05_1894a817:

    # fn "「Oh,{w=.3} that's not what I meant.{p} I noticed all those buttons and the tuner,\n and was just curious.」"
    fn "「啊，{w=.3}没有啦不是那样。{p}因为看到那个手电筒上有按钮和调频器的关系，所以就想问问看。」"

# game/day 5.rpy:1046
translate chinese_simplified juuichi05_28c5fc66:

    # fn "「...But it looks like it's seen some use, doesn't it?{p} It seems like it's an old design, too.」"
    fn "「……不过，{w=.3}那手电筒是不是有点老了啊？{p}造型看起来也比较像以前的设计。」"

# game/day 5.rpy:1052
translate chinese_simplified juuichi05_090313e5:

    # "When I ask him about that,\nhe strikes the flashlight, hard.\nIt sounds much more solid than I thought it would."
    "我刚问完，柔一就拿起手电筒用力敲了两下给我看。声音听起来比想像中还要硬的感觉。"

# game/day 5.rpy:1056
translate chinese_simplified juuichi05_12601869:

    # ju "「It used to be my father's.{p} It may look old-fashioned,{w=.3}\n but it's well-built, so it still works fine.」"
    ju "「这原本是我老爸在用的东西。{p}看起来或许是有点老旧，{w=.3}不过因为做得很好所以现在还能用。」"

# game/day 5.rpy:1057
translate chinese_simplified juuichi05_c2fd7ea7:

    # ju "「Besides,{w=.3} you grow attached to the things you\n use for a long time, even if it is just a tool.」"
    ju "「而且，{w=.3}使用了很久的东西，就算只是一般物品也多少会有点感情的。」"

# game/day 5.rpy:1058
translate chinese_simplified juuichi05_26f374f1:

    # fn "「It's a ten-year veteran!」"
    fn "「用惯的武器那种感觉？」"

# game/day 5.rpy:1062
translate chinese_simplified juuichi05_f2950b75:

    # ju "「...It might be even older than that.」"
    ju "「……我也不太会说，可能比那个还重要吧。」"

# game/day 5.rpy:1063
translate chinese_simplified juuichi05_074cda5b:

    # "The rugged model and chipped paint\nmake it seem even more mysterious."
    "明明是造型看起来硬梆梆的，而且外面的漆还有很多地方剥落了的手电筒，{w=.3}用这种方式去看它之后反而有种奇妙的感觉。"

# game/day 5.rpy:1064
translate chinese_simplified juuichi05_121f5ca4:

    # fn "「It might even be older than us.{p} ...By the way, how long does it take\n to get to where the fireflies are?」"
    fn "「这东西的年纪可能比我们还要大也不一定呢。{p}……说起来，{w=.3}到有萤火虫的地方还很远吗？」"

# game/day 5.rpy:1068
translate chinese_simplified juuichi05_a0e33080:

    # ju "「...From here,{w=.3} about twenty minutes or so.」"
    ju "「……从这里的话，{w=.3}大概还要走二十分钟吧。」"

# game/day 5.rpy:1069
translate chinese_simplified juuichi05_e930209e:

    # fn "「It's farther upstream, right?」"
    fn "「在更上游的地方？」"

# game/day 5.rpy:1070
translate chinese_simplified juuichi05_40f2a2a4:

    # ju "「Yeah.」"
    ju "「啊啊。」"

# game/day 5.rpy:1071
translate chinese_simplified juuichi05_ecd2bc8e:

    # fn "「I'm looking forward to it.{p} It's been a while since I've seen something magical.」"
    fn "「让人好期待喔。{p}到底是多么幻想般的景象呢。」"

# game/day 5.rpy:1075
translate chinese_simplified juuichi05_8facd34f:

    # ju "「...Magical?」"
    ju "「……幻想？」"

# game/day 5.rpy:1076
translate chinese_simplified juuichi05_7b2566df:

    # fn "「You know the feeling where you've been overwhelmed\n by the beauty of nature?{p} That was the best way I could describe it.」"
    fn "「就是说，{w=.3}自然的美景不是有时候会有那种压倒性的美感吗？{p}这是我能想到最接近的说法啦。」"

# game/day 5.rpy:1077
translate chinese_simplified juuichi05_a0745a35:

    # "I guess it wasn't the best way to say it...?\nI start to worry about it."
    "是不是这种说法哪里怪怪的呢……{w=.3}我心中忍不住开始有点担心了起来。"

# game/day 5.rpy:1081
translate chinese_simplified juuichi05_684f1486:

    # ju "「...I see.{p} {nw}"
    ju "「……原来如此。{p}{nw}"

# game/day 5.rpy:1083
translate chinese_simplified juuichi05_6932e8ba:

    # extend "Well,{w=.3} that's just like you to think that.」"
    extend "{fast}哎，{w=.3}真是有西村风格的想法啊。」"

# game/day 5.rpy:1084
translate chinese_simplified juuichi05_9324e0aa:

    # "Just for a moment,{w=.3} I caught a glimpse of a smile.{p}I couldn't tell in the dark,{w=.3}\nbut I don't think it was a malicious one."
    "那一瞬间，{w=.3}柔一的脸上浮现出一个小小的笑容。{p}虽然因为光线很暗看不清楚，{w=.3}不过那应该是苦笑吧。"

# game/day 5.rpy:1085
translate chinese_simplified juuichi05_132565b8:

    # "That said...{p}I've thought it before,{w=.3}\nbut Juuichi-san is such a handsome guy."
    "即使如此……{p}以前就一直这么想了，{w=.3}像柔一这样帅气的男人如果平常也能多笑笑的话一定很好看。"

# game/day 5.rpy:1086
translate chinese_simplified juuichi05_478f206f:

    # "I wish he'd smile more often."
    "虽然说那样好像也是有些会被说像糟老头的可能性就是了。"

# game/day 5.rpy:1087
translate chinese_simplified juuichi05_d27f5132:

    # "If he did, I have a feeling\nthat he wouldn't be mistaken for a scary old man."
    "如果那么做的话，恐怕会被误认为是个吓人的老大叔吧——我有这种感觉。"

# game/day 5.rpy:1091
translate chinese_simplified juuichi05_a2275cef:

    # ju "「...[ln],{w=.3} why have you stopped?」"
    ju "「……西村，{w=.3}怎么停下来了。」"

# game/day 5.rpy:1092
translate chinese_simplified juuichi05_753e75ed:

    # fn "「Oh, sorry.」"
    fn "「啊，抱歉。」"

# game/day 5.rpy:1093
translate chinese_simplified juuichi05_a91c820d:

    # "I run to catch up to Juuichi-san."
    "为了追上已经从视线中消失的柔一，我连忙往前跑过去。"

# game/day 5.rpy:1097
translate chinese_simplified juuichi05_a57cc6a8:

    # ju "「...Well,{w=.3} I don't often get the chance either.{p} What exactly do you see?{w=.3}\n I've heard it's a fun thing to do.」"
    ju "「……哎，{w=.3}我也是没什么机会这样特别跑去看。{p}实际上看起来到底会是怎样，{w=.3}我自己也是挺期待的。」"

# game/day 5.rpy:1098
translate chinese_simplified juuichi05_dddf819d:

    # fn "「Wait,{w=.3} you don't go firefly catching that much?{p} Don't you like going for walks?」"
    fn "「咦，{w=.3}柔一平常不会去看萤火虫吗？{p}不是说很喜欢散步吗。」"

# game/day 5.rpy:1099
translate chinese_simplified juuichi05_f1a28413:

    # ju "「No.{w} If I wasn't with someone, like today,{w=.3}\n I probably wouldn't go.」"
    ju "「啊啊。{w}平常不会像今天一样有别人一起去，{w=.3}所以不会特别想去看。」"

# game/day 5.rpy:1100
translate chinese_simplified juuichi05_85f50fac:

    # fn "「That seems like a bit of a waste, though...」"
    fn "「总觉得有点可惜的感觉说……」"

# game/day 5.rpy:1101
translate chinese_simplified juuichi05_a6c8ad23:

    # "I cock my head, confused.{p}I think I'd want to see beautiful things every day."
    "我把头侧向一旁。{p}如果萤火虫很漂亮的话，我应该会每天都想去看吧。"

# game/day 5.rpy:1105
translate chinese_simplified juuichi05_8a16fe92:

    # ju "「I suppose,{w=.3} but wouldn't you tire of it,\n if you went and saw it every day?{p} It's better as a rare thing.」"
    ju "「虽然那么说，{w=.3}但是每天都去看的话很快就看腻了吧？{p}这种东西还是想起来的时候再去看就好了。」"

# game/day 5.rpy:1106
translate chinese_simplified juuichi05_9203bb60:

    # fn "「Hmm,{w=.3} I guess.」"
    fn "「嗯——{w=.3}这么说的话也是啦。」"

# game/day 5.rpy:1107
translate chinese_simplified juuichi05_381cb592:

    # "Well,{w=.3} they say you get tired of\nseeing a beautiful person after 3 days."
    "哎，{w=.3}也是有美人看三天就会看腻的说法。"

# game/day 5.rpy:1108
translate chinese_simplified juuichi05_6b854d6f:

    # "I guess, if you kept looking at a beautiful scene,{w=.3}\nyou'd appreciate it less."
    "和那差不多，{w=.3}不管是再美的景色，如果一直看的话，渐渐的也会越来越没感觉，就是这么回事吧。"

# game/day 5.rpy:1114
translate chinese_simplified juuichi05_fc38e213:

    # ju "「Like I said,{w=.3} I don't go on\n walks to admire the scenery.」"
    ju "「而且刚才也说了，{w=.3}我出来散步不是为了要看风景的。」"

# game/day 5.rpy:1115
translate chinese_simplified juuichi05_bae900ed:

    # ju "「It's rare to meet people at this hour.{p} I find that listening to my steps calms my mind.{w=.3}\n That's why it's perfect for thinking.」"
    ju "「这种时间带出门几乎不会遇到其他人。{p}在安静的夜里听着自己的脚步声，{w=.3}内心自然而然就会沉静下来。」"

# game/day 5.rpy:1116
translate chinese_simplified juuichi05_2cd878c1:

    # "Wow, really?{w} I decide to imitate him,{w=.3}\nand walk in silence for a bit."
    "咦，是那样的啊。{w}接着我也跟柔一一样，{w=.3}暂时沉默地继续踏着脚步前进。"

# game/day 5.rpy:1121
translate chinese_simplified juuichi05_8b524c41:

    # "I hear the sound of our footsteps,\nthe calls of insects,\nand the sounds of the river."
    "两人的脚步声和虫鸣声、溪水流动的声音，各种夜晚的声音混合在一起。"

# game/day 5.rpy:1122
translate chinese_simplified juuichi05_e9974c03:

    # "When I focus,{w=.3}\nI can tell the difference between our steps."
    "仔细竖起耳朵去听的话，{w=.3}虽然都是脚步声，我和柔一的脚步声也有少许的不同。"

# game/day 5.rpy:1123
translate chinese_simplified juuichi05_7d8e70d7:

    # "Is it because he has a larger stride?{w=.3}\nThere's a longer gap between his steps than mine."
    "柔一的步伐比较大，{w=.3}脚步声的间隔会比我的还要久。"

# game/day 5.rpy:1124
translate chinese_simplified juuichi05_fddb9ac9:

    # "It seems like the ground\ncrunches louder when he steps, too."
    "而且踏在草地上的声音也比较大声。"

# game/day 5.rpy:1125
translate chinese_simplified juuichi05_e0a95bb8:

    # "It's a really small thing,{w=.3}\nbut if Juuichi-san hadn't pointed it out,\nI never would have noticed..."
    "虽然只是没什么的小事，{w=.3}不过如果不是这样和柔一不说话地走着的话，肯定是不会注意到的吧……"

# game/day 5.rpy:1126
translate chinese_simplified juuichi05_bfdff656:

    # "I usually only rely on my sight when walking.{p}When I pay attention to my sense of hearing, too...{w=.3}\nIt's very interesting."
    "一般来说走路都是依靠视觉，{p}像现在这样靠听觉来走路……{w=.3}总觉得意外地也还挺有趣的。"

# game/day 5.rpy:1127
translate chinese_simplified juuichi05_d8159a93:

    # "I'm really not used to walking like this.{p}I need to watch my feet,\nor else I'm going to trip."
    "本来我是很不习惯这样的走路方式的，{p}没有仔细看着脚下的状况的话肯定一下子就会踩到石头跌倒。"

# game/day 5.rpy:1128
translate chinese_simplified juuichi05_c1c97332:

    # "...Juuichi-san's trick gets pretty dangerous,{w=.3}\neven by talking about it."
    "……刚刚差点不小心跌到柔一身上什么的，{w=.3}我是不会说出来的。"

# game/day 5.rpy:1138
translate chinese_simplified juuichi05_939dd608:

    # ju "「...We're almost there.」"
    ju "「……差不多就是这里了。」"

# game/day 5.rpy:1139
translate chinese_simplified juuichi05_b5ad05af:

    # fn "「Huh?」"
    fn "「咦？」"

# game/day 5.rpy:1140
translate chinese_simplified juuichi05_0a84f459:

    # "As he says that, I shine my flashlight on my watch.{p}The long hand shows that 15 minutes have passed."
    "听到柔一说的，我连忙将手电筒的光对着手表一看。{p}确实照分针所示已经过了十五分钟了。"

# game/day 5.rpy:1141
translate chinese_simplified juuichi05_6a60dcba:

    # fn "「It's been that long, huh?{p} Sorry for being so quiet the whole time.」"
    fn "「没想到已经过了那么久了啊。{p}难得跟柔一一起出门，{w=.3}路上一直都没说话真是不好意思。」"

# game/day 5.rpy:1142
translate chinese_simplified juuichi05_9b641131:

    # ju "「Don't worry about it.{p} ...Besides,{w=.3} we're close enough friends that\n we don't need to talk all the time.」"
    ju "「没什么，不用在意。{p}……而且，{w=.3}我也觉得既然我们关系够亲密，就不是一定得要一直聊天才行。」"

# game/day 5.rpy:1143
translate chinese_simplified juuichi05_a350e3f4:

    # "He says that with a shrug of his shoulders.{p}Hmm, am I giving it too much thought...?{p}Juuichi-san doesn't seem to mind."
    "柔一说着耸了耸肩膀。{p}嗯——是不是我想太多了呢……{p}柔一看起来倒是不觉得自己说的话有什么奇怪。"

# game/day 5.rpy:1144
translate chinese_simplified juuichi05_e6f64f5a:

    # ju "「Turn your flashlight off.」"
    ju "「差不多可以关掉手电筒了。」"

# game/day 5.rpy:1145
translate chinese_simplified juuichi05_f5fbb406:

    # fn "「Oh,{w=.3} sure.」"
    fn "「啊，{w=.3}好的。」"

# game/day 5.rpy:1150
translate chinese_simplified juuichi05_74df1374:

    # "Just as he asks, I turn it off.{p}Our surroundings are plunged into darkness,{w=.3}\nmore abruptly than I was expecting."
    "说着我便将手电筒的电源关掉。{p}接着柔一也关掉了他的手电筒，{w=.3}一下子四周变得一片漆黑。"

# game/day 5.rpy:1151
translate chinese_simplified juuichi05_41109424:

    # ju "「[ln],{w=.3} can you walk?」"
    ju "「西村，{w=.3}这样能走吗？」"

# game/day 5.rpy:1152
translate chinese_simplified juuichi05_82d0b4f4:

    # fn "「Uhh,{w=.3} can you hold on a second?{p} My eyes need to adjust to the dark.」"
    fn "「那个，{w=.3}稍等一下应该就可以了。{p}等一下眼睛应该就能习惯黑暗了。」"

# game/day 5.rpy:1153
translate chinese_simplified juuichi05_068947bf:

    # ju "「...I see.」"
    ju "「……这样啊。」"

# game/day 5.rpy:1154
translate chinese_simplified juuichi05_09c7e1ef:

    # "I try rubbing my eyes.{p}...Doing so doesn't really help,\nbut I guess it's just a habit."
    "我试着揉了揉眼睛周围。{p}……虽然知道不可能因为这样就能够马上看见东西，{w=.3}不过还是忍不住会想做。"

# game/day 5.rpy:1155
translate chinese_simplified juuichi05_fe9bc822:

    # ju "「Would you like to walk while holding my hand?」"
    ju "「这样的话，{w=.3}要不要牵着手走？」"

# game/day 5.rpy:1156
translate chinese_simplified juuichi05_057779ae:

    # "...Wha-?"
    "……咦？"

# game/day 5.rpy:1157
translate chinese_simplified juuichi05_5a397cf0:

    # "While I'm trying to think\nof an appropriate response,{w=.3}\nhe lets out a small snort."
    "这个突然的提议害我一下子不知道该怎么回答，{w=.3}柔一轻轻地叹了口气。"

# game/day 5.rpy:1158
translate chinese_simplified juuichi05_44405c69:

    # ju "「What's with that look on your face?{p} {nw}"
    ju "「不要一脸困扰的表情嘛。{p}{nw}"

# game/day 5.rpy:1160
translate chinese_simplified juuichi05_55affca1:

    # extend "It was a joke.」"
    extend "{fast}开玩笑的。」"

# game/day 5.rpy:1161
translate chinese_simplified juuichi05_198125c0:

    # fn "「I didn't hear it as a joke...」"
    fn "「柔一的玩笑听起来实在不像是玩笑呢。」"

# game/day 5.rpy:1165
translate chinese_simplified juuichi05_a8cca079:

    # ju "「...Did you say something?」"
    ju "「……你说什么？」"

# game/day 5.rpy:1166
translate chinese_simplified juuichi05_5fe1d440:

    # fn "「No, nothing.」"
    fn "「不不没事。」"

# game/day 5.rpy:1167
translate chinese_simplified juuichi05_b473c64a:

    # "While we talked,{w=.3}\nmy eyes adjusted to the darkness.{p}The adaptability of the body is truly amazing."
    "就在这段不知道是不是开玩笑的过程中，{w=.3}我的眼睛也渐渐开始适应眼前的黑暗了。{p}身体的适应力真的很惊人呢。"

# game/day 5.rpy:1168
translate chinese_simplified juuichi05_9384af0a:

    # "Asking Juuichi-san if he's ready to go,\nI get a nod of the head in response."
    "柔一问我能不能看得清楚，我沉默着小小点了个头。"

# game/day 5.rpy:1169
translate chinese_simplified juuichi05_2fa8b5b1:

    # "He leaves the path we were walking on,\nand heads down the slope beside it."
    "柔一点了个头，大概是表示「这样啊」的意思吧。{p}接着柔一离开了刚刚在走的步道，跨步到旁边的斜坡上。"

# game/day 5.rpy:1173
translate chinese_simplified juuichi05_323e061a:

    # "I go after him so I don't get left behind,\nbut I take care to watch my feet."
    "我也怕没跟上，一边小心注意着自己的脚下，一边跟在柔一的身后追了上去。"

# game/day 5.rpy:1174
translate chinese_simplified juuichi05_466d6f78:

    # "Don't they trim the plants around here?{w=.3}\nThe weeds reach up to my waist.{p}There are even some that are as tall as Juuichi-san."
    "应该是道路修整不会整理到这么远的地方来的关系，{w=.3}这里的杂草都长到了我的腰际了。{p}偶尔有一些甚至会长得比柔一还要高。"

# game/day 5.rpy:1175
translate chinese_simplified juuichi05_b03c78ac:

    # "If I'm not willing to get my hands dirty,\nthen I won't get to the fireflies.{w=.3}\nIt's still difficult to walk, though."
    "不过要是平常会有人去的地方，就不可能会成为萤火虫的出没地点了吧，{w=.3}所以果然也只能勉强走这种不好走的路了。"

# game/day 5.rpy:1176
translate chinese_simplified juuichi05_0344d6cd:

    # "Thank goodness Juuichi-san's making a path in front.{p}If I came here alone,\nit would be quite the struggle."
    "有柔一帮忙把草踩倒，确保前进的道路真的很方便。{p}如果只有我自己一个人来的话，这肯定会变成一件非常辛苦的事吧。"

# game/day 5.rpy:1177
translate chinese_simplified juuichi05_bd65482c:

    # "Juuichi-san's back looks bigger than usual\nas he pushes through the reeds in silence.{p}Surely it can't be an optical illusion."
    "一言不发沉默地把草分开往前踏进的柔一，他的背影会变得看起来如此高大，{p}肯定只是我的错觉吧。"

# game/day 5.rpy:1181
translate chinese_simplified juuichi05_e419ab28:

    # "We continue through the weeds for about 20 meters.{p}As we get close to the river,{w=.3}\nthe number of green lights in the air increases."
    "在没有道路的地方前进着，差不多走了二十公尺左右吧。{p}在靠近溪流附近的同时，{w=.3}四周一闪一闪的绿色光点的数量也开始渐渐增加了。"

# game/day 5.rpy:1182
translate chinese_simplified juuichi05_abdc8163:

    # "As the number of them increases,{w=.3}\nI give up trying to count them.{p}There are more here than I imagined."
    "想来数一下到底有几只，{w=.3}但发现根本就算不完，我算了没多久就放弃了。{p}这些，真的比想像中还要多许多。"

# game/day 5.rpy:1183
translate chinese_simplified juuichi05_b1be12b6:

    # "Finally, I push out of the tall weeds.{p}{nw}"
    "接着，我们穿过了杂草长到和人一样高的地带。{p}{nw}"

# game/day 5.rpy:1188
translate chinese_simplified juuichi05_f1e2d080:

    # extend "In front of us,{w=.3} a spectacle of\ngreen, interweaving fireflies fills my vision."
    extend "{fast}出现在眼前的，{w=.3}是充满了我的视野，无数的萤火虫所编织出来的一整片绿色的光景。"

# game/day 5.rpy:1189
translate chinese_simplified juuichi05_e461dd7f:

    # "It's as if the stars had changed color,\nand were dancing around."
    "这景象，简直就像是在夜空中闪耀的星星，变成绿色给移到了地面上似的。"

# game/day 5.rpy:1190
translate chinese_simplified juuichi05_aaade0ad:

    # "The sight overwhelms me.\nMy mouth agape, I'm unable to move."
    "美丽，这世界上竟然有只用这个词还不足以形容的美景，我今天还是第一次知道。"

# game/day 5.rpy:1191
translate chinese_simplified juuichi05_4b928459:

    # "With each gust of wind,{w=.3}\nripples appear in the mass of light."
    "每当风吹过草地的同时，{w=.3}就会带起绿光的波浪。一道又一道的光之波浪在地面上流过。"

# game/day 5.rpy:1192
translate chinese_simplified juuichi05_dfaeed7c:

    # "Earlier, I half-jokingly used the term 'magical',{p}but now, I don't think that was the wrong term."
    "刚刚虽然半开玩笑地用了「幻想」这样的形容词，{p}但现在看来这个形容一点都不会不适合，我忍不住这么想。"

# game/day 5.rpy:1193
translate chinese_simplified juuichi05_83b3bbe4:

    # fn "「...Amazing...」"
    fn "「……好厉害。」"

# game/day 5.rpy:1196
translate chinese_simplified juuichi05_0d558294:

    # ju "「It is.{p} ...It's beautiful.」"
    ju "「啊啊。{p}……好美。」"

# game/day 5.rpy:1197
translate chinese_simplified juuichi05_2b0ea327:

    # fn "「I'm really glad I came out here.」"
    fn "「真的，我来真是太好了。」"

# game/day 5.rpy:1201
translate chinese_simplified juuichi05_068947bf_1:

    # ju "「...I see.」"
    ju "「……是啊。」"

# game/day 5.rpy:1202
translate chinese_simplified juuichi05_d85e3197:

    # "Juuichi-san smiles, just slightly."
    "柔一的嘴角微微地动了一下。"

# game/day 5.rpy:1203
translate chinese_simplified juuichi05_5110f1fb:

    # ju "「I am, too-」"
    ju "「我也——」"

# game/day 5.rpy:1207
translate chinese_simplified juuichi05_6529aafe:

    # "As he speaks, a strong gust of wind kicks up.{p}The rattling grass makes a loud sound,\nmaking me instinctively cover my face with my arm."
    "这时，忽然有一阵强风笼罩了四周。{p}风吹过草间，发出了相当大的声音。{p}我反射性地用空着的手遮住脸。"

# game/day 5.rpy:1208
translate chinese_simplified juuichi05_50b1e3f9:

    # "Juuichi-san's words become lost."
    "结果柔一要说的话，就这样被风声给掩盖过去了。"

# game/day 5.rpy:1209
translate chinese_simplified juuichi05_a4b6cfd8:

    # fn "「Ah, sorry.{p} Could you repeat that?」"
    fn "「啊，{w=.3}抱歉。{p}我刚刚没听清楚，可以再说一次吗？」"

# game/day 5.rpy:1213
translate chinese_simplified juuichi05_b5f4b1bb:

    # ju "「...The lifespan of a firefly is about 2-3 weeks.{p} They live a hard, short life,\n literally spent glowing.」"
    ju "「……萤火虫的寿命，大概只有两到三周左右。{p}真的是非常短暂的一生。{w=.3}如同字面所说，是燃烧着生命来发光的。{p}也因此所以才能够这么地美丽吧。」"

# game/day 5.rpy:1214
translate chinese_simplified juuichi05_445c8d2f:

    # ju "「I guess that's why they look so beautiful.」"
    ju "「所以才这么美丽吧。」"

# game/day 5.rpy:1215
translate chinese_simplified juuichi05_d3ed47de:

    # fn "「Juuichi-san, isn't that a\n bit of an odd thing to say?」"
    fn "「柔一，这种说法会不会有点悲观啊？」"

# game/day 5.rpy:1218
translate chinese_simplified juuichi05_2d5bc6dd:

    # ju "「...Hm,{w=.3} you think so?」"
    ju "「……唔，{w=.3}是这样吗？」"

# game/day 5.rpy:1219
translate chinese_simplified juuichi05_a73440a5:

    # fn "「...But I agree with you.{p} This scenery is like a living creature.{p} It really is beautiful, isn't it?」"
    fn "「……不过，我也有跟柔一差不多的想法。{p}这种景色，是生物尽全力在活着的模样。{p}所以绝对不可能会不美丽吧。」"

# game/day 5.rpy:1223
translate chinese_simplified juuichi05_30a8efc4:

    # ju "「Quite the poet, aren't you?」"
    ju "「西村也蛮有诗人的资质的嘛。」"

# game/day 5.rpy:1224
translate chinese_simplified juuichi05_29e7a78b:

    # fn "「No way,{w=.3} I don't even come close to you.」"
    fn "「不不，{w=.3}怎么比得上柔一呢。」"

# game/day 5.rpy:1225
translate chinese_simplified juuichi05_2b1aa1bc:

    # "We both laugh at this.{p}Then, we shift our attention\nback to the scene in front of us."
    "说着我们两人一同笑了起来。{p}接着，再次将视线转向眼前的景致。"

# game/day 5.rpy:1226
translate chinese_simplified juuichi05_cd04bd03:

    # "Oh, I should have brought my phone.{p}I could have taken a photo of this sight...{p}I'd forgotten that it even existed."
    "啊，难得的机会要是有带手机的话就好了啊。{p}真想把这风景拍入照相机内。{p}关了电源收在包包内，完全忘记它的存在了啊。"

# game/day 5.rpy:1227
translate chinese_simplified juuichi05_91f2677f:

    # "But even a photograph of this\nstill wouldn't compare to the real thing..."
    "不过，虽然可以把这个景象的一部分保存下来，比起在相片中的样貌，还是无法跟大自然中的景象相提并论啊……"

# game/day 5.rpy:1228
translate chinese_simplified juuichi05_4f3e2461:

    # "The green-colored waves are endless.{p}Juuichi-san and I say little,{w=.3}\nbut there's no need. Just sharing this is enough."
    "绿色的光波不断地交织着。{p}虽然没有跟柔一说到多少话，{w=.3}不过能在同个时间，一起看同样的景色，就已经足够了吧。"

# game/day 5.rpy:1229
translate chinese_simplified juuichi05_e8149834:

    # "Instead of trying to hold inelegant conversation,\nthere's a strange feeling in the air."
    "甚至可以说，觉得这种时候说话反而很破坏气氛，有这种不可思议的感觉。"

# game/day 5.rpy:1230
translate chinese_simplified juuichi05_8bc2fa9d:

    # "We can get along and hang out together like this.{p}For however short the moment may be,\nI can feel truly relaxed."
    "像这样和不用特别顾虑对方的朋友，一起渡过的这段时间。{p}虽然不是什么大事，{w=.3}但就是会让人觉得很安心。"

# game/day 5.rpy:1231
translate chinese_simplified juuichi05_a2e56fff:

    # "Is this what I came back to my hometown for?{p}Juuichi-san stands beside me,\nhis eyes focused on the dazzling scene."
    "这就是所谓的，回到故乡了的感觉吧。{p}站在我身旁的柔一，{w=.3}一直眯着眼看着前方的景色。"

# game/day 5.rpy:1232
translate chinese_simplified juuichi05_61bc9d82:

    # "Suddenly, he turns his head to look at me.{p}As our eyes meet,{w=.3}\nI feel really embarrassed for some reason."
    "突然间，柔一转头看向我这里。{p}一下子对上了他的眼神，{w=.3}不知怎地突然觉得莫名的有点害羞。"

# game/day 5.rpy:1233
translate chinese_simplified juuichi05_75fdd8ff:

    # ju "「[ln].{w} It's getting late...」"
    ju "「西村。{w}差不多该……」"

# game/day 5.rpy:1234
translate chinese_simplified juuichi05_49d4473f:

    # fn "「...Huh?{w=.3} Oh,{w=.3} already?」"
    fn "「……咦，{w=.3}啊，{w=.3}已经这时候啦？」"

# game/day 5.rpy:1235
translate chinese_simplified juuichi05_e404adca:

    # "When I chack the time, it's just about 10.{p}It took about 30 minutes to get here,{w=.3}\nso is this about the time to leave?"
    "确认一下时间，已经差不多快要十点了。{p}从这里回到家大约要三十分钟左右，{w=.3}这种时候差不多该撤退了。"

# game/day 5.rpy:1236
translate chinese_simplified juuichi05_22fa6af9:

    # "I'd like to forget about the time and keep watching,{w=.3}\nbut Grandpa will get worried if I'm too late."
    "不小心忘记时间盯着眼前的景色看太久了，{w=.3}要是太晚回到家的话可是会让爷爷担心的。"

# game/day 5.rpy:1237
translate chinese_simplified juuichi05_9a325480:

    # "I stare at the wonderful scene,\ntrying to etch it into my memory."
    "我集中精神，像是要把这个惊人的美景给深深刻在心中似的，睁大眼睛凝视着前方。"

# game/day 5.rpy:1238
translate chinese_simplified juuichi05_88079db6:

    # ju "「...Would you like to come back here again,{w=.3}\n before you go home?」"
    ju "「……这样的话，{w=.3}在你回去前再来看一次如何？」"

# game/day 5.rpy:1239
translate chinese_simplified juuichi05_6a20a80d:

    # "I shake my head."
    "听到柔一的提议后我摇了摇头。"

# game/day 5.rpy:1240
translate chinese_simplified juuichi05_72a41a22:

    # fn "「No.{w=.3} By the time I come back,\n there won't be as many fireflies.{p} I want to keep this time as special as possible.」"
    fn "「不了，{w=.3}我要回去那边的时候，萤火虫的数量可能已经少很多了。{p}我想趁现在把它好好地记在脑海里。」"

# game/day 5.rpy:1241
translate chinese_simplified juuichi05_068947bf_2:

    # ju "「...I see.」"
    ju "「……这样啊。」"

# game/day 5.rpy:1242
translate chinese_simplified juuichi05_3ebc2ccb:

    # "He says no more,{w=.3}\nand pats my shoulder a few times."
    "柔一之后没有再多说什么，{w=.3}只是轻轻地拍了拍我的肩膀。"

# game/day 5.rpy:1247
translate chinese_simplified juuichi05_35b6bc15:

    # "I just gained another precious\nmemory of this summer."
    "就这样，在我的心中，又增加了一个在这个夏天的珍贵回忆。"

