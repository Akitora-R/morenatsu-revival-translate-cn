    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 187-188)
    su "「好……」"

# game/day 15.rpy:124
translate chinese_simplified camp15_wakeup_shun_5680480e:

    # fn "「Now, rock your body a little\n and say 'good morning' like you did earlier.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 190-192)
