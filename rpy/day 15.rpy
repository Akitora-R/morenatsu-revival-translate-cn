# game/day 15.rpy:497
translate chinese_simplified camp15_tatsuki_9ea021c3:

    # ta "「Yeah, of course there is!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 953-954)
    ta "【辰樹】哦——当然有啊。"

# game/day 15.rpy:498
translate chinese_simplified camp15_tatsuki_8755102a:

    # fn "「And what would that be?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 956-957)
    fn "【博行】是什么呢？"

# game/day 15.rpy:502
translate chinese_simplified camp15_tatsuki_79edb539:

    # ta "「I want to explore.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 960-961)
    ta "【辰樹】探险哦！"

# game/day 15.rpy:503
translate chinese_simplified camp15_tatsuki_e9a06028:

    # fn "「Exploring,{w=.2} huh...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 963-964)
    fn "【博行】探险……"

# game/day 15.rpy:504
translate chinese_simplified camp15_tatsuki_37b22dd6:

    # "What an odd suggestion from the oldest one here..."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 966)
    "最年长的家伙说出了他古怪的想法……"

# game/day 15.rpy:509
translate chinese_simplified camp15_tatsuki_061f87ea:

