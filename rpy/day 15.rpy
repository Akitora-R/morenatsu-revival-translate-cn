    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 971-972)
    to "【虎彦】我要想钓鱼，鱼竿我都带来了。"

# game/day 15.rpy:513
translate chinese_simplified camp15_tatsuki_62e8e7dd:

    # so "「How about soccer?{p} We'll have five per team,{p} I think it'd be fun with this many people here.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 976-979)
    so "【宗太郎】踢足球怎么样？[l]每队正好五个人，或许会比许多人在一起踢更有趣。"

# game/day 15.rpy:517
translate chinese_simplified camp15_tatsuki_06a76f25:

    # ky "「Taro, you really do love soccer.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 983-984)
    ky "【京慈】宗，你可真是喜欢足球啊。"

# game/day 15.rpy:521
translate chinese_simplified camp15_tatsuki_a020f1c2:

    # so "「'course I do!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 987-988)
    so "【宗太郎】当然啦。"

# game/day 15.rpy:525
translate chinese_simplified camp15_tatsuki_1d0d74e3:

    # si "「I'll just take it easy around here.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 992-993)
    si "【深】我只想四处走走。"

# game/day 15.rpy:529
translate chinese_simplified camp15_tatsuki_5dc90200:

    # "We haven't settled on anything..."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 996)
    "结果还是没有决定下来……。"

# game/day 15.rpy:533
translate chinese_simplified camp15_tatsuki_9b4aaa50:

    # "30 minutes later..."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 998-999)
    "30分钟后。"

# game/day 15.rpy:538
translate chinese_simplified camp15_tatsuki_b0770aae:

    # ta "「All right, let's do this.{p} I'm starting the Midoriya Exploration Party.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1002-1005)
    ta "【辰樹】哦唔——我们走吧。[l]翠屋探险队，迎风起动！"

# game/day 15.rpy:542
translate chinese_simplified camp15_tatsuki_2a18b88d:

    # su "「Woof! I'll come exploring!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1009-1010)
    su "【峻】哇，探险喽。"

# game/day 15.rpy:546
translate chinese_simplified camp15_tatsuki_ec21eb33:

    # ko "「Haah, we never did settle on anything.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1014-1015)
    ko "【孝之助】哈，最后我们倒是什么都没有决定下来。"

# game/day 15.rpy:547
translate chinese_simplified camp15_tatsuki_3da3d97c:

    # fn "「Anybody else?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1017-1018)
    fn "【博行】其他人不加入吗？"

# game/day 15.rpy:552
translate chinese_simplified camp15_tatsuki_fca1e7fb:

    # ka "「I saw Juuichi-san dragging Torahiko off.{p} Looks like he did something again.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1023-1025)
    ka "【洸哉】我刚才看到柔一君把虎彦拖走了。[l]他们大概又在做什么事吧。"

# game/day 15.rpy:556
translate chinese_simplified camp15_tatsuki_53cf2699:

    # ta "「Kyouji and Soutarou are enjoying themselves,\n so we'll just leave them alone.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1028-1030)
    ta "【辰樹】京慈和宗太郎似乎沉浸在二人世界的欢愉之中，就不要去管他们啦。"

# game/day 15.rpy:557
translate chinese_simplified camp15_tatsuki_622fb772:

    # fn "「Then what about Shin-kun?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1032-1033)
    fn "【博行】那，深君呢？"

# game/day 15.rpy:558
translate chinese_simplified camp15_tatsuki_8899b805:

    # "I look around and see him reading under the\nshade of a tree."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1035-1036)
    "我环视四周，终于在一片树荫之下，发现正在读书的深君。"

# game/day 15.rpy:563
translate chinese_simplified camp15_tatsuki_addb959b:

    # ta "「Shin, join the Midoriya Exploration Party!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1041-1042)
    ta "【辰樹】深，加入翠屋探险队吧。"

# game/day 15.rpy:567
translate chinese_simplified camp15_tatsuki_945b7b60:

    # si "「Tatsuki-san, I'm fine.{p} I'm just going to read this book.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1045-1047)
    si "【深】辰树君，我这样就很好了。[l]我只想看看书。"

# game/day 15.rpy:571
translate chinese_simplified camp15_tatsuki_f4c180fe:

    # ta "「This isn't the place to be reading.{p} Let's explore!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1050-1052)
    ta "【辰樹】这里又不是看书的地方。[l]一起来探险吧。"

# game/day 15.rpy:575
translate chinese_simplified camp15_tatsuki_dc617bc7:

    # si "「But this place is good, precisely because...{p} What are you going to explore?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1055-1057)
    si "【深】这个地方明明相当和谐……你们到底有啥可探险的？"

# game/day 15.rpy:579
translate chinese_simplified camp15_tatsuki_ea43b479:

    # ta "「Actually...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1060-1061)
    ta "【辰樹】这个嘛……"

# game/day 15.rpy:583
translate chinese_simplified camp15_tatsuki_03aba604:

    # ta "「There's a river here that leads to a waterfall.{p} A guardian spirit is said to live in the basin.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1064-1067)
    ta "【辰樹】这附近有条河。所以如果顺着探索的话，总会找到瀑布的。[l]在那里沉睡着瀑布的领主，[l]我们的目标就是找到它！"

# game/day 15.rpy:584
translate chinese_simplified camp15_tatsuki_26dd6d41:

    # ta "「We're going to find it!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1067)
    ta "我们的目标就是找到它！"

# game/day 15.rpy:588
translate chinese_simplified camp15_tatsuki_160c0671:

    # ta "「The name for this exploration is\n 'I saw the Mysterious Giant Salamander at\n the Waterfall Basin Deep in the Mountains'!!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1070-1073)
    ta "【辰樹】这次活动的名字就叫，翠屋探险队……[l]寻找深山瀑布神秘巨蜥！！[l]如何？"

# game/day 15.rpy:592
translate chinese_simplified camp15_tatsuki_60a56ee7:

    # ka "「How is it mysterious if you\n give away its true identity?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1076-1077)
    ka "【洸哉】它的真实身份，还真是相当神秘呢。"

# game/day 15.rpy:596
translate chinese_simplified camp15_tatsuki_e6f12e5b:

    # si "「See you later.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1080-1081)
    si "【深】那你们快去吧。"

# game/day 15.rpy:600
translate chinese_simplified camp15_tatsuki_620cb987:

    # ta "「Don't just say that and leave,\n there'll be huge crayfish, rhinoceros beetles,\n and maybe even lots of frogs!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1084-1087)
    ta "【辰樹】别拒绝得这么干脆吧，[l]或许还能碰到大龙虾、独角仙，许许多多的青蛙。"

# game/day 15.rpy:605
translate chinese_simplified camp15_tatsuki_f781cec8:

    # "Shun-kun doesn't need to make\nhis eyes sparkle anymore...{p}Everybody's going."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1092-1093)
    "峻君的眼中闪耀着无比的光芒……[l]同行的人们也是。"

# game/day 15.rpy:609
translate chinese_simplified camp15_tatsuki_c721f3ab:

    # si "「Don't be childish...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1096-1097)
    si "【深】真孩子气……"

# game/day 15.rpy:615
translate chinese_simplified camp15_tatsuki_aa8c1464:

    # ta "「There'll be some nice stag beetles too.{p} Stag beetles are tough.{w} There's also\n dragonflies and swallowtail butterflies there.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1103-1106)
    ta "【辰樹】还会有锹形甲虫哦。[l]锹形甲虫硬邦邦的。[l]还有蜻蜓和燕尾蝶。"

# game/day 15.rpy:619
translate chinese_simplified camp15_tatsuki_395218cd:

    # ka "「Tatsuki-san...{p} We're exploring, not bug catching.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1109-1110)
    ka "【洸哉】辰树……这是探险，不是抓虫……"

# game/day 15.rpy:623
translate chinese_simplified camp15_tatsuki_bf994ac5:

    # si "「...Okay, if you insist.{p} I'm not interested in wildlife, however.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1113-1115)
    si "【深】……如果你坚持这样下去，那好吧。[l]不过我可对野外生物什么的没兴趣。"

# game/day 15.rpy:627
translate chinese_simplified camp15_tatsuki_2cdedd8f:

    # ta "「Good, I was going to make you if you weren't.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1118-1119)
    ta "【辰樹】好吧，我会让你产生兴趣的。"

# game/day 15.rpy:631
translate chinese_simplified camp15_tatsuki_3f1c9cca:

    # ta "「All right, we're leaving!{p} The Midoriya Exploration Party is departing!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1122-1124)
    ta "【辰樹】我们走吧。[l]翠屋探险队，出发！"

# game/day 15.rpy:636
translate chinese_simplified camp15_tatsuki_0458decc:

    # fn "「We've been walking for quite a while.{p} I wonder where we are now?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1130-1132)
    fn "【博行】[咱]感觉走了挺久了。现在到哪儿了？"

# game/day 15.rpy:637
translate chinese_simplified camp15_tatsuki_26ac6464:

    # "We're heading upstream,\nthe river goes deep into the forest."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1134-1135)
    "[咱]和大家一起向上流走，河流已经流入密林深处。"

# game/day 15.rpy:638
translate chinese_simplified camp15_tatsuki_59941ed4:

    # "We continue walking through the thicket.{p}Every time I inhale, the lush scent of trees\nfills my lungs."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1137-1138)
    "[咱]继续沿着灌木丛前行，每呼吸一次，便觉得树叶的芬芳沁入心脾。"

# game/day 15.rpy:639
translate chinese_simplified camp15_tatsuki_1387759f:

    # "Next to the stream, a glittering brook babbles,\nand the sunlight shining through\nthe trees flickers in the breeze."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1140-1141)
    "到达下一流域，看到了哗啦啦流淌着的波光粼粼的小溪，枝叶间漏下的斑驳的阳光，随着微风频频闪烁。"

# game/day 15.rpy:643
translate chinese_simplified camp15_tatsuki_031da8e3:

    # ko "「Are we there yet?{p} I'm already exhausted.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1144-1145)
    ko "【孝之助】我们还没到吗，有多远啊？[l] 我都累毁了。"

# game/day 15.rpy:647
translate chinese_simplified camp15_tatsuki_fdce0927:

    # ta "「Gahahahaha!{w=.2} I don't know how much longer it is.{p} I did hear that we're gonna have to climb, though.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1148-1151)
    ta "【辰樹】嘎哈哈哈哈——不用在意有多远，[l]我听说，只要一直走就可以啦。"

# game/day 15.rpy:648
translate chinese_simplified camp15_tatsuki_1ff03629:

    # fn "「Who did you hear that from?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1153-1154)
    fn "【博行】听谁说的？"

# game/day 15.rpy:652
translate chinese_simplified camp15_tatsuki_99e2e05c:

    # ta "「My dad.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1157-1158)
    ta "【辰樹】我爸。"

# game/day 15.rpy:653
translate chinese_simplified camp15_tatsuki_20f7d378:

    # "Tappei-san, huh...{p}He doesn't seem to have much credibility."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1160-1161)
    "辰平叔啊……[l]可信度相当低呢。"

# game/day 15.rpy:657
translate chinese_simplified camp15_tatsuki_57c8bc21:

    # si "「I don't think complaining is going to\n accomplish anything.{w} It's selfish to blame,\n but let's just keep walking for the time being.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1164-1166)
    si "【深】抱怨解决不了什么问题。[l]现在责备某人也没用，继续走路来消磨时间吧。"

# game/day 15.rpy:661
translate chinese_simplified camp15_tatsuki_3d0e9ca6:

    # ta "「What's the matter?{p} Who's to blame here?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1169-1170)
    ta "【辰樹】谁啊？[l]要责备谁啊！"

# game/day 15.rpy:665
translate chinese_simplified camp15_tatsuki_bef95801:

    # si "「...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1174-1175)
    si "【深】……"

# game/day 15.rpy:669
translate chinese_simplified camp15_tatsuki_58c4e7f3:

    # ta "「Hey, watch yourself, this place is a jungle.{p} Don't let your guard down.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1178-1180)
    ta "【辰樹】这可是密林喂，[l]保持警惕，警惕！"

# game/day 15.rpy:673
translate chinese_simplified camp15_tatsuki_3e741291:

    # ko "「This is just a thicket, isn't it?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1183-1184)
    ko "【孝之助】不就是个树林嘛……"

# game/day 15.rpy:677
translate chinese_simplified camp15_tatsuki_3dff382a:

    # ta "「You're terrible...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1187-1188)
    ta "【辰樹】你小子……"

# game/day 15.rpy:678
translate chinese_simplified camp15_tatsuki_f0cb8bc5:

    # fn "「Err... What?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1190-1191)
    fn "【博行】诶诶……那是什么？"

# game/day 15.rpy:682
translate chinese_simplified camp15_tatsuki_b850e2c9:

    # ta "「Look at this weird object!{p} This must be a something by the native people!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1194-1196)
    ta "【辰樹】快看！[l]那件不寻常之物，必是隐藏在森林中的土著人的东西！"

# game/day 15.rpy:687
translate chinese_simplified camp15_tatsuki_aaa9a15f:

    # su "「'Do not leave empty cans' is written on it.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1204-1205)
    su "【峻】这上面写着，……不要乱丢空易拉罐。"

# game/day 15.rpy:691
translate chinese_simplified camp15_tatsuki_d5483690:

    # ka "「...This is definitely something put up by natives.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1208-1209)
    ka "【洸哉】……这个肯定也是隐藏在森林中的土著人建的吧。"

# game/day 15.rpy:695
translate chinese_simplified camp15_tatsuki_3dff382a_1:

    # ta "「You're terrible...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1212-1213)
    ta "【辰樹】你小子……"

# game/day 15.rpy:700
translate chinese_simplified camp15_tatsuki_bef95801_1:

    # si "「...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1217-1218)
    si "【深】……"

# game/day 15.rpy:701
translate chinese_simplified camp15_tatsuki_e4f5b1e0:

    # "Shin-kun's eyes are ice-cold..."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1220)
    "深君的目光越来越冷……"

# game/day 15.rpy:706
translate chinese_simplified camp15_tatsuki_e4503e03:

    # su "「Oh,{w=.2} a butterfly.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1224-1225)
    su "【峻】啊，[wdt]是蝴蝶。"

# game/day 15.rpy:710
translate chinese_simplified camp15_tatsuki_ed829517:

    # ko "「Ah, it's an Oomurasaki.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1228-1229)
    ko "【孝之助】啊，是大紫蛱蝶。"

# game/day 15.rpy:711
translate chinese_simplified camp15_tatsuki_9acf2eb9:

    # fn "「It is. Those are common around here.{p} I even happened to see one in Minasato.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1231-1233)
    fn "【博行】确实是。我之前在水边也碰见过。[l]在水乡村这附近很常见的样子。"

# game/day 15.rpy:715
translate chinese_simplified camp15_tatsuki_67f4ad51:

    # ka "「Those things drive away wasps, don't they?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1236-1237)
    ka "【洸哉】我记得这东西可以把大黄蜂赶得远远的，对不对？"

# game/day 15.rpy:719
translate chinese_simplified camp15_tatsuki_fdab67e7:

    # ta "「I've seen 'em chasing small birds.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1240-1241)
    ta "【辰樹】我还看过它们追小鸟哩。"

# game/day 15.rpy:720
translate chinese_simplified camp15_tatsuki_4a6fc904:

    # fn "「Yeah, they're pretty aggresive\n about defending their territory.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1243-1244)
    fn "【博行】是啊，一旦触犯它们的领地，它们就会很凶。"

# game/day 15.rpy:724
translate chinese_simplified camp15_tatsuki_a4f326ff:

    # ko "「Enough about that, I'm already worn-out...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1247-1248)
    ko "【孝之助】别管那个啦，我都要累得不行了……"

# game/day 15.rpy:725
translate chinese_simplified camp15_tatsuki_a8b3bb81:

    # fn "「I'm beat, should be take a quick break?{p} It looks like it's further than we thought.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1250-1252)
    fn "【博行】好吧，是不是休息一下比较好？[l]路程似乎比想象中要长。"

# game/day 15.rpy:729
translate chinese_simplified camp15_tatsuki_1d27b1de:

    # ta "「It's too soon to be giving up.{p} The Great Tatsuki Team makes\n the impossible possible!!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1255-1257)
    ta "【辰樹】不，让我们继续前进。[l]现在要放弃还太早。[l]变不可能为可能，正是我们大辰树团的信条！！"

# game/day 15.rpy:733
translate chinese_simplified camp15_tatsuki_35f75f17:

    # ka "「You changed the name...?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1260-1261)
    ka "【洸哉】名字是不是变了……"

# game/day 15.rpy:738
translate chinese_simplified camp15_tatsuki_09386c8d:

    # si "「Assuming we continue...\n If the waterfall isn't there,\n won't we just keep on walking?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1265-1267)
    si "【深】假如我们继续走下去……并且没看到瀑布，是不是我们就要一直走下去。"

# game/day 15.rpy:742
translate chinese_simplified camp15_tatsuki_03c8e0f4:

    # ta "「That's...{w=.2} we'll see.{p} Mmm, we do have a return time.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1270-1272)
    ta "【辰樹】那……我们会看到的啦。[l]嗯嗯，我们有足够的时间往回走呐。"

# game/day 15.rpy:747
translate chinese_simplified camp15_tatsuki_3382d51a:

    # ko "「Return?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1276-1277)
    ko "【孝之助】还要往回走？"

# game/day 15.rpy:748
translate chinese_simplified camp15_tatsuki_dbf75070:

    # fn "「Wait,{w=.2} is that it?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1279-1280)
    fn "【博行】等一下，[wdt]是不是那里？"

# game/day 15.rpy:752
translate chinese_simplified camp15_tatsuki_c4a0da25:

    # su "「Oh, I can see the bottom of the waterfall!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1283-1284)
    su "【峻】哦，我看到瀑布的底端了。"

# game/day 15.rpy:756
translate chinese_simplified camp15_tatsuki_561c9b0b:

    # ta "「All right, let's go and take a look.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1287-1288)
    ta "【辰樹】好啊，咱们快去看看吧。"

# game/day 15.rpy:761
translate chinese_simplified camp15_tatsuki_3e141b03:

    # si "「That's strange. If there's a waterfall around here,\n we should have heard it.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1292-1294)
    si "【深】很奇怪呢，[l]如果周围要是有瀑布的话，我们应该事先听得到才对吧。"

# game/day 15.rpy:765
translate chinese_simplified camp15_tatsuki_76637bac:

    # fn "「This is... a pond?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1298-1299)
    fn "【博行】这是……池塘？"

# game/day 15.rpy:766
translate chinese_simplified camp15_tatsuki_bc16ee98:

    # "Ahead of us, there's a clearing,\nwith a small pond surrounded by rocks.{p}The water is so clear that you can see the bottom."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1301-1303)
    "在杂木丛之中，有一方净土，岩石包围之中是一个小池塘。[l]池水十分澄澈，通透可见池底。"

# game/day 15.rpy:767
translate chinese_simplified camp15_tatsuki_531d5c2e:

    # "Hmm, it doesn't seem to be a waterfall basin,\nand there's no waterfall in sight."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1305-1306)
    "嗯——这似乎并不是瀑布池，周围也看不到什么瀑布。"

# game/day 15.rpy:771
translate chinese_simplified camp15_tatsuki_802eec82:

    # ka "「Looks like a spring.{p} The river doesn't go on any further,\n so this must be the source.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1309-1312)
    ka "【洸哉】看起来似乎是泉水。[l]这附近没有作为来源的水流，所以这里应该就是河的源头。"

# game/day 15.rpy:776
translate chinese_simplified camp15_tatsuki_553937ce:

    # ko "「Ah, I see. You can see the basin here,\n it's just that the waterfall we were\n talking about is different.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1316-1318)
    ko "【孝之助】啊，是啊。[l]我看到这池子了，但是它可不是什么瀑布啊。"

# game/day 15.rpy:780
translate chinese_simplified camp15_tatsuki_14e5de31:

    # ta "「First of all, let's look for\n what we came here for.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1321-1322)
    ta "【辰樹】我们本来就是为了探险嘛。"

# game/day 15.rpy:784
translate chinese_simplified camp15_tatsuki_1f60e24a:

    # su "「I agree.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1325-1326)
    su "【峻】确实呐。"

# game/day 15.rpy:789
translate chinese_simplified camp15_tatsuki_17c2b344:

    # ta "「Don't slip.{p} You won't get hurt, but negligence is forbidden.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1330-1332)
    ta "【辰樹】当心脚下很滑。[l]虽然不会受伤，但是还是小心为上。"

# game/day 15.rpy:793
translate chinese_simplified camp15_tatsuki_16f743be:

    # si "「I think you're the most dangerous thing here.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1335-1336)
    si "【深】我觉得你才是我们当中最可能遇险的人。"

# game/day 15.rpy:797
translate chinese_simplified camp15_tatsuki_df592497:

    # ta "「Gahaha.{p} No way...{nw}"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1339-1340)
    ta "【辰樹】嘎哈哈。[l]怎么可能呢……"

# game/day 15.rpy:799
translate chinese_simplified camp15_tatsuki_9e4847b5:

    # extend "] Whoa.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1340)
    extend "呜哇！——"

# game/day 15.rpy:803
translate chinese_simplified camp15_tatsuki_93afdc63:

    # "Tatsu-nii takes a bad step and loses his balace.{p}It looks like he could fall at any moment."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1344-1345)
    "辰兄迈错一步，整个人都失去了平衡，看起来似乎随时都会掉下去的样子。"

# game/day 15.rpy:804
translate chinese_simplified camp15_tatsuki_5ad64dbc:

    # fn "「Wha-? Tatsu-nii, that's a weird place to grab on to.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1347-1348)
    fn "【博行】辰兄，快随便扶住一个地方！"

# game/day 15.rpy:809
translate chinese_simplified camp15_tatsuki_80923320:

    # ko "「Watch out!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1352-1353)
    ko "【孝之助】诶诶，呜哇！"

# game/day 15.rpy:814
translate chinese_simplified camp15_tatsuki_1ac78f86:

    # ka "「Kounosuke, don't push.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1357-1358)
    ka "【洸哉】孝之助别推我！"

# game/day 15.rpy:820
translate chinese_simplified camp15_tatsuki_7671dfc9:

    # "{size=+10}Splooosh!"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1360-1361)
    "噗，哗————"

# game/day 15.rpy:826
translate chinese_simplified camp15_tatsuki_431e7391:

    # ta "「Well, that felt good... sorry.{p} Forgive me if that was bad.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1369-1371)
    ta "【辰樹】哦，这真是太棒了……抱歉，[l]如果觉得不好的话，就无视我说的吧。"

# game/day 15.rpy:830
translate chinese_simplified camp15_tatsuki_98c1831f:

    # ka "「You don't need to apologize for that.{p} It did feel good, it's pretty nice.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1375-1377)
    ka "【洸哉】辰树不用道歉啊。[l]真的很棒，棒到不行。"

# game/day 15.rpy:834
translate chinese_simplified camp15_tatsuki_e8bbd068:

    # su "「It feels nice to swim.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1381-1382)
    su "【峻】在这里游真不错。"

# game/day 15.rpy:839
translate chinese_simplified camp15_tatsuki_a81d19d9:

    # ko "「The water from the rocks\n is good enough to drink...!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1387-1388)
    ko "【孝之助】从岩石里流出来的水还可以喝呢。"

# game/day 15.rpy:844
translate chinese_simplified camp15_tatsuki_c2ea3d8c:

    # si "(I thought I was going to die...)"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1393-1394)
    si "【深】（我有一种想死的感觉……）"

# game/day 15.rpy:848
translate chinese_simplified camp15_tatsuki_a5ea6ab0:

    # si "「Why did I have to get so wet?{p} And I wasn't planning on swimming in the only pair\n of underwear I brought.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1397-1399)
    si "【深】为什么我非得把自己搞得这么湿！[l]而且，[wdt]我才不想穿着自己带来的唯一一条内裤游泳。"

# game/day 15.rpy:853
translate chinese_simplified camp15_tatsuki_e8fb513a:

    # ta "「Sorry guys, I only have one pair of underwear.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1406-1407)
    ta "【辰樹】抱歉啦，我也只有一条内裤。"

# game/day 15.rpy:854
translate chinese_simplified camp15_tatsuki_cf7f9165:

    # fn "「Should we swim a little longer before going back?{p} Um, what did we come here for again?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1409-1411)
    fn "【博行】回去之前，再游一会儿吧。[l]啊咧，我们当初来这里是干啥的？"

# game/day 15.rpy:858
translate chinese_simplified camp15_tatsuki_0c6be8d4:

    # ta "「I heard there was a guardian spirit here.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1414-1415)
    ta "【辰樹】我听说是有什么领主的……"

# game/day 15.rpy:862
translate chinese_simplified camp15_tatsuki_01ce9e91:

    # ka "「Even if there was one,\n it probably ran away when things got noisy.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1418-1420)
    ka "【洸哉】就算有的话，刚才那么一顿闹，也早把它吓走了吧。"

# game/day 15.rpy:866
translate chinese_simplified camp15_tatsuki_1766e0ba:

    # si "「There's no way a protected species would even be\n here in the first place.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1423-1425)
    si "【深】在这种地方，才不会有什么珍惜保护物种出没呢。"

# game/day 15.rpy:871
translate chinese_simplified camp15_tatsuki_6f82996f:

    # su "「That's too bad.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1429-1430)
    su "【峻】真遗憾。"

# game/day 15.rpy:875
translate chinese_simplified camp15_tatsuki_6001fe36:

    # ko "「There might be some ordinary fish around here.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1433-1434)
    ko "【孝之助】这里倒是有许多普普通通的鱼。"

# game/day 15.rpy:876
translate chinese_simplified camp15_tatsuki_99fdebca:

    # fn "「But I am kind of glad that we found something\n like an unexplored area. You would never see\n a beautiful place like this in Minasato.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1436-1438)
    fn "【博行】虽然没有秘境，但是仍然很高兴。[l]水乡村之中可没有这么美丽的风景。"

# game/day 15.rpy:880
translate chinese_simplified camp15_tatsuki_310e9cd6:

    # ka "「I guess the result was\n worth coming out here for.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1441-1442)
    ka "【洸哉】所以说此行还是相当有收获的。"

# game/day 15.rpy:881
translate chinese_simplified camp15_tatsuki_71217b35:

    # "I got tired of walking around soaking wet,\nbut as they say, all's well that ends well.{p}And this is definitely nice."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1444-1446)
    "在湿地中走来走去的，真是累死人，但是正如洸哉所说，确实是不虚此行。[l]真心不错。"

# game/day 15.rpy:885
translate chinese_simplified camp15_tatsuki_4376dceb:

    # ko "「Huh?{p} What happened to Tatsu-nii's fundoshi?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1449-1450)
    ko "【孝之助】啊咧？[l]辰兄的丁字裤哪里去了？"

# game/day 15.rpy:890
translate chinese_simplified camp15_tatsuki_e266ddbe:

    # ta "「It got washed away...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1454-1455)
    ta "【辰樹】被水冲走啦……"

# game/day 15.rpy:891
translate chinese_simplified camp15_tatsuki_a20cefa7:

    # "..."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1457)
    "……"

# game/day 15.rpy:914
translate chinese_simplified camp15_shun_2be65586:

    # ky "「...So, this is a monument to the God of Marriage.\n It seems they say that it dwells within it.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1518)
    ky "「……就是因为这样，这个石碑据说是有结缘的神明寄宿的样子。」"

# game/day 15.rpy:918
translate chinese_simplified camp15_shun_7531db79:

    # su "「Wow-, I see-」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1524)
    su "「哇～原来如此～」"

# game/day 15.rpy:922
translate chinese_simplified camp15_shun_7662eefd:

    # ko "「W,wait a minute, that isn't very convincing.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1530)
    ko "「等、[wdt]等一下啦，[wdt]那完全不能令人接受啊。」"

# game/day 15.rpy:923
translate chinese_simplified camp15_shun_d5d25228:

    # ko "「Don't you feel sorry for the second person?\n In the end, their sweetheart is taken away.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1533)
    ko "「第二个人未免也太可怜了吧？[l]最后不是也有恋人了吗？」"

# game/day 15.rpy:924
translate chinese_simplified camp15_shun_4f49ce23:

    # fn "「It sort of makes sense,\n although it looks like later you're supposed to\n have a real fateful encounter and live happily ever after.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1537)
    fn "「虽然听上去很合乎道理，不过在之后要是真的能有命运般的相遇的话那就太好了，大概就是这个样子吧。」"

# game/day 15.rpy:928
translate chinese_simplified camp15_shun_031ed1bd:

    # ko "「Hmm...mmm」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1544)
    ko "「哼……唔唔唔。」"

# game/day 15.rpy:929
translate chinese_simplified camp15_shun_eb2842f6:

    # "Standing near the campground, there's a fairly old-looking wooden sign with an arrow on it.{w} 'Mountain Trail' is written on it, and quietly in the corner, are the characters for 'marriage'."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1547)
    "在露营场的角落，有一个看上去相当古老的箭头状的木制立牌。\n\n在写着「山路」的文字旁边还有另外一串，「结缘」的文字。"

# game/day 15.rpy:930
translate chinese_simplified camp15_shun_c56db407:

    # "Fascinated by this, we made our way down the trackless path indicated by the 'Mountain Path' sign, hoping that it wasn't wrong."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1553)
    "对此相当感兴趣的[漏れ]们，走在这名为「山路」的不是道路的道路上并且一边祈祷着自己没走错路。"

# game/day 15.rpy:931
translate chinese_simplified camp15_shun_950e094c:

    # "Somehow, we finally arrived at a place with what looks like a stone monument.{w} After reading an explaination of it's origins, we take a look around."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1557)
    "就这样子总算到达了石碑所在的场所。[l]看了看解说与由来之后，就开始在附近到处看看。"

# game/day 15.rpy:932
translate chinese_simplified camp15_shun_36b3c41d:

    # ky "「It's pretty far off the wide trail,\n but there's a trampled pathway that leads\n to this medow with a monument in it.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1560)
    ky "「虽然已经离大的山路有一段距离了，但是到石碑这段路的草地，已经被踩得像是一条通道了。」"

# game/day 15.rpy:933
translate chinese_simplified camp15_shun_26a46f6a:

    # ky "「This especially shows that many people stop here on\n their way up, that in itself is a blessing, isn't it?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1565)
    ky "「这是很多人特地绕道来此的证据啊，这也就表示这还蛮灵验的吧？」"

# game/day 15.rpy:937
translate chinese_simplified camp15_shun_894a589e:

    # ko "「I see. It's like following pioneers.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1572)
    ko "「原来如此。[wdt]随着前者的脚步，就是这样子吧。」"

# game/day 15.rpy:938
translate chinese_simplified camp15_shun_f4d84d46:

    # so "「There's different kinds of offerings around the monument.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1575)
    so "「在石碑的旁边也有许多供奉的东西在呢。」"

# game/day 15.rpy:942
translate chinese_simplified camp15_shun_b8589210:

    # ky "「Hmm... Praying? That might be what it's for.\n It seems you offer something related to the\n person on your mind.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1580)
    ky "「嗯……许愿？[wdt]　我想应该不是。[l]应该是为了中意的对象所以将一些象征缘分的东西放在此吧。」"

# game/day 15.rpy:943
translate chinese_simplified camp15_shun_f08e2e75:

    # fn "「I thought it would be a little smaller than this,\n but it's a pretty big monument,\n and a lot of people have come here.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1584)
    fn "「[漏れ]还以为会是小一点的石碑呢，没想到是相当大的石碑啊，也很有人气。」"

# game/day 15.rpy:947
translate chinese_simplified camp15_shun_66bc87bc:

    # ky "「This is the place where the god quietly sleeps too,\n so if we drag it out to pray to it,\n that might put it in a bad mood.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1591)
    ky "「这也是个可以让神明大人好好安眠的地方啊，要是强行地祭拜的话，也许会让神明不高兴吧……[wdt]你觉得呢宗太郎？」"

# game/day 15.rpy:951
translate chinese_simplified camp15_shun_98690cd7:

    # so "「F-For real?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1599)
    so "「是、是这样吗？」"

# game/day 15.rpy:952
translate chinese_simplified camp15_shun_a42a78a4:

    # fn "「On the other hand, it could be the god of divorce.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1602)
    fn "「也许啊，很意外的是切断缘分的神明呢。」"

# game/day 15.rpy:957
translate chinese_simplified camp15_shun_f83c2967:

    # so "「P-please stop!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1607)
    so "「别、别闹了啦！」"

# game/day 15.rpy:958
translate chinese_simplified camp15_shun_9ed32b70:

    # ky "「Hahaha, you don't have to think about it that hard. If you \n pray while holding onto feelings of deep gratitude, you won't \n befall any sort of misfortune, no matter which god.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1612)
    ky "「哈哈哈，不用想那么多也没关系的。[l]只要好好的抱持着感谢的心境去祈祷的话，就不会产生不好的结果，不管是什么样的神明都是一样的啊。」"

# game/day 15.rpy:962
translate chinese_simplified camp15_shun_f80e1ce0:

    # so "「I-is that true?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1620)
    so "「是、是这样啊？」"

# game/day 15.rpy:963
translate chinese_simplified camp15_shun_e85722f1:

    # ky "「Look, if this monument is in accordance with the legend and\n has been here for hundreds of years, and we assume it's\n been left alone that whole time,"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1623)
    ky "「你看，如果真的跟传言一样那么这个石碑是从百年前就存在的，如果一直都没有人来管理的话，一定会更加地不干净的对吧？」"

# game/day 15.rpy:964
translate chinese_simplified camp15_shun_62ad90a0:

    # ky "shouldn't it be a little more worn-down?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1623)
    ky "「你看，如果真的跟传言一样那么这个石碑是从百年前就存在的，如果一直都没有人来管理的话，一定会更加地不干净的对吧？」"

# game/day 15.rpy:965
translate chinese_simplified camp15_shun_103bb746:

    # ky "「There are a lot of goods being offered too,\n and in the case of the food, I think it would have been\n spoiled, eaten, or cluttered about.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1623)
    ky "「你看，如果真的跟传言一样那么这个石碑是从百年前就存在的，如果一直都没有人来管理的话，一定会更加地不干净的对吧？」"

# game/day 15.rpy:966
translate chinese_simplified camp15_shun_f396e005:

    # ky "「It's been properly arranged in order to look this way.\n Somebody has been keeping this thing maintained.\n It's probably the campground manager.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1628)
    ky "「像这样周边干干净净的，肯定是有人在整理的啊。[l]应该是露营场的管理人吧。」"

# game/day 15.rpy:967
translate chinese_simplified camp15_shun_b56f8804:

    # ky "「Because of that, I don't think the god is in a bad mood.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1633)
    ky "「所以，我想神明大人是不会不高兴的喔。」"

# game/day 15.rpy:971
translate chinese_simplified camp15_shun_6bc815c5:

    # so "「I see! That's a relief.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1639)
    so "「这样啊！[wdt]　那就安心了。」"

# game/day 15.rpy:975
translate chinese_simplified camp15_shun_8d759850:

    # ko "「It does feel like it's been skillfully put together\n to seem that way.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1645)
    ko "「看来是很好的被说服了呢。」"

# game/day 15.rpy:976
translate chinese_simplified camp15_shun_c3952fa4:

    # fn "「Hahaha, well then, I'll pray for everybody.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1648)
    fn "「哈哈哈，那么大家也来祈祷吧。」"

# game/day 15.rpy:977
translate chinese_simplified camp15_shun_febc1400:

    # "Then, as I'm about to take a step forward,"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1651)
    "就在[漏れ]向前踏出一步的同时，"

# game/day 15.rpy:981
translate chinese_simplified camp15_shun_9b5c7fa2:

    # su "「[fn]-san...um」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1655)
    su "「[博行]桑……[wdt]那个……」"

# game/day 15.rpy:982
translate chinese_simplified camp15_shun_0b4f0089:

    # "Shun-kun hangs his head down and speaks to me."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1658)
    "低下头一看是峻君在说话。"

# game/day 15.rpy:986
translate chinese_simplified camp15_shun_9fc17792:

    # su "「Is Minasato's shrine god going to get angry?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1662)
    su "「水乡神社的神明大人不会生气吗？」"

# game/day 15.rpy:987
translate chinese_simplified camp15_shun_b5ad05af:

    # fn "「Huh?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1665)
    fn "「诶？」"

# game/day 15.rpy:988
translate chinese_simplified camp15_shun_118820e8:

    # "He seems to think that\nif you make a request to another god,\nMinasato's god will become very jealous."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1668)
    "对着其他的神明许愿，[wdt]水乡的神明要是妒忌的话那就糟糕了。峻君这么说着。"

# game/day 15.rpy:989
translate chinese_simplified camp15_shun_5ba25803:

    # "I see.\nThat somewhat brooding behavior he had\nwas because he was worried about this."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1672)
    "这样啊。[l]还以为只是在单纯地陷入思考的样子，没想到是在烦恼这样子的事情啊。"

# game/day 15.rpy:990
translate chinese_simplified camp15_shun_12f988e7:

    # ky "「Shun is the type to worry about those kinds of things」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1676)
    ky "「峻就是会对这类的事情感到在意的类型啊。」"

# game/day 15.rpy:994
translate chinese_simplified camp15_shun_1dcfdae0:

    # so "「Eh...I don't think it'll get angry, but...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1681)
    so "「嗯……[wdt]我是觉得不会生气啦……」"

# game/day 15.rpy:998
translate chinese_simplified camp15_shun_31683712:

    # ko "「It should be all right, shouldn't it?\n We're pretty far away from that shrine」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1687)
    ko "「没问题的不是吗？[wdt]神社距离这边很远嘛。」"

# game/day 15.rpy:999
translate chinese_simplified camp15_shun_b5983c29:

    # su "「B-but what about all the way up in the sky?\n It could be watching us from there」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1691)
    su "「不、不过，神明大人是在最高最高的地方吧？[l]不管在哪里都会看见的啊。」"

# game/day 15.rpy:1000
translate chinese_simplified camp15_shun_d2dffa67:

    # "Shun-kun looks seriously worried.\nWhat should I do? We stopped here to pray,\nmaybe we should go back... but we've already come this far."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1695)
    "峻君是很认真地在担心的样子。[l]怎么办呢？[wdt]　放弃在这里许愿直接回去比较好吗……[l]不过人都到这边来了啊。"

# game/day 15.rpy:1001
translate chinese_simplified camp15_shun_48e2d445:

    # ky "「Hmm... If Shun thinks Minasato's god\n is important, then why not ask\n both gods to answer our prayers?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1701)
    ky "「嗯……[wdt]因为水乡的神明度量是很大的，所以会跟着这个石碑的神明一起，[wdt]倾听着大家的愿望不是吗？」"

# game/day 15.rpy:1005
translate chinese_simplified camp15_shun_513c8841:

    # su "「Oh! You can do that!?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1709)
    su "「啊！[wdt]　是这样子啊！」"

# game/day 15.rpy:1006
translate chinese_simplified camp15_shun_3635e80a:

    # ky "「Between both gods, it should work out all right.\n If you're still worried, you can pray to the god back home\n before praying to the god here」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1714)
    ky "「同样是神明大人，一定可以的。[l]如果还是很在意的话，在向这边的神明大人祈祷之前先向另一边的神明大人祈祷就行了啊。」"

# game/day 15.rpy:1007
translate chinese_simplified camp15_shun_784aa87b:

    # ky "「You could make the two gods become friends, right?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1721)
    ky "「像是[wdt]『请跟石碑的神明大人，好好相处』[wdt]这样」"

# game/day 15.rpy:1008
translate chinese_simplified camp15_shun_cab2356d:

    # "Then, Kyouji shows a slight wink.\nIn that instant, the light in Shun-kun's eyes quickly returns."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1724)
    "京慈像是轻轻眨了眨眼那样。[l]听见京慈这么说的峻君眼中恢复了先前的光芒。"

# game/day 15.rpy:1012
translate chinese_simplified camp15_shun_e7bcd3b2:

    # su "「Okay!{w=.2}{nw}"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1731)
    su "「我知道了！[wdt][峻 hide normal][wt]　那个，那个，水乡神社的神明大人，今天在很远的地方向您打招呼，我们大家一起来露营……」"

# game/day 15.rpy:1014
translate chinese_simplified camp15_shun_e1c47929:

    # extend " Umm, umm\n Minasato's shrine god, today I am saying hello from far\n away,I've gone camping with everybody...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1731)
    extend "「我知道了！[wdt][峻 hide normal][wt]　那个，那个，水乡神社的神明大人，今天在很远的地方向您打招呼，我们大家一起来露营……」"

# game/day 15.rpy:1015
translate chinese_simplified camp15_shun_e469579f:

    # "Shun-kun speaks with his back turned to the stone monument and looking up at the sky."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1736)
    "峻君背对着石碑，朝着天空一句一句地说着。"

# game/day 15.rpy:1016
translate chinese_simplified camp15_shun_6e9afb47:

    # ky "「Well then, I'm praying for many long years of\n friendship with Soutarou」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1740)
    ky "「好了，我也来为能够跟宗太郎长久的相处而祈祷吧。」"

# game/day 15.rpy:1020
translate chinese_simplified camp15_shun_de934848:

    # so "「Wait Takahara-senpai! I'm prayin' too!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1745)
    so "「哇哇，高原前辈！[wdt]　我也来祈祷！」"

# game/day 15.rpy:1021
translate chinese_simplified camp15_shun_d32b7fd6:

    # ky "「For soccer, I'm guessing?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1750)
    ky "「是希望能在足球上更加努力？」"

# game/day 15.rpy:1025
translate chinese_simplified camp15_shun_1016b3b0:

    # so "「……{w=.2}{nw}"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1755)
    so "「……[wdt][宗太郎 普 normal][wt]是、是的！[wdt]　当然了！」"

# game/day 15.rpy:1027
translate chinese_simplified camp15_shun_1aed0b8f:

    # extend "Y-yeah!{w=.2} of course!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1755)
    extend "「……[wdt][宗太郎 普 normal][wt]是、是的！[wdt]　当然了！」"

# game/day 15.rpy:1028
translate chinese_simplified camp15_shun_59307291:

    # "Soutarou-kun looks a little down."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1758)
    "宗太郎君的样子显得有些许的失望。"

# game/day 15.rpy:1032
translate chinese_simplified camp15_shun_2cdafb96:

    # ko "「...」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1762)
    ko "「……」"

# game/day 15.rpy:1033
translate chinese_simplified camp15_shun_1a6f3bbc:

    # "Next to me, the always noisy Kounosuke\nis unusually silent... No, under his breath\nhe's mumbling something with his hands together."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1765)
    "在旁边，一直都是不停讲话很吵的孝之助很难得的静了下来……[wdt]不对，正确地来说是双手合十地小声地碎碎念着。"

# game/day 15.rpy:1034
translate chinese_simplified camp15_shun_cdafc753:

    # ky "「Well, we should get going soon」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1771)
    ky "「好了，差不多该回去了。」"

# game/day 15.rpy:1038
translate chinese_simplified camp15_shun_a13cf24e:

    # so "「Okay!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1776)
    so "「好的！」"

# game/day 15.rpy:1042
translate chinese_simplified camp15_shun_30664e37:

    # ko "「...Ah, wait a minute,\n I'm still not done yet...whisperwhisper」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1781)
    ko "「……啊，[wdt]等一下啦，[wdt]还没结束啦……[wdt]真是的。」"

# game/day 15.rpy:1047
translate chinese_simplified camp15_shun_2025e659:

    # "Quickly, Shun-kun turns in place\nand faces his body this way,\nthen finishes his prayer to the god on the other side."
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1793)
    "峻君转身面向石碑的地方。[l]看来跟水乡的神明打招呼已经结束了的样子。"

# game/day 15.rpy:1048
translate chinese_simplified camp15_shun_a8ebbccf:

    # fn "「Well then Shun-kun, did you pray to both of them?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 1796)
