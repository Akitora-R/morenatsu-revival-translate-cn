# game/day 15.rpy:130
translate chinese_simplified camp15_wakeup_shun_eef8f307:

    # fn "「Then I'll hold on to your waist.」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 199-200)
