# game/day 15.rpy:137
translate chinese_simplified camp15_wakeup_shun_17177bb8:

    # su "「Uh, umm...{w=.2} Good morning-,\n [fn]-san, {w=.2}it's time to get up-,{w=.2}\n Wake up please-...{w=.2} Like that?」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 209-211)
