translate chinese_simplified camp15_wakeup_shun_2af9d6dd:

    # su "「Okay! I'll do my best for you!」"
    # [旧版翻译] 来源: extract/orig/キャンプ02.ks (KS 138-139)
    su "「好！[wdt]　为了[博行]桑我会努力的！」"

