    # to "「Oh.{w} There will be my advisor and other members but\n it's okay to go with them.」"
    # [旧版翻译] 来源: 12日目.ks (KS 247-248)
    to "「嗯。[l]今天顾问老师跟其他社员也会来，嘛，一起去没问题吧」"

# game/day 12.rpy:242
translate chinese_simplified torahiko12_74b555ef:

    # fn "「Then I'll go with you!」"
    # [旧版翻译] 来源: 12日目.ks (KS 251)
    fn "「那就一起去！」"

# game/day 12.rpy:243
translate chinese_simplified torahiko12_a3fad1a4:

    # fn "「As Torahiko Ooshima's private coach, I have to\n check his practice carefully.」"
    # [旧版翻译] 来源: 12日目.ks (KS 254-255)
    fn "「身为虎彦的私人教练，得好好看看虎彦的练习状况」"

# game/day 12.rpy:247
translate chinese_simplified torahiko12_e2dce078:

    # to "「But if you're really my coach, then the\n next tournament is surely hopeless.」"
    # [旧版翻译] 来源: 12日目.ks (KS 259)
    to "「博行是教练的话，下次大会就没希望了」"

# game/day 12.rpy:253
translate chinese_simplified torahiko12_885f84f8:

    # "After having breakfast, I return to Torahiko's room to change my clothes.{w} It seems that Takemi-san has dried them up and folded them neatly."
    # [旧版翻译] 来源: 12日目.ks (KS 267-269)
    "我吃完早餐后，收起自己的衣服。[l]阿姨已经烘干并整齐地折好了。"

# game/day 12.rpy:254
translate chinese_simplified torahiko12_203df9cd:

    # fn "「Torahiko, thank you for lending me your shirt and\n pants.{w} Should I put them in the washing machine?」"
    # [旧版翻译] 来源: 12日目.ks (KS 272-273)
    fn "「虎彦，谢谢你借我衣服和裤子。[l]要放进洗衣机吗？」"

# game/day 12.rpy:258
translate chinese_simplified torahiko12_d1a3a83d:

    # to "「It's okay to just leave them there, I'll finally do\n it later.」"
    # [旧版翻译] 来源: 12日目.ks (KS 277)
    to "「之后再说，先放在旁边没关系的」"

# game/day 12.rpy:259
translate chinese_simplified torahiko12_29be8b4d:

    # fn "「Alright.{w} As you said.」"
    # [旧版翻译] 来源: 12日目.ks (KS 280)
    fn "「啊，是吗？[l]那就这样咯」"

# game/day 12.rpy:260
translate chinese_simplified torahiko12_8d25dab4:

    # to "「Heh.」"
    to "「OK」"

# game/day 12.rpy:264
translate chinese_simplified torahiko12_7f15823e:

    # to "「I've changed into my uniform.{w} Let's get going.」"
    # [旧版翻译] 来源: 12日目.ks (KS 287)
    to "「那么，我也该换好制服，然后出门」"

# game/day 12.rpy:265
translate chinese_simplified torahiko12_a02c4f04_1:

    # fn "「Sure!」"
    # [旧版翻译] 来源: 12日目.ks (KS 290)
    fn "「了解」"

# game/day 12.rpy:266
translate chinese_simplified torahiko12_e395426c:

    # "I get on the back of Torahiko's bicycle and then we head to Kazenari High School."
    # [旧版翻译] 来源: 12日目.ks (KS 292)
    "我坐在虎彦的自行车后面，前往风鸣高中。"

# game/day 12.rpy:274
translate chinese_simplified torahiko12_179be225:

    # to "「Good morning!」"
    # [旧版翻译] 来源: 12日目.ks (KS 302)
    to "「大家早——」"

# game/day 12.rpy:275
translate chinese_simplified torahiko12_0e0e9ec8:

    # "We arrived at the pool of Kazenari High School later and entered the changing room."
    # [旧版翻译] 来源: 12日目.ks (KS 304)
    "到了风鸣高中游泳池的我们，进入更衣室。"

# game/day 12.rpy:276
translate chinese_simplified torahiko12_dceba229:

    # everyone "「Morning, Torahiko!」"
    # [旧版翻译] 来源: 12日目.ks (KS 307)
    everyone "「早啊——虎彦」"

# game/day 12.rpy:277
translate chinese_simplified torahiko12_b16c10aa:

    # "I see there're also several beastmen who seem to be his members are sitting inside the changing room..."
    # [旧版翻译] 来源: 12日目.ks (KS 309)
    "有几位社员好像是兽人……"

# game/day 12.rpy:282
translate chinese_simplified torahiko12_5b459242:

    # who "「Good morning, Torahiko.」"
    # [旧版翻译] 来源: 12日目.ks (KS 316)
    who "「虎彦，早安啊」"

# game/day 12.rpy:283
translate chinese_simplified torahiko12_3b0c1009:

    # "A bull beastman wearing a blue jersey seems to be Torahiko's advisor."
    # [旧版翻译] 来源: 12日目.ks (KS 318-319)
    "站在那穿着清爽的蓝色运动衫的牛兽人似乎就是顾问。"

# game/day 12.rpy:287
translate chinese_simplified torahiko12_74566ff5:

    # to "「Hi Boss!」"
    # [旧版翻译] 来源: 12日目.ks (KS 323)
    to "「早安！」"

# game/day 12.rpy:288
translate chinese_simplified torahiko12_c12f2fde:

    # "This person is insanely huge...{w} He has such a body of a raging buffalo."
    # [旧版翻译] 来源: 12日目.ks (KS 325-326)
    "应该说，这个人不好惹啊……[l]看种族是水牛吧？"

# game/day 12.rpy:289
translate chinese_simplified torahiko12_3141072d:

    # "The thickness of his body is amazing,{w} and the feeling of intimidation is also amazing in proportion to it.{w} Yeah, he might be a little scary..."
    # [旧版翻译] 来源: 12日目.ks (KS 328-330)
    "体型很惊人，而且这比例很有威吓感。有点可怕啊……"

# game/day 12.rpy:293
translate chinese_simplified torahiko12_66742f63:

    # who "「Hmm?{w} Who is this human boy?」"
    # [旧版翻译] 来源: 12日目.ks (KS 334)
    who "「嗯？[l]这是人类小孩吗？」"

# game/day 12.rpy:297
translate chinese_simplified torahiko12_8bb4c0a4:

    # to "「He's my childhood friend.」"
    # [旧版翻译] 来源: 12日目.ks (KS 338)
    to "「是我的儿时玩伴」"

# game/day 12.rpy:298
translate chinese_simplified torahiko12_eb3eea2c:

    # fn "「Nice to meet you...{w} I'm [fn] [ln],{w}\n I came here today with Torahiko to see\n him practice.」"
    # [旧版翻译] 来源: 12日目.ks (KS 341-343)
    fn "「初，初次见面……[l]我叫西村。[l]今天是来参观虎彦练习，所以就来了」"

# game/day 12.rpy:299
translate chinese_simplified torahiko12_9eae7fac:

    # who "「You are [ln]?{w} Torahiko says a lot about you.{p} He's been really happy that his childhood friend is\n back.」"
    # [旧版翻译] 来源: 12日目.ks (KS 346-348)
    who "「你就是西村啊？[l]我有听虎彦说过。[l]儿时玩伴回来了，因为最近会一直在这，所以很开心啊」"

# game/day 12.rpy:303
translate chinese_simplified torahiko12_a3744bf6:

    # who "「I'm Kuroda, an advisor and also the coach of the\n swimming club.{w} Nice to meet you.」"
    # [旧版翻译] 来源: 12日目.ks (KS 352)
    who "「我是游泳社的顾问兼教练——黑田。[l]请多指教」"

# game/day 12.rpy:304
translate chinese_simplified torahiko12_d243df7a:

    # kr "「Watch them swim today.{w} Torahiko and other members\n will be encouraged a lot if there's an audience.」"
    # [旧版翻译] 来源: 12日目.ks (KS 355-356)
    kr "「今天有很多人参观呢。[l]虎彦也是，其他社员也是，听见观众席上有人加油，会更卖力的吧」"

# game/day 12.rpy:305
translate chinese_simplified torahiko12_783da7f8:

    # fn "「Thank you!」"
    # [旧版翻译] 来源: 12日目.ks (KS 359)
    fn "「真的很感谢您！」"

# game/day 12.rpy:309
translate chinese_simplified torahiko12_8bb42db2:

    # kr "「Then if you notice anything during the tour or think\n that I should improve something, please tell me.」"
    # [旧版翻译] 来源: 12日目.ks (KS 363-365)
    kr "「那么，如果在参观的途中感觉到有什么地方要改善的，请务必告诉我。[l]任何细微的数据，对体育界都很重要」"

# game/day 12.rpy:310
translate chinese_simplified torahiko12_073aab77:

    # kr "「Any kind of trivial data is also important in the\n world of sports.」"
    # [旧版翻译] 来源: 12日目.ks (KS 368)
    kr "「我知道了，黑田老师」"

# game/day 12.rpy:311
translate chinese_simplified torahiko12_9b1f6d34:

    # fn "「Okay, Kuroda-sensei.」"
    # [旧版翻译] 来源: 12日目.ks (KS 368)
    fn "「我知道了，黑田老师」"

# game/day 12.rpy:315
translate chinese_simplified torahiko12_c8f2670e:

    # "Kuroda-sensei smiles and opens a file that seems to be crucial.{w} I'm glad that he's really a kinder teacher than he looks..."
    # [旧版翻译] 来源: 12日目.ks (KS 372-374)
    "黑田老师笑了笑，打开看上去很重要的文件。看上去是位很温柔的老师，太好了……"

# game/day 12.rpy:319
translate chinese_simplified torahiko12_44709fa0:

    # kr "「Okay, we'll have a meeting since we're all here now.{p} Let's get started!」"
    # [旧版翻译] 来源: 12日目.ks (KS 378-379)
    kr "「好，那全员开始准备讨论。[l]集合！」"

# game/day 12.rpy:320
translate chinese_simplified torahiko12_e97c022e:

    # mems "「Roger!」"
    # [旧版翻译] 来源: 12日目.ks (KS 382)
    mems "「是——」"

# game/day 12.rpy:325
translate chinese_simplified torahiko12_14896652:

    # "After the meeting, we move to the poolside and do some stretching.{w} Then, the members starts to practice and measure their time."
    # [旧版翻译] 来源: 12日目.ks (KS 388-390)
    "会议结束后，朝泳池旁边移动，做了热身运动。之后，社员们各自练习，测算时间。"

# game/day 12.rpy:329
translate chinese_simplified torahiko12_68991d1a:

    # kr "「Inuzuka, your time is shorter than usual.{w} You can\n see the result of your previous practice coming out.」"
    # [旧版翻译] 来源: 12日目.ks (KS 394-396)
    kr "「犬冢，你的时间渐渐缩短咯。[l]之前回游的练习成果体现出来了，[l]是你自己努力的结果啊」"

# game/day 12.rpy:330
translate chinese_simplified torahiko12_a9863981:

    # kr "「Takahito is also much better than the previous time.{p} The form of your arm, however, is gradually returning\n to the previous bad form.」"
    # [旧版翻译] 来源: 12日目.ks (KS 399-401)
    kr "「鹰仁也是，比之前快了很多。[l]但是，手臂的动作因为回游有点变成之前错误的动作，要注意啊」"

# game/day 12.rpy:331
translate chinese_simplified torahiko12_9565a99b:

    # kr "「Shoma, did you change the timing of breathing?{p} Compare it with the previous timings and decide\n which one is easier for you to do.」"
    # [旧版翻译] 来源: 12日目.ks (KS 404-406)
    kr "「祥马，换气的时间有改变吗？[l]跟以前相比，看看哪个方法比较容易」"

# game/day 12.rpy:332
translate chinese_simplified torahiko12_55b82deb:

    # kr "「Since other elements have been cleared, let's just\n focus on that for now.」"
    # [旧版翻译] 来源: 12日目.ks (KS 409-410)
    kr "「其他人大多都有达到标准，接下来只要集中精神」"

# game/day 12.rpy:333
translate chinese_simplified torahiko12_4ff99afc:

    # "Then Kuroda-sensei writes more and more information on the board while giving accurate advice to the members. He feels like a talented super coach."
    # [旧版翻译] 来源: 12日目.ks (KS 412-414)
    "黑田老师向社员们提出清楚明了的建议，并把情况写在记录本里。感觉就是位超级教练。"

# game/day 12.rpy:334
translate chinese_simplified torahiko12_7191d5c8:

    # "Now, it's Torahiko's turn."
    # [旧版翻译] 来源: 12日目.ks (KS 416)
    "那么，接下来轮到虎彦。"

# game/day 12.rpy:335
translate chinese_simplified torahiko12_6ea65715:

    # "When Torahiko jumps brilliantly from the diving board, he accelerates steadily with the same flowing motion as last time and reaches the goal in no time."
    # [旧版翻译] 来源: 12日目.ks (KS 418-420)
    "虎彦从跳水台华丽地跳下去，和之前一样，随着动作迅速加速，很快就到终点了。"

# game/day 12.rpy:336
translate chinese_simplified torahiko12_29714649:

    # "It's a swim that seems to have no flaws at all..."
    # [旧版翻译] 来源: 12日目.ks (KS 422-423)
    "从我来看，没有任何要改进的地方。虽然是游泳……"

# game/day 12.rpy:340
translate chinese_simplified torahiko12_632bc3cb:

    # kr "「Torahiko, it's slower than your last time ...?」"
    # [旧版翻译] 来源: 12日目.ks (KS 427)
    kr "「虎彦，速度比之前慢了哦……？」"

# game/day 12.rpy:344
translate chinese_simplified torahiko12_0e8e78c9:

    # to "「Gee, really...」"
    # [旧版翻译] 来源: 12日目.ks (KS 431)
    to "「咦，真的假的……」"

# game/day 12.rpy:345
translate chinese_simplified torahiko12_8d311e21:

    # kr "「You can't concentrate on swimming as a whole and\n your body wasn't moving as usual.{w} Be aware of using\n your whole body properly.」"
    # [旧版翻译] 来源: 12日目.ks (KS 434-436)
    kr "「游泳时不集中精神，身体就会比平常还不好动。[l]要好好注意正确运用整个身体」"

# game/day 12.rpy:346
translate chinese_simplified torahiko12_21f6f051:

    # kr "「If your body is stiff, then you should stretch out a\n little more.」"
    # [旧版翻译] 来源: 12日目.ks (KS 439-440)
    kr "「如果身体僵硬，就伸展一下」"

# game/day 12.rpy:350
translate chinese_simplified torahiko12_f0de3bfc:

    # to "「Alright.」"
    # [旧版翻译] 来源: 12日目.ks (KS 444)
    to "「可恶……」"

# game/day 12.rpy:356
translate chinese_simplified torahiko12_e0657261:

    # "As Torahiko replies grudgingly,{w} he walks towards where I'm standing."
    # [旧版翻译] 来源: 12日目.ks (KS 448)
    "虎彦没什么精神地回应着，向我的方向走过来。"

# game/day 12.rpy:360
translate chinese_simplified torahiko12_690a6745:

    # fn "「I thought that was a good swim... wasn't it?」"
    # [旧版翻译] 来源: 12日目.ks (KS 453)
    fn "「这次，我觉得很好……不行吗？」"

# game/day 12.rpy:364
translate chinese_simplified torahiko12_763e708d:

    # to "「Ah, I also thought that swim wasn't really that good.\n As Kuroda-sensei has pointed out.」"
    # [旧版翻译] 来源: 12日目.ks (KS 457-458)
    to "「是啊，我也觉得游泳时的状况不好。[l]就跟黑田老师说的一样」"

# game/day 12.rpy:365
translate chinese_simplified torahiko12_e82d2396:

    # fn "「After all...{w} Is that because I'm here?」"
    # [旧版翻译] 来源: 12日目.ks (KS 461)
    fn "「果然我，不应该来吧？」"

# game/day 12.rpy:369
translate chinese_simplified torahiko12_e1626a60:

    # to "「What are you even saying?{w} That's not the problem.」"
    # [旧版翻译] 来源: 12日目.ks (KS 465)
    to "「在说什么啊，[l]那不是问题所在」"

# game/day 12.rpy:370
translate chinese_simplified torahiko12_d928654c:

    # to "「I just wonder if I should practice earnestly.」"
    # [旧版翻译] 来源: 12日目.ks (KS 468)
    to "「嘛，就只能练习了」"

# game/day 12.rpy:371
translate chinese_simplified torahiko12_b4bab96d:

    # fn "「Oh...{w} Then do your best. I'm supporting you.」"
    # [旧版翻译] 来源: 12日目.ks (KS 471)
    fn "「这样啊……[l]加油哦，[l]我会支持你的」"

# game/day 12.rpy:375
translate chinese_simplified torahiko12_26e94f4a:

    # to "「Yeah!」"
    # [旧版翻译] 来源: 12日目.ks (KS 475)
    to "「哦！」"

# game/day 12.rpy:376
translate chinese_simplified torahiko12_99ebe6d9:

    # "The actual tournament is getting closer and closer. I hope that we will finally meet the day after we manage to survive this slump."
    # [旧版翻译] 来源: 12日目.ks (KS 477-478)
    "重要的日子也在慢慢逼近，虎彦却不知道为什么发挥不到最佳水平。希望大会当天，能跨过那道坎……"

# game/day 12.rpy:383
translate chinese_simplified torahiko12_9593e7d9:

    # kr "「Okay, everyone gather around!」"
    # [旧版翻译] 来源: 12日目.ks (KS 488)
    kr "「好，全员集合！」"

# game/day 12.rpy:384
translate chinese_simplified torahiko12_045a6070:

    # "Kuroda-sensei blows a whistle and gathers all the members."
    # [旧版翻译] 来源: 12日目.ks (KS 490)
    "黑田老师吹了哨子，全部社员集合了过来。"

# game/day 12.rpy:388
translate chinese_simplified torahiko12_d5b9fe03:

    # kr "「That's enough for today.{w} Everyone is improving\n steadily.{w} Many people are steadily shortening their\n time.」"
    # [旧版翻译] 来源: 12日目.ks (KS 494-496)
    kr "「今天的练习就到这。[l]大家，进步越来越大了呢。[l]很多人的时间也渐渐缩短了」"

# game/day 12.rpy:389
translate chinese_simplified torahiko12_abcdae0c:

    # kr "「Until the day of the tournament on the 17th, please\n prepare yourself.」"
    # [旧版翻译] 来源: 12日目.ks (KS 499-500)
    kr "「在17日大会当天，各自要好好维持状态」"

# game/day 12.rpy:390
translate chinese_simplified torahiko12_9c0c0123:

    # kr "「If you have any questions or want to consult with\n us,{w} please come to me when in the changing room.」"
    # [旧版翻译] 来源: 12日目.ks (KS 503-504)
    kr "「就算事情很小也好，有问题要问的，换好衣服后就来我这边」"

# game/day 12.rpy:394
translate chinese_simplified torahiko12_d8487c18:

    # kr "「That's all. Club dismissed.」"
    # [旧版翻译] 来源: 12日目.ks (KS 508)
    kr "「以上，解散！」"

# game/day 12.rpy:395
translate chinese_simplified torahiko12_f17d503b:

    # mems "「So tired!」"
    # [旧版翻译] 来源: 12日目.ks (KS 511)
    mems "「大家辛苦了——！」"

# game/day 12.rpy:399
translate chinese_simplified torahiko12_053d605c:

    # "Each member then enters the changing room."
    # [旧版翻译] 来源: 12日目.ks (KS 515)
    "社员们各自前往更衣室。"

# game/day 12.rpy:403
translate chinese_simplified torahiko12_f07f98a5:

    # to "「I'll go change my clothes, so please wait.」"
    # [旧版翻译] 来源: 12日目.ks (KS 519)
    to "「博行，我也要去换衣服，先等一下」"

# game/day 12.rpy:404
translate chinese_simplified torahiko12_e6ab0e27:

    # fn "「Alright.」"
    # [旧版翻译] 来源: 12日目.ks (KS 522)
    fn "「嗯，我知道了」"

# game/day 12.rpy:408
translate chinese_simplified torahiko12_e797aa35:

    # "With that being said, Torahiko also disappears into the changing room."
    # [旧版翻译] 来源: 12日目.ks (KS 525)
    "这么说着，虎彦也消失在更衣室里。"

# game/day 12.rpy:412
translate chinese_simplified torahiko12_30dbd2dd:

    # kr "「Hey [ln].」"
    # [旧版翻译] 来源: 12日目.ks (KS 529)
    kr "「西村」"

# game/day 12.rpy:413
translate chinese_simplified torahiko12_bb76eb3a:

    # fn "「Oh, Kuroda-sensei.{w} Thank you for today.」"
    # [旧版翻译] 来源: 12日目.ks (KS 532)
    fn "「啊，黑田老师。[l]今天真的很谢谢您」"

# game/day 12.rpy:417
translate chinese_simplified torahiko12_d977988c:

    # kr "「How is it?{w} Have you noticed anything during the\n tour today?」"
    # [旧版翻译] 来源: 12日目.ks (KS 536)
    kr "「怎么样？[l]来参观后有什么感觉？」"

# game/day 12.rpy:418
translate chinese_simplified torahiko12_c6a077f5:

    # fn "「Hmm... Everyone here are really skillful swimmers.{p} Then, I'd say I didn't notice anything in particular.」"
    # [旧版翻译] 来源: 12日目.ks (KS 539-540)
    fn "「嗯……对游泳业余水平的我来说，也没什么特别的……」"

# game/day 12.rpy:419
translate chinese_simplified torahiko12_a3eb3cb9:

    # kr "「Is that so?」"
    # [旧版翻译] 来源: 12日目.ks (KS 543)
    kr "「是吗？」"

# game/day 12.rpy:420
translate chinese_simplified torahiko12_e1ec26f5:

    # fn "「Yes...{w} Moreover, Kuroda-sensei's instructions are\n really accurate and they're analyzed fairly\n logically.」"
    # [旧版翻译] 来源: 12日目.ks (KS 546-548)
    fn "「是啊……[l]而且，黑田老师的指示很明确，看的出来是从理论上思考后，进行各种分析得到的结果」"

# game/day 12.rpy:424
translate chinese_simplified torahiko12_db3344d2:

    # kr "「I'm glad if you say so.{w} All of our members\n are very hard-working people.」"
    # [旧版翻译] 来源: 12日目.ks (KS 552-553)
    kr "「你这么说我很高兴。[l]我们的社员们都很努力啊」"

# game/day 12.rpy:425
translate chinese_simplified torahiko12_31bcdd0d:

    # kr "「I want them to grow and achieve good results\n in the tournament.」"
    # [旧版翻译] 来源: 12日目.ks (KS 556-557)
    kr "「不管是什么样的成长，希望他们都能在大会上取得优秀的成绩」"

# game/day 12.rpy:429
translate chinese_simplified torahiko12_18b8a130:

    # kr "「That's why, I want to collect and analyze as\n much data as I can.」"
    # [旧版翻译] 来源: 12日目.ks (KS 561)
    kr "「这就是我们尽可能地收集数据来分析的理由」"

# game/day 12.rpy:430
translate chinese_simplified torahiko12_f9c8e7c8:

    # "Kuroda-sensei smiles again."
    # [旧版翻译] 来源: 12日目.ks (KS 563)
    "黑田老师又笑了。"

# game/day 12.rpy:431
translate chinese_simplified torahiko12_2065f427:

    # fn "「I'm sorry for not helping you much with that...」"
    # [旧版翻译] 来源: 12日目.ks (KS 566)
    fn "「不好意思，没帮上忙……」"

# game/day 12.rpy:435
translate chinese_simplified torahiko12_5cfb15e3:

    # kr "「No, that's not the case.{w} As there're things that\n only you can do.」"
    # [旧版翻译] 来源: 12日目.ks (KS 570-571)
    kr "「不，并不是这样哦。[l]而且，有只有西村才做得到的事啊」"

# game/day 12.rpy:436
translate chinese_simplified torahiko12_c7a9c987:

    # fn "「There're things that only I can do?」"
    # [旧版翻译] 来源: 12日目.ks (KS 574)
    fn "「只有我才做得到的事？」"

# game/day 12.rpy:437
translate chinese_simplified torahiko12_65451cff:

    # kr "「Torahiko.{w} You are his childhood friend.{p} If you play with him a lot during this summer, I'd\n like you to provide him some mental support.」"
    # [旧版翻译] 来源: 12日目.ks (KS 577-579)
    kr "「关于虎彦。[l]西村身为虎彦的儿时玩伴，是位好朋友吧？[l]如果这个暑假跟虎彦多多玩在一起，就可以为他在精神上加油打气」"

# game/day 12.rpy:438
translate chinese_simplified torahiko12_330fa3d8:

    # kr "「It's not uncommon for sports to be affected\n by mental aspects.」"
    # [旧版翻译] 来源: 12日目.ks (KS 582-583)
    kr "「在运动中，心理状态影响比赛结果的情况并不罕见」"

# game/day 12.rpy:439
translate chinese_simplified torahiko12_c00002f1:

    # kr "「If you are a professional, you will have your own\n way to transcend your emotions.{w} But he is still a\n student.」"
    # [旧版翻译] 来源: 12日目.ks (KS 586-587)
    kr "「因为虎彦还是个学生，如果他的心理能力能够达到专家水准的话，就很有机会在技术上超越对手」"

# game/day 12.rpy:440
translate chinese_simplified torahiko12_e26701af:

    # kr "「So, I want you to support the inside of Torahiko\n toward the actual performance.」"
    # [旧版翻译] 来源: 12日目.ks (KS 590)
    kr "「所以，我希望你能成为虎彦的心灵支柱」"

# game/day 12.rpy:441
translate chinese_simplified torahiko12_a5d299e0:

    # fn "「I wonder if I could do such kind of thing...」"
    # [旧版翻译] 来源: 12日目.ks (KS 593)
    fn "「这种事，我做得到吗……」"

# game/day 12.rpy:445
translate chinese_simplified torahiko12_8113958e:

    # kr "「You don't have to think too hard.{w} I usually get\n along with Torahiko, and that itself has also had a\n positive effect on him.」"
    # [旧版翻译] 来源: 12日目.ks (KS 597)
    kr "「不用想得这么难。[l]你平常都和虎彦在一起，这点对虎彦来说是有正面影响的」"

# game/day 12.rpy:446
translate chinese_simplified torahiko12_0c03cb26:

    # fn "「Well then, I think I can do it.」"
    # [旧版翻译] 来源: 12日目.ks (KS 600)
    fn "「嗯……[l]嘛，那样的话我做得到」"

# game/day 12.rpy:450
translate chinese_simplified torahiko12_c63e9f58:

    # kr "「Uhm.{w} Then see you on the day of the tournament.」"
    # [旧版翻译] 来源: 12日目.ks (KS 604)
    kr "「嗯。[l]朝大会当天，努力吧」"

# game/day 12.rpy:451
translate chinese_simplified torahiko12_f07c7e4f:

    # mem "「Kuroda-sensei, I have a question about the form.」"
    # [旧版翻译] 来源: 12日目.ks (KS 607)
    mem "「黑田老师，我对动作有个疑问」"

# game/day 12.rpy:455
translate chinese_simplified torahiko12_a4dd491b:

    # kr "「Oops, excuse me.{w} Please come to see us practice\n again.」"
    # [旧版翻译] 来源: 12日目.ks (KS 611-612)
    kr "「那么，我先失陪了。[l]下次练习时再来看看」"

# game/day 12.rpy:456
translate chinese_simplified torahiko12_e8901806:

    # "Kuroda-sensei then leave as he is called by a member. He disappear within a blink of an eye."
    # [旧版翻译] 来源: 12日目.ks (KS 614-615)
    "社员朝我的方向呼叫黑田老师。一眨眼间，他就走了。"

# game/day 12.rpy:460
translate chinese_simplified torahiko12_b4a785b7:

    # "I definitely want Torahiko to win the swimming competition."
    # [旧版翻译] 来源: 12日目.ks (KS 619-621)
    "虎彦绝对能在游泳大会上获胜的。因此我觉得自己帮不上忙。"

# game/day 12.rpy:461
translate chinese_simplified torahiko12_f3e7fe4d:

    # "At first, I thought there was nothing I can do to help him in particular,{w} but Kuroda-sensei says that there seems to be something that only I can do."
    # [旧版翻译] 来源: 12日目.ks (KS 622-623)
    "但是我想起来，黑田老师说过有只有我才能做得到的事。"

# game/day 12.rpy:462
translate chinese_simplified torahiko12_1fec88b1:

    # "That I'll just need to get along with Torahiko...?"
    # [旧版翻译] 来源: 12日目.ks (KS 625)
    "身为虎彦的好朋友……吗。[l]就算那样，我也……"

# game/day 12.rpy:463
translate chinese_simplified torahiko12_88e30cc6:

    # "Even so...{w} I've been doing that without being told. I have decided to enjoy this summer with all my might."
    # [旧版翻译] 来源: 12日目.ks (KS 626-627)
    "不，就算不说我也会做的。[l]因为我决定要尽全力享受夏天。"

# game/day 12.rpy:464
translate chinese_simplified torahiko12_84aec942:

    # to "「[fn]!」"
    # [旧版翻译] 来源: 12日目.ks (KS 630)
    to "「博行——！」"

# game/day 12.rpy:468
translate chinese_simplified torahiko12_07ad1d58:

    # fn "「Oh!」"
    # [旧版翻译] 来源: 12日目.ks (KS 635)
    fn "「哦！！」"

# game/day 12.rpy:472
translate chinese_simplified torahiko12_93ed300b:

    # to "「I've changed my clothes, so let's go home.{p} Get behind me!」"
    # [旧版翻译] 来源: 12日目.ks (KS 639)
    to "「终于换好衣服回来了，[l]来坐在自行车后面吧」"

# game/day 12.rpy:473
translate chinese_simplified torahiko12_d6b58ec9:

    # fn "「Don't jump on me so suddenly!」"
    # [旧版翻译] 来源: 12日目.ks (KS 642)
    fn "「别突然扑过来啦」"

# game/day 12.rpy:474
translate chinese_simplified torahiko12_f62d7d89:

    # to "「Heheheh!」"
    # [旧版翻译] 来源: 12日目.ks (KS 645)
    to "「嘿嘿嘿——」"

# game/day 12.rpy:475
translate chinese_simplified torahiko12_94cec6f9:

    # "After that, we sway on Torahiko's bicycle again and head home."
    # [旧版翻译] 来源: 12日目.ks (KS 647-648)
    "之后，我因为虎彦的自行车而摇晃着，就这样一路骑回家。"

# game/day 12.rpy:491
translate chinese_simplified juuichi12_abb64e17:

    # "In the midst of a chorus of cicadas,{w=.2}\nI steadily walk along the river bank."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 10)
    "在蝉鸣声大合唱中，[wdt]我在河边的沙滩上漫步着。"

# game/day 12.rpy:492
translate chinese_simplified juuichi12_5331682a:

    # "Clear water flows beside me.{p}Man, it'd feel good to jump into that."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 12-13)
    "旁边是流着清澈溪水的河川。[l]要是跳进去的话应该会相当舒服吧，[wdt]"

# game/day 12.rpy:493
translate chinese_simplified juuichi12_dbcbfdba:

    # "I'm thinking like an elementary school kid."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 14)
    "不过会这么想的我也太像小学生了。"

# game/day 12.rpy:494
translate chinese_simplified juuichi12_d52444f7:

    # "...Hell, there are so few people out\nhere in the countryside,{w=.2}\nI probably could go skinny-dipping if I wanted."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 16-17)
    "……哎，在这种没什么人的乡下地方，[wdt]就算全裸下去游泳应该也没什么大不了的。"

# game/day 12.rpy:495
translate chinese_simplified juuichi12_bca96b4c:

    # "...Of course any person would think that."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 19-20)
    "……不过难免还是会想到，做为一个人好像不该做那种事。"

# game/day 12.rpy:496
translate chinese_simplified juuichi12_3582bf96:

    # "It'll be okay if I cool off a little, right?{p}My feet are tired from walking too,\nso this is a good time."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 22-23)
    "哎不过稍微让自己凉快点，[wdt]应该也不错吧。[l]脚也走得有点累了，稍微休息一下好了。"

# game/day 12.rpy:497
translate chinese_simplified juuichi12_cc6b23f7:

    # "I place my feet in the river,\n{w=.2}{nw}"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 25-26)
    "我向着河边，[wdt][se step13b]一边踩着河畔丛生的野草一边前进。"

# game/day 12.rpy:499
translate chinese_simplified juuichi12_7698da9c:

    # extend "And push my way through the reeds."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 26)
    extend "一边踩着河畔丛生的野草一边前进。"

# game/day 12.rpy:505
translate chinese_simplified juuichi12_ee37a4dd:

    # fn "「Whew,{w=.2} I needed this...」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 35)
    fn "「呼，[wdt]终于活过来了……」"

# game/day 12.rpy:506
translate chinese_simplified juuichi12_b9ff7718:

    # "A few minutes later,{p}I'm soaking in the clear water up to my shins,{w=.2}\nand I sigh with satisfaction."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 37-38)
    "几分钟后。[l]我把小腿以下都泡在透明的溪水，[wdt]满足地叹了口气。"

# game/day 12.rpy:507
translate chinese_simplified juuichi12_104c2a0f:

    # "Being warmed by the sun and cooled by the water\nat the same time is conflicting."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 40-41)
    "在被太阳晒到发烫的同时，[wdt]又感受着水的冰凉。两种完全相反的感觉。[l]在夏天或许是理所当然的事，[wdt]"

# game/day 12.rpy:508
translate chinese_simplified juuichi12_10c766f7:

    # "It's probably natural to feel this way during\nsummer, but it feels somewhat fresh."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 42)
    "不过我却觉得很新鲜。"

# game/day 12.rpy:509
translate chinese_simplified juuichi12_5cca9b0a:

    # "Maybe it's simply because the water is so nice,{w=.2}\nand I'm in this peaceful village\ninstead of the hectic city."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 44-46)
    "这可能是单纯因为水给人的感觉很美丽，[wdt]也可能是因为我现在不在那个嘈杂的都市，而是在这个和煦的村庄里的关系。"

# game/day 12.rpy:510
translate chinese_simplified juuichi12_e9f63c47:

    # "...Is it like me to think of things like that?"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 48)
    "……在想着一些乱七八糟的事呢。"

# game/day 12.rpy:511
translate chinese_simplified juuichi12_0c50e045:

    # "I try kicking one of my legs.{p}{nw}"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 50)
    "我试着用脚拍了拍水面。[l][se water01_c][wait time=\"300\"][se water01_c]"

# game/day 12.rpy:515
translate chinese_simplified juuichi12_a1798356:

    # extend "The sound of splashing is mixed with the cicadas.{p}I get cooler from the splash getting me more wet."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 51-52)
    extend "啪打啪打的声音混在蝉鸣声中，[l]弹起来的水珠沾湿了大腿，感觉变得更清爽。"

# game/day 12.rpy:516
translate chinese_simplified juuichi12_538adf97:

    # "Ah, did I get my clothes wet?{p}...Oh well, I'm sure they'll dry in the sun.{p}I keep doing it."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 54-55)
    "啊，衣服被弄湿了。[l]……算了，在这种大太阳下，肯定一下子就乾了。[l]"

# game/day 12.rpy:517
translate chinese_simplified juuichi12_f966fe71:

    # "I try kicking my leg as hard as I can.{p}{nw}"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 56)
    "再多弄点也没差。"

# game/day 12.rpy:523
translate chinese_simplified juuichi12_6e7b84cb:

    # extend "The droplets of flying water glitter in the sun.{p}I keep splashing, not caring how wet I get."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 58-59)
    extend "想着这些的同时动了动脚。[l][se water01_c][wait time=\"300\"][se water01_c][wait time=\"500\"][se water01_c]飞弹上来的水珠，在太阳光下映照出闪耀的光芒。[l]"

# game/day 12.rpy:524
translate chinese_simplified juuichi12_ef95f29d:

    # "For a short while, I play in the water like that."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 60)
    "虽然有些水珠弹到脸上，不过我还是不怎么在意地继续拍水。"

# game/day 12.rpy:525
translate chinese_simplified juuichi12_6fc9d157:

    # fn "「...?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 68)
    fn "忽然间我听到附近好像有说话声，停下了脚步。[l]"

# game/day 12.rpy:526
translate chinese_simplified juuichi12_a683964b:

    # "I could swear I just heard a voice.{p}There shouldn't be anyone nearby, though..."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 69)
    "不管怎么说在这附近会有人都……"

# game/day 12.rpy:530
translate chinese_simplified juuichi12_425adeee:

    # "Oh.{p}There is somebody.{p}And it's people that I know."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 73-75)
    "啊。[l]真的有。[l]而且，[wdt]这不是我认识的人吗。"

# game/day 12.rpy:531
translate chinese_simplified juuichi12_60272896:

    # "A short way down the river,{w=.2}\nJuuichi-san is walking with Soutarou-kun."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 77-78)
    "在离河流不远的地方，[wdt]柔一和宗太郎一起散着步。"

# game/day 12.rpy:532
translate chinese_simplified juuichi12_e31e0733:

    # "They're deep in discussion,{w=.2}\nand don't seem to notice me."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 80-81)
    "看他们很热烈地在对话着，[wdt]似乎没有注意到我人在这里的样子。"

# game/day 12.rpy:533
translate chinese_simplified juuichi12_8ee44fc3:

    # "With a bit of trouble, {nw}"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 83)
    "我烦恼了一下，[se mizu07]把脚抬出水面。[l]"

# game/day 12.rpy:535
translate chinese_simplified juuichi12_883dde7d:

    # extend "I step out of the water.{p}After all, 2 people are more than 1,\nand 3 people is more than 2!"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 84)
    extend "不过果然与其一人不如两人，[wdt]与其两人不如三人。"

# game/day 12.rpy:536
translate chinese_simplified juuichi12_ee05a946:

    # "I didn't bring a towel with me.{w=.2}\nI guess I can just use my socks to dry off.{p}I'll stick my wet socks in my pockets for now."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 86-87)
    "因为没有带毛巾，[wdt]我只好用袜子来把水擦乾。[l]"

# game/day 12.rpy:540
translate chinese_simplified juuichi12_383b7caf:

    # "...Okay. I'm done putting my shoes on.{p}{nw}"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 92)
    "……很好。[wdt]鞋子也装备完成了。[l][se step03]"

# game/day 12.rpy:542
translate chinese_simplified juuichi12_e412d220:

    # extend "I run along the gravel, taking care not to trip.{p}I greet them as I approach."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 93-94)
    extend "我小心地踩在河边的砾石上避免跌倒，[l]然后，[wdt]慢慢走到他们旁边对他们打招呼。"

# game/day 12.rpy:543
translate chinese_simplified juuichi12_397715fb:

    # fn "「Hey!{w=.2} Juuichi-san,{w=.2} Soutarou-kun!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 97)
    fn "「喂――[wdt]柔一、[wdt]宗太郎――」"

# game/day 12.rpy:550
translate chinese_simplified juuichi12_17b16bea:

    # ju "「...[ln]?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 107)
    ju "「……西村吗。」"

# game/day 12.rpy:551
translate chinese_simplified juuichi12_60e94ebf:

    # so "「Oh, good afternoon, Senpai!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 111)
    so "「啊，[wdt]学长午安的说。」"

# game/day 12.rpy:552
translate chinese_simplified juuichi12_24c1660f:

    # "There's quite a contrast in their greetings.{p}I guess Soutarou-kun is yang,{w=.2}\nand Juuichi-san is ying?"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 113-114)
    "差异超大的招呼。[l]如果要说宗太郎是阳的话，[wdt]柔一就应该算是阴吧？"

# game/day 12.rpy:553
translate chinese_simplified juuichi12_cb12e9ff:

    # "...No, while Juuichi-san certainly is surly,\nI don't think that's true."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 116-117)
    "……不，[wdt]就算这样要说柔一是阴气的话也未免有点太夸张了。"

# game/day 12.rpy:554
translate chinese_simplified juuichi12_cf7d6c4f:

    # ju "「...Why are you here?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 120)
    ju "「……西村怎么会在这？」"

# game/day 12.rpy:555
translate chinese_simplified juuichi12_ab65d4c0:

    # fn "「I was just cooling off a bit.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 123)
    fn "「这里比较凉嘛。」"

# game/day 12.rpy:556
translate chinese_simplified juuichi12_7c63ef91:

    # "I look behind me as I say that.{p}Juuichi-san gets my meaning."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 125-126)
    "我说着看了看身后。[l]透过这个动作，柔一他们很快就看懂了我的意思。"

# game/day 12.rpy:557
translate chinese_simplified juuichi12_47508f34:

    # fn "「So,{w=.2} what are you two up to?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 129)
    fn "「那么，[wdt]你们两人是在做什么呢？」"

# game/day 12.rpy:558
translate chinese_simplified juuichi12_d488f578:

    # ju "「Well,{w=.2} Touno called me up.{p} There's something he wanted to talk to me about.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 132-133)
    ju "「没，[wdt]橙野突然叫我出来。[l]说是有事要谈什么的。」"

# game/day 12.rpy:559
translate chinese_simplified juuichi12_ff838e80:

    # "Upon hearing what he says,{w=.2}\nI tilt my head in confusion."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 135-136)
    "听到柔一说的话，[wdt]让我不禁猛然抬起头。"

# game/day 12.rpy:560
translate chinese_simplified juuichi12_171a29b2:

    # fn "「Huh? He didn't call Kyouji?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 139)
    fn "「咦，怎么不去找京慈谈？」"

# game/day 12.rpy:561
translate chinese_simplified juuichi12_71d08651:

    # "I'm sure Soutarou-kun has\nquite a lot of respect for Kyouji."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 141)
    "宗太郎他明明相当尊敬京慈才对。[l]"

# game/day 12.rpy:562
translate chinese_simplified juuichi12_c762d1dd:

    # "I don't know him very well,\nbut even I can tell that when I see him."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 142-143)
    "虽然认识宗太郎还不久，但是看看平常的宗太郎，[wdt]就算是我也看得出来。"

# game/day 12.rpy:563
translate chinese_simplified juuichi12_8ee36428:

    # "That's why it seems out of place for him\nto call Juuichi-san instead of Kyouji."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 145-146)
    "所以不是去找京慈商谈而是找柔一，[wdt]总觉得哪里怪怪的。"

# game/day 12.rpy:567
translate chinese_simplified juuichi12_515a7ec4:

    # ju "「That's what I thought, too.{p} I asked him why he didn't talk to Takahara.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 151-152)
    ju "「啊啊，我也这么想。[l]不是高原可以吗，[wdt]虽然我这么问了……」"

# game/day 12.rpy:572
translate chinese_simplified juuichi12_cbcfaba8:

    # so "「No,{w=.2} Takahara-senpai can't know about this!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 158)
    so "「啊不，[wdt]这件事情就是不可以让高原学长知道的说！」"

# game/day 12.rpy:576
translate chinese_simplified juuichi12_d91161b7:

    # ju "「...So,{w=.2} here we are.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 163)
    ju "「……这样，[wdt]就是这么回事。」"

# game/day 12.rpy:577
translate chinese_simplified juuichi12_9f4276b3:

    # fn "「I see...{p} Something he can't talk to Kyouji about, huh?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 166-167)
    fn "「原来如此……[l]不能跟京慈商谈的事情，这样吗。」"

# game/day 12.rpy:578
translate chinese_simplified juuichi12_061a12ca:

    # ju "「Correct.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 170)
    ju "「啊啊。」"

# game/day 12.rpy:579
translate chinese_simplified juuichi12_42fdd223:

    # "Juuichi-san glances over at Soutarou-kun.{p}I guess he's saying I should decide whether\nor not to talk to him myself."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 172-173)
    "柔一向宗太郎看了过去。[l]要不要跟我讲由他自己决定，[wdt]"

# game/day 12.rpy:580
translate chinese_simplified juuichi12_62a8b587:

    # "When I take a closer look at him,{w=.2}\nSoutarou-kun's face doesn't have its usual cheer.{p}It's kind of... Gloomy, I guess?"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 176-177)
    "仔细观察了一下，[wdt]宗太郎的表情不像平常那样高兴了。[l]"

# game/day 12.rpy:581
translate chinese_simplified juuichi12_8cae0d1f:

    # "He looks troubled for quite a long time,\nbut eventually looks towards me with resolve."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 178-181)
    "该说是有些阴暗呢，还是说看来有些疲倦呢……宗太郎稍微困扰了一下，[wdt]接着像是下定决心似的看向我这里。"

# game/day 12.rpy:585
translate chinese_simplified juuichi12_80f23667:

    # so "「Um,{w=.2} Senpai,{w=.2}\n how do I get bigger?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 186-187)
    so "「那个，[wdt]学长，[wdt]我想变大的话应该要怎么做才好的说？」"

# game/day 12.rpy:586
translate chinese_simplified juuichi12_9a5d7caa:

    # "I think I'm missing something here.{w=.2}\nHe wants to get... Bigger?"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 189-190)
    "不知为何没讲主词让我有点不大懂，[wdt]不过总之宗太郎是想要变大吧。"

# game/day 12.rpy:587
translate chinese_simplified juuichi12_ebdd196c:

    # "What does he mean?{p}What's bothering Soutarou-kun is..."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 192-193)
    "到底是在说什么？[l]会在宗太郎在意的东西，[wdt]应该是……"

# game/day 12.rpy:602
translate chinese_simplified juuichi12_body_3a50fd03:

    # "Hmm, I wonder...{p}Do soccer players body-build too?"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 216-217)
    "唔嗯，[wdt]踢足球也是体型大一点比较……[l]是这么回事吗？"

# game/day 12.rpy:603
translate chinese_simplified juuichi12_body_4d9fd5ce:

    # fn "「I see,{w=.2} you want a better physique?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 220)
    fn "「果然，[wdt]体格好的人踢足球也比较有利吗？」"

# game/day 12.rpy:607
translate chinese_simplified juuichi12_body_eda756ec:

    # so "「Yeah!{w} That's right!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 225)
    so "「是的说！[l] 就是这样的说！」"

# game/day 12.rpy:608
translate chinese_simplified juuichi12_body_12eec59e:

    # "He nods vigorously.{p}I can't help but laugh at the honest\nway he expresses himself."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 227-229)
    "宗太郎一边嗯嗯嗯一边用力点头。[l]这种率直的，可以明显看出他的性格的表现方法，[wdt]让我忍不住笑了出来。"

# game/day 12.rpy:612
translate chinese_simplified juuichi12_body_1071a0b1:

    # so "「...Senpai,{w=.2} did I say somethin' weird?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 234)
    so "「……学长，[wdt]我说了什么奇怪的话吗？」"

# game/day 12.rpy:613
translate chinese_simplified juuichi12_body_a5b575f0:

    # fn "「No,{w=.2} it's nothing.{p} I just remembered something funny.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 237)
    fn "「啊不，[wdt]没什么。[l]只是想到点事情。」"

# game/day 12.rpy:614
translate chinese_simplified juuichi12_body_4d8c3c8b:

    # so "「...Huh,{w=.2} really?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 240)
    so "「……啊，[wdt]这样吗。」"

# game/day 12.rpy:615
translate chinese_simplified juuichi12_body_95f4285c:

    # "He tilts his head, confused.\nI clear my throat to try and\nworm my way out of this situation."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 242-244)
    "宗太郎揉着自己的头。不行不行，[wdt]这样下去会跑出邪念的。[l]总之先咳了两声转移注意力。"

# game/day 12.rpy:616
translate chinese_simplified juuichi12_body_515e650b:

    # ju "「Just having a good physique is\n often an advantage in sports.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 247-248)
    ju "「要让体格变好的运动，[wdt]说起来也还是很多的。」"

# game/day 12.rpy:620
translate chinese_simplified juuichi12_body_8d3ea23c:

    # "Hearing what Juuichi-san says,{w=.2}\nSoutarou-kun voices his agreement."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 252-253)
    "宗太郎听到柔一说的话后，[wdt]简直像说相声似的马上「对对！」接了下去。"

# game/day 12.rpy:621
translate chinese_simplified juuichi12_body_fe7c7133:

    # "...There's still something he's not telling us.{p}I can tell, just by looking at him."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 255-256)
    "……果然，是很率直的孩子呢。[l]我看着宗太郎的样子不禁这么想着。"

# game/day 12.rpy:622
translate chinese_simplified juuichi12_body_679d7de8:

    # so "「I really want a slim, athletic body.{w=.2}\n Just like Takahara-senpai!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 259-260)
    so "「高原学长那样既高大又浑身肌肉，[wdt]这种类型我超憧景的说！」"

# game/day 12.rpy:623
translate chinese_simplified juuichi12_body_733d4ec4:

    # fn "「Ah,{w=.2} Kyouji definitely is the slim type.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 263)
    fn "「啊，[wdt]确实京慈是那种穿衣显瘦脱衣显肉的类型呢。」"

# game/day 12.rpy:624
translate chinese_simplified juuichi12_body_a4bf21ce:

    # "Juuichi-san nods in confirmation."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 265)
    "柔一点了点头，一脸确实呢的表情。"

# game/day 12.rpy:625
translate chinese_simplified juuichi12_body_83519253:

    # "...Hm? Wait."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 267)
    "……咦，等等？"

# game/day 12.rpy:626
translate chinese_simplified juuichi12_body_eb241417:

    # "Juuichi-san isn't in the same club as Kyouji.\nHow often does he see him naked?{w=.2}\nThat's going to bother me for a while."
    "柔一明明跟京慈不同社团，但却常常可以见到京慈的裸体吗？"

# game/day 12.rpy:627
translate chinese_simplified juuichi12_body_e05df5e5:

    # "...Now that I think about it,{w=.2}\nI'm pretty sure they're in the same class.{p}I'm sure there would be plenty of chances, right?"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 270-272)
    "柔一明明跟京慈不同社团，但却常常可以见到京慈的裸体吗？[wdt]我的脑袋里忍不住浮现出这样的疑问。"

# game/day 12.rpy:631
translate chinese_simplified juuichi12_body_1e749941:

    # ju "「...I doubt you've finished growing yet.{w=.2}\nYou shouldn't push yourself too hard, you know?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 272-274)
    ju "……不过仔细想想，[wdt]柔一和京慈确实是同个班级的。[l]这样的话常常有机会看到好像也不奇怪。"

# game/day 12.rpy:635
translate chinese_simplified juuichi12_body_da694350:

    # so "「Huh?{w=.2} Really?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 279-280)
    so "「……不过橙野的情况的来说，[wdt]因为接下来才要进入成长期，[l]不要做太大量的重量训练比较好喔？」"

# game/day 12.rpy:636
translate chinese_simplified juuichi12_body_c3920fe9:

    # "Soutarou-kun's voice rises in surprise."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 285)
    "「咦，[wdt]是那样的吗？」"

# game/day 12.rpy:637
translate chinese_simplified juuichi12_body_7f5f5377:

    # fn "「Oh, I think I've heard about that.{p} If you train too hard,{w=.2}\n you can't support the weight of your muscles.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 287)
    fn "宗太郎惊讶地回答。"

# game/day 12.rpy:638
translate chinese_simplified juuichi12_body_3ef6cfef:

    # fn "「In the worst case, you actually shrink, right?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 290-292)
    fn "「啊，[wdt]这我好像有听说过。[l]该怎么说，如果肌肉无法负荷那个重量的话，可能会出问题，[wdt]最糟的情况身高还会缩水的样子喔？」"

# game/day 12.rpy:639
translate chinese_simplified juuichi12_body_9e584aa3:

    # "It may seem like I'm making that up,\nbut I did actually see that on television."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 294-295)
    "虽然说的挺漂亮，不过这也只是我从电视上看来的而已。"

# game/day 12.rpy:643
translate chinese_simplified juuichi12_body_87e14ee1:

    # so "「Shrink...?!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 300)
    so "「身高会……！」"

# game/day 12.rpy:644
translate chinese_simplified juuichi12_body_4467f192:

    # "Soutarou-kun shudders in shock at what I said.{p}...That was more of a reaction that I expected."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 302-304)
    "我说的话似乎造成很大的衝击，[wdt]宗太郎的身体震了好大一下。[l]……哎呀，[wdt]比想像中的反应还大。"

# game/day 12.rpy:649
translate chinese_simplified juuichi12_body_d13614ae:

    # ju "「Well, it's best to be careful.{p} Don't use weights that are too heavy,{w=.2}\n stick to push-ups and squats.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 310-312)
    ju "「啊，只要小心一点就没什么好担心的。[l]不要一次做太大的重量，[wdt]从简单的伏地挺身和仰卧起坐做起吧。」"

# game/day 12.rpy:650
translate chinese_simplified juuichi12_body_618fc1c2:

    # ju "「Don't forget to eat well and sleep well, too.{p} They're just as important as exercise.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 315-317)
    ju "「……然后就是，和一般的说法一样，除了适当的运动外，[wdt]还要好好吃好好睡。[l]对健身来说休息也是非常重要的。」"

# game/day 12.rpy:651
translate chinese_simplified juuichi12_body_7e04cd61:

    # "Juuichi-san gently pats Soutarou-kun's shoulder.{p}When a big person like Juuichi-san tells you that,\nit really does seem true."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 319-321)
    "柔一温柔地轻轻拍了拍宗太郎君的肩膀。[l]该怎么说，[wdt]这种话由柔一这样大块头的人来说，更是特别的有说服力。"

# game/day 12.rpy:655
translate chinese_simplified juuichi12_body_97ec826f:

    # "...Wait.{p}Soutarou-kun sighs and says something more."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 325-326)
    "……然后。[l]这时，[wdt]宗太郎开始断断续续地小声说道。"

# game/day 12.rpy:659
translate chinese_simplified juuichi12_body_eb382621:

    # so "「...I'm tired of waiting.{p} I want to be a regular on the team soon,{w=.2}\n to be an important player like Takahara-senpai.」"
    so "「……我，有点心急的说。想早点成为正式球员，想早点向高原学长那样活跃。」"

# game/day 12.rpy:660
translate chinese_simplified juuichi12_body_c75c5ade:

    # so "「So you can tell me to stop weight training,{w=.2}\n but I can't.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 334-337)
    so "「……我，[wdt]有点心急的说。[l]想早点成为正式球员，[wdt]想早点向高原学长那样活跃。」"

# game/day 12.rpy:661
translate chinese_simplified juuichi12_body_f5c192ed:

    # "His expression gets more cloudy as he speaks."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 336-337)
    "「所以，[wdt]虽然学长说不要，但我还是假装没听到拼命在做重训。」"

# game/day 12.rpy:662
translate chinese_simplified juuichi12_body_c9517622:

    # so "「...But that actually isn't good for me, huh...」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 339)
    so "宗太郎在说这句话时，表情相当阴暗。"

# game/day 12.rpy:663
translate chinese_simplified juuichi12_body_27abf989:

    # "He looks down.{p}I can hear him sniffling."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 342-343)
    "「……可是，[wdt]这样好像就变成不是为了我自己而是在做坏事了……」"

# game/day 12.rpy:664
translate chinese_simplified juuichi12_body_d1e74de4:

    # "I should say something...{w=.2}\nBut I can't think of any words to comfort him with."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 345-346)
    "宗太郎低了下头。[l]然后，可以听到吸着鼻水的声音。"

# game/day 12.rpy:668
translate chinese_simplified juuichi12_body_061ecb17:

    # ju "「Hey, Touno, I like your proactive way of thinking.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 348-349)
    ju "得说点什么……虽然这样想，[wdt]可是实在想不出什么可以安慰宗太郎的话。[l]"

# game/day 12.rpy:669
translate chinese_simplified juuichi12_body_fa0c5e15:

    # "Juuichi-san places his hands on Soutarou-kun's\nshoulders, and looks into his face."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 350)
    "就当我正在手足无措的时候。"

# game/day 12.rpy:670
translate chinese_simplified juuichi12_body_eb0d1c9a:

    # so "「...*sniff*」"
    so "「……呜。」"

# game/day 12.rpy:671
translate chinese_simplified juuichi12_body_df727270:

    # ju "「You just happened to go the wrong way this time,\n okay? All you need to do is take a slightly\n different course of action.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 355-356)
    ju "「呐，橙野，[wdt]像你这样一个劲往前衝的思考方式我倒是不讨厌。」"

# game/day 12.rpy:672
translate chinese_simplified juuichi12_body_eb0d1c9a_1:

    # so "「...*sniff*」"
    so "「……呜。」"

# game/day 12.rpy:676
translate chinese_simplified juuichi12_body_11b7cb4c:

    # "He makes small sobbing sounds.{p}Over time, they disappear,\nand the sounds of the cicadas are all that's left."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 358-359)
    "柔一把两手放到宗太郎的肩膀上，[wdt]把脸靠了过去低声说道。"

# game/day 12.rpy:677
translate chinese_simplified juuichi12_body_956af3f2:

    # "...I think that went on for about 5 minutes."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 362)
    "「……呜。」"

# game/day 12.rpy:681
translate chinese_simplified juuichi12_body_baee08ed:

    # "Soutarou-kun regains his composure,{w=.2}\nthen says something quietly into Juuichi-san's ears.{p}He nods, several times."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 365-366)
    "「这次虽然走到了不正确的方向，[wdt]不过。[l]下次只要好好地修正轨道就行了。」"

# game/day 12.rpy:682
translate chinese_simplified juuichi12_body_88fb88f3:

    # "Juuichi-san takes his hands\noff Soutarou-kun's shoulders."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 369)
    "「……呜。」"

# game/day 12.rpy:686
translate chinese_simplified juuichi12_body_b651bc61:

    # "Although his eyes are still slightly red,{w=.2}\nSoutarou-kun rubs his face with his arm,\nbringing back his usual bright smile."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 373-374)
    "宗太郎那小小的呜咽声，以及轻拍他身体的声音。[l]随着时间过去，两种声音都慢慢地跟周围的蝉鸣融合一起。"

# game/day 12.rpy:687
translate chinese_simplified juuichi12_body_f1e02106:

    # "Hm, it seems he's all better now.{p}...I didn't do anything, though."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 376)
    "……体感上，应该没有超过五分钟吧。"

# game/day 12.rpy:691
translate chinese_simplified juuichi12_body_c362c435:

    # ju "「...Even so,{w=.2}\n it seems I've become Takahara by acting like this.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 380-381)
    ju "完全冷静下来的宗太郎，[wdt]在柔一的耳朵旁边低声说了些什么。[l]"

# game/day 12.rpy:692
translate chinese_simplified juuichi12_body_0772f7b6:

    # "Did Juuichi-san just lighten the mood?{w=.2}\nIt's rare for him to joke around.{p}Soutarou-kun and I both laugh."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 384)
    "接着柔一放开了握住宗太郎肩膀的手。[l][宗太郎 普 normal][wt]"

# game/day 12.rpy:693
translate chinese_simplified juuichi12_body_d5446a86:

    # fn "「Certainly!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 385-386)
    fn "虽然眼睛还有点红，[wdt]不过用手腕擦了擦脸后，宗太郎终于露出了平常的笑容。"

# game/day 12.rpy:694
translate chinese_simplified juuichi12_body_7e70565a:

    # so "「Haha,{w=.2} that's right!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 388-389)
    so "嗯，这样应该就没问题了。[l]……虽然我什么都没做就是了。"

# game/day 12.rpy:695
translate chinese_simplified juuichi12_body_bab0a1cd:

    # "Then, Soutarou-kun bows his head."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 394-395)
    "「……虽说如此，[wdt]做这些事感觉我好像变成了高原似的。」"

# game/day 12.rpy:699
translate chinese_simplified juuichi12_body_01dca105:

    # so "「...Mikazuki-senpai,{w=.2} [ln]-senpai.{p} I'm sorry you had to see me so pitiful!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 397-399)
    so "似乎是为了缓和这沉重的气氛，[wdt]柔一难得地开了点小玩笑。[l]我和宗太郎都忍不住笑了出来。"

# game/day 12.rpy:700
translate chinese_simplified juuichi12_body_d1eab31b:

    # so "「So,{w=.2} thank you very much!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 402)
    so "「真的呢！」"

# game/day 12.rpy:704
translate chinese_simplified juuichi12_body_86775cb4:

    # ju "「You don't need to be so formal.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 405)
    ju "「哈哈，[wdt]确实很像的说！」"

# game/day 12.rpy:705
translate chinese_simplified juuichi12_body_4e42b0ec:

    # fn "「Yeah.{w=.2} I was just a bystander, really.{p} Juuichi-san is the only one you should be thanking.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 407)
    fn "这时，宗太郎迅速地低下了头。"

# game/day 12.rpy:709
translate chinese_simplified juuichi12_body_100a79fd:

    # ju "「Hey, [ln].{w} You're saying too much.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 412-413)
    ju "「……三日月学长，[wdt]西村学长。[l]让你们看到丢脸的样子真的很抱歉！」"

# game/day 12.rpy:710
translate chinese_simplified juuichi12_body_d4ee1755:

    # "He sounds slightly flustered.{p}Did I embarrass him?"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 416)
    "「……然后还有，[wdt]真的很谢谢你们！」"

# game/day 12.rpy:714
translate chinese_simplified juuichi12_body_2925b347:

    # so "「Well, you gave me advice,{w=.2}\n so of course I have to thank you!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 421)
    so "「不用那么恭敬没关系的。」"

# game/day 12.rpy:715
translate chinese_simplified juuichi12_body_dbdde761:

    # "...I think he might be overdoing it,{w=.2}\nbut I suppose he is the kind\nof guy to be so sportsmanlike."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 424-425)
    "「对啊对啊。[wdt]而且我后来根本就只是在旁观而已。[l]要道谢的话跟柔一说就好了。」"

# game/day 12.rpy:719
translate chinese_simplified juuichi12_body_f90a208d:

    # ju "「...Touno,{w=.2} may I have a word?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 430)
    ju "「喂，西村。[l]不要说多馀的话。」"

# game/day 12.rpy:720
translate chinese_simplified juuichi12_body_ee42eca4:

    # "Did he just think of something?{w=.2}\nJuuichi-san whispers to Soutarou-kun with a grimace."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 432-433)
    "柔一有点慌张地提高了语调。[l]这样也会不好意思啊。"

# game/day 12.rpy:722
translate chinese_simplified juuichi12_body_a7b2193d:

    # so "「I-I understand.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 438-439)
    so "「不，既然学长特地给了我建议，[wdt]那不道谢就说不过去了的说！」"

# game/day 12.rpy:723
translate chinese_simplified juuichi12_body_0cdefa76:

    # "Soutarou-kun stiffens at the pressure coming\nfrom Juuichi-san."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 441-442)
    "……虽然觉得有点太夸张了，[wdt]不过这也是宗太郎流的『运动员精神』吧。"

# game/day 12.rpy:725
translate chinese_simplified juuichi12_body_377604a5:

    # "I'd turn and run if he showed me a face like that.{p}Soutarou-kun must be amazing to stand his\nground against a look like that."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 447)
    "「……那橙野，[wdt]等等跟我过来一下。」"

# game/day 12.rpy:726
translate chinese_simplified juuichi12_body_d23c2a46:

    # ju "「Now, let's go to the candy store.{p} {nw}"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 449-450)
    ju "似乎想到了什么，柔一用低沉的声音，[wdt]靠到宗太郎面前用一脸不爽的表情说道。"

# game/day 12.rpy:728
translate chinese_simplified juuichi12_body_ec5294a9:

    # extend "...We'll get some ice cream,{w=.2} okay?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 452-454)
    extend "柔一，[wdt]这样看起来不是跟流氓没什么两样吗……[l]该说是坏人也会吓一跳呢，还是说柔一就是坏人本身呢。[l]那种表情小孩子看了就算会哭着逃跑也不奇怪。"

# game/day 12.rpy:732
translate chinese_simplified juuichi12_body_c6b89367:

    # so "「Sure!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 457)
    so "「我，[wdt]我知道了的说……」"

# game/day 12.rpy:733
translate chinese_simplified juuichi12_body_660a004b:

    # "Soutarou-kun's relief shows on his face.{p}I wonder what Juuichi-san told him?{w=.2}\nIt'd be rude of me to ask, though."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 459-461)
    "面对柔一突然发出的压迫感，[wdt]宗太郎的身体和表情都僵硬了起来。[l]哎呀，看到那种坏人般的表情会这样也是没办法的。"

# game/day 12.rpy:734
translate chinese_simplified juuichi12_body_28278919:

    # ju "「Good answer.{p} ...Get whatever you like,{w=.2}\n it's my treat today.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 463-465)
    ju "如果是我看到那样的脸也是肯定会转头避开的。[l]就这点来说，[wdt]没有逃跑而是正面迎视柔一的视线的宗太郎君，或许可以说是很厉害的人材也不一定。"

# game/day 12.rpy:738
translate chinese_simplified juuichi12_body_bbc93ae5:

    # so "「No, you don't need to do that!{p} I've got enough money!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 468-469)
    so "「等等去零食店吧。[l][柔一 笑 normal][wt]……去买点冰吃，[wdt]如何。」"

# game/day 12.rpy:742
translate chinese_simplified juuichi12_body_815edef6:

    # "Juuichi-san gives him a stern glare.{p}Once again, Soutarou-kun cringes."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 474)
    "「了解的说！」"

# game/day 12.rpy:743
translate chinese_simplified juuichi12_body_8e2937ee:

    # ju "「Are you crushing your senpai's honour?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 476-478)
    ju "宗太郎明显露出了放心的表情。[l]到底他们是说了什么虽然相当在意，[wdt]但这里要是插嘴的话也太不会看气氛了。"

# game/day 12.rpy:744
translate chinese_simplified juuichi12_body_cb31ec75:

    # so "「No,{w=.2} that's not what I meant...」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 480)
    so "……结果害我把各式各样的情况都想像了一次。"

# game/day 12.rpy:745
translate chinese_simplified juuichi12_body_3f00a793:

    # ju "「{cps=10}Then take it, it's my treat.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 483-485)
    ju "「回答的不错。[l]……这样吧，[wdt]你想吃哪种冰都行，[l]今天我请客。」"

# game/day 12.rpy:746
translate chinese_simplified juuichi12_body_caf11b2b:

    # "He speaks in a low, forceful tone.{p}I don't think anyone would disobey that.{p}...Except Torahiko."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 490-491)
    "「不不，[wdt]那样怎么可以的说！[l]我也有带钱的所以没问题的说！」"

# game/day 12.rpy:750
translate chinese_simplified juuichi12_body_1f9a4c1c:

    # so "「...Got it!{w} I'll take it!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 495-496)
    so "柔一的眼光一闪，再次射向宗太郎。[l]结果宗太郎身体又抖了一下。"

# game/day 12.rpy:751
translate chinese_simplified juuichi12_body_c14e5913:

    # "Soutarou-kun seems to have understood the point."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 499)
    "「不给学长面子吗？」"

# game/day 12.rpy:752
translate chinese_simplified juuichi12_body_d3c1afb5:

    # ju "「Now then,{w=.2} let's go, Touno, [ln].」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 502)
    ju "「不不，[wdt]不是那个意思的说……」"

# game/day 12.rpy:753
translate chinese_simplified juuichi12_body_d7460776:

    # fn "「Me too?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 505)
    fn "「[wds]那么，[l]就好好听话，[l]让我请客吧。[rd]」"

# game/day 12.rpy:754
translate chinese_simplified juuichi12_body_7b16b618:

    # "I reflexively ask.{p}Juuichi's voice somehow manages to go even lower\nas he replies:"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 507-509)
    "柔一的重低音，让人不敢说不。[l]敢违抗这样的柔一的人应该不存在吧，我想。[l]……虎彦以外啦。"

# game/day 12.rpy:755
translate chinese_simplified juuichi12_body_ea21e82f:

    # ju "「...Are you coming or not?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 514)
    ju "「……知道了的说！[l] 请多指教的说！」"

# game/day 12.rpy:756
translate chinese_simplified juuichi12_body_40d9ca7f:

    # fn "「Th-th-there's no reason for me not to!{p} Of course I'll come!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 516)
    fn "……看来是雨过天晴了的样子。"

# game/day 12.rpy:757
translate chinese_simplified juuichi12_body_dc9f0629:

    # "Is he satisfied with my response?{w=.2}\nHe nods, and turns to head towards the candy store."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 519)
    "「那，[wdt]出发吧，橙野、西村。」"

# game/day 12.rpy:762
translate chinese_simplified juuichi12_body_b37fb356:

    # "At least Soutarou-kun's worries have been solved.{p}Looking over at him, he has a cheerful face,\nlike his gloomy one before never even happened."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 522)
    "「咦我也去吗？」"

# game/day 12.rpy:763
translate chinese_simplified juuichi12_body_da01104d:

    # "Yeah, now that's the Soutarou-kun I know."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 524-525)
    "不假思索地就反问了。[l]结果，是比刚刚还要低音的回答。"

# game/day 12.rpy:768
translate chinese_simplified juuichi12_body_d70d3d3d:

    # ju "「[ln],{w=.2} you're paying for your own.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 528)
    ju "「……你打算不来吗？」"

# game/day 12.rpy:769
translate chinese_simplified juuichi12_body_6802cfb0:

    # fn "「What?{w=.2} That's not fair!」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 533-534)
    fn "「怎怎怎怎么会呢！[l]请一定要让我去！」"

# game/day 12.rpy:770
translate chinese_simplified juuichi12_body_7132db15:

    # ju "「That was a joke.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 536-537)
    ju "听到我的回答后，[wdt]柔一满意地点了一下头，往零食店的方向走去。"

# game/day 12.rpy:771
translate chinese_simplified juuichi12_body_00b00233:

    # fn "「...」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 542-544)
    fn "啊，总之宗太郎的烦恼也解决了，这样就好啦。[l]稍微瞄了宗太郎一眼，之前那阴暗的表情简直像不存在过似的，[wdt]现在是满脸的开朗。"

# game/day 12.rpy:772
translate chinese_simplified juuichi12_body_52b83b4c:

    # "Please stop joking with a straight face."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 546)
    "嗯，[wdt]果然宗太郎比较适合这种表情呢。"

# game/day 12.rpy:784
translate chinese_simplified juuichi12_stick_2289b98e:

    # "There's only one thing a boy would want bigger!{p}His crotch match...\nI'm sure it's his magic wand!"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 575-577)
    "要说到男人会想要变大的东西的话，就只有一个！[l]那就是，下面的火柴……啊不，绝对是在说下面的如意棒没错！"

# game/day 12.rpy:785
translate chinese_simplified juuichi12_stick_d6f5c9cb:

    # "Wow, Soutarou-kun,\nI wasn't expecting that from\nsomeone as innocent-looking as you."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 579)
    "宗太郎也真是，[wdt]看来很纯真但意外地挺直接的嘛。"

# game/day 12.rpy:786
translate chinese_simplified juuichi12_stick_b3d555b9:

    # "But how should I answer?{p}While I'm weighing up my options,\nJuuichi-san speaks first."
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 581-582)
    "不过啊这个，[wdt]要怎么回答才好呢。[l]当我想来想去正不知道该怎么办时，柔一倒是先开口了。"

# game/day 12.rpy:787
translate chinese_simplified juuichi12_stick_bcec3276:

    # ju "「I think daily training is important.」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 585)
    ju "「我想平常的锻鍊是最重要的。」"

# game/day 12.rpy:791
translate chinese_simplified juuichi12_stick_77e09f5f:

    # so "「Training?」"
    # [旧版翻译] 来源: 柔一_s_02.ks (KS 590)
    so "「锻鍊，[wdt]是吗？」"

# game/day 12.rpy:792
translate chinese_simplified juuichi12_stick_cad8b7d3:

