# game/day 12.rpy:2083
translate chinese_simplified tatsuki12_dcad9462:

    # ni "「I won't quit.」"
    # [旧版翻译] 来源: extract/orig/辰樹_m_03.ks (KS 340-341)
    ni "「我才不会不干的。」"

