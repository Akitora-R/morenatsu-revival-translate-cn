    "「选哪个好呢？」"

# game/day 12.rpy:2958
translate chinese_simplified tatsuki12_tappei_85ce3f29:

    # fn "「What should I get?」"
    # [旧版翻译] 来源: extract/orig/辰樹_m_03.ks (KS 1732-1733)
