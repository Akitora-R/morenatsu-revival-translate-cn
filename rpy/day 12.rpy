# game/day 12.rpy:2965
translate chinese_simplified tatsuki12_tappei_cd68673d:

    # fn "「Well then, I'll have some oolong tea, and\n whatever goes well with that, please.」"
    # [旧版翻译] 来源: extract/orig/辰樹_m_03.ks (KS 1746-1747)
