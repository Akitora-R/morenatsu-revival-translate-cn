translate chinese_simplified beach07_juuichi_4c0f705a:

    # "I regroup and shout loudly."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2132)
    "我和柔一会合，大声嚷道。"

# game/day 7.rpy:2266
translate chinese_simplified beach07_juuichi_1952fb49:

    # ju "「...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2105)
    ju "「……是吗」"

# game/day 7.rpy:2267
translate chinese_simplified beach07_juuichi_03f62d76:

    # "...?{p}No reply.{p}Juuichi-san is still staring at me."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2108-2109)
    "他听懂我的意思了么？{p}柔一迅速转了过去，"

# game/day 7.rpy:2268
translate chinese_simplified beach07_juuichi_210ca71b:

    # "I look around my body,{p}to see if there's something strange,{p}but I can't find anything."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2110)
    "穿上了泳衣。"

# game/day 7.rpy:2269
translate chinese_simplified beach07_juuichi_1a0fdeea:

    # "I speak to Juuichi-san."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2143)
    "于是我对他仔细说了起来。"

# game/day 7.rpy:2270
translate chinese_simplified beach07_juuichi_ea4d8bb2:

    # fn "「Juuichi-san, is there something wrong?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2118)
    fn "「啊，{w=.3}对不起。」"

# game/day 7.rpy:2274
translate chinese_simplified beach07_juuichi_69c3e54c:

    # ju "「...Oh, sorry.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2135)
    ju "「……」"

# game/day 7.rpy:2275
translate chinese_simplified beach07_juuichi_e3f61981:

    # fn "「You're dissapointed,{p} you couldn't see mine...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2146)
    fn "「柔一君，我身上有什么问题么？」"

# game/day 7.rpy:2279
translate chinese_simplified beach07_juuichi_73c31316:

    # ju "「That's not it.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2150)
    ju "「……呃，对不起。」"

# game/day 7.rpy:2280
translate chinese_simplified beach07_juuichi_3ee26477:

    # fn "「Then hurry up and...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2154)
    fn "「你难道很失望，就是因为没看到我的……」"

# game/day 7.rpy:2281
translate chinese_simplified beach07_juuichi_c09159b5:

    # "That was a joke.{p}...Let me at least say the end of it, please."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2163-2164)
    "我只是开了一个玩笑。{p}……请让我至少给这件事画一个句号吧……"

# game/day 7.rpy:2282
translate chinese_simplified beach07_juuichi_e2c9c223:

    # ju "「S-stop fooling around and go.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2158)
    ju "「不是啊」"

# game/day 7.rpy:2283
translate chinese_simplified beach07_juuichi_3c99b3c3:

    # fn "「All right...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2161)
    fn "「那就快走吧！」"

# game/day 7.rpy:2284
translate chinese_simplified beach07_juuichi_c30c62b1:

    # "With the stuff we brought at out sides,{p}we head out to the beach."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2163-2164)
    "我只是开了一个玩笑。{p}……请让我至少给这件事画一个句号吧……"

# game/day 7.rpy:2288
translate chinese_simplified beach07_juuichi_bc7ea534:

    # fn "「...So, What are you going to do?{p} A little bit of swimming?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2170)
    fn "「是……」"

# game/day 7.rpy:2289
translate chinese_simplified beach07_juuichi_6552e08b:

    # "Making a shifting sound,{p}while walking on the sand,{p}I throw out a topic of discussion"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2172-2182)
    "我たちは持ってきた荷物を脇に抱えると、{p}夏の砂浜へと繰り出した。{p}游泳么？」{p}走到沙滩上时，我想活跃一下气氛，{p}于是抛出这么一个问题。"

# game/day 7.rpy:2293
translate chinese_simplified beach07_juuichi_96d19861:

    # ju "「...Hm, how about watermelon splitting?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2186)
    ju "「……嗯……要不要来玩切西瓜？」"

# game/day 7.rpy:2294
translate chinese_simplified beach07_juuichi_78f3288d:

    # fn "「Oh, that's definitely something,{p} you do at the beach.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2189)
    fn "「喔，在海边玩这个，的确是你的风格。」"

# game/day 7.rpy:2295
translate chinese_simplified beach07_juuichi_1df88702:

    # "...Wait, did we bring any watermelon?{p}I ask him that question."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2191-2192)
    "……啊咧，{w=.3}我们带西瓜来了么？{p}我问他。"

# game/day 7.rpy:2296
translate chinese_simplified beach07_juuichi_164f550e:

    # ju "「I didn't overlook that.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2195)
    ju "「我可没忘了它。」"

# game/day 7.rpy:2297
translate chinese_simplified beach07_juuichi_b08f4a7d:

    # "He returns with a downright surprising answer."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2197)
    "他的回答是一个彻底的惊喜。"

# game/day 7.rpy:2298
translate chinese_simplified beach07_juuichi_5bf36004:

    # "As expected of Juuichi-san.{p}He wasn't just showing off\nwhen he patted his backpack."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2198-2199)
    "正如我所期待的，{p}柔一抱着他的包，走了过来。"

# game/day 7.rpy:2299
translate chinese_simplified beach07_juuichi_4da01056:

    # ju "「I put it in the cooler,{p} we can eat it when it gets cold.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2202-2203)
    ju "「我把它冷藏过了，{p}那样我们就可以吃凉的了。」"

# game/day 7.rpy:2300
translate chinese_simplified beach07_juuichi_39135230:

    # "...It's already good enough."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2203-2205)
    "那样我们就可以吃凉的了。」{p}……这太完美了。"

# game/day 7.rpy:2301
translate chinese_simplified beach07_juuichi_136d4bcb:

    # "While talking, we come back to our spot,{p}and immediately start preparing."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2207-2208)
    "说着，我们到了放行李的地方，{p}然后就立即开始准备游戏了。"

# game/day 7.rpy:2305
translate chinese_simplified beach07_juuichi_e8a25de2:

    # ju "「Kuroi, a moment please?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2212)
    ju "「黒井，打扰一下好么？」"

# game/day 7.rpy:2306
translate chinese_simplified beach07_juuichi_95a2a2ea:

    # "Noticing Shin-kun using his backpack,{p}as the back of a chair and reading,{p}Juuichi-san speaks to him."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2214)
    "柔一对正在用背包做靠背来看书的深说。"

# game/day 7.rpy:2310
translate chinese_simplified beach07_juuichi_bef95801:

    # si "「...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2219)
    si "「……」"

# game/day 7.rpy:2311
translate chinese_simplified beach07_juuichi_913c4c46:

    # "With a fleeting glance,{p}Shin-kun creates a space between him\nand the backpack."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2221-2222)
    "一眨眼间，{p}深腾出了一个能放一个包的空位。"

# game/day 7.rpy:2312
translate chinese_simplified beach07_juuichi_f32151d2:

    # "To make sure he doesn't get in the way,{p}of Juuichi-san's work,{p}he puts down the book he was reading."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2224-2225)
    "为了确保自己没有妨碍到柔一干活，{p}他放下了书。"

# game/day 7.rpy:2316
translate chinese_simplified beach07_juuichi_c00f5b25:

    # ju "「Excuse me.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2230)
    ju "「抱歉」"

# game/day 7.rpy:2317
translate chinese_simplified beach07_juuichi_78bceb24:

    # "Juuichi-san bends his large body over,{p}and sticks his hand into the backpack,{p}he begins rummaging around."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2232-2233)
    "柔一弯下他庞大的身躯，{p}把手伸进包中，开始一件一件的往外掏。"

# game/day 7.rpy:2318
translate chinese_simplified beach07_juuichi_b280483e:

    # "One small sheet.{p}This is what we'll put the watermelon on."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2235-2236)
    "一个小垫子。{p}我们要把西瓜放在上面。"

# game/day 7.rpy:2319
translate chinese_simplified beach07_juuichi_b5ba3efa:

    # "One cooler.{p}This is what the watermelon,{p}was being stored in."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2238-2239)
    "一个冷藏器。{p}它里面装着西瓜。"

# game/day 7.rpy:2320
translate chinese_simplified beach07_juuichi_c01248f4:

    # "One wooden sword.{p}...He even brought one of those?{p}Juuichi-san is frightening."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2241-2242)
    "一把木刀。{p}……他竟然带了一把木刀？！柔一也吓了一跳。"

# game/day 7.rpy:2321
translate chinese_simplified beach07_juuichi_32e7b931:

    # ju "「...Is this it?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2245)
    ju "「……这」"

# game/day 7.rpy:2322
translate chinese_simplified beach07_juuichi_9f1b24ae:

    # "A few minutes later.{p}Finished setting up the watermelon splitting,{p}Juuichi-san takes a short rest."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2247-2249)
    "几分钟后，{p}所有的工作都完成了，{p}柔一便稍微休息了一下。"

# game/day 7.rpy:2328
translate chinese_simplified beach07_juuichi_1553b627:

    # to "「All right, let's get started!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2262)
    to "「那么，我们开始玩吧！」"

# game/day 7.rpy:2329
translate chinese_simplified beach07_juuichi_1d935b42:

    # "Torahiko suddenly calls out from the side.{p}Where the heck did he come from?{p}Where was he up until now?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2264-2266)
    "虎彦忽然从旁边大叫了一声。{p}这个混蛋是从哪里冒出来的？{p}难道他一直就在这里？"

# game/day 7.rpy:2333
translate chinese_simplified beach07_juuichi_fcfa28be:

    # to "「It's fine guys,\n don't worry about it!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2270)
    to "「伙计们这棒极了，这么点我肯定吃得完。」"

# game/day 7.rpy:2334
translate chinese_simplified beach07_juuichi_55edbc28:

    # "He opens his big mouth and laughs."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2272)
    "他笑着，张开了大口。"

# game/day 7.rpy:2338
translate chinese_simplified beach07_juuichi_4d84ec6b:

    # su "「I want to split the watermelon too!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2277)
    su "「我也要玩！」"

# game/day 7.rpy:2342
translate chinese_simplified beach07_juuichi_9def788c:

    # ka "「Oh, that looks like fun doesn't it?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2282)
    ka "「喔，{w=.3}这看起来不错啊。」"

# game/day 7.rpy:2343
translate chinese_simplified beach07_juuichi_70cb26ff:

    # "One by one, more people show up.{p}...This must be the immense power of food."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2284-2290)
    "更多的人一个接一个的出现了。{p}……这就是食物的巨大吸引力么……{p}我，柔一，虎彦，还有洸哉和峻，"

# game/day 7.rpy:2347
translate chinese_simplified beach07_juuichi_a090f7ad:

    # "So, Juuichi-san and I, Torahiko,{p}and Kouya, and then Shun-kun,{p}are going to split the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2291-2293)
    "五个人开始准备切西瓜了。{p}我问深要不要一起来玩，"

# game/day 7.rpy:2348
translate chinese_simplified beach07_juuichi_594b660a:

    # "I asked Shin-kun,{p}but he mildly turned me down.{p}Just to look good or something."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2294-2295)
    "他委婉地拒绝了我。{p}去找别的乐子去了。"

# game/day 7.rpy:2349
translate chinese_simplified beach07_juuichi_175b581a:

    # "I think it would actually be more fun,{p}if he joined...{p}Oh well. It would be bad to force him."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2297-2300)
    "我觉得如果他也来一起玩，会更有意思……。{p}算了，强拉他来玩也没什么好处。{p}于是，我们用猜拳来决定我们的顺序。"

# game/day 7.rpy:2350
translate chinese_simplified beach07_juuichi_fbb053fe:

    # "We play rock-paper-scissors,{p}to determine the order we go."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2301)
    "结果是：峻，洸哉，我，虎彦，最后是柔一。"

# game/day 7.rpy:2351
translate chinese_simplified beach07_juuichi_b3013d60:

    # "It's Shun-kun, Kouya, me,{p}Torahiko, and then Juuichi-san."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2290-2291)
    "我，柔一，虎彦，还有洸哉和峻，{p}五个人开始准备切西瓜了。"

# game/day 7.rpy:2355
translate chinese_simplified beach07_juuichi_04013124:

    # ka "「Here's the blindfold.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2308)
    ka "「给你蒙眼布。」"

# game/day 7.rpy:2356
translate chinese_simplified beach07_juuichi_07b17338:

    # "Kouya hands over a towel to Shun-kun.{p}Shun-kun says thank you,{p}then tightly ties the towel to mask his eyes."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2310-2312)
    "洸哉递给峻一条毛巾。{p}峻说了声谢谢，{p}便紧紧地蒙住了自己的眼睛。"

# game/day 7.rpy:2360
translate chinese_simplified beach07_juuichi_fe49b102:

    # ju "「Take this.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2316)
    ju "「拿着。」"

# game/day 7.rpy:2361
translate chinese_simplified beach07_juuichi_add7cdc7:

    # "Juuichi-san lets Shun-kun,{p}take a hold of the wooden sword."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2318)
    "柔一让峻拿着那把木刀。"

# game/day 7.rpy:2362
translate chinese_simplified beach07_juuichi_1e1f8ffb:

    # "His body staggers when he carries it.{p}The way he sways side to side worries me."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2319-2320)
    "他在那里拿着木刀蹒跚着。{p}他在那里晃来晃去的真叫我担心啊。"

# game/day 7.rpy:2363
translate chinese_simplified beach07_juuichi_d14ee855:

    # "...Hmm, will he be okay?{p}I hope he doesn't trip half-way through."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2322-2323)
    "嗯……他还好吧？{p}我希望他不会在半路上跌倒。"

# game/day 7.rpy:2370
translate chinese_simplified beach07_juuichi_01d564de:

    # to "「Come on, let's spin!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2331)
    to "「好了，现在开始转咯！」"

# game/day 7.rpy:2371
translate chinese_simplified beach07_juuichi_e2848963:

    # "As soon as he says that,{p}Torahiko forcefully rotates Shun-kun around."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2333)
    "说时迟那时快，虎彦开始猛烈地旋转着峻。"

# game/day 7.rpy:2377
translate chinese_simplified beach07_juuichi_bffe1910:

    # su "「Wawawawawa!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2339)
    su "「哇哇哇哇哇哇——！」"

# game/day 7.rpy:2378
translate chinese_simplified beach07_juuichi_9888693b:

    # fn "「...Torahiko, don't overdo it.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2342)
    fn "「……虎彦，别太过火了……」"

# game/day 7.rpy:2382
translate chinese_simplified beach07_juuichi_fa38d7d8:

    # to "「I know!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2346)
    to "「明白！」"

# game/day 7.rpy:2383
translate chinese_simplified beach07_juuichi_244b843e:

    # "Unexpectedly, the speed at which he spins,{p}Shun-kun doesn't drop.{p}...I really wonder if he understood."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2348-2349)
    "没想到，以这么高速度旋转的峻竟还没有倒下。{p}……我真怀疑虎彦有没有听懂……"

# game/day 7.rpy:2389
translate chinese_simplified beach07_juuichi_9c94e809:

    # su "「The worle world's spinning...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2355)
    su "「世界都在旋转啊……」"

# game/day 7.rpy:2390
translate chinese_simplified beach07_juuichi_a8063265:

    # "After being spun about 20 times,{p}Shun-kun is finally let go."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2357)
    "峻被转了20圈后，终于被从虎彦的臂膀中放出来了。"

# game/day 7.rpy:2391
translate chinese_simplified beach07_juuichi_6dff7a48:

    # "His gait is as unsteady,{p}as a drunken old man's."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2358)
    "他的步伐十分凌乱，好像喝醉了一样。"

# game/day 7.rpy:2392
translate chinese_simplified beach07_juuichi_5a4c09b9:

    # "He repeatedly staggers,{p}from one side to another."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2359)
    "他蹒跚着，从一边到另一边。"

# game/day 7.rpy:2393
translate chinese_simplified beach07_juuichi_168d775e:

    # "Reminds me of Tatsu-nii."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2359)
    "这让我想起了辰兄。"

# game/day 7.rpy:2397
translate chinese_simplified beach07_juuichi_2e156b62:

    # to "「...Did I spin him too much?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2364)
    to "「……我是不是转得太过火了？」"

# game/day 7.rpy:2398
translate chinese_simplified beach07_juuichi_f9418cd7:

    # "You're slow to notice that, Torahiko."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2366)
    "等你发觉时已然迟了，虎彦。"

# game/day 7.rpy:2402
translate chinese_simplified beach07_juuichi_bb9f4e68:

    # ju "「Kodori, go straight forward.」{w} {nw}"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2371)
    ju "「古酉，直走。」"

# game/day 7.rpy:2406
translate chinese_simplified beach07_juuichi_4f7d61aa:

    # "Relying on Juuichi-san's words,{p}Shun-kun totters towards the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2374-2375)
    "凭着柔一的指挥，{p}峻摇摇欲坠地移向西瓜。"

# game/day 7.rpy:2410
translate chinese_simplified beach07_juuichi_c8ff6382:

    # ka "「Right, a little more to the right.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2380)
    ka "「向右，向右一点点。」"

# game/day 7.rpy:2411
translate chinese_simplified beach07_juuichi_6bd71231:

    # fn "「Too far!{p} Get a little back to the right!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2383)
    fn "「啊，过了！{p}再回来一点！」"

# game/day 7.rpy:2415
translate chinese_simplified beach07_juuichi_503c75ba:

    # to "「There, keep going straight ahead!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2388)
    to "「好，好，继续直走！」"

# game/day 7.rpy:2419
translate chinese_simplified beach07_juuichi_395fe425:

    # "With everybody's guidance,{p}Shun-kun gets right up to the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2394-2395)
    "在大家的指挥下，{p}峻直直地走向了西瓜。"

# game/day 7.rpy:2420
translate chinese_simplified beach07_juuichi_706db81f:

    # ka "「Shun, right there!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2398)
    ka "「峻，就是这！」"

# game/day 7.rpy:2424
translate chinese_simplified beach07_juuichi_c77d2b9a:

    # "At the sound of his voice,{p}Shun-kun swings the sword down."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2401)
    "一声令下，手起刀落，眼看要正中靶心。"

# game/day 7.rpy:2425
translate chinese_simplified beach07_juuichi_cb8fa305:

    # "He's going right on target.{p}Is this going to end with the first person?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2402)
    "这才第一个人游戏就结束了？"

# game/day 7.rpy:2426
translate chinese_simplified beach07_juuichi_081101c4:

    # "Swoosh."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2403)
    "正在这样想着……"

# game/day 7.rpy:2427
translate chinese_simplified beach07_juuichi_52b6a87e:

    # "Shun-kun loses his balance,{p}and completely misses the watermelon.{p}The sword flies off somewhere."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2405-2408)
    "嗖——{p}峻突然失去了平衡，恰好偏离了西瓜，{p}木刀也应声飞走了。"

# game/day 7.rpy:2431
translate chinese_simplified beach07_juuichi_8b7a7aac:

    # to "「Oh jeez...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2413)
    to "「哦，天啊……」"

# game/day 7.rpy:2432
translate chinese_simplified beach07_juuichi_4dd85c58:

    # "Torahiko can't look,{p}and places his palm on his forehead."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2415)
    "虎彦的手托着脑门，都不忍直视这一幕。"

# game/day 7.rpy:2436
translate chinese_simplified beach07_juuichi_73f31138:

    # su "「I messed up at the end...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2423)
    su "「我最后还是搞砸了……」"

# game/day 7.rpy:2437
translate chinese_simplified beach07_juuichi_3a770210:

    # "Shun-kun removes the blindfold,{p}and sadly looks towards the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2425)
    "峻摘下蒙眼布，悲伤地看着这个见证失败的球体。"

# game/day 7.rpy:2438
translate chinese_simplified beach07_juuichi_4b548462:

    # "The rotund, green form of it,{p}is no longer a tasty snack, but rather,{p}it is only a reminder of his failure."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2425)
    "峻摘下蒙眼布，悲伤地看着这个见证失败的球体。"

# game/day 7.rpy:2442
translate chinese_simplified beach07_juuichi_f02d149b:

    # ju "「You almost had it.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2430)
    ju "「你差点就成功了。」"

# game/day 7.rpy:2443
translate chinese_simplified beach07_juuichi_b2a81cd9:

    # ka "「Well, maybe you won't get so dizzy,{p} a second time.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2435)
    ka "「下一次你可能就不会那么晕了。」"

# game/day 7.rpy:2447
translate chinese_simplified beach07_juuichi_e9064649:

    # "Shun-kun's face brightens,{p}when he hears Kouya's words."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2438)
    "当峻听到洸哉这句话时，一下就高兴了起来。"

# game/day 7.rpy:2448
translate chinese_simplified beach07_juuichi_caeac970:

    # to "「Oh, what's with this...{p} premature celebration?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2443)
    to "「啊啊，这是要打算提前庆祝一下吗？」"

# game/day 7.rpy:2452
translate chinese_simplified beach07_juuichi_7e386a3f:

    # ka "「Oh...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2448)
    ka "「唔……」"

# game/day 7.rpy:2453
translate chinese_simplified beach07_juuichi_d2d24891:

    # "Kouya scratches his head,{p}with embarrassment."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2450)
    "洸哉尴尬地挠了挠头。"

# game/day 7.rpy:2454
translate chinese_simplified beach07_juuichi_bde8cef2:

    # "...Huh, when he says that,{p}I wonder what's going to happen next."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2451-2452)
    "呃……他这样说时，我还真不知道，{p}接下来会发生什么。"

# game/day 7.rpy:2455
translate chinese_simplified beach07_juuichi_b6d66e59:

    # "I have no idea."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2452)
    "我完全没有头绪。"

# game/day 7.rpy:2460
translate chinese_simplified beach07_juuichi_4561d506:

    # ju "「Next is Kouya's turn.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2460)
    ju "「下一个轮到洸哉。」"

# game/day 7.rpy:2461
translate chinese_simplified beach07_juuichi_a831afb5:

    # "Shun-kun excitedly hands over the blindfold,{p}and sword to Kouya.{p}He begins to prepare."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2462-2463)
    "从峻君那里接过蒙眼布和木刀，{p}洸哉兴冲冲地开始了准备。"

# game/day 7.rpy:2465
translate chinese_simplified beach07_juuichi_0c895550:

    # su "「Kouya-san, please do your best!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2469)
    su "「洸哉，加油噢！」"

# game/day 7.rpy:2468
translate chinese_simplified beach07_juuichi_a97a0e2a:

    # ka "「Yeah.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2473)
    ka "「哦！」"

# game/day 7.rpy:2475
translate chinese_simplified beach07_juuichi_8037bc8e:

    # to "「Right, looks like you're all ready!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2484)
    to "「很好，{w=.3}看来你已经准备好了！」"

# game/day 7.rpy:2480
translate chinese_simplified beach07_juuichi_e656ddba:

    # "Just as he did with Shun-kun,{p}Torahiko vigorously spins Kouya."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2491)
    "于是虎彦开始用力地旋转着洸哉，"

# game/day 7.rpy:2481
translate chinese_simplified beach07_juuichi_365034c3:

    # "...{p}...{p}..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2492-2498)
    "就好像刚才转峻一样。{p}呃……他一定要转这么多圈么？"

# game/day 7.rpy:2482
translate chinese_simplified beach07_juuichi_7bd5fec2:

    # "...Does he needs to spin him that many times?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2498)
    "他一定要转这么多圈么？"

# game/day 7.rpy:2486
translate chinese_simplified beach07_juuichi_86f6a6f6:

    # to "「Spin spin spin!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2502)
    to "「转呐！{w=.3}转呐！{w=.3}转啊啊！」"

# game/day 7.rpy:2487
translate chinese_simplified beach07_juuichi_77ea51fd:

    # ka "「Don't you think that's enough spinning!?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2505)
    ka "「你不觉得你转得太多了？！」"

# game/day 7.rpy:2488
translate chinese_simplified beach07_juuichi_1651b03e:

    # to "「No, not yet!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2508)
    to "「不，还不够！」"

# game/day 7.rpy:2489
translate chinese_simplified beach07_juuichi_a03d9dcf:

    # "Torahiko completely ignores him.{p}Kouya squeezes out those faint words."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2510-2511)
    "洸哉艰难地吐着他的槽，{p}而虎彦却彻底无视了他。"

# game/day 7.rpy:2490
translate chinese_simplified beach07_juuichi_6d32710b:

    # to "「...Whew. Is that enough?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2515)
    to "「……喔，这够了吧？」"

# game/day 7.rpy:2497
translate chinese_simplified beach07_juuichi_e6f975b3:

    # ka "「B-Bastard...{p} I-I'll remember this...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2521)
    ka "「混、{w=.3}混蛋，{p}你给我、{w=.3}记着……」"

# game/day 7.rpy:2498
translate chinese_simplified beach07_juuichi_ffc52a19:

    # "Torahiko finally gives his hands a rest,{p}and Kouya timidly states his words."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2523-2524)
    "虎彦终于松了手，{p}洸哉艰难地放出了这句话。"

# game/day 7.rpy:2499
translate chinese_simplified beach07_juuichi_d009f8eb:

    # fn "「Kouya, are you all right?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2527)
    fn "「洸哉，没关系吧？」"

# game/day 7.rpy:2500
translate chinese_simplified beach07_juuichi_e594a849:

    # ka "「I'm feeling a little sick...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2530)
    ka "「我觉得不太舒服……」"

# game/day 7.rpy:2501
translate chinese_simplified beach07_juuichi_77fe9c18:

    # "After being spun that much,{p}and for that long,{p}anybody would feel that way."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2532-2533)
    "在被那样转，而且还被转了那么久之后，{p}是谁都会觉得不舒服。"

# game/day 7.rpy:2502
translate chinese_simplified beach07_juuichi_5453f48d:

    # "If it were me,{p}I'd sit down somewhere."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2534-2536)
    "如果是我的话，我肯定就直接坐下了。{p}洸哉摇摇晃晃的，"

# game/day 7.rpy:2503
translate chinese_simplified beach07_juuichi_f3be64d9:

    # "Kouya's body sways back and forth a lot,{p}and each time it looks like,{p}he's going to lose his balance."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2537-2538)
    "看起来总觉得要失去平衡一样。{p}他艰难地落步，尽量控制着不摔倒。"

# game/day 7.rpy:2504
translate chinese_simplified beach07_juuichi_904e01c1:

    # "He steps his foot down,{p}to try to not fall over."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2540-2541)
    "可是，只是保持站立就已经相当辛苦。{p}……没事吧，洸哉这家伙。"

# game/day 7.rpy:2505
translate chinese_simplified beach07_juuichi_2f861d91:

    # "Through sheer willpower,{p}Kouya deals with splitting the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2537-2541)
    "洸哉摇摇晃晃的，{p}看起来总觉得要失去平衡一样。{p}他艰难地落步，尽量控制着不摔倒。{p}可是，只是保持站立就已经相当辛苦。{p}……没事吧，洸哉这家伙。"

# game/day 7.rpy:2506
translate chinese_simplified beach07_juuichi_5325ad78:

    # "Still, it ended with the swing,{p}missing the direction of the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2545)
    "结果还是没能打中西瓜。"

# game/day 7.rpy:2507
translate chinese_simplified beach07_juuichi_a3b482d4:

    # to "「I knew it was going to end like this...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2551)
    to "「我就知道会这样。」"

# game/day 7.rpy:2508
translate chinese_simplified beach07_juuichi_8e7a302b:

    # "Torahiko shrugs his shoulders.{p}Kouya gives Torahiko a glare,{p}then hands the blindfold and sword."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2553-2555)
    "虎彦耸了耸肩。{p}洸哉瞪了他一眼，{p}然后把蒙眼布和木刀交给了我。"

# game/day 7.rpy:2512
translate chinese_simplified beach07_juuichi_4374691b:

    # ka "「Please destroy my rival...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2560)
    ka "「请击败我的敌人……」"

# game/day 7.rpy:2513
translate chinese_simplified beach07_juuichi_07f3649e:

    # fn "「Y-your rival...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2563)
    fn "「你的、{w=.3}敌人……」"

# game/day 7.rpy:2519
translate chinese_simplified beach07_juuichi_6c3177eb:

    # to "「N-next is [fn]'s turn!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2572)
    to "「那，{w=.3}下一个轮到[fn]了！」"

# game/day 7.rpy:2520
translate chinese_simplified beach07_juuichi_2ca689ac:

    # "At Torahiko's words,{p}I hide my eyes with the towel."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2574)
    "虎彦正说着，我就蒙上了眼睛。"

# game/day 7.rpy:2526
translate chinese_simplified beach07_juuichi_25add1d6:

    # to "「Okay, ready to spin?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2579)
    to "「准备好转圈了么？」"

# game/day 7.rpy:2527
translate chinese_simplified beach07_juuichi_0f11912f:

    # "Torahiko places his hands,{p}on my shoulders."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2581)
    "虎彦把他的手搭在我的肩上说道。"

# game/day 7.rpy:2531
translate chinese_simplified beach07_juuichi_20bb7a10:

    # "...{p}..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2587)
    "啊，他转得比我想象的还要快。"

# game/day 7.rpy:2532
translate chinese_simplified beach07_juuichi_8a136c44:

    # "Ah, this is faster than I imagined.{p}I think while spinning."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2588)
    "这时，我觉得……"

# game/day 7.rpy:2533
translate chinese_simplified beach07_juuichi_20bb7a10_1:

    # "...{p}..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2593)
    "我也毫无悬念地晕了。"

# game/day 7.rpy:2534
translate chinese_simplified beach07_juuichi_63d1564a:

    # "As expected, my head feels dizzy.{p}I ask Torahiko to stop."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2594)
    "我请求虎彦能停下来。"

# game/day 7.rpy:2538
translate chinese_simplified beach07_juuichi_05088cbb:

    # to "「Already?{p} That's unexpectedly sloppy.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2598)
    to "「是吗？{p}我觉得还不够哦。」"

# game/day 7.rpy:2539
translate chinese_simplified beach07_juuichi_a31f23a9:

    # fn "「No, I don't think,{p} that's the problem...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2601)
    fn "「不，我觉得，已经够了……」"

# game/day 7.rpy:2540
translate chinese_simplified beach07_juuichi_a9e79f85:

    # "With my body moving unsteadily,{p}I think I muttered that,{p}in Torahiko's direction."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2603-2604)
    "我一边无助地旋转着，{p}冲着我认为貌似是虎彦方向的方向抗议到。"

# game/day 7.rpy:2545
translate chinese_simplified beach07_juuichi_75ac6aac:

    # su "「[fn]-san, it's right ahead.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2608)
    su "「[fn]，直走！」"

# game/day 7.rpy:2546
translate chinese_simplified beach07_juuichi_d0e6b8cb:

    # ka "「No, right, it's to the right.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2611)
    ka "「错了，{w=.3}向右边，向右走。」"

# game/day 7.rpy:2547
translate chinese_simplified beach07_juuichi_dacffc28:

    # to "「It's to the left!{p} [fn] go left!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2614)
    to "「在左边啊！{w=.3} [fn]，左边！」"

# game/day 7.rpy:2548
translate chinese_simplified beach07_juuichi_19d13ac8:

    # ju "「Go in the direction your feet lead you.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2617)
    ju "「凭着你的直觉走！」"

# game/day 7.rpy:2549
translate chinese_simplified beach07_juuichi_75fc9e2d:

    # "Juuichi-san, I think that goes against,{p}the spirit of watermelon splitting."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2619)
    "柔一君，我很清楚这个和切西瓜游戏的精神相悖。"

# game/day 7.rpy:2550
translate chinese_simplified beach07_juuichi_0db85e3f:

    # "Still, I wonder with all these...{p}scattered directions."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2620-2621)
    "但是我还是想知道……为什么他们指的方向差别这么大？{p}我真不知道该听谁的好。"

# game/day 7.rpy:2551
translate chinese_simplified beach07_juuichi_ad550a04:

    # "I have no idea which one to follow."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2623)
    "于是，我就凭着直觉，"

# game/day 7.rpy:2552
translate chinese_simplified beach07_juuichi_8609fa18:

    # "For now, I'll just go in the direction,{p}I think the watermelon is."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2624)
    "朝着我所认为西瓜所在的位置走去。"

# game/day 7.rpy:2553
translate chinese_simplified beach07_juuichi_4fb70182:

    # ka "「Hey, that's the wrong way.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2627)
    ka "「嘿，不是这个方向。」"

# game/day 7.rpy:2554
translate chinese_simplified beach07_juuichi_00196335:

    # to "「Keep going that way, [fn]!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2630)
    to "「继续前进啊，[fn]！」"

# game/day 7.rpy:2555
translate chinese_simplified beach07_juuichi_6f993de6:

    # su "「Wah, [fn]-san it's not over there!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2633)
    su "「哇，[fn]，不是这个方向啊！」"

# game/day 7.rpy:2556
translate chinese_simplified beach07_juuichi_255db449:

    # "...{p}I follow the majority rule,{p}and correct my angle."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2636)
    "我听着大多数人的指挥，改变了我的方向。"

# game/day 7.rpy:2557
translate chinese_simplified beach07_juuichi_08b50f98:

    # to "「...Tch.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2639)
    to "「……切」"

# game/day 7.rpy:2558
translate chinese_simplified beach07_juuichi_a714bb30:

    # fn "「...Torahiko, I just now heard,{p} you clicked your tongue.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2642)
    fn "「……虎彦，我可是听到了你咋舌头的声音。」"

# game/day 7.rpy:2559
translate chinese_simplified beach07_juuichi_1709ed2f:

    # to "「No, that was just your imagination.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2645)
    to "「不，那是你的错觉。」"

# game/day 7.rpy:2560
translate chinese_simplified beach07_juuichi_accf6c01:

    # "Torahiko tries to whistle,{p}to cover up his cheating."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2647)
    "虎彦试着用吹口哨来掩盖他刚才的谎言。"

# game/day 7.rpy:2561
translate chinese_simplified beach07_juuichi_ac7ffbc5:

    # "Isn't that the same,{p}as confessing the truth?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2648)
    "这不就是在承认他在撒谎么？"

# game/day 7.rpy:2562
translate chinese_simplified beach07_juuichi_b433c2ed:

    # "Okay, from now on,{p}I'll ignore Torahiko's navigation."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2649)
    "好吧，从现在开始，我不理会虎彦的误导了。"

# game/day 7.rpy:2563
translate chinese_simplified beach07_juuichi_365034c3_1:

    # "...{p}...{p}..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2989-2991)
    "……{p}……{p}……"

# game/day 7.rpy:2564
translate chinese_simplified beach07_juuichi_6c72fd53:

    # fn "「Ultra Dragon Fang Sword!{p} Slice it in two!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2656)
    fn "「超·业炎龙牙！ 斩断！」"

# game/day 7.rpy:2573
translate chinese_simplified beach07_juuichi_0110d4b3:

    # "With a pointless yell,{p}I swing my sword down."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2660)
    "我活跃气氛地喊道，然后挥刀而下。"

# game/day 7.rpy:2577
translate chinese_simplified beach07_juuichi_934df81d:

    # "Thump.{p}Unfortunately, that isn't the response,{p}of the watermelon splitting."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2662-2663)
    "啵哧——{p}遗憾，完全没有劈中的手感。"

# game/day 7.rpy:2581
translate chinese_simplified beach07_juuichi_e79c7a5e:

    # "I remove the blindfold,{p}to check the position of the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2667)
    "我扯开蒙眼布，检查了一下西瓜的位置。"

# game/day 7.rpy:2582
translate chinese_simplified beach07_juuichi_9eb4cc42:

    # "It seems I'm too far,{p}from smashing it."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2668)
    "它离我发招的位置还有好远的距离……"

# game/day 7.rpy:2583
translate chinese_simplified beach07_juuichi_faa5430c:

    # "I scatter the sand in regret of this result,{p}and drop my shoulders in dissapointment."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2670-2671)
    "我失望地踢开脚边的沙子，{p}垂下了肩膀。"

# game/day 7.rpy:2587
translate chinese_simplified beach07_juuichi_255793d8:

    # to "「Don't worry about it [fn]!{p} Because I'm gonna slice the watermelon open!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2676-2677)
    to "「别担心呐，[fn]！{p}我一定会把西瓜切开的！」"

# game/day 7.rpy:2588
translate chinese_simplified beach07_juuichi_213751d5:

    # "I hand over the blindfold and sword,{p}to a very enthusiastic Torahiko."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2677-2680)
    "我一定会把西瓜切开的！」{p}我把蒙眼布和木刀{p}递给满腔热血的虎彦。"

# game/day 7.rpy:2601
translate chinese_simplified beach07_juuichi_46703e50:

    # su "「Are you going to spin?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2690)
    su "「你要开始了么？」"

# game/day 7.rpy:2605
translate chinese_simplified beach07_juuichi_fc9e06d5:

    # ju "「...Have you prepared yourself?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2695)
    ju "「……你准备好了么？」"

# game/day 7.rpy:2606
translate chinese_simplified beach07_juuichi_1d2d5d21:

    # "Both of them look like they're enjoying this.{p}Did I just sense something disturbing from them?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2697-2698)
    "他们两个看着都很享受的样子。{p}但是我觉得有点不太对劲。"

# game/day 7.rpy:2607
translate chinese_simplified beach07_juuichi_bcf3d828:

    # to "「...Please be gentle.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2703)
    to "「……请手下留情哦。」"

# game/day 7.rpy:2608
translate chinese_simplified beach07_juuichi_3daf9f52:

    # "Torahiko has a very timid tone.{p}...Where did all that power he had,{p}up till now go?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2705-2711)
    "虎彦胆怯地说。{p}……他刚才的激情都跑哪里去了？{p}当虎彦蒙上眼睛时，"

# game/day 7.rpy:2613
translate chinese_simplified beach07_juuichi_756077f3:

    # "When Torahiko puts on the blindfold,{p}Shun-kun borrows the support of Juuichi-san,{p}to carry out the spinning."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2712-2714)
    "在柔一的支撑下，峻开始旋转虎彦。{p}……从外人眼中看去，"

# game/day 7.rpy:2614
translate chinese_simplified beach07_juuichi_20968051:

    # "From an outside perspective,{p}it looks as if Shun-kun and Juuichi-san{p}are a parent and a child having fun."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2715-2716)
    "柔一和峻真的好像一对父子在玩啊。{p}如果我敢说出这句话的话，柔一一定会揍飞我。"

# game/day 7.rpy:2615
translate chinese_simplified beach07_juuichi_5d97c964:

    # "But if I were to say that,{p}Juuichi-san would throw me."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2718)
    "正看着他们两个转虎彦时，"

# game/day 7.rpy:2616
translate chinese_simplified beach07_juuichi_1f270052:

    # "Watching the two of them spin Torahiko,{p}Kouya approaches me from the side,{p}and quietly whispers."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2719)
    "洸哉凑到我的身边来， 悄悄地对我说。"

# game/day 7.rpy:2622
translate chinese_simplified beach07_juuichi_452fc0d3:

    # ka "「Hey, [fn], want to tell him,{p} the opposite directions for revenge?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2729)
    ka "「呐，[fn]，想不想误导他来报一箭之仇？」"

# game/day 7.rpy:2623
translate chinese_simplified beach07_juuichi_97a36e2a:

    # fn "「...Isn't that against the rules?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2732)
    fn "「……这不就违规了么？」"

# game/day 7.rpy:2627
translate chinese_simplified beach07_juuichi_525c1ecc:

    # ka "「Didn't Torahiko break the rules?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2736)
    ka "「虎彦那小子不也是吗？」"

# game/day 7.rpy:2628
translate chinese_simplified beach07_juuichi_7a00e393:

    # "...He did.{p}He spun Kouya like crazy,{p}and then he mislead me..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2738-2739)
    "……他的确是{p}他不但疯狂地转洸哉，还误导我……"

# game/day 7.rpy:2629
translate chinese_simplified beach07_juuichi_eeb410fa:

    # fn "「...All right. Let's do it.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2742)
    fn "「……行，就这么干。」"

# game/day 7.rpy:2633
translate chinese_simplified beach07_juuichi_e0793960:

    # ka "「Now you're talking.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2746)
    ka "「那么你先来。」"

# game/day 7.rpy:2634
translate chinese_simplified beach07_juuichi_f299c212:

    # "Kouya gives me a wink."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2748)
    "洸哉冲我眨了眨眼。"

# game/day 7.rpy:2638
translate chinese_simplified beach07_juuichi_957eaf2e:

    # "Good timing too,{p}Torahiko has just begun to walk."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2752)
    "正好，虎彦也开始移动了。"

# game/day 7.rpy:2639
translate chinese_simplified beach07_juuichi_ea8b5ba2:

    # "Although he seems confident in his strength,{p}when it comes to his feet,{p}he's meandering from side to side."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2753-2754)
    "虽然虎彦对自己非常自信，{p}但是当他落步时，走起来还是歪歪扭扭的。"

# game/day 7.rpy:2646
translate chinese_simplified beach07_juuichi_706cadee:

    # su "「Keep going that way...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2764)
    su "「直走直走……」"

# game/day 7.rpy:2647
translate chinese_simplified beach07_juuichi_66170a79:

    # fn "「Torahiko, go the other way,{p} the other way!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2767)
    fn "「虎彦，另一边！」"

# game/day 7.rpy:2651
translate chinese_simplified beach07_juuichi_c8c395c1:

    # ka "「Don't you have any sense of direction?{p} It's the exact opposite way.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2772)
    ka "「你一点方向感都没有么？{p}明显是你的背后啊！」"

# game/day 7.rpy:2655
translate chinese_simplified beach07_juuichi_2bcc8012:

    # "At our unexpected yelling,{p}Shun-kun blinks at us in surprise."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2776)
    "峻听了之后，迷惑地看着我们。"

# game/day 7.rpy:2656
translate chinese_simplified beach07_juuichi_20ffa021:

    # "He doesn't seem to have any idea,{p}of what we're doing."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2777)
    "他真心不知道，我们是在干什么。"

# game/day 7.rpy:2657
translate chinese_simplified beach07_juuichi_a4ea7f63:

    # "Sorry Shun-kun, this is our form of justice...!"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2779)
    "对不起，峻，这是我们对他的正义的审判！"

# game/day 7.rpy:2658
translate chinese_simplified beach07_juuichi_66fbfd50:

    # "Torahiko quickly turns around,{p}and goes in the opposite direction,{p}of the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2781)
    "虎彦立即转身，"

# game/day 7.rpy:2659
translate chinese_simplified beach07_juuichi_a7813412:

    # "Kouya and I look at each other and grin."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2782)
    "开始向西瓜的反方向走去。"

# game/day 7.rpy:2660
translate chinese_simplified beach07_juuichi_e007fc98:

    # "When Juuichi-san looks at us,{p}he sighs deeply.{p}It looks like he doesn't blame us."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2783)
    "我和洸哉相视一笑。"

# game/day 7.rpy:2661
translate chinese_simplified beach07_juuichi_365034c3_2:

    # "...{p}...{p}..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2785-2787)
    "当柔一看到我们在做的事时，{p}深深地叹了一口气。{p}看来他也不打算干涉了。"

# game/day 7.rpy:2662
translate chinese_simplified beach07_juuichi_b0181627:

    # fn "「Torahiko, now!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2794)
    fn "「虎彦，就是现在！」"

# game/day 7.rpy:2663
translate chinese_simplified beach07_juuichi_ae13e214:

    # to "「Let's go go go!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2798)
    to "「哪里跑，{w=.3}哪里跑，{w=.3}走你！！」"

# game/day 7.rpy:2664
translate chinese_simplified beach07_juuichi_bb74f3bd:

    # "Torahiko swings down the sword,{p}with all the strength he can muster."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2800)
    "虎彦用尽全身力气，奋力一劈。"

# game/day 7.rpy:2665
translate chinese_simplified beach07_juuichi_35fa6893:

    # "Not in front of the watermelon, of course.{p}It's... driftwood."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2801-2806)
    "当然，他面前的当然不是西瓜，{p}是一块……{p}漂木。{p}咚！！"

# game/day 7.rpy:2670
translate chinese_simplified beach07_juuichi_ee6b42a4:

    # "Clunk!"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3014)
    "嘎哧！"

# game/day 7.rpy:2671
translate chinese_simplified beach07_juuichi_606f1775:

    # to "{size=+15}「...YEEEEEEOW!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2809)
    to "「……耶耶耶耶————！！」"

# game/day 7.rpy:2672
translate chinese_simplified beach07_juuichi_3fb9da7d:

    # "Torahiko drops the sword,{p}and shakes his hands around,{p}while jumping up and down."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2811)
    "虎彦扔下木刀，"

# game/day 7.rpy:2676
translate chinese_simplified beach07_juuichi_15264cb5:

    # "Kouya and I give each other a bro-fist.{p}The sound it makes me feel great."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2812)
    "激动不已，十分抓狂。"

# game/day 7.rpy:2677
translate chinese_simplified beach07_juuichi_5166e491:

    # "I'm making a note here,{p}huge success."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2815-2816)
    "我和洸哉击了一下拳，这胜利的撞拳声大快人心。{p}我会记住这一天的，这真是巨大的胜利。"

# game/day 7.rpy:2683
translate chinese_simplified beach07_juuichi_7521c0ef:

    # to "「[fn], Kouya, you jerks...!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2826)
    to "「[fn]、洸哉，你们两个混帐……！」"

# game/day 7.rpy:2684
translate chinese_simplified beach07_juuichi_81d6b6fd:

    # "He glares at us while blowing his hands.{p}There are tears in his eyes."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2828-2829)
    "他挥舞着双手瞪着我们，{p}眼中含着泪水。"

# game/day 7.rpy:2688
translate chinese_simplified beach07_juuichi_268a4826:

    # ju "「Are you satisfied?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2834)
    ju "「你们这下子解气了？」"

# game/day 7.rpy:2689
translate chinese_simplified beach07_juuichi_a97a0e2a_1:

    # ka "「Yeah.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2837)
    ka "「嗯。」"

# game/day 7.rpy:2690
translate chinese_simplified beach07_juuichi_b8bff96c:

    # fn "「You bet!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2840)
    fn "「没错。」"

# game/day 7.rpy:2691
translate chinese_simplified beach07_juuichi_d4f8359e:

    # ju "「Tora, you're not going to forget,{p} why they did that?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2843)
    ju "「虎，你应该知道他们为什么这么做吧？」"

# game/day 7.rpy:2692
translate chinese_simplified beach07_juuichi_f9104e70:

    # to "「...I understand!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2848)
    to "「……我明白！」"

# game/day 7.rpy:2693
translate chinese_simplified beach07_juuichi_6c709e18:

    # "Torahiko humphs and turns away.{p}He's in a completely bad mood now.{p}...D-did we go a little too far?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2850-2852)
    "虎彦哼了一声转了过去。{p}他现在的心情可是坏透了。{p}……我们是不是有些过火了？"

# game/day 7.rpy:2694
translate chinese_simplified beach07_juuichi_bbcdf476:

    # fn "「Last up is Juuichi-san.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2855)
    fn "「最后是柔一了。」"

# game/day 7.rpy:2695
translate chinese_simplified beach07_juuichi_a2f2d328:

    # ju "「Okay.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2858)
    ju "「嗯。」"

# game/day 7.rpy:2696
translate chinese_simplified beach07_juuichi_b17df63e:

    # "Juuichi-san gets the watermelon splitting set,{p}from Torahiko and puts the blindfold on."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2860-2861)
    "柔一从虎彦手里接过工具，{p}蒙上了眼睛。"

# game/day 7.rpy:2703
translate chinese_simplified beach07_juuichi_2769a6bc:

    # "With a discouraged look on his face,{p}Torahiko starts spinning Juuichi-san's body."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2868)
    "虎彦一脸沮丧地开始旋转柔一了。"

# game/day 7.rpy:2704
translate chinese_simplified beach07_juuichi_ba72d522:

    # fn "「Torahiko, don't overdo it,{p} if you don't want to receive,{p} one of Juuichi-san's techniques...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2871-2872)
    fn "「虎彦，可别再乱来了，{p}除非……你想尝尝柔一的技术。」"

# game/day 7.rpy:2709
translate chinese_simplified beach07_juuichi_36b7e708:

    # to "「...Oh.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2879)
    to "「……哦」"

# game/day 7.rpy:2714
translate chinese_simplified beach07_juuichi_529a8e95:

    # "There was a slight delay,{p}before he replied."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2884)
    "他稍稍迟疑了一下，才给出了答复。"

# game/day 7.rpy:2715
translate chinese_simplified beach07_juuichi_5f072451:

    # "Is he trying to provoke Juuichi-san's temper?{p}And it doesn't look like he's thought,{p}of a counter-attack."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2885)
    "看来他原来还是有那种坏想法的。"

# game/day 7.rpy:2716
translate chinese_simplified beach07_juuichi_d68aad36:

    # "Even though he received that firm punishment,{p}at the welcoming party..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2886-2888)
    "他难道不怕激怒柔一么？{p}明明在欢迎会上受到了柔一的严厉惩罚……。"

# game/day 7.rpy:2717
translate chinese_simplified beach07_juuichi_b3e2cb7e:

    # "Torahiko, how long,{p}have you had that daredevil personality?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2889)
    "虎彦的性格什么时候变得这么勇于冒险了？"

# game/day 7.rpy:2724
translate chinese_simplified beach07_juuichi_9a9cf065:

    # to "「Senpai, that should be enough.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2895)
    to "「前辈，这就够了吧。」"

# game/day 7.rpy:2725
translate chinese_simplified beach07_juuichi_b91dd8e1:

    # "Reluctantly holding his tail,{p}Torahiko finishes up by giving a push,{p}to Juuichi-san's back."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2897-2898)
    "虎彦极不情愿地拉住柔一的尾巴，{p}然后朝着他的背推了一把。"

# game/day 7.rpy:2729
translate chinese_simplified beach07_juuichi_fdc3a188:

    # su "「Juuichi-san, go straight!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2903)
    su "「柔一君，向前，向前，直走啊！」"

# game/day 7.rpy:2733
translate chinese_simplified beach07_juuichi_f77f821d:

    # to "「A little to the right, right!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2909)
    to "「向右，向右一点！」"

# game/day 7.rpy:2737
translate chinese_simplified beach07_juuichi_6bdd4135:

    # ka "「A little to the left?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2914)
    ka "「向左一点」"

# game/day 7.rpy:2738
translate chinese_simplified beach07_juuichi_5eff5da9:

    # fn "「Juuichi-san, straight!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2917)
    fn "「柔一君，前边，直走」"

# game/day 7.rpy:2739
translate chinese_simplified beach07_juuichi_30d39dcb:

    # "I shout so that my voice{p}won't lose out to everybody else's."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2919-2920)
    "我吼了出来，{p}声音上我是不会输给别人的。"

# game/day 7.rpy:2743
translate chinese_simplified beach07_juuichi_bcbdcd89:

    # su "「Wah, please go back a little!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2925)
    su "「哇，请往后再走一点！」"

# game/day 7.rpy:2747
translate chinese_simplified beach07_juuichi_19901b2b:

    # to "「Keep going straight!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2929)
    to "「继续直走！」"

# game/day 7.rpy:2751
translate chinese_simplified beach07_juuichi_14101730:

    # ka "「Straight, straight.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2933)
    ka "「直走，直走！」"

# game/day 7.rpy:2752
translate chinese_simplified beach07_juuichi_a9f3a58e:

    # fn "「A little more to the right.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2936)
    fn "「再向右一点点。」"

# game/day 7.rpy:2756
translate chinese_simplified beach07_juuichi_d50e639b:

    # to "「Woah, too far!{p} More to the left!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2941)
    to "「喔，太远了！{p}再向左一点！」"

# game/day 7.rpy:2760
translate chinese_simplified beach07_juuichi_46f6fd21:

    # su "「It's left, please go more to the left.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2946)
    su "「右边，再右边一点！」"

# game/day 7.rpy:2761
translate chinese_simplified beach07_juuichi_275955c5:

    # fn "「Juuichi-san, make an adjustment to the left!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2949)
    fn "「柔一君，在左边调整一下！」"

# game/day 7.rpy:2767
translate chinese_simplified beach07_juuichi_c14ecf66:

    # ka "「It's a little more to the left.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2954)
    ka "「往左太远了！」"

# game/day 7.rpy:2771
translate chinese_simplified beach07_juuichi_eae5d233:

    # to "「Keep going that way!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2959)
    to "「就这样，直走！」"

# game/day 7.rpy:2772
translate chinese_simplified beach07_juuichi_5a6c7b1e:

    # su "「Juuichi-san, straight ahead!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2962)
    su "「柔一君，直走!」"

# game/day 7.rpy:2776
translate chinese_simplified beach07_juuichi_89f836f6:

    # to "「More to the right, right!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2967)
    to "「向右，向右一点！」"

# game/day 7.rpy:2777
translate chinese_simplified beach07_juuichi_9a39ab33:

    # fn "「Just a tiny bit more to the right!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2970)
    fn "「向右移一点点就够了！」"

# game/day 7.rpy:2781
translate chinese_simplified beach07_juuichi_9b78e109:

    # "...Hm?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2973-2974)
    "……嗯？{p}忽然觉得，"

# game/day 7.rpy:2782
translate chinese_simplified beach07_juuichi_404c3513:

    # "For some reason,{p}it feels as if he's only,{p}following my directions."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2975)
    "他好像只在听我的指挥。"

# game/day 7.rpy:2783
translate chinese_simplified beach07_juuichi_5d2f8254:

    # fn "「Juuichi-san, left!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2978)
    fn "「柔一君，向左！」"

# game/day 7.rpy:2784
translate chinese_simplified beach07_juuichi_c2322448:

    # "I try shouting the appropiate direction.{p}Juuichi-san changes his course to the left,{p}just as I said. I yell out in a hurry."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2980-2982)
    "我尝试喊出确切的方向，{p}而我一喊出来， 柔一就立即向左转了。{p}我于是马上慌张地再喊一声。"

# game/day 7.rpy:2785
translate chinese_simplified beach07_juuichi_acd0cc36:

    # fn "「Just a little more to the right!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 2985)
    fn "「是向右一点！」"

# game/day 7.rpy:2789
translate chinese_simplified beach07_juuichi_e3777505:

    # "Juuichi-san changes his body's direction.{p}...Ooh, this is a serious responsibility.{p}I'm terrified."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2988-2989)
    "柔一就立即改了个方向。{p}……哦哦……这是个很重大的责任啊。我突然有些胆颤。"

# game/day 7.rpy:2790
translate chinese_simplified beach07_juuichi_365034c3_3:

    # "...{p}...{p}..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 2994-2996)
    "……{p}……{p}……。"

# game/day 7.rpy:2791
translate chinese_simplified beach07_juuichi_d2c414ef:

    # fn "「Juuichi-san, now!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3000)
    fn "「柔一君，就是现在！」"

# game/day 7.rpy:2792
translate chinese_simplified beach07_juuichi_de531019:

    # "I give my final instruction.{p}Juuichi-san readies his sword.{p}Then..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3002-3004)
    "我发出了最后的指令。{p}柔一举起了他的刀。{p}……然后……"

# game/day 7.rpy:2796
translate chinese_simplified beach07_juuichi_51a3ba3b:

    # ju "「...HA!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3009)
    ju "「……哈！！」"

# game/day 7.rpy:2797
translate chinese_simplified beach07_juuichi_c4b47210:

    # "With a sharp exhale,{p}he swings the sword,{p}directly onto the watermelon."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3011-3014)
    "他深吸一口气，直直地冲着西瓜挥刀而下。{p}嘎哧！"

# game/day 7.rpy:2801
translate chinese_simplified beach07_juuichi_b1e5f261:

    # "Crack!{p}The watermelon that was once a single sphere,{p}had become 2 perfect domes."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3015-3016)
    "这个完整的球体，{p}被切成完美的两半。"

# game/day 7.rpy:2805
translate chinese_simplified beach07_juuichi_908c751c:

    # su "「Wow, Juuichi-san is amazing!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3021)
    su "「哇，柔一君你真厉害！」"

# game/day 7.rpy:2809
translate chinese_simplified beach07_juuichi_a89881d9:

    # ka "「...Well done.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3026)
    ka "「……干得漂亮！」"

# game/day 7.rpy:2813
translate chinese_simplified beach07_juuichi_5c41602c:

    # to "「Jeez, in the end, senpai just had to...{p} have that deliciouness, didn't he?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3031)
    to "「切，到最后还是前辈尝到甜头了啊……」"

# game/day 7.rpy:2814
translate chinese_simplified beach07_juuichi_2cf9be18:

    # fn "「As expected of a martial artist.{p} The watermelon is in two beatiful equal parts.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3034)
    fn "「不愧是学空手道的啊！」"

# game/day 7.rpy:2815
translate chinese_simplified beach07_juuichi_97c024af:

    # "We run over to Juuichi-san's side,{p}and tell him how impressed we are."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3036)
    "我们纷纷跑到柔一旁边发表各自的感想。"

# game/day 7.rpy:2816
translate chinese_simplified beach07_juuichi_867dbed8:

    # "He takes off the blindfold,{p}to check out the state of the watermelon,{p}and seems to be a little surprised."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3037-3038)
    "他解下蒙眼布，看了一下西瓜，{p}看起来他也有些惊喜。"

# game/day 7.rpy:2820
translate chinese_simplified beach07_juuichi_7972efb0:

    # ju "「That's a pretty clean cut.{p} ...I wonder if it was because...{p} of those precise instructions?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3042)
    ju "「这只是碰巧罢了」"

# game/day 7.rpy:2821
translate chinese_simplified beach07_juuichi_2f2c42ea:

    # "...Huh?{p}Is he talking to me?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3050)
    "……啊咧？{p}他说的是我吗？"

# game/day 7.rpy:2822
translate chinese_simplified beach07_juuichi_912a3739:

    # "I look over at Juuichi-san,{p}and our eyes perfectly meet.{p}He immediately turns away, though."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3053-3054)
    "我看了下柔一，正好四目相视。{p}然后他立即把目光移开了。"

# game/day 7.rpy:2823
translate chinese_simplified beach07_juuichi_17308704:

    # ju "「Hey, Kuroi.{p} Go get the knife out of my bag.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3048)
    ju "「……那么，这应该归功于精确的指挥吧」"

# game/day 7.rpy:2824
translate chinese_simplified beach07_juuichi_fd12b2c1:

    # "He speaks to Shin-kun."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3050)
    "……啊咧？"

# game/day 7.rpy:2828
translate chinese_simplified beach07_juuichi_e171eea8:

    # "Hmm, maybe he wasn't referring to me...{p}But he did quickly look away."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3051-3053)
    "他说的是我吗？{p}我看了下柔一，正好四目相视。"

# game/day 7.rpy:2829
translate chinese_simplified beach07_juuichi_fbbfab2f:

    # "I wonder why Juuichi-san,{p}would say something like that?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3054)
    "然后他立即把目光移开了。"

# game/day 7.rpy:2830
translate chinese_simplified beach07_juuichi_39bfb673:

    # "...It's no good.{p}The more I think about it,{p}the more confused I get."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3060-3068)
    "他朝深的方向说。{p}嗯……也许他指的不是我吧。{p}深听到柔一在叫他，就往正在看的书里插上一个书签，"

# game/day 7.rpy:2831
translate chinese_simplified beach07_juuichi_413d6224:

    # "I decide to just throw up the white flag."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3069)
    "然后打开柔一的背包，拿出了一把小刀。"

# game/day 7.rpy:2832
translate chinese_simplified beach07_juuichi_16ea1b9a:

    # "When he hears Juuichi-san,{p}calling out to him,{p}Shin-kun puts a bookmark in the book."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3071)
    "然后深君拿着刀向柔一的方向走来，"

# game/day 7.rpy:2833
translate chinese_simplified beach07_juuichi_2029f762:

    # "Then, he opens Juuichi-san's backpack,{p}and pulls out a knife."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3072)
    "这时我对柔一说。"

# game/day 7.rpy:2834
translate chinese_simplified beach07_juuichi_0e51a6aa:

    # "When I see that Shin-kun,{p}is heading this way,{p}I talk to Juuichi-san."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3071-3072)
    "然后深君拿着刀向柔一的方向走来，{p}这时我对柔一说。"

# game/day 7.rpy:2840
translate chinese_simplified beach07_juuichi_4decd63f:

    # fn "「...Juuichi-san, you're always prepared.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3079)
    fn "「……柔一君，你总是把什么都准备好了。」"

# game/day 7.rpy:2844
translate chinese_simplified beach07_juuichi_066be0b5:

    # ju "「Forewarned is forearmed.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3083)
    ju "「有备无患{w=.3}嘛。」"

# game/day 7.rpy:2845
translate chinese_simplified beach07_juuichi_db08399a:

    # "Juuichi-san has a vague expression,{p}of satisfaction on his face."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3085)
    "一脸满足的柔一含糊地解释着。"

# game/day 7.rpy:2849
translate chinese_simplified beach07_juuichi_cf358189:

    # si "「Here.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3090)
    si "「给」"

# game/day 7.rpy:2850
translate chinese_simplified beach07_juuichi_02c8bc9a:

    # "Shin-kun tries to give Juuichi-san the knife,{p}but he stops him."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3092-3093)
    "深君把刀递给柔一，{p}他没有接。"

# game/day 7.rpy:2854
translate chinese_simplified beach07_juuichi_087cb2b3:

    # ju "「This would be more suitable for Ooshima.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3097)
    ju "「把他给大岛会更好。」"

# game/day 7.rpy:2855
translate chinese_simplified beach07_juuichi_ede25b96:

    # si "「...Certainly.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3100)
    si "「……确实」"

# game/day 7.rpy:2859
translate chinese_simplified beach07_juuichi_40396eb0:

    # "Shin-kun gives the knife,{p}to Torahiko as he's told."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3104)
    "深如他所说，把刀给了虎彦。"

# game/day 7.rpy:2860
translate chinese_simplified beach07_juuichi_acac8bec:

    # "That sulleness Juuichi-san had up until now,{p}doesn't concern him at all."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3105)
    "直到现在，柔一才终于收起愠怒的眼，唤了一下虎彦。"

# game/day 7.rpy:2861
translate chinese_simplified beach07_juuichi_12efed97:

    # "Torahiko gives a high-spirited shout."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3106)
    "虎彦听了之后兴高采烈地呼喊着。"

# game/day 7.rpy:2865
translate chinese_simplified beach07_juuichi_69aba358:

    # to "「Please leave it to me!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3111)
    to "「请交给我吧！」"

# game/day 7.rpy:2869
translate chinese_simplified beach07_juuichi_12694ca8:

    # ka "「You're such a simple guy...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 3116)
    ka "「真是个头脑简单的家伙……」"

# game/day 7.rpy:2870
translate chinese_simplified beach07_juuichi_2dcb0b42:

    # "Kouya stands alone and mutters that."
    # [旧版翻译] 来源: c_海水浴.ks (KS 3118)
    "洸哉在一旁说道，{p}……当然是小声地。"

# game/day 7.rpy:2874
translate chinese_simplified beach07_juuichi_d589f4d1:

    # "Torahiko evenly carves the watermelon,{p}and we eat happily together.{p}Even incluiding Shin-kun."
