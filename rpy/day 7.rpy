    # [旧版翻译] 来源: c_海水浴.ks (KS 185-186)
    su "「大家早安！」"

# game/day 7.rpy:554
translate chinese_simplified beach07_meetup_4fbb9d0e:

    # fn "「Good morning.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 188-189)
    fn "「早安」"

# game/day 7.rpy:555
translate chinese_simplified beach07_meetup_ae21c16b:

