# game/day 7.rpy:569
translate chinese_simplified beach07_meetup_2b7b3938:

    # su "「Yep.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 212-213)
    su "「嗯。」"

# game/day 7.rpy:578
translate chinese_simplified beach07_meetup_4d5ef8fd:

    # ka "「...Speaking of getting somebody,\n are they going to get here soon?{p} It's almost time to go.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 220-223)
