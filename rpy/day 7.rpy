# game/day 7.rpy:650
translate chinese_simplified beach07_meetup_e805cc9b:

    # ta "「You guys haven't forgotten anything?{p} The bus is here, so let's go!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 309-310)
    ta "「大伙没有忘记些什么吧？{p}啊，巴士到了，出发吧！」"

# game/day 7.rpy:659
translate chinese_simplified beach07_meetup_c9d973e3:

    # fn "「Yeah!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 316-317)
    fn "「哦！」"

# game/day 7.rpy:660
translate chinese_simplified beach07_meetup_ae8d4fe6:

    # so "「All right!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 319-320)
    so "「没问题！」"

# game/day 7.rpy:661
translate chinese_simplified beach07_meetup_c666627f:

    # su "「Okay!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 322-323)
    su "「好啊！」"

# game/day 7.rpy:669
translate chinese_simplified beach07_meetup_b089ad76:

    # fn "「Come to think of it,\n was there a beach around here?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 333-334)
    fn "「让我想想，这附近有沙滩么？」"

# game/day 7.rpy:670
translate chinese_simplified beach07_meetup_bb8726d8:

    # ju "「There is...{p} If you go the other direction, away from Kazenari.{p} There's no other reason to go out this way.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 339-342)
