# game/day 7.rpy:588
translate chinese_simplified beach07_meetup_00ea3b67:

    # "Hm?"
    # [旧版翻译] 来源: c_海水浴.ks (KS 234)
    "……嗯？"

# game/day 7.rpy:589
translate chinese_simplified beach07_meetup_81524156:

