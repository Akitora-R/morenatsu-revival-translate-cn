# game/day 7.rpy:314
translate chinese_simplified beach07_invite_shin_09886c1c:

    # fn "「Oh, Shin-kun?」"
    # [旧版翻译] 来源: 7日目.ks (KS 646)
    fn "「啊，深君？」"

# game/day 7.rpy:315
