# game/day 7.rpy:703
translate chinese_simplified beach07_meetup_8dc589cd:

    # su "「It's the ocean.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 437-438)
    su "「海！」"

# game/day 7.rpy:704
translate chinese_simplified beach07_meetup_d1b48bf5:

    # ko "「It is!{w} It's beautiful.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 440-441)
    ko "「这就是！{w}真漂亮！」"

