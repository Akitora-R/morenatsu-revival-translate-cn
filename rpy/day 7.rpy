translate chinese_simplified beach07_meetup_c375d21f:

    # si "「Oh, I've heard of that.」"
    # [旧版翻译] 来源: torahiko/7日目.ks (KS 379-380)
    si "「哦，是这个啊，那我也听说过」"

# game/day 7.rpy:675
translate chinese_simplified beach07_meetup_c2d650d3:

    # ky "「In fact, the one that runs through the inner\n part of the village seems to come from the\n largest mountain in the area.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 368-370)
    ky "「实际上这条河只是流过部分村庄罢了……\n看起来它的源头是在这附近最大的山里。」"

# game/day 7.rpy:676
translate chinese_simplified beach07_meetup_1afd47d0:

    # fn "「Is that so?{p} You seem to know a lot about this.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 372-373)
    fn "「是这样么？{p}前辈好像很了解这个。」"

# game/day 7.rpy:677
translate chinese_simplified beach07_meetup_9624dcf8:

    # ky "「No, this is just some second-hand knowledge.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 376-378)
    ky "「不，这只是一些听来的知识罢了。」"

# game/day 7.rpy:678
translate chinese_simplified beach07_meetup_08b0207b:

    # so "「But if it's in the mountains,\n what does it have to do with the sea?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 382-384)
    so "「但是如果在山里，\n那么和海还有什么关系呢？」"

# game/day 7.rpy:679
translate chinese_simplified beach07_meetup_73596db6:

    # ky "「Tarou, you'll understand some day.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 386-387)
    ky "「宗，总有一天你会明白的。」"

# game/day 7.rpy:684
translate chinese_simplified beach07_meetup_84cae152:

    # su "「Hawawawa, it got dark all of a sudden.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 394-395)
    su "「啊哇哇，突然天就黑了。」"

# game/day 7.rpy:685
translate chinese_simplified beach07_meetup_99fe5d53:

    # ju "「Looks like we entered a tunnel.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 397-398)
    ju "「看起来好像我们进隧道了。」"

# game/day 7.rpy:686
translate chinese_simplified beach07_meetup_365034c3:

    # "...{p}...{p}..."
    # [旧版翻译] 来源: c_海水浴.ks (KS 400-402)
    "……{p}……{p}……"

# game/day 7.rpy:687
translate chinese_simplified beach07_meetup_5075e0f5:

    # fn "「This tunnel sure is long.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 404-405)
    fn "「这个隧道可真长啊。」"

# game/day 7.rpy:688
translate chinese_simplified beach07_meetup_e07bf47a:

    # ka "「I don't really like tunnels...{p} They make a weird sound.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 409-411)
    ka "「我不喜欢隧道……{p}在里面会发出奇怪的声音。」"

# game/day 7.rpy:689
translate chinese_simplified beach07_meetup_f4409bea:

    # fn "「I know, the air pressure feels strange.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 413-414)
    fn "「我知道，在里面气压会变得很奇怪。」"

# game/day 7.rpy:693
translate chinese_simplified beach07_meetup_4ec69518:

    # to "「Oh, seems like it'll be over soon.{p} Look.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 418-420)
    to "「喔，看起来隧道快到头了。{p}看。」"

# game/day 7.rpy:701
translate chinese_simplified beach07_meetup_144aef16:

    # fn "「Whoa, it's so blue!」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 431-432)
    fn "「嚯，这可真蓝啊！」"

# game/day 7.rpy:702
translate chinese_simplified beach07_meetup_55d8c571:

