# game/day 7.rpy:586
translate chinese_simplified beach07_meetup_a487df47:

    # ju "「If I remember correctly,\n Tora was going to go get him,\n to make sure he isn't late.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 229-231)
