    # si "「[fn]?」"
    # [旧版翻译] 来源: 7日目.ks (KS 649)
    si "「[fn]？」"

# game/day 7.rpy:316
translate chinese_simplified beach07_invite_shin_3d372691:

    # fn "「Yeah. This is unusual.{p} A call from Shin-kun.」"
    # [旧版翻译] 来源: 7日目.ks (KS 652-653)
