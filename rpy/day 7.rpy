# game/day 7.rpy:289
translate chinese_simplified beach07_invite_juuichi_8dbc98cd:

    # ju "「We're meeting at the bus stop at 7 tomorrow.」"
    # [旧版翻译] 来源: 7日目.ks (KS 594-596)
