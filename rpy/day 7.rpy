    # ko "「Oh really?{p} But I didn't hurry,{p} and everything's okay, right?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 290-292)
    ko "「噢，是么？{p}但是我不急，\n这也没什么问题，不是么？」"

# game/day 7.rpy:641
translate chinese_simplified beach07_meetup_98893d0a:

    # to "「Well...」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 298-299)
    to "「好吧……」"

# game/day 7.rpy:645
translate chinese_simplified beach07_meetup_2ed01389:

    # ka "「...No matter what we say,\n he's not going to get any better.」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 302-303)
    ka "「无论怎么说……他是不能表现得更好了。」"

# game/day 7.rpy:649
