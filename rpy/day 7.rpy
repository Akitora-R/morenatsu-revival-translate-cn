# game/day 7.rpy:559
translate chinese_simplified beach07_meetup_da8b3553:

    # ta "「Oh, good morning.{p} Hang on, there's another person\n hiding behind Kyouji, isn't there?」"
    # [旧版翻译] 来源: c_海水浴.ks (KS 195-197)
