# game/Welcome Party.rpy:1763

translate chinese_simplified sit_with_juuichi_97994194:

    # to "「[fn], sit down!」"
    # [旧版翻译] 来源: オープニング.ks
    to "「[fn]，快坐下！」"

# game/Welcome Party.rpy:1767

translate chinese_simplified sit_with_juuichi_fd331285:

    # si "「...You know,\n the guest of honor being late to his own party\n is a grave situation.」"
    # [旧版翻译] 来源: オープニング.ks
