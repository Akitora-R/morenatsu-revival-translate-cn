# game/Welcome Party.rpy:2817
translate chinese_simplified sit_with_torahiko_2cb832b2:

    # extend "Dahaha! 」"
    # KS:4629 无直接对应
    extend "啊——哈哈——！」"

# game/Welcome Party.rpy:2821
translate chinese_simplified sit_with_torahiko_c98f5c6b:

