translate chinese_simplified sit_with_shun_1aa9e966:

    # su "「I don't have that.」"
    # [旧版翻译] 来源: オープニング.ks
    su "「我没有那个。」"

# game/Welcome Party.rpy:2206

translate chinese_simplified sit_with_shun_7bfd7b13:

    # "He swallows a big mouthful,\nthen continues talking."
    # [旧版翻译] 来源: オープニング.ks
    "他大口吞下，\\n然后继续说话。"
# game/Welcome Party.rpy:2207

translate chinese_simplified sit_with_shun_66961307:

    # "A big mouthful again,\nthen the same as before.{p}Somtimes I can't keep up with the conversation."
    # [旧版翻译] 来源: オープニング.ks
    "又是大口，\\n然后和之前一样。{p}有时候我跟不上对话的节奏。"
# game/Welcome Party.rpy:2208

translate chinese_simplified sit_with_shun_09c2115a:

    # "He doesn't have very good manners,\nmaybe I should teach him some."
    # [旧版翻译] 来源: オープニング.ks
    "他吃相不太好看，\\n也许我该教教他。"
# game/Welcome Party.rpy:2209

translate chinese_simplified sit_with_shun_a9154256:

    # "There's a difference between how he eats,\nand how everyone else does."
    # [旧版翻译] 来源: オープニング.ks
    "他吃的样子和其他人完全不一样。"
# game/Welcome Party.rpy:2210

translate chinese_simplified sit_with_shun_bb384860:

    # "I'd like to to tell him how to carry his food,\nor how to evenly break his chopsticks."
    # [旧版翻译] 来源: オープニング.ks
    "我想教教他怎么夹菜，\\n还有怎么整齐地掰开筷子。"
# game/Welcome Party.rpy:2214

translate chinese_simplified sit_with_shun_64b1fd73:

    # su "「Ah, [fn]-san,\n a grain of rice.」"
    # [旧版翻译] 来源: オープニング.ks
    su "「啊，[fn]先生，\\n \\ 一粒米饭。」"

# game/Welcome Party.rpy:2215

translate chinese_simplified sit_with_shun_fd147890:

    # fn "「Hm?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「嗯？」"

# game/Welcome Party.rpy:2216

translate chinese_simplified sit_with_shun_2206a2cf:

    # "Shun-kun gently sets his dish down,\nstretches his hand out to my cheek,\nand picks up the rice with his finger."
    # [旧版翻译] 来源: オープニング.ks
    "小瞬轻轻放下盘子，\\n伸出手到我的脸颊边，\\n用手指捡起了那粒米饭。"
# game/Welcome Party.rpy:2220

translate chinese_simplified sit_with_shun_a2f50b00:

    # "He wraps it in a nearby napkin."
    # [旧版翻译] 来源: オープニング.ks
    "他用旁边的纸巾把它包了起来。"
# game/Welcome Party.rpy:2221

translate chinese_simplified sit_with_shun_6f02cf81:

    # "I felt a little humiliated.{p}\"Oh, it's not a big deal.\" he says.{p}Well, if he says so."
    ""

# game/Welcome Party.rpy:2222

translate chinese_simplified sit_with_shun_a4244732:

    # "Should I have just licked it off?"
    # [旧版翻译] 来源: オープニング.ks
    "我是不是该直接舔掉算了？"
# game/Welcome Party.rpy:2226

translate chinese_simplified sit_with_shun_296a2ecd:

    # su "「[fn]-san, you've gotten so much bigger!」"
    # [旧版翻译] 来源: オープニング.ks
    su "「[fn]先生，你长大了好多啊！」"

# game/Welcome Party.rpy:2227

translate chinese_simplified sit_with_shun_b20a0fc8:

    # fn "「You think so?{p} Shun-kun, you've...」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「小瞬，你是在长身体吗……？」"
# game/Welcome Party.rpy:2231

translate chinese_simplified sit_with_shun_8a810275:

    # "I take a good look at him.{p}From head to toe,\nno matter how hard I try to convince myself,"
    # [旧版翻译] 来源: オープニング.ks
    "我好好打量了他一番。{p}从头到脚，\\n不管怎么说服自己，"
# game/Welcome Party.rpy:2232

translate chinese_simplified sit_with_shun_d1155757:

    # "Shun-kun just hasn't changed that much."
    # [旧版翻译] 来源: オープニング.ks
    "小瞬真的没怎么变。"
# game/Welcome Party.rpy:2233

translate chinese_simplified sit_with_shun_a14a929f:

    # fn "「Shun-kun, I guess you're growing...?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「小瞬，你是在长身体吗……？」"

# game/Welcome Party.rpy:2234

translate chinese_simplified sit_with_shun_9ccb2ffc:

    # "I try to make my words vague."
    # [旧版翻译] 来源: オープニング.ks
    "我尽量说得委婉一些。"
# game/Welcome Party.rpy:2238

translate chinese_simplified sit_with_shun_1d21b516:

    # su "「That makes me happy,\n not a lot of people say that to me.」"
    # [旧版翻译] 来源: オープニング.ks
    su "「这让我很开心，\\n \\ 不太有人这么对我说。」"

# game/Welcome Party.rpy:2239

translate chinese_simplified sit_with_shun_3f7eb4bf:

    # "It's been 5 years,\nI wonder if anybody's said something about...{p}his height as well."
    # [旧版翻译] 来源: オープニング.ks
    "已经5年了，\\n不知道有没有人说过……{p}关于他的身高的事。"
# game/Welcome Party.rpy:2243

translate chinese_simplified sit_with_shun_f69c0de4:

    # "The party goes on.{p}The sound of this familiar hustle and bustle,\nit tickles my ears."
    # [旧版翻译] 来源: オープニング.ks
    "派对继续着。{p}这熟悉的喧闹声，\\n撩动着我的耳畔。"
# game/Welcome Party.rpy:2244

translate chinese_simplified sit_with_shun_b4b73504:

    # "I had no choice but to loosen my cheeks.{p}Time stopped, then started.{p}That's what it feels like."
    # [旧版翻译] 来源: オープニング.ks
    "我不禁放松了脸颊。{p}时间仿佛静止，又重新流动。{p}就是这种感觉。"
# game/Welcome Party.rpy:2245

translate chinese_simplified sit_with_shun_d3299059:

    # "Has Shun-kun really not gotten any taller...?"
    # [旧版翻译] 来源: オープニング.ks
    "小瞬真的没有长高吗……？"
# game/Welcome Party.rpy:2254

translate chinese_simplified sit_with_shin_81e355dc:

    # fn "「Is it all right if I sit next to you?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「我坐你旁边可以吗？」"

# game/Welcome Party.rpy:2258

translate chinese_simplified sit_with_shin_07039076:

    # si "「...Go ahead.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「……坐吧。」"

# game/Welcome Party.rpy:2259

translate chinese_simplified sit_with_shin_de0e0ed4:

    # "His reply is half-hearted,\nbut it's not to the point of being unsocial."
    # [旧版翻译] 来源: オープニング.ks
    "他的回答有些敷衍，\\n但还不至于到不合群的地步。"
# game/Welcome Party.rpy:2260

translate chinese_simplified sit_with_shin_35d8952e:

    # "This is my childhood friend speaking like this,\nbut I'd feel uncomfortable if it was anyone else."
    # [旧版翻译] 来源: オープニング.ks
    "这是我的青梅竹马在说话，\\n但如果换作别人我肯定会很不自在。"
# game/Welcome Party.rpy:2264

translate chinese_simplified sit_with_shin_4d0f823a:

    # ka "「Shin, are you like, anxious or something?」"
    # [旧版翻译] 来源: オープニング.ks
    ka "「心，你怎么了，紧张吗？」"

# game/Welcome Party.rpy:2265

translate chinese_simplified sit_with_shin_014736bf:

    # si "「Not particularly...」"
    # [旧版翻译] 来源: オープニング.ks
    si "「没什么……」"

# game/Welcome Party.rpy:2269

translate chinese_simplified sit_with_shin_21afcdc7:

    # ka "「Yeah, you're saying that, but...{p} you got here even earlier than I did.{p} Isn't there something you wanted to say to him?」"
    # [旧版翻译] 来源: オープニング.ks
    ka "「你说得倒轻巧……{p} \\ 但你来得比我还早啊。{p} \\ 是不是有什么想跟他说的？」"

# game/Welcome Party.rpy:2270

translate chinese_simplified sit_with_shin_07689e46:

    # fn "「Huh? Is that true?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「诶？是真的吗？」"

# game/Welcome Party.rpy:2271

translate chinese_simplified sit_with_shin_a97a0e2a:

    # ka "「Yeah.」"
    # [旧版翻译] 来源: オープニング.ks
    ka "「嗯。」"

# game/Welcome Party.rpy:2272

translate chinese_simplified sit_with_shin_2df4d354:

    # si "「I just didn't want to be late.{p} So I got here ahead of time.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「我只是不想迟到而已。{p} \\ 所以就早到了一点。」"

# game/Welcome Party.rpy:2276

translate chinese_simplified sit_with_shin_cf4c6f3e:

    # ka "「Is that really it?」"
    # [旧版翻译] 来源: オープニング.ks
    ka "「真的是这样吗？」"

# game/Welcome Party.rpy:2280

translate chinese_simplified sit_with_shin_2b1e243b:

    # ko "「Hah, doubt it.」"
    # [旧版翻译] 来源: オープニング.ks
    ko "「哈，我才不信。」"

# game/Welcome Party.rpy:2284

translate chinese_simplified sit_with_shin_bef95801:

    # si "「...」"
    # [旧版翻译] 来源: オープニング.ks
    si "「……」"

# game/Welcome Party.rpy:2285

translate chinese_simplified sit_with_shin_45e8259b:

    # "Kounosuke cuts in from the side.{p}Shin-kun tries to keep his cool.{p}His cheeks are red, is he embarrassed?"
    # [旧版翻译] 来源: オープニング.ks
    "孝之助也从旁插嘴，{p}深君不高兴地闭上了嘴。{p}脸颊微微发红，难道是害羞了？"
# game/Welcome Party.rpy:2286

translate chinese_simplified sit_with_shin_052b203a:

    # "Come to think of it,\nShin-kun was never a very social person.{p}I see what's going on here."
    # [旧版翻译] 来源: オープニング.ks
    "说起来，深君从以前开始就很不擅长与人相处。{p}原来如此，确实是这样呢。"
# game/Welcome Party.rpy:2287

translate chinese_simplified sit_with_shin_f2fb5442:

    # fn "「Shin-kun, have you been thinking about me?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「深君～。就这么挂念着我吗？」"

# game/Welcome Party.rpy:2288

translate chinese_simplified sit_with_shin_80514554:

    # "I tease him a little,\nand put my hand on his shoulder.{p}A little fooling around will brighten the mood."
    # [旧版翻译] 来源: オープニング.ks
    "稍微逗弄他一下，{p}把手搭在他的肩上。{p}稍微打打闹闹，气氛也会轻松些。"
# game/Welcome Party.rpy:2292

translate chinese_simplified sit_with_shin_8ec90519:

    # si "「...It would be stupid...{p} for me to think about things like that.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「……别说那种蠢话好吗。」"

# game/Welcome Party.rpy:2293

translate chinese_simplified sit_with_shin_6bbab0f6:

    # "Guh!{p}As expected, my teasing has no effect."
    # [旧版翻译] 来源: オープニング.ks
    "咕叭！{p}看来是使坏得有些过火了。"
# game/Welcome Party.rpy:2294

translate chinese_simplified sit_with_shin_7971e153:

    # "He roughly brushes my hand off his shoulder,\nand glances at me with a look of contempt.{p}I quickly look away from him."
    # [旧版翻译] 来源: オープニング.ks
    "搭在他肩上的手，被粗暴地甩开了。{p}用鄙视的眼神瞪了我一眼，{p}深君就生气地把头别向一边了。"
# game/Welcome Party.rpy:2295

translate chinese_simplified sit_with_shin_a6e5a6af:

    # fn "「S-Shin-kun.{p} It was just a hand on the shoulder,\n I'm just messing with you.」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「深、深君。{p} \\ 只是想碰碰你而已……{p} \\ 开玩笑而已……」"

# game/Welcome Party.rpy:2296

translate chinese_simplified sit_with_shin_cf7957fc:

    # si "「I know.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「是么」"

# game/Welcome Party.rpy:2303

translate chinese_simplified sit_with_shin_cbf622ff:

    # ko "「Uh-oh.」"
    # [旧版翻译] 来源: オープニング.ks
    ko "「啊——啊」"

# game/Welcome Party.rpy:2307

translate chinese_simplified sit_with_shin_9772480b:

    # "Apparently, I've completely offended him.{p}Before I know it,\nKouya and Kounosuke withdraw from the conversation."
    # [旧版翻译] 来源: オープニング.ks
    "看来，是完全地惹毛他了呢。{p}孝之助和洸哉也一副「我什么也不知道」的模样，回避开了。"
# game/Welcome Party.rpy:2308

translate chinese_simplified sit_with_shin_43af86e3:

    # "Tension arises between Shin-kun and me.{p}However, everyone else is asking me many questions.{p}Food and drink arrive at the same time."
    # [旧版翻译] 来源: オープニング.ks
    "正在我和深君之间流动着这般微妙的气氛之时，{p}来自四面八方的询问向我袭来，{p}肉和饮料也跟着上来了。"
# game/Welcome Party.rpy:2309

translate chinese_simplified sit_with_shin_3f69680e:

    # "We didn't have to wait long,\nprobably because we've rented the place out."
    # [旧版翻译] 来源: オープニング.ks
    "点了菜和饮品后不久，肉就已经摆了满桌，每个人也都拿到了自己点的饮料。"
# game/Welcome Party.rpy:2310

translate chinese_simplified sit_with_shin_6c8165f0:

    # "The meat is served to each table,\nand the drinks are served as well.{p}Then, Tatsu-nii stands up."
    # [旧版翻译] 来源: オープニング.ks
    "肉已经摆了满桌，{p}每个人也都拿到了自己点的饮料。{p}辰兄看准时机，站了起来。"
# game/Welcome Party.rpy:2316

translate chinese_simplified sit_with_shin_d5c96c35:

    # ta "「So then, this time we're celebrating our reunion!{p} Cheers!」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「诶，既然差不多齐了，为庆祝与[博行]的再会，{p} \\ 干杯！」"

# game/Welcome Party.rpy:2317

translate chinese_simplified sit_with_shin_d256e48b:

    # "{size=+30}「CHEERS!」"
    # [旧版翻译] 来源: オープニング.ks
    "{size=+30}「干杯——」"

# game/Welcome Party.rpy:2323

translate chinese_simplified sit_with_shin_241ce3e1:

    # "With a beer in each hand,\nTatsu-nii raises them for a toast."
    # [旧版翻译] 来源: オープニング.ks
    "随着辰兄举起啤酒，其他人也拿起自己的杯子，彼此干杯。{p}深君也低调地举起了蜜瓜苏打。"
# game/Welcome Party.rpy:2324

translate chinese_simplified sit_with_shin_ada30ca9:

    # "Shin-kun is a little more conservative.{p}He raises his melon soda."
    # [旧版翻译] 来源: オープニング.ks
    "深君则比较低调。{p}他举起了蜜瓜苏打。"
# game/Welcome Party.rpy:2328

translate chinese_simplified sit_with_shin_0b507983:

    # ta "「Glug, glug, bwah!」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「咕嗯咕嗯，呼嘎！」"

# game/Welcome Party.rpy:2329

translate chinese_simplified sit_with_shin_1b4f1e41:

    # "Right after the toast,\nTatsu-nii chugs down both his drinks."
    # [旧版翻译] 来源: オープニング.ks
    "干杯之后，辰兄一口气喝光了两杯酒。"
# game/Welcome Party.rpy:2333

translate chinese_simplified sit_with_shin_288f8ca6:

    # ta "「[fn], hurry up and eat!{p} There's no need to hold back!」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「[博行]也快吃啊！{p} \\ 不要客气。」"

# game/Welcome Party.rpy:2334

translate chinese_simplified sit_with_shin_cd78866c:

    # fn "「Yeah, I will.」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「嗯，好的。」"

# game/Welcome Party.rpy:2338

translate chinese_simplified sit_with_shin_c8f44083:

    # "While holding his alcohol with vigor,\nTatsu-nii throws some meat onto his plate."
    # [旧版翻译] 来源: オープニング.ks
    "辰兄借着酒劲，兴奋地把肉也分铺到了铁板上。"
# game/Welcome Party.rpy:2339

translate chinese_simplified sit_with_shin_5be53839:

    # "The sizzle of cooking meat,\nand the smell of it as well,\ncarries itself throughout the restaurant."
    # [旧版翻译] 来源: オープニング.ks
    "一瞬间，烤肉的声音和味道，在店中扩散开来。"
# game/Welcome Party.rpy:2340

translate chinese_simplified sit_with_shin_08146a58:

    # "Tatsu-nii grabs lumps of meat,\nwhile Shin-kun neatly takes pieces,\none by one."
    # [旧版翻译] 来源: オープニング.ks
    "身边的深君把辰兄摆在上面的肉，一片片地分散排列开来。"
# game/Welcome Party.rpy:2341

translate chinese_simplified sit_with_shin_6f3a90b8:

    # "Enchanted by the smell and sound,\nmy stomach is already begging for some.{p}I decide to go for it."
    # [旧版翻译] 来源: オープニング.ks
    "被肉的香味引诱起来，{p}我的肚子似乎一下子变得饿了起来。"
# game/Welcome Party.rpy:2345

translate chinese_simplified sit_with_shin_59e81ee5:

    # si "「Wait, it hasn't cooked yet.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「那些，还没烤好。」"

# game/Welcome Party.rpy:2346

translate chinese_simplified sit_with_shin_b5ad05af:

    # fn "「Huh?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「咦？」"

# game/Welcome Party.rpy:2347

translate chinese_simplified sit_with_shin_85293073:

    # si "「I turned it over a little bit ago.{p} This way it will cook slowly.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「因为我才刚给翻过来。{p} \\ 这边这些才是差不多烤好的。」"

# game/Welcome Party.rpy:2348

translate chinese_simplified sit_with_shin_575afd8d:

    # fn "「Th-thanks.」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「呀，谢谢」"

# game/Welcome Party.rpy:2349

translate chinese_simplified sit_with_shin_2175c87c:

    # "He points to the meat as he explains.{p}It certainly is going to be cooked well,\nbut half my life will be gone before that."
    # [旧版翻译] 来源: オープニング.ks
    "他指着肉解释着。{p}确实烤得相当不错了，{p}但对我来说，五成熟便好了。"
# game/Welcome Party.rpy:2350

translate chinese_simplified sit_with_shin_346165a9:

    # si "「Half a lifetime isn't good for digestion.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「五成熟对消化不好」"

# game/Welcome Party.rpy:2351

translate chinese_simplified sit_with_shin_88b88ef8:

    # "Shin-kun adds,\nas if he heard what I was saying in my head."
    # [旧版翻译] 来源: オープニング.ks
