    su ""

# game/Welcome Party.rpy:2825
translate chinese_simplified sit_with_torahiko_5aaefe95:

    # to "「Yeah, the grub grub grill...{p} \ The grab grub grade...{p} \ {nw}"
    # KS:4635 无直接对应，直译
    to "「是呢，烤肉烤肉……{p} \ 抢肉烤肉……{p} \ {nw}"

# game/Welcome Party.rpy:2827
