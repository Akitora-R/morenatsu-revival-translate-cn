# game/Welcome Party.rpy:1797

translate chinese_simplified sit_with_juuichi_fd56bb88:

    # "Back then,\nthey would get in fights all the time.{p}It looks like that hasn't changed."
    # [旧版翻译] 来源: オープニング.ks
