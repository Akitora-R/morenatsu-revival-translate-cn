# game/Welcome Party.rpy:2357

translate chinese_simplified sit_with_shin_5cbb5b9c:

    # si "「I will.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「吃」"

# game/Welcome Party.rpy:2358

translate chinese_simplified sit_with_shin_df0fdc1d:

    # "Although he says that,\nShin-kun has just been poking around with his food.{p}I haven't been able to get a plate for myself."
    # [旧版翻译] 来源: オープニング.ks
    "虽然他这样说，{p}但是从刚才开始深君就一直只是在排列肉和菜而已，{p}完全没有把它们夹来自己吃的意思。"
# game/Welcome Party.rpy:2359

translate chinese_simplified sit_with_shin_505bbe02:

    # fn "「But it's been so long.」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「不过，从刚才开始就一直……」"

# game/Welcome Party.rpy:2360

translate chinese_simplified sit_with_shin_7c753d53:

    # si "「Hm? Oh.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「嗯？ 啊——」"

# game/Welcome Party.rpy:2361

translate chinese_simplified sit_with_shin_26768997:

    # "Without much reaction,\nShin-kun shifts from arranging his food to eating it.{p}Maybe he's still mad at me?"
    # [旧版翻译] 来源: オープニング.ks
    "也根本没有什么反应，{p}深君继续排着肉。{p}完全不考虑自己的碟子。"
# game/Welcome Party.rpy:2362

translate chinese_simplified sit_with_shin_cda07b0f:

    # si "「Is something wrong?{p} It looks like you stopped moving your chopsticks.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「怎么了？{p} \\ 你怎么不吃了。」"

# game/Welcome Party.rpy:2363

translate chinese_simplified sit_with_shin_e4833b4d:

    # fn "「N-no, it's nothing...」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「不、不，没什么……」"

# game/Welcome Party.rpy:2364

translate chinese_simplified sit_with_shin_7221e9d1:

    # "I-I don't understand.{p}I really have no idea what he's thinking.{p}Is he not angry...?"
    # [旧版翻译] 来源: オープニング.ks
    "完全……搞不懂。{p}完全搞不懂他在想什么。{p}不是在生气么……？"
# game/Welcome Party.rpy:2368

translate chinese_simplified sit_with_shin_bccf14e5:

    # ta "「Heeey, you!{p} Are you eating right?」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「喂，那边的。{p} \\ 有好好的吃么——」"

# game/Welcome Party.rpy:2369

translate chinese_simplified sit_with_shin_1f690123:

    # si "「Eh, err. Well...」"
    # [旧版翻译] 来源: オープニング.ks
    si "「诶，唉唉。{p} \\ 嘛」"

# game/Welcome Party.rpy:2373

translate chinese_simplified sit_with_shin_367e4dd9:

    # ta "「Hmm, w-what's the matter Shin?{p} You've been w-waiting so long for...{p} [fn] to be at y-your side,」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「嗯嗯，这样可不行啊，深。{p} \\ 难得他在你身边，可不能这么阴沉沉的。」"

# game/Welcome Party.rpy:2374

translate chinese_simplified sit_with_shin_4b7a381e:

    # ta "「but you still look down.」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「而且你这家伙，又——偏食了。{p} \\ 这可不行～～呐，什么都要多多地吃才对！」"
# game/Welcome Party.rpy:2376

translate chinese_simplified sit_with_shin_7db70b81:

    # si "「It's nothing, this is how I usually am.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「没有，我很平常。」"

# game/Welcome Party.rpy:2380

translate chinese_simplified sit_with_shin_6eb90f91:

    # ta "「I know you can be picky.{p} Go on. M-make sure you're eating right,\n and as much as y-ya can, too!」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「而且你这家伙，又——偏食了。{p} \\ 这可不行～～呐，什么都要多多地吃才对！」"

# game/Welcome Party.rpy:2381

translate chinese_simplified sit_with_shin_42c64b7a:

    # si "「Ah!?」"
    # [旧版翻译] 来源: オープニング.ks
    si "「啊！？」"

# game/Welcome Party.rpy:2385

translate chinese_simplified sit_with_shin_41aa6c16:

    # ta "「[fn], you should eat more v-veggies, too!{p} If you only e-eat meat you'll get fat.」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「你也多吃一些蔬菜！{p} \\ 光吃肉的话，可是会变胖的。」"

# game/Welcome Party.rpy:2386

translate chinese_simplified sit_with_shin_f12f230d:

    # "While saying that,\nTatsu-nii fills up my plate with veggies."
    # [旧版翻译] 来源: オープニング.ks
    "辰兄一边这样说，一边不由分说地夹了一堆蔬菜到我的盘子里。"
# game/Welcome Party.rpy:2390

translate chinese_simplified sit_with_shin_83d0121f:

    # ta "「Hey, little kids!{p} Are you eating right?」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「喂～。{p} \\ 小伙子们～。{p} \\ 有好好地吃东西吗～」"

# game/Welcome Party.rpy:2391

translate chinese_simplified sit_with_shin_d83eb17c:

    # su "「Yes, I am.」"
    # [旧版翻译] 来源: オープニング.ks
    su "「是——的～」"

# game/Welcome Party.rpy:2392

translate chinese_simplified sit_with_shin_a03799d5:

    # ta "「You're not eating anything at all are you?{p} You're not g-going to grow at this rate!」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「我看完全就没有吃啊～。{p} \\ 就是因为这样，所以才一直长不大哦～」"

# game/Welcome Party.rpy:2393

translate chinese_simplified sit_with_shin_5e15258f:

    # su "「Whawhawhawha!?{p} I-I can't eat that much!」"
    # [旧版翻译] 来源: オープニング.ks
    su "「哈啊啊啊啊——！？{p} \\ 那、那么多根本吃不完啦——！」"

# game/Welcome Party.rpy:2394

translate chinese_simplified sit_with_shin_1d0c9301:

    # so "「M-Midoriya-senpai!{p} There's no way I could eat all that!」"
    # [旧版翻译] 来源: オープニング.ks
    so "「翠、翠屋前辈！{p} \\ 是不是有点儿太多了！」"

# game/Welcome Party.rpy:2395

translate chinese_simplified sit_with_shin_011631a2:

    # "H-he's completely drunk...{p}And keeps finding little games to get involved in."
    # [旧版翻译] 来源: オープニング.ks
    "完全喝高了吧，辰兄。{p}他又抓到新的「猎物」，然后纠缠不休起来。"
# game/Welcome Party.rpy:2396

translate chinese_simplified sit_with_shin_99acee6b:

    # "With a bitter smile on my face,\nI return to eating for the second time."
    # [旧版翻译] 来源: オープニング.ks
    "对于这种情景，一边苦笑着一边准备接着吃，{p}但是面对自己碟子里堆积如山的蔬菜，又不知道该如何是好。"
# game/Welcome Party.rpy:2397

translate chinese_simplified sit_with_shin_55291c9b:

    # "I can use my chopsticks again,\nnow that he stopped using them to get food."
    # [旧版翻译] 来源: オープニング.ks
    "肉已经放不进来了，{p}这些菜还不能放回去……。"
# game/Welcome Party.rpy:2398

translate chinese_simplified sit_with_shin_a5991ca1:

    # "I can't get to the meat like this.{p}Still, I don't want to return it..."
    # [旧版翻译] 来源: オープニング.ks
    "肉已经放不进来了，{p}这些菜还不能放回去……。"
# game/Welcome Party.rpy:2399

translate chinese_simplified sit_with_shin_6b1fa90d:

    # si "「[fn], wait.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「博行，来一下」"

# game/Welcome Party.rpy:2400

translate chinese_simplified sit_with_shin_465703d0:

    # "I think about asking someone for help,\nbut Shin-kun speaks out."
    # [旧版翻译] 来源: オープニング.ks
    "正考虑要不要向别人求助，{p}深君的声音响起来。"
# game/Welcome Party.rpy:2401

translate chinese_simplified sit_with_shin_ac35754f:

    # fn "「What's the matter?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「怎么了？」"

# game/Welcome Party.rpy:2402

translate chinese_simplified sit_with_shin_d19f18b2:

    # si "「...You can have my meat.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「……这些肉，可以帮我吃掉么？」"

# game/Welcome Party.rpy:2403

translate chinese_simplified sit_with_shin_5e2691a4:

    # fn "「Huh? Th-thanks, but why?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「诶？{p} \\ 倒是可以……不过，为什么？」"

# game/Welcome Party.rpy:2404

translate chinese_simplified sit_with_shin_f2349218:

    # "Shin-kun holds out his plate.{p}There's a sharp contrast between\nthe amount of meat on our plates."
    # [旧版翻译] 来源: オープニング.ks
    "深君递过来的碟子与我的形成了鲜明的对比，{p}堆满了肉。"
# game/Welcome Party.rpy:2405

translate chinese_simplified sit_with_shin_92d10248:

    # si "「I don't like beef.{p} It's too greasy...」"
    # [旧版翻译] 来源: オープニング.ks
    si "「牛肉は、苦手なんだ。{p} \\ 脂っこくて……」"

# game/Welcome Party.rpy:2406

translate chinese_simplified sit_with_shin_eac434a6:

    # "With him and his high class ways,\nI was expecting something like,"
    # [旧版翻译] 来源: オープニング.ks
    "本来还以为会说「便宜肉好难吃」之类的话呢，{p}没想到却是比想象要普通得多的这样一个回答。"
# game/Welcome Party.rpy:2407

translate chinese_simplified sit_with_shin_38d8158f:

    # "\"This cheap meat isn't suitable for me.\"{p}But his answer was surprisingly... Normal."
    # [旧版翻译] 来源: オープニング.ks
    "「这便宜肉我可吃不惯」之类的话呢，{p}没想到得到的回答却是意外地普通……。"
# game/Welcome Party.rpy:2408

translate chinese_simplified sit_with_shin_086db145:

    # "Come to think of it,\nShin-kun was eating meat a little bit ago."
    # [旧版翻译] 来源: オープニング.ks
    "说起来，从刚才开始，深君拿的肉貌似都是鸡肉呢，{p}难道和辰兄一样，有健康饮食的习惯？"
# game/Welcome Party.rpy:2409

translate chinese_simplified sit_with_shin_eb21e291:

    # "It was chicken, though.{p}Does he have the same nutritious, healthy,\neating habits as Tatsu-nii?"
    # [旧版翻译] 来源: オープニング.ks
    "说起来，从刚才开始，深君拿的肉貌似都是鸡肉呢。{p}难道和辰兄一样，有健康饮食的习惯？"
# game/Welcome Party.rpy:2410

translate chinese_simplified sit_with_shin_d5a8df60:

    # fn "「Would you like to switch with mine?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「啊，那么的话，我也拜托你一件事可以么？」"

# game/Welcome Party.rpy:2411

translate chinese_simplified sit_with_shin_f4393ae5:

    # si "「It doesn't matter.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「不介意。」"

# game/Welcome Party.rpy:2412

translate chinese_simplified sit_with_shin_1c6759e0:

    # "Yes!{p}Now that Tatsu-nii is bothering Torahiko,\nwe secretly swap plates."
    # [旧版翻译] 来源: オープニング.ks
    "太好了！{p}辰兄正在纠缠着那边的虎彦，{p}趁他没注意这边，偷偷地把碟子交换吧。"
# game/Welcome Party.rpy:2413

translate chinese_simplified sit_with_shin_64602ba5:

    # "It's yakiniku, so of course there should be meat.{p}But was forcing all of that on him... Rude?"
    # [旧版翻译] 来源: オープニング.ks
    "既然是烤肉，那就当然要多吃肉才行。{p}不过把蔬菜全给了深君……不会有点儿亏待他了吧？"
# game/Welcome Party.rpy:2414

translate chinese_simplified sit_with_shin_7fc83ff9:

    # "I check my thoughts with Shin-kun,\nbut he's already shoveling them into his mouth,\none after another."
    # [旧版翻译] 来源: オープニング.ks
    "一边这样想着，一边不安地望向深君，{p}看着他不断把蔬菜送到口中的侧脸，{p}似乎露出一种难以名状的高兴的模样。"
# game/Welcome Party.rpy:2415

translate chinese_simplified sit_with_shin_3bb4b5c4:

    # "I think he's almost smiling."
    # [旧版翻译] 来源: オープニング.ks
    "似乎露出一种难以名状的高兴的模样。"
# game/Welcome Party.rpy:2419

translate chinese_simplified sit_with_shin_030e4a68:

    # si "「Ah, onion...」"
    # [旧版翻译] 来源: オープニング.ks
    si "「啊，洋葱……」"

# game/Welcome Party.rpy:2420

translate chinese_simplified sit_with_shin_71d32d06:

    # "He stops his chopsticks.{p}The way he whispers to himself is... Funny."
    # [旧版翻译] 来源: オープニング.ks
    "筷子突然停了下来，{p}轻声地说了这么一句，样子变得好生奇怪。"
# game/Welcome Party.rpy:2434

translate chinese_simplified sit_with_kounosuke_f374b184:

    # fn "「Kounosuke, is here all right?」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「孝之助，坐这里可以吗？」"

# game/Welcome Party.rpy:2438

translate chinese_simplified sit_with_kounosuke_ef398cf2:

    # ko "「Go ahead, go ahead.」"
    # [旧版翻译] 来源: オープニング.ks
    ko "「请坐请坐～」"

# game/Welcome Party.rpy:2439

translate chinese_simplified sit_with_kounosuke_b0fb96b3:

    # "Even though he says that,\nhe's stuffed in there."
    # [旧版翻译] 来源: オープニング.ks
    "一边这样说着，孝之助一边向里面挤去。"
# game/Welcome Party.rpy:2443

translate chinese_simplified sit_with_kounosuke_b78ac705:

    # ju "「Kounosuke, there's not enough room.」"
    # [旧版翻译] 来源: オープニング.ks
    ju "「孝之助，挤死了。」"

# game/Welcome Party.rpy:2447

translate chinese_simplified sit_with_kounosuke_b7f5a8df:

    # ko "「Ah, sorry.」"
    # [旧版翻译] 来源: オープニング.ks
    ko "「啊，抱歉。」"

# game/Welcome Party.rpy:2451

translate chinese_simplified sit_with_kounosuke_2ffc2275:

    # to "「Why are you going over there?」"
    # [旧版翻译] 来源: オープニング.ks
    to "「为啥坐在那边啊？！」"

# game/Welcome Party.rpy:2452

translate chinese_simplified sit_with_kounosuke_76e54dbd:

    # fn "「Well, it looked like there was space...」"
    # [旧版翻译] 来源: オープニング.ks
    fn "「也没啥，就是看这边有空位……」"

# game/Welcome Party.rpy:2453

translate chinese_simplified sit_with_kounosuke_7a1ea16d:

    # to "「If it wasn't so packed there would be.」"
    # [旧版翻译] 来源: オープニング.ks
    to "「坐在我这边然后反过来往那边挤挤的话，也可以有空位的。」"

# game/Welcome Party.rpy:2457

translate chinese_simplified sit_with_kounosuke_e211da26:

    # ko "「You're being bossy, Torahiko.{p} He can sit wherever he wants,\n it's not a big deal.」"
    # [旧版翻译] 来源: オープニング.ks
    ko "「真的是，虎彦你好吵啊。{p} \\ 这种事情怎样都无所谓吧，他喜欢坐哪就坐哪。」"

# game/Welcome Party.rpy:2458

translate chinese_simplified sit_with_kounosuke_9afeb3cb:

    # to "「Well yeah, but...」"
    # [旧版翻译] 来源: オープニング.ks
    to "「嘛，话倒是这么说……」"

# game/Welcome Party.rpy:2459

translate chinese_simplified sit_with_kounosuke_1b1c2239:

    # "Now that I think about it,\nTorahiko did say he wanted to sit next to me,\nwhen he greeted me."
    # [旧版翻译] 来源: オープニング.ks
    "这么说来，刚才虎彦好像有邀请我去他那边坐来的。{p}而且在车站接我的人也是他，{p}一定是非常期待与我的见面吧？"
# game/Welcome Party.rpy:2460

translate chinese_simplified sit_with_kounosuke_2e699aed:

    # "I guess he was really excited to see me..."
    # [旧版翻译] 来源: オープニング.ks
    "如果真是这样的话，那还真是对不起他了。"
# game/Welcome Party.rpy:2461

translate chinese_simplified sit_with_kounosuke_7c336b3f:

    # "If that's the case, sorry Torahiko."
    # [旧版翻译] 来源: オープニング.ks
    "如果真是这样的话，那还真是对不起他了。"
# game/Welcome Party.rpy:2466

translate chinese_simplified sit_with_kounosuke_254db603:

    # ko "「By the way, [fn]...」"
    # [旧版翻译] 来源: オープニング.ks
    ko "「话说哦，[博行]」"

# game/Welcome Party.rpy:2467

translate chinese_simplified sit_with_kounosuke_8f4993b4:

    # "Here it comes, I'm prepared for this.{p}That's why I sat here.{p}The assault of questions begins."
    # [旧版翻译] 来源: オープニング.ks
    "来了。{p}早就有了这样的心理准备……{p}或者可以说，正是为了这个目的才选择坐在这里，{p}为了迎击孝之助的问题大轰炸。"
# game/Welcome Party.rpy:2468

translate chinese_simplified sit_with_kounosuke_5caff36e:

