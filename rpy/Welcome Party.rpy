# game/Welcome Party.rpy:1750

translate chinese_simplified sit_with_kyoutarou_c260481c:

    # "I hate to say it but,\nthanks to Tatsu-nii,\nthe distance between Soutarou and I has shortened."
    # [旧版翻译] 来源: オープニング.ks
