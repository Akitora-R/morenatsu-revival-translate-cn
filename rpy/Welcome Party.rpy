# game/Welcome Party.rpy:1889

translate chinese_simplified sit_with_juuichi_f1e8bf83:

    # su "「Uh, umm...{p} Torahiko-san is still...」"
    # [旧版翻译] 来源: オープニング.ks
    su "「那个……{p} \\ 虎虎先生他还……」"

# game/Welcome Party.rpy:1890

translate chinese_simplified sit_with_juuichi_7a6a6ff3:

    # "Shun-kun timidly points at Torahiko."
    # [旧版翻译] 来源: オープニング.ks
    "小瞬怯生生地指着虎虎。"
# game/Welcome Party.rpy:1894

translate chinese_simplified sit_with_juuichi_4e1fcc91:

    # si "「You'll have to wait until sunset before he recovers.」"
    # [旧版翻译] 来源: オープニング.ks
    si "「你得等到太阳下山他才能恢复。」"

# game/Welcome Party.rpy:1898

translate chinese_simplified sit_with_juuichi_074ad1d5:

    # ta "「Leave him alone for now.{p} He'll be up and running again soon enough.」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「先别管他了。{p} \\ 他很快就会恢复活力的。」"

# game/Welcome Party.rpy:1902

translate chinese_simplified sit_with_juuichi_700f1d0e:

    # su "「Hmmm...{p} will he really be all right?」"
    # [旧版翻译] 来源: オープニング.ks
    su "「嗯……{p} \\ 他真的会没事吗？」"

# game/Welcome Party.rpy:1903

translate chinese_simplified sit_with_juuichi_7017e8b0:

    # "Even after hearing their reassurances,\nShun-kun turns his head in doubt."
    # [旧版翻译] 来源: オープニング.ks
