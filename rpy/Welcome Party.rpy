# game/Welcome Party.rpy:1869

translate chinese_simplified sit_with_juuichi_1d1e8f0f:

    # ta "「Ah, ahem.」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「啊，咳咳。」"

# game/Welcome Party.rpy:1870

translate chinese_simplified sit_with_juuichi_1b77e4e7:

