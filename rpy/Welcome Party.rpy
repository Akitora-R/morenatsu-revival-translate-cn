    "只是这样应答一句，深君又继续开始他的排肉工作了。"
# game/Welcome Party.rpy:2356

translate chinese_simplified sit_with_shin_b918a582:

    # fn "「Are you going to eat?」"
    # [旧版翻译] 来源: オープニング.ks
