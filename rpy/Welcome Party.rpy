# game/Welcome Party.rpy:1796

translate chinese_simplified sit_with_juuichi_03f80979:

    # "With a clack of his chair,{p}Torahiko stands up too.{p}Sparks silently fly between them."
    # [旧版翻译] 来源: オープニング.ks
