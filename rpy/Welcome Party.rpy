    # NOTE: ks无对应，直译
    "虎彦把他绑得死死的，{p}辰兄只能扭来扭去。"

# game/Welcome Party.rpy:1147
translate chinese_simplified sit_with_tatsuki_2320e10c:

    # "That rope won't be coming off right now."
    # NOTE: ks无对应，直译
    "那绳子一时半会儿是解不开了。"

# game/Welcome Party.rpy:1153
translate chinese_simplified sit_with_tatsuki_c8318e9b:

    # to "「There, that's good. 」"
    # NOTE: ks无对应，直译
    to "「好了，这样就行了。」"

# game/Welcome Party.rpy:1154
translate chinese_simplified sit_with_tatsuki_7dcaee2a:

    # "Wait, what? Why is he naked?"
    # NOTE: ks无对应，直译
    "等等，什么？他怎么脱光了？"

# game/Welcome Party.rpy:1160
translate chinese_simplified sit_with_tatsuki_72131f52:

    # ju "「I'll take it from here. 」"
    # NOTE: ks无对应，直译
    ju "「接下来交给我吧。」"

# game/Welcome Party.rpy:1161
translate chinese_simplified sit_with_tatsuki_5072a868:

    # "Juuichi-san winds the rope around Tatsu-nii.{p}He puts him inside a bag,\nand carries him outside over his shoulder."
    # NOTE: ks无对应，直译
    "柔一用绳子把辰兄捆好。{p}把他塞进一个袋子里，{p}扛在肩上带了出去。"

# game/Welcome Party.rpy:1167
translate chinese_simplified sit_with_tatsuki_7cdb25fb:

    # fn "「Err... will he be okay? 」"
    # NOTE: ks无对应，直译
    fn "「呃……他没事吧？」

# game/Welcome Party.rpy:1171
translate chinese_simplified sit_with_tatsuki_7e1ef6d8:

    # ko "「Don't worry, happens all the time. 」"
    # NOTE: ks无对应，直译
    ko "「别担心，经常这样的。」"

# game/Welcome Party.rpy:1175
translate chinese_simplified sit_with_tatsuki_397aeed8:

    # ka "「Give him 10 minutes and the alcohol will pass.{p} \ The party must go on. 」"
    # NOTE: ks无对应，直译
    ka "「给他十分钟，酒劲就过去了。{p}派对还得继续呢。」"

# game/Welcome Party.rpy:1179
translate chinese_simplified sit_with_tatsuki_d4858347:

    # to "「He's a bit of an alcoholic.{p} \ Also, when he's driving,\n \ be careful when you're riding with him. 」"
    # NOTE: ks无对应，直译
    to "「他有点贪杯。{p}还有，要是他开车的话，{p}坐他的车要小心点。」"

# game/Welcome Party.rpy:1180
translate chinese_simplified sit_with_tatsuki_515e5f7b:

    # "I'll keep that in mind..."
    # NOTE: ks无对应，直译
    "我会记住的……"

# game/Welcome Party.rpy:1181
translate chinese_simplified sit_with_tatsuki_91b577af:

    # "Wait. Isn't Tatsu-nii the oldest of us?"
    # NOTE: ks无对应，直译
    "等等。辰兄不是我们中年纪最大的吗？"

# game/Welcome Party.rpy:1185
translate chinese_simplified sit_with_tatsuki_3d676491:

    # ky "「Come on, we're in the middle of a meal.{p} \ You should eat something, too. 」"
    # NOTE: ks无对应，直译
    ky "「好啦，我们正吃着饭呢。{p}你也该吃点东西。」"

# game/Welcome Party.rpy:1189
translate chinese_simplified sit_with_tatsuki_e14acd5f:

    # ka "「Old man, no more alcohol without asking, okay? 」"
    # NOTE: ks无对应，直译
    ka "「大叔，以后没问过就别给酒了，行吗？」"

# game/Welcome Party.rpy:1190
translate chinese_simplified sit_with_tatsuki_a57b6f4f:

    # om "「I hear ya! 」"
    # NOTE: ks无对应，直译
    om "「知道了！」"

# game/Welcome Party.rpy:1191
translate chinese_simplified sit_with_tatsuki_7b2db7e7:

    # "This happens all the time?\nEveryone was so nonchalant about it..."
    # NOTE: ks无对应，直译
    "这种事经常发生？{p}大家居然都这么淡定……"

# game/Welcome Party.rpy:1197
translate chinese_simplified sit_with_tatsuki_18ee30f0:

    # to "「Hey, [fn]. You gonna eat that?{p} \ Or can I have it? 」"
    # NOTE: ks无对应，直译
    to "「喂，[fn]。那个你还吃吗？{p}不吃给我吧？」

# game/Welcome Party.rpy:1198
translate chinese_simplified sit_with_tatsuki_44cc74fd:

    # fn "「Hold on, I'm eating, I'm eating. 」"
    # NOTE: ks无对应，直译
    fn "「等等，我在吃，我在吃。」"

# game/Welcome Party.rpy:1199
translate chinese_simplified sit_with_tatsuki_9b02b42f:

    # "Mmm, it's good.\nI'll just eat more meat."
    # NOTE: ks无对应，直译
    "嗯，真好吃。{p}再多吃点肉吧。"

# game/Welcome Party.rpy:1214
translate chinese_simplified sit_with_kouya_5e3387dd:

    # "When I look around,\nI see an open spot next to Kouya."
    # NOTE: ks无对应，直译
    "[fn]环顾四周，{p}发现洸哉旁边有个空位。"

# game/Welcome Party.rpy:1215
translate chinese_simplified sit_with_kouya_43d27545:

    # "I wanted to talk to him,\nso I'll sit there."
    # NOTE: ks无对应，直译
    "[fn]想和他聊聊，{p}于是决定坐在那里。"

# game/Welcome Party.rpy:1216
translate chinese_simplified sit_with_kouya_f963f928:

    # fn "「Is it all right if I sit here? 」"
    # NOTE: ks无对应，直译
    fn "「我可以坐这里吗？」"

# game/Welcome Party.rpy:1220
translate chinese_simplified sit_with_kouya_d7497b6f:

    # ka "「Oh, go ahead. 」"
    # NOTE: ks无对应，直译
    ka "「哦，请坐。」"

# game/Welcome Party.rpy:1221
translate chinese_simplified sit_with_kouya_8a654085:

    # fn "「Thanks. Excuse me... 」"
    # NOTE: ks无对应，直译
    fn "「谢谢，打扰了……」"

# game/Welcome Party.rpy:1222
translate chinese_simplified sit_with_kouya_1b0e1842:

    # "I lower my waist to sit down,\nwhile I'm doing that however,\nI can hear Torahiko's voice."
    # NOTE: ks无对应，直译
    "[fn]正要坐下，{p}却听到了虎彦的声音。"

# game/Welcome Party.rpy:1229
translate chinese_simplified sit_with_kouya_5f6dbd2e:

    # to "「[fn], what are you doing?{p} \ Next to Kouya? 」"
    # NOTE: ks无对应，直译
    to "「[fn]，你在干嘛？{p}坐在洸哉旁边？」

# game/Welcome Party.rpy:1230
translate chinese_simplified sit_with_kouya_cf631d3f:

    # fn "「Huh? Do you have a problem? 」"
    # NOTE: ks无对应，直译
    fn "「嗯？有什么问题吗？」"

# game/Welcome Party.rpy:1234
translate chinese_simplified sit_with_kouya_ad4386d4:

    # to "「No... nothing in particular... 」"
    # NOTE: ks无对应，直译
    to "「没……没什么特别的……」"

# game/Welcome Party.rpy:1238
translate chinese_simplified sit_with_kouya_f028c901:

    # ka "「What, are you jealous? 」"
    # NOTE: ks无对应，直译
    ka "「怎么，吃醋了？」"

# game/Welcome Party.rpy:1239
translate chinese_simplified sit_with_kouya_d7145f85:

    # "Kouya mocks him with a faint sneer.{p}Torahiko struggles to find his words,\nand his face turns a little red."
    # NOTE: ks无对应，直译
    "洸哉带着一丝冷笑嘲弄着他。{p}虎彦一时语塞，{p}脸微微泛红。"

# game/Welcome Party.rpy:1243
translate chinese_simplified sit_with_kouya_0006b2e9:

    # to "「Oh...{p} \ i-it's not like that! 」"
    # NOTE: ks无对应，直译
    to "「哦……{p}才、才不是那样呢！」"

# game/Welcome Party.rpy:1247
translate chinese_simplified sit_with_kouya_b7151484:

    # ju "「What are you so upset about, Tora?{p} \ Next to me is fine. 」"
    # NOTE: ks无对应，直译
    ju "「虎，你生什么气啊？{p}坐我旁边不也挺好。」"

# game/Welcome Party.rpy:1248
translate chinese_simplified sit_with_kouya_b7fe99de:

    # "As he says that,\nhe puts his hands on Torahiko's shoulders."
    # NOTE: ks无对应，直译
    "说着，{p}他把手搭在虎彦的肩膀上。"

# game/Welcome Party.rpy:1249
translate chinese_simplified sit_with_kouya_64924792:

    # "...Oh, that's why Torahiko said that.{p}He invited me to sit with him first.{p}Did I do something wrong?"
    # NOTE: ks无对应，直译
    "……哦，原来虎彦是这个意思。{p}他先邀请我坐他旁边的。{p}我是不是做错什么了？"

# game/Welcome Party.rpy:1253
translate chinese_simplified sit_with_kouya_aaa83275:

    # to "「Nah... it's never fun sitting with you,\n \ Juuichi-sanowowowowowow!! 」"
    # NOTE: ks无对应，直译
    to "「不……跟你坐一起从来没意思过，{p}柔一前辈哇哇哇哇哇！！」"

# game/Welcome Party.rpy:1254
translate chinese_simplified sit_with_kouya_5e6ea836:

    # to "「It just slipped outKAAAAAA!!{p} \ {nw}"
    # NOTE: ks无对应，直译
    to "「我不小心说漏嘴了卡啊啊啊！！{p}{nw}"

# game/Welcome Party.rpy:1256
translate chinese_simplified sit_with_kouya_f3d91ad4:

    # extend "Wait, I give up! Sorry! 」"
    # NOTE: ks无对应，直译
    extend "等等，我投降！对不起！」"

# game/Welcome Party.rpy:1260
translate chinese_simplified sit_with_kouya_3ff7c8bf:

    # "Torahiko's pained cries echo,\nlooks like Juuichi-san is tightening his grip."
    # NOTE: ks无对应，直译
    "虎彦痛苦的叫声回荡着，{p}看来柔一前辈正在收紧他的钳制。"

# game/Welcome Party.rpy:1261
translate chinese_simplified sit_with_kouya_ccb12bdb:

    # "His seat is a short distance away,\nbut I can see those fingers digging into him.{p}I can almost hear it..."
    # NOTE: ks无对应，直译
    "他的座位离得不远，{p}[fn]能看到那些手指深深陷进他的肉里。{p]几乎能听到声音……"

# game/Welcome Party.rpy:1262
translate chinese_simplified sit_with_kouya_dea7eecf:

    # "Juuichi-san did say he was still doing judo,\nthat must be where his grip is from.{p}All I can hear is Torahiko screaming..."
    # NOTE: ks无对应，直译
    "柔一前辈确实说过他还在练柔道，{p}这握力肯定就是练出来的。{p}[fn]只能听到虎彦的惨叫声……"

# game/Welcome Party.rpy:1263
translate chinese_simplified sit_with_kouya_7bf2c855:

    # "Ouch... watching is making me sore..."
    # NOTE: ks无对应，直译
    "哎哟……看着都觉得疼……"

# game/Welcome Party.rpy:1267
translate chinese_simplified sit_with_kouya_387cdcd8:

    # ju "「Don't know why you need to sit next to [fn],\n \ but don't say such heartless things.{p} \ {nw}"
    # NOTE: ks无对应，直译
    ju "「不知道你为什么非要坐[fn]旁边，{p}但别说这种无情的话。{p}{nw}"

# game/Welcome Party.rpy:1269
translate chinese_simplified sit_with_kouya_408f7f70:

    # extend "Now do you have a problem with me? 」"
    # NOTE: ks无对应，直译
    extend "现在你对我有意见吗？」"

# game/Welcome Party.rpy:1273
translate chinese_simplified sit_with_kouya_8e1265ba:

    # to "「No, n-not at all!\n \ I-in fact, I should be really thankful, r-right?! 」"
    # NOTE: ks无对应，直译
    to "「不，完全没有！{p}事、事实上，我应该很感激才对，对吧？！」"

# game/Welcome Party.rpy:1274
translate chinese_simplified sit_with_kouya_4e63b005:

    # ju "「Good. 」"
    # NOTE: ks无对应，直译
    ju "「很好。」"

# game/Welcome Party.rpy:1278
translate chinese_simplified sit_with_kouya_7c33b58e:

    # "Finally, Juuichi-san releases Torahiko."
    # NOTE: ks无对应，直译
    "终于，柔一前辈松开了虎彦。"

# game/Welcome Party.rpy:1282
translate chinese_simplified sit_with_kouya_d018b342:

    # to "「I-I thought my collarbone was gonna... 」"
    # NOTE: ks无对应，直译
    to "「我、我以为我的锁骨要断了……」"

# game/Welcome Party.rpy:1283
translate chinese_simplified sit_with_kouya_4b58ac89:

    # "Torahiko mumbles as he rubs his shoulders.{p}His face has gone from red to pale."
    # NOTE: ks无对应，直译
    "虎彦一边揉着肩膀一边嘟囔着。{p}他的脸从红色变成了苍白。"

# game/Welcome Party.rpy:1284
translate chinese_simplified sit_with_kouya_aa5ebaf8:

    # "What should I say...{p}sorry Torahiko."
    # NOTE: ks无对应，直译
    "我该说什么好……{p}对不起啊虎彦。"

# game/Welcome Party.rpy:1290
translate chinese_simplified sit_with_kouya_7a7b8feb:

    # ta "「Hey, playin' around is fine, but control it!{p} \ Let's start, [fn]'s returned!{p} \ {nw}"
    # NOTE: ks无对应，直译
    ta "「喂，玩闹可以，但要适可而止！{p}开始吧，[fn]回来了！{p}{nw}"

# game/Welcome Party.rpy:1292
translate chinese_simplified sit_with_kouya_5d0ddb0c:

    # extend "Pops! I wanna order something! 」"
    # NOTE: ks无对应，直译
    extend "大叔！我要点东西！」"

# game/Welcome Party.rpy:1293
translate chinese_simplified sit_with_kouya_dc2b6b33:

    # om "「Yeah, whaddya want?! 」"
    # NOTE: ks无对应，直译
    om "「好嘞，要什么？！」"

# game/Welcome Party.rpy:1297
translate chinese_simplified sit_with_kouya_077cbd6d:

    # "At the sound of Tatsu-nii's voice,\nthings got moving along."
    # NOTE: ks无对应，直译
    "听到辰兄的声音，{p}事情开始推进了。"

# game/Welcome Party.rpy:1298
translate chinese_simplified sit_with_kouya_fd89c82c:

    # "The old man comes out,\nand begins to take our orders.{p}I just ask for some oolong tea."
    # NOTE: ks无对应，直译
    "大叔走了出来，{p}开始点单。{p}[fn]只要了乌龙茶。"

# game/Welcome Party.rpy:1299
translate chinese_simplified sit_with_kouya_5194f8e1:

    # "I think it'd take a while for things to come,\nbut because we rented out the place,\nour drinks were brought to us immediately."
    # NOTE: ks无对应，直译
    "[fn]以为要等一会儿，{p}但因为包场了，{p}饮料马上就送来了。"

# game/Welcome Party.rpy:1300
translate chinese_simplified sit_with_kouya_48b826d2:

    # "The food, that is to say, the yakiniku,\nhas already been prepared.{p}It was brought out with the drinks."
    # NOTE: ks无对应，直译
    "食物，也就是烤肉，{p}已经准备好了。{p}和饮料一起端了上来。"

# game/Welcome Party.rpy:1301
translate chinese_simplified sit_with_kouya_96f7b362:

    # "And with that,\nthe preparations are complete.\nTorahiko stands to check things out."
    # NOTE: ks无对应，直译
    "就这样，{p}准备工作完成了。{p}虎彦站起来查看情况。"

# game/Welcome Party.rpy:1302
translate chinese_simplified sit_with_kouya_5da15413:

    # "Because his shoulders are still sore,\nhe gives a small grimace.{p}He seems to have recovered a bit."
    # NOTE: ks无对应，直译
    "因为肩膀还在痛，{p}他微微皱了下眉。{p}看起来恢复了一些。"

# game/Welcome Party.rpy:1303
translate chinese_simplified sit_with_kouya_a120bf11:

    # "It wasn't too serious,\nbut I'm still relieved."
    # NOTE: ks无对应，直译
    "虽然不是什么重伤，{p}但[fn]还是松了口气。"

# game/Welcome Party.rpy:1304
translate chinese_simplified sit_with_kouya_1bc088b6:

    # "He coughs once to clear his throat.\nThe noisy restaurant quiets down."
    # NOTE: ks无对应，直译
    "他咳了一声清清嗓子。{p}吵闹的餐厅安静了下来。"

# game/Welcome Party.rpy:1305
translate chinese_simplified sit_with_kouya_c6f7c4b2:

    # "At last, it's beginning."
    # NOTE: ks无对应，直译
    "终于，要开始了。"

# game/Welcome Party.rpy:1309
translate chinese_simplified sit_with_kouya_99c0731b:

    # to "「All right then,\n \ did everyone get a drink? 」"
    # NOTE: ks无对应，直译
    to "「好了，{p}大家都拿到饮料了吗？」"

# game/Welcome Party.rpy:1310
translate chinese_simplified sit_with_kouya_1ce32404:

    # "{size=+15}YEAH!"
    # NOTE: ks无对应，直译
    "{size=+15}有——！"

# game/Welcome Party.rpy:1314
translate chinese_simplified sit_with_kouya_8a958852:

    # to "「Good, good.{p} \ Let's get this party started! 」"
    # NOTE: ks无对应，直译
    to "「好，好。{p}让我们开始派对吧！」"

# game/Welcome Party.rpy:1318
translate chinese_simplified sit_with_kouya_449734e0:

    # to "「After five years,\n \ let's pick up right where we left off.{p} \ Let's have fun, everybody! 」"
    # NOTE: ks无对应，直译
    to "「五年了，{p}让我们接着五年前的地方继续吧。{p}大家玩得开心！」"

# game/Welcome Party.rpy:1324
translate chinese_simplified sit_with_kouya_8ca309b7:

    # ta "「Tora, stop talking already! 」"
    # NOTE: ks无对应，直译
    ta "「虎，别说了快开始吧！」"

# game/Welcome Party.rpy:1328
translate chinese_simplified sit_with_kouya_5462b07f:

    # "{size=+15}「Hahahahaha! 」"
    # NOTE: ks无对应，直译
    "{size=+15}「哈哈哈哈！」"

# game/Welcome Party.rpy:1329
translate chinese_simplified sit_with_kouya_ea451325:

    # "Tatsu-nii causes everybody to laugh.{p}Even Torahiko gives an embarrassed giggle."
    # NOTE: ks无对应，直译
    "辰兄逗得大家哈哈大笑。{p}连虎彦都不好意思地笑了。"

# game/Welcome Party.rpy:1330
translate chinese_simplified sit_with_kouya_73500dc7:

    # "I have to say, I missed this atmosphere."
    # NOTE: ks无对应，直译
    "不得不说，[fn]很怀念这种气氛。"

# game/Welcome Party.rpy:1336
translate chinese_simplified sit_with_kouya_470187da:

    # to "「Shut up!{p} \ I don't have anything else to say.{p} \ Just get started already! 」"
    # NOTE: ks无对应，直译
    to "「闭嘴！{p}我没什么好说的了。{p}赶紧开始吧！」"

# game/Welcome Party.rpy:1340
translate chinese_simplified sit_with_kouya_629a4ee7:

    # to "「Ahem, but first,\n \ I think it'd be nice to hear a greeting. 」"
    # NOTE: ks无对应，直译
    to "「咳咳，不过首先，{p}我觉得应该先听个问候。」"

# game/Welcome Party.rpy:1341
translate chinese_simplified sit_with_kouya_ffae0518:

    # to "「A greeting from our honored guest,\n \ [fn]! 」"
    # NOTE: ks无对应，直译
    to "「那么，来自贵客[fn]的问候！」

# game/Welcome Party.rpy:1345
translate chinese_simplified sit_with_kouya_2754553c:

    # to "「So then, [fn].{p} \ I ask you to make the toast!{p} \ I'm leaving it to you! 」"
    # NOTE: ks无对应，直译
    to "「那么，[fn]。{p}请你来致祝酒词！{p}就交给你了！」"

# game/Welcome Party.rpy:1346
translate chinese_simplified sit_with_kouya_676308b3:

    # fn "「Whaaaa?! 」"
    # NOTE: ks无对应，直译
    fn "「诶——！？」

# game/Welcome Party.rpy:1347
translate chinese_simplified sit_with_kouya_dfc5a07e:

    # "I didn't see this coming.{p}Did I hear him correctly?!"
    # NOTE: ks无对应，直译
    "这完全出乎意料。{p}我没听错吧？！"

# game/Welcome Party.rpy:1348
translate chinese_simplified sit_with_kouya_fb396f33:

    # "Still, everyone looks at me.{p}They turn in anticipation,\nexpecting me to say something."
    # NOTE: ks无对应，直译
    "尽管如此，大家都看着[fn]。{p}他们满怀期待地转过头，{p}等着[fn]说点什么。"

# game/Welcome Party.rpy:1349
translate chinese_simplified sit_with_kouya_43480b8a:

    # "Are...{p}Are they ganging up on me?"
    # NOTE: ks无对应，直译
    "难道……{p}他们是在联合起来整我吗？"

# game/Welcome Party.rpy:1350
translate chinese_simplified sit_with_kouya_a2884380:

    # fn "「U-umm... well... 」"
    # NOTE: ks无对应，直译
    fn "「呃……那个……」"

# game/Welcome Party.rpy:1351
translate chinese_simplified sit_with_kouya_47d515e0:

    # "I stand up in an attempt,\nto over come the pressure."
    # NOTE: ks无对应，直译
    "[fn]站起来，试图克服压力。"

# game/Welcome Party.rpy:1352
translate chinese_simplified sit_with_kouya_724e98ff:

    # "However, I suddenly struggle with my words.{p}We're all friends, but I'm still nervous."
    # NOTE: ks无对应，直译
    "然而，[fn]突然说不出话来。{p}虽然都是朋友，但还是很紧张。"

# game/Welcome Party.rpy:1353
translate chinese_simplified sit_with_kouya_f7444e6c:

    # "Wh-what do I do?!{p}My face is turning white..."
    # NOTE: ks无对应，直译
    "怎、怎么办？！{p}脸都白了……"

# game/Welcome Party.rpy:1357
translate chinese_simplified sit_with_kouya_35b6bb3a:

    # ka "「[fn], you can do it. 」"
    # NOTE: ks无对应，直译
    ka "「[fn]，你能行的。」"

# game/Welcome Party.rpy:1358
translate chinese_simplified sit_with_kouya_adfac41b:

    # "I look to my side.{p}I can see Kouya calling out to me,\nsmiling gently."
    # NOTE: ks无对应，直译
    "[fn]看向身旁。{p}看到洸哉微笑着向[fn]打招呼。"

# game/Welcome Party.rpy:1359
translate chinese_simplified sit_with_kouya_1fd3bf25:

    # "Because of that,\nmy tension eases a little."
    # NOTE: ks无对应，直译
    "因为这个，{p}[fn]的紧张感稍微缓解了一些。"

# game/Welcome Party.rpy:1363
translate chinese_simplified sit_with_kouya_9a82c85f:

    # fn "Err... i-it's been a long time,\nb-but I have this to say,\nI'm glad to be back like t-this! 」"
    # NOTE: ks无对应，直译
    fn "呃……好、好久不见，{p}但、但我有话要说，{p}很高兴能像这样回来！"

# game/Welcome Party.rpy:1367
translate chinese_simplified sit_with_kouya_563699ca:

    # to "「The hell, [fn]!{p} \ We're your friends! 」"
    # NOTE: ks无对应，直译
    to "「搞什么啊，[fn]！{p}我们是朋友啊！」"

# game/Welcome Party.rpy:1371
translate chinese_simplified sit_with_kouya_fc54c4fa:

    # ta "「Yeah, you're bein' too shy! 」"
    # NOTE: ks无对应，直译
    ta "「是啊，你也太害羞了！」"

# game/Welcome Party.rpy:1372
translate chinese_simplified sit_with_kouya_cf15e005:

    # "Voices from everywhere rise up."
    # NOTE: ks无对应，直译
    "四面八方响起了声音。"

# game/Welcome Party.rpy:1373
translate chinese_simplified sit_with_kouya_1f19a83e:

    # "This is kind of embarrassing,\nbut more than that, I'm happy."
    # NOTE: ks无对应，直译
    "虽然有点难为情，{p}但更多的是开心。"

# game/Welcome Party.rpy:1377
translate chinese_simplified sit_with_kouya_ab3ad676:

    # fn "「Thanks. I'm not very good at,\n \ err, saying these kinds of things,\n \ but thanks for everything guys! 」"
    # NOTE: ks无对应，直译
    fn "「谢谢。我不太擅长，{p}呃，说这种话，{p}但还是谢谢大家了！」"

# game/Welcome Party.rpy:1378
translate chinese_simplified sit_with_kouya_34498de0:

    # fn "「Well then, to our reunion!{p} \ Cheers! 」"
    # NOTE: ks无对应，直译
    fn "「那么，为了我们的重逢！{p}干杯！」"

# game/Welcome Party.rpy:1379
translate chinese_simplified sit_with_kouya_877daf65:

    # "{size=+15}CHEERS!"
    # NOTE: ks无对应，直译
    "{size=+15}干杯！"

# game/Welcome Party.rpy:1383
translate chinese_simplified sit_with_kouya_5bc0f444:

    # "And with that,\nthe peaceful hustle and bustle returns."
    # NOTE: ks无对应，直译
    "就这样，{p}平静的喧闹又回来了。"

# game/Welcome Party.rpy:1384
translate chinese_simplified sit_with_kouya_0f0e228e:

    # "There aren't any other customers,\nbut we're enough to keep it busy"
    # NOTE: ks无对应，直译
    "虽然没有其他客人，{p]但我们足够让这里热闹起来了。"

# game/Welcome Party.rpy:1385
translate chinese_simplified sit_with_kouya_c385cab0:

    # fn "「Whew... 」"
    # NOTE: ks无对应，直译
    fn "「呼……」"

# game/Welcome Party.rpy:1386
translate chinese_simplified sit_with_kouya_9789c3a5:

    # "The sounds of joyous laughter,\nthe sound of the roasting meat,\nhearing them makes my nervousness dissipate."
    # NOTE: ks无对应，直译
    "欢快的笑声，{p}烤肉的声音，{p}听着这些，[fn]的紧张感消散了。"

# game/Welcome Party.rpy:1387
translate chinese_simplified sit_with_kouya_c0d3586e:

    # "Getting tired from the crowd,\nI sit back down."
    # NOTE: ks无对应，直译
    "被人群弄得有些疲惫，{p}[fn]坐回了座位。"

# game/Welcome Party.rpy:1393
translate chinese_simplified sit_with_kouya_10307ac5:

    # ka "「Nice job.{p} \ That was quite the greeting. 」"
    # NOTE: ks无对应，直译
    ka "「干得漂亮。{p}那问候真不错。」"

# game/Welcome Party.rpy:1394
translate chinese_simplified sit_with_kouya_0c88fc0e:

    # "He still has the same smile from earlier.{p}I say thanks to Kouya."
    # NOTE: ks无对应，直译
    "他还是保持着刚才的微笑。{p}[fn]向洸哉道谢。"

# game/Welcome Party.rpy:1395
translate chinese_simplified sit_with_kouya_bd67d48c:

    # fn "「Oh, thanks. It was surprising.{p} \ I wasn't expecting Torahiko to...{p} \ put me on the spot like that. 」"
    # NOTE: ks无对应，直译
    fn "「哦，谢谢。真让人意外。{p}没想到虎彦会……{p}这样突然让我上台。」"

# game/Welcome Party.rpy:1396
translate chinese_simplified sit_with_kouya_d675ce89:

    # fn "「It was weird, I got really nervous! 」"
    # NOTE: ks无对应，直译
    fn "「太奇怪了，我真的很紧张！」"

# game/Welcome Party.rpy:1400
translate chinese_simplified sit_with_kouya_f0ea7812:

    # ka "「You looked like you were frozen solid.{p} \ Well, you gotta expect the unexpected sometimes. 」"
    # NOTE: ks无对应，直译
    ka "「你看起来整个人都僵住了。{p}嘛，有时候就得预料到意外情况。」"

# game/Welcome Party.rpy:1401
translate chinese_simplified sit_with_kouya_ad1ff20a:

    # fn "「Eh, sorry about that.{p} \ My face was beginning to turn white.{p} \ Ah, but because of you, 」"
    # NOTE: ks无对应，直译
    fn "「呃，抱歉啊。{p}脸都开始发白了。{p}啊，不过多亏了你，」"

# game/Welcome Party.rpy:1402
translate chinese_simplified sit_with_kouya_da56f84f:

    # fn "「I was able to get back on track.{p} \ Thanks, it would've been awful if I didn't. 」"
    # NOTE: ks无对应，直译
    fn "「我才能重新镇定下来。{p}谢谢，要是没你我就惨了。」"

# game/Welcome Party.rpy:1406
translate chinese_simplified sit_with_kouya_a6ef095d:

    # ka "「Well, thanks for the gratitude. 」"
    # NOTE: ks无对应，直译
    ka "「嗯，谢谢你的感激。」"

# game/Welcome Party.rpy:1407
translate chinese_simplified sit_with_kouya_6a03a5cb:

    # ka "「Anyway, it's been a while, [fn].{p} \ You seem to be doing well. 」"
    # NOTE: ks无对应，直译
    ka "「话说回来，好久不见了，[fn]。{p}你看起来过得不错。」"

# game/Welcome Party.rpy:1408
translate chinese_simplified sit_with_kouya_e85419c8:

    # "While saying that,\nKouya gives me a light pat on the shoulder"
    # NOTE: ks无对应，直译
    "说着，{p}洸哉轻轻拍了拍[fn]的肩膀。"

# game/Welcome Party.rpy:1409
translate chinese_simplified sit_with_kouya_ab34257d:

    # fn "「You too.{p} \ Actually, everyone seems to be doing well. 」"
    # NOTE: ks无对应，直译
    fn "「你也是。{p}其实，大家都看起来过得很好。」"

# game/Welcome Party.rpy:1413
translate chinese_simplified sit_with_kouya_d4e8c56c:

    # ka "「Heh, I think that's my line.{p} \ You never contacted us,\n \ weren't you ever concerned? 」"
    # NOTE: ks无对应，直译
    ka "「呵，这话该我说才对。{p}你从来没联系过我们，{p}难道一点都不担心吗？」"

# game/Welcome Party.rpy:1414
translate chinese_simplified sit_with_kouya_2038eb14:

    # fn "「Oh yeah, sorry about that... 」"
    # NOTE: ks无对应，直译
    fn "「哦，是啊，抱歉……」"

# game/Welcome Party.rpy:1418
translate chinese_simplified sit_with_kouya_b38eb5f5:

    # ka "「Well, now you'll be able to see,\n \ just how good everyone is doing.{p} \ So [fn], you seem to have grown. 」"
    # NOTE: ks无对应，直译
    ka "「嘛，现在你就能亲眼看看{p}大家过得有多好了。{p}[fn]，你好像长高了。」"

# game/Welcome Party.rpy:1419
translate chinese_simplified sit_with_kouya_43734e9c:

    # fn "「You think so?{p} \ Not too long after I moved,\n \ I started to get taller. 」"
    # NOTE: ks无对应，直译
    fn "「是吗？{p}搬走没多久，{p}我就开始长高了。」"

# game/Welcome Party.rpy:1420
translate chinese_simplified sit_with_kouya_8db9562c:

    # fn "「You have too, haven't you? 」"
    # NOTE: ks无对应，直译
    fn "「你也长高了，不是吗？」"

# game/Welcome Party.rpy:1421
translate chinese_simplified sit_with_kouya_8999503f:

    # fn "「You're taller than me,\n \ and you seem even more mature...{p} \ you were always so cool. 」"
    # NOTE: ks无对应，直译
    fn "「你比我高，{p}而且看起来更成熟了……{p}你一直都这么酷。」"

# game/Welcome Party.rpy:1425
translate chinese_simplified sit_with_kouya_1046ad36:

    # ka "「Thanks.{p} \ A little bit of flattery is never bad. 」"
    # NOTE: ks无对应，直译
    ka "「谢谢。{p}稍微奉承一下也不错。」"

# game/Welcome Party.rpy:1426
translate chinese_simplified sit_with_kouya_c9c2b5b2:

    # "He says that while giving me a smile. 」"
    # NOTE: ks无对应，直译
    "他一边说着，一边微笑着。"

# game/Welcome Party.rpy:1427
translate chinese_simplified sit_with_kouya_745916f8:

    # fn "「Well, I didn't mean it like that... 」"
    # NOTE: ks无对应，直译
    fn "「呃，我不是那个意思……」"

# game/Welcome Party.rpy:1428
translate chinese_simplified sit_with_kouya_9b851653:

    # "When he says thanks to me,\nI feel a bit embarrassed.{p}My face is turning red."
    # NOTE: ks无对应，直译
    "他向我道谢，{p}[fn]反而觉得有点不好意思。{p}脸都红了。"

# game/Welcome Party.rpy:1429
translate chinese_simplified sit_with_kouya_08980720:

    # "On the other hand, he's so nonchalant.{p}The more I think about it,\nthe more I feel stuck."
    # NOTE: ks无对应，直译
    "相反，他却是一副若无其事的样子。{p}[fn]越想越觉得{p}自己有点尴尬。"

# game/Welcome Party.rpy:1430
translate chinese_simplified sit_with_kouya_7da370fa:

    # "Aah, this is really embarrassing..."
    # NOTE: ks无对应，直译
    "啊，真是难为情……"

# game/Welcome Party.rpy:1431
translate chinese_simplified sit_with_kouya_2507dfd9:

    # fn "「A-anyway, what have you been up to?{p} \ Like club activities, or something? 」"
    # NOTE: ks无对应，直译
    fn "「总、总之，你最近在忙什么？{p}比如社团活动之类的？」

# game/Welcome Party.rpy:1432
translate chinese_simplified sit_with_kouya_dcb8c48e:

    # "I change the subject quickly,\nto conceal my humiliation."
    # NOTE: ks无对应，直译
    "[fn]迅速转移话题，{p}试图掩饰自己的窘迫。"

# game/Welcome Party.rpy:1433
translate chinese_simplified sit_with_kouya_cf4bb786:

    # "Because I left after junior high,\nI've had no idea what everyone's up to.{p}So, I was a little interested."
    # NOTE: ks无对应，直译
    "因为初中毕业后就离开了，{p}[fn]完全不知道大家在做什么。{p}所以有点好奇。"

# game/Welcome Party.rpy:1437
translate chinese_simplified sit_with_kouya_8b32c77c:

    # ka "「Nope, I don't do clubs.{p} \ I'm in a band. 」"
    # NOTE: ks无对应，直译
    ka "「不，我不参加社团。{p}我组了个乐队。」"

# game/Welcome Party.rpy:1438
translate chinese_simplified sit_with_kouya_ffe193cd:

    # fn "「Oh, really?{p} \ What do you do? Vocals? 」"
    # NOTE: ks无对应，直译
    fn "「哦，真的吗？{p}你负责什么？主唱吗？」"

# game/Welcome Party.rpy:1442
translate chinese_simplified sit_with_kouya_c78f8685:

    # ka "「No, I only do that occasionally.{p} \ I mainly play the guitar. 」"
    # NOTE: ks无对应，直译
    ka "「不，偶尔才唱一下。{p}我主要是弹吉他。」"

# game/Welcome Party.rpy:1443
translate chinese_simplified sit_with_kouya_8bcb339f:

    # fn "「Wow, that's amazing!{p} \ I'm no good with music.{p} \ I have to confess, I'm jealous. 」"
    # NOTE: ks无对应，直译
    fn "「哇，好厉害！{p}我对音乐一窍不通。{p}说实话，我有点羡慕。」"

# game/Welcome Party.rpy:1444
translate chinese_simplified sit_with_kouya_558bd707:

    # fn "「Even if I could play one instrument,\n \ I'd be satisfied. 」"
    # NOTE: ks无对应，直译
    fn "「哪怕能学会一种乐器，{p}我也满足了。」"

# game/Welcome Party.rpy:1445
translate chinese_simplified sit_with_kouya_5818a57c:

    # ka "「Yeah, it is pretty nice.{p} \ {nw}"
    # NOTE: ks无对应，直译
    ka "「是啊，感觉确实不错。{p}{nw}"

# game/Welcome Party.rpy:1447
translate chinese_simplified sit_with_kouya_5b3d9a96:

    # extend "I know, you want lessons sometimes? 」"
    # NOTE: ks无对应，直译
    extend "我知道，你想学学吗？」"

# game/Welcome Party.rpy:1449
translate chinese_simplified sit_with_kouya_ba813c96:

    # fn "「Eh, would that be all right? 」"
    # NOTE: ks无对应，直译
    fn "「诶，那样可以吗？」"

# game/Welcome Party.rpy:1450
translate chinese_simplified sit_with_kouya_e91699e0:

    # ka "「Sure.{p} \ If you're interested, let's talk. 」"
    # NOTE: ks无对应，直译
    ka "「当然。{p}如果你感兴趣，我们可以聊聊。」"

# game/Welcome Party.rpy:1451
translate chinese_simplified sit_with_kouya_35677399:

    # "With those words,\nKouya gives a smile."
    # NOTE: ks无对应，直译
    "说着，{p}洸哉露出了微笑。"

# game/Welcome Party.rpy:1452
translate chinese_simplified sit_with_kouya_17124408:

    # "It's as if he's confirming my determination,\nand saying \"what will you do?\""
    # NOTE: ks无对应，直译
    "仿佛在确认[fn]的决心，{p}说着“你会怎么做呢？”"

# game/Welcome Party.rpy:1453
translate chinese_simplified sit_with_kouya_c6654470:

    # "Without any thought,\nI already know the answer."
    # NOTE: ks无对应，直译
    "不用想，{p}[fn]已经知道答案了。"

# game/Welcome Party.rpy:1454
translate chinese_simplified sit_with_kouya_3cce9b7b:

    # "I don't have any reason to refuse.{p}And more importantly, it sounds fun.{p}That's enough for me."
    # NOTE: ks无对应，直译
    "[fn]没有理由拒绝。{p}更重要的是，听起来很有趣。{p}这就足够了。"

# game/Welcome Party.rpy:1455
translate chinese_simplified sit_with_kouya_642d6833:

    # fn "「Well, if I get the opportunity,\n \ I'll take you up on your offer. 」"
    # NOTE: ks无对应，直译
    fn "「嗯，如果有机会，{p}我会接受你的提议的。」"

# game/Welcome Party.rpy:1456
translate chinese_simplified sit_with_kouya_5e8aee87:

    # fn "「If it's not too much trouble,\n \ I'd also like to hear you play sometime. 」"
    # NOTE: ks无对应，直译
    fn "「如果不太麻烦的话，{p]我也想找个时间听听你演奏。」"

# game/Welcome Party.rpy:1460
translate chinese_simplified sit_with_kouya_038feb38:

    # ka "「Ah, I don't mind at all.{p} \ Actually, I'm going to be playing live,\n \ so you could come then if you want. 」"
    # NOTE: ks无对应，直译
    ka "「啊，完全没问题。{p}其实我马上要演出了，{p}你想来的话可以那时候来。」"

# game/Welcome Party.rpy:1461
translate chinese_simplified sit_with_kouya_d93dbaf1:

    # fn "「You're playing live?{p} \ That sounds like a big deal. 」"
    # NOTE: ks无对应，直译
    fn "「你要演出了？{p]听起来很厉害的样子。」"

# game/Welcome Party.rpy:1465
translate chinese_simplified sit_with_kouya_2cb6f9d2:

    # ka "「I'm aiming for it to be my debut,\n \ so it is a pretty big deal. 」"
    # NOTE: ks无对应，直译
    ka "「我打算把它当作我的出道演出，{p}所以确实挺重要的。」"

# game/Welcome Party.rpy:1466
translate chinese_simplified sit_with_kouya_274c1973:

    # ka "「I can get you a ticket if you want. 」"
    # NOTE: ks无对应，直译
    ka "「如果你想要的话，我可以给你弄张票。」"

# game/Welcome Party.rpy:1467
translate chinese_simplified sit_with_kouya_5359b8cf:

    # fn "「Yeah, I'd love to go!{p} \ I'm looking forward to it. 」"
    # NOTE: ks无对应，直译
    fn "「嗯，我很想去！{p}我很期待。」"

# game/Welcome Party.rpy:1471
translate chinese_simplified sit_with_kouya_a56b6aa9:

    # ka "「I'll be expecting you then.{p} \ Well, enough about that.{p} \ Look, the meat is starting to burn around here. 」"
    # NOTE: ks无对应，直译
    ka "「那我就等着你了。{p}好了，这个话题就到此为止。{p}看，这边的肉都快烤焦了。」"

# game/Welcome Party.rpy:1472
translate chinese_simplified sit_with_kouya_fd58e862:

    # "As he says that,\nhe serves me a plate of food."
    # NOTE: ks无对应，直译
    "说着，{p}他给[fn]盛了一盘吃的。"

# game/Welcome Party.rpy:1473
translate chinese_simplified sit_with_kouya_c2de7175:

    # fn "「Oh, sorry Kouya, thanks! 」"
    # NOTE: ks无对应，直译
    fn "「哦，不好意思洸哉，谢谢！」"

# game/Welcome Party.rpy:1477
translate chinese_simplified sit_with_kouya_4f6a8a44:

    # ka "「Eat all you want.{p} \ Today is your welcoming party after all,\n \ or are you going to hold back? 」"
    # NOTE: ks无对应，直译
    ka "「尽管吃。{p}今天毕竟是你的欢迎会，{p]难道还要客气吗？」"

# game/Welcome Party.rpy:1478
translate chinese_simplified sit_with_kouya_46a0f514:

    # "Kouya's grin made me feel a little warm.{p}It was a nostalgic feeling that I had forgotten."
    # NOTE: ks无对应，直译
    "洸哉的笑容让[fn]感到一丝温暖。{p}那是[fn]早已遗忘的怀念感觉。"

# game/Welcome Party.rpy:1479
translate chinese_simplified sit_with_kouya_c2eeb748:

    # fn "「Yeah!{p} \ Let's eat right away.{p} \ Thanks for the food. 」"
    # NOTE: ks无对应，直译
    fn "「嗯！{p}那我就不客气了。{p}我开动了。」"

# game/Welcome Party.rpy:1480
translate chinese_simplified sit_with_kouya_0fdd9736:

    # "I pick up my chopsticks and begin."
    # NOTE: ks无对应，直译
    "[fn]拿起筷子开始吃。"

# game/Welcome Party.rpy:1481
translate chinese_simplified sit_with_kouya_5f9dce73:

    # "It's been a long time since I've eaten here.\nThe taste was also a nostalgic feeling."
    # NOTE: ks无对应，直译
    "很久没在这里吃饭了。{p}味道也是令人怀念的感觉。"

# game/Welcome Party.rpy:1493
translate chinese_simplified sit_with_kyoutarou_3bd48d22:

    # ky "「Oh, [fn].{p} \ Are you looking for an empty seat? 」"
    # NOTE: ks无对应，直译
    ky "「哦，[fn]。{p}在找空位吗？」"

# game/Welcome Party.rpy:1494
translate chinese_simplified sit_with_kyoutarou_fa73c749:

    # "Kyouji stands up.{p}There's an empty seat across from him."
    # NOTE: ks无对应，直译
    "京慈站了起来。{p}他对面有个空位。"

# game/Welcome Party.rpy:1495
translate chinese_simplified sit_with_kyoutarou_aba04ecc:

    # fn "「Ah, thank you.{p} \ Err, Kyouji... Senpai. 」"
    # NOTE: ks无对应，直译
    fn "「啊，谢谢。{p}呃，京慈……前辈。」"

# game/Welcome Party.rpy:1496
translate chinese_simplified sit_with_kyoutarou_85ed7c37:

    # ky "「Haha, you don't have to call me senpai.{p} \ It'd be better if we dropped the honorifics. 」"
    # NOTE: ks无对应，直译
    ky "「哈哈，不用叫我前辈。{p}还是去掉敬语比较好。」"

# game/Welcome Party.rpy:1497
translate chinese_simplified sit_with_kyoutarou_d790b4e6:

    # ky "「This is your long-awaited welcoming party.{p} \ It's not suitable for us to be so formal, right? 」"
    # NOTE: ks无对应，直译
    ky "「这是你期待已久的欢迎会。{p]我们这么拘谨也不合适，对吧？」"

# game/Welcome Party.rpy:1498
translate chinese_simplified sit_with_kyoutarou_7d967b29:

    # fn "「A-are you sure?{p} \ Well in that case...{p} \ Is here all right... Kyouji? 」"
    # NOTE: ks无对应，直译
    fn "「真、真的可以吗？{p}那……{p}坐这里可以吗……京慈？」"

# game/Welcome Party.rpy:1499
translate chinese_simplified sit_with_kyoutarou_dc0617e7:

    # ky "「Ah, by all means, of course. 」"
    # NOTE: ks无对应，直译
    ky "「啊，当然可以。」"

# game/Welcome Party.rpy:1500
translate chinese_simplified sit_with_kyoutarou_579ca897:

    # "His openhearted response makes me feel awkward,\nbut I cheerfully sit down anyway."
    # NOTE: ks无对应，直译
    "他坦率的回答让[fn]有点不好意思，{p}但[fn]还是愉快地坐下了。"

# game/Welcome Party.rpy:1506
translate chinese_simplified sit_with_kyoutarou_1988dc28:

    # to "「Hey, [fn]!{p} \ Are you gonna order something? 」"
    # NOTE: ks无对应，直译
    to "「喂，[fn]！{p}你要点些什么吗？」"

# game/Welcome Party.rpy:1507
translate chinese_simplified sit_with_kyoutarou_a0d03305:

    # fn "「What, order? 」"
    # NOTE: ks无对应，直译
    fn "「什么，点单？」"

# game/Welcome Party.rpy:1511
translate chinese_simplified sit_with_kyoutarou_69c410c9:

    # su "「Get your favorite drink,\n \ [fn]-san. 」"
    # NOTE: ks无对应，直译
    su "「点你喜欢的饮料吧，{p}[fn]哥。」"

# game/Welcome Party.rpy:1512
translate chinese_simplified sit_with_kyoutarou_6577f83e:

    # "Whoops, looks like I kept everyone waiting.{p}I take a peek at the menu and order some tea."
    # NOTE: ks无对应，直译
    "哎呀，好像让大家久等了。{p}[fn]瞄了一眼菜单，点了茶。"

# game/Welcome Party.rpy:1516
translate chinese_simplified sit_with_kyoutarou_1930f2e5:

    # "Shortly after that,\ndishes of meat are carried out."
    # NOTE: ks无对应，直译
    "没过多久，{p}一盘盘肉就被端了上来。"

# game/Welcome Party.rpy:1520
translate chinese_simplified sit_with_kyoutarou_be865494:

    # so "「Whoa, that looks really good... 」"
    # NOTE: ks无对应，直译
    so "「哇，看起来真好吃……」"

# game/Welcome Party.rpy:1524
translate chinese_simplified sit_with_kyoutarou_de92304a:

    # ky "「Tarou, doesn't it still need to be cooked? 」"
    # NOTE: ks无对应，直译
    ky "「宗，这不还得烤吗？」"

# game/Welcome Party.rpy:1528
translate chinese_simplified sit_with_kyoutarou_a1af42f0:

    # so "「I-I know... 」"
    # NOTE: ks无对应，直译
    so "「我、我知道……」"

# game/Welcome Party.rpy:1529
translate chinese_simplified sit_with_kyoutarou_2f1a79e0:

    # fn "「Ahaha! 」"
    # NOTE: ks无对应，直译
    fn "「啊哈哈！」"

# game/Welcome Party.rpy:1530
translate chinese_simplified sit_with_kyoutarou_8d33b3c0:

    # "Those two have a good tempo when they talk,\nI can't help but laugh a little."
    # NOTE: ks无对应，直译
    "那两人说话的节奏很好，{p}[fn]忍不住笑了。"

# game/Welcome Party.rpy:1531
translate chinese_simplified sit_with_kyoutarou_39ded623:

    # "In these kinds of situations,\nthis must be how they usually act."
    # NOTE: ks无对应，直译
    "在这种场合，{p]他们平时大概就是这样的吧。"

# game/Welcome Party.rpy:1535
translate chinese_simplified sit_with_kyoutarou_1d1c32bd:

    # "Before long, everyone gets their drinks.{p}Torahiko raises his glass and begins to speak."
    # NOTE: ks无对应，直译
    "没过多久，大家都拿到了饮料。{p}虎彦举起酒杯开始说话。"

# game/Welcome Party.rpy:1539
translate chinese_simplified sit_with_kyoutarou_7e852079:

    # to "「All right, now we're ready,{p} \ ready to reunite with [fn]!{p} \ Cheers! 」"
    # NOTE: ks无对应，直译
    to "「好了，现在准备就绪，{p}准备与[fn]重逢！{p}干杯！」"

# game/Welcome Party.rpy:1544
translate chinese_simplified sit_with_kyoutarou_877daf65:

    # "{size=+15}CHEERS!"
    # NOTE: ks无对应，直译
    "{size=+15}干杯！"

# game/Welcome Party.rpy:1545
translate chinese_simplified sit_with_kyoutarou_cbd17d57:

    # "The sound of clinking glasses echo in unison."
    # NOTE: ks无对应，直译
    "碰杯的声音齐声回响。"

# game/Welcome Party.rpy:1546
translate chinese_simplified sit_with_kyoutarou_9e2b7b74:

    # "After the toast is over,\nthe food is set out in front of us."
    # NOTE: ks无对应，直译
    "祝酒结束后，{p}食物摆在了我们面前。"

# game/Welcome Party.rpy:1547
translate chinese_simplified sit_with_kyoutarou_5c22add6:

    # "The delicious aroma of cooking meat,\nit spreads throughout the restaurant."
    # NOTE: ks无对应，直译
    "烤肉的香味飘散在餐厅里。"

# game/Welcome Party.rpy:1553
translate chinese_simplified sit_with_kyoutarou_b7720db1:

    # so "「I'm already really hungry... 」"
    # NOTE: ks无对应，直译
    so "「我已经饿得不行了……」"

# game/Welcome Party.rpy:1554
translate chinese_simplified sit_with_kyoutarou_b1fc0eb3:

    # ky "「Haha, I am too.{p} \ It's because of all that exercise. 」"
    # NOTE: ks无对应，直译
    ky "「哈哈，我也是。{p}大概是因为刚运动完吧。」"

# game/Welcome Party.rpy:1555
translate chinese_simplified sit_with_kyoutarou_572097b9:

    # fn "「Oh, that's right.{p} \ You just got back from your club. 」"
    # NOTE: ks无对应，直译
    fn "「哦，对了。{p]你刚从社团回来吧。」"

# game/Welcome Party.rpy:1556
translate chinese_simplified sit_with_kyoutarou_a662296b:

    # ky "「Yeah, we had a pretty close practice game.{p} \ We're still working on our formations. 」"
    # NOTE: ks无对应，直译
    ky "「是啊，刚打了一场很胶着的练习赛。{p}我们还在磨合阵型。」"

# game/Welcome Party.rpy:1557
translate chinese_simplified sit_with_kyoutarou_9012b7b9:

    # fn "「Wow...{p} \ You're still serious about soccer. 」"
    # NOTE: ks无对应，直译
    fn "「哇……{p]你对足球还是这么认真啊。」"

# game/Welcome Party.rpy:1558
translate chinese_simplified sit_with_kyoutarou_278f659a:

    # ky "「Yep, I never tire of kicking that little ball.{p} \ I'm still playing soccer,\n \ just like when I was younger. 」"
    # NOTE: ks无对应，直译
    ky "「是啊，踢那个小球永远不会腻。{p}我还是在踢足球，{p]就像小时候一样。」"

# game/Welcome Party.rpy:1559
translate chinese_simplified sit_with_kyoutarou_f11eedf9:

    # fn "「Yeah. Back in elementary school,\n \ especially after class. 」"
    # NOTE: ks无对应，直译
    fn "「是啊。小学的时候，{p]特别是放学后。」"

# game/Welcome Party.rpy:1560
translate chinese_simplified sit_with_kyoutarou_1c8c9f42:

    # ky "「After you moved, everybody changed a little.{p} \ For example, Ooshima is swimming,\n \ and Kouya's into music. 」"
    # NOTE: ks无对应，直译
    ky "「你搬走以后，大家都变了一点。{p}比如大岛在游泳，{p]洸哉搞音乐去了。」"

# game/Welcome Party.rpy:1561
translate chinese_simplified sit_with_kyoutarou_3f44eaf5:

    # ky "「But then there's me.{p} \ I haven't changed one bit. 」"
    # NOTE: ks无对应，直译
    ky "「但我就不一样了。{p}我一点都没变。」"

# game/Welcome Party.rpy:1562
translate chinese_simplified sit_with_kyoutarou_21fceef4:

    # fn "「Th-that's not true!{p} \ You're way different. 」"
    # NOTE: ks无对应，直译
    fn "「才、才不是那样！{p}你变了很多。」"

# game/Welcome Party.rpy:1563
translate chinese_simplified sit_with_kyoutarou_7c113d32:

    # "I take a good look at Kyouji."
    # NOTE: ks无对应，直译
    "[fn]仔细打量着京慈。"

# game/Welcome Party.rpy:1564
translate chinese_simplified sit_with_kyoutarou_fdd40932:

    # "First of all, there's his body.{p}Soccer has made his arms and legs stronger.{p}His shoulders have also gotten wider."
    # NOTE: ks无对应，直译
    "首先是他的体型。{p}足球让他的手脚更加强壮了。{p}肩膀也变宽了。"

# game/Welcome Party.rpy:1565
translate chinese_simplified sit_with_kyoutarou_09044df8:

    # "We haven't seen each other in five years.{p}It isn't strange that he's different..."
    # NOTE: ks无对应，直译
    "我们五年没见了。{p]他变了也没什么好奇怪的……"

# game/Welcome Party.rpy:1566
translate chinese_simplified sit_with_kyoutarou_3cc955e6:

    # "On the other hand,\nhis facial expressions and eyes haven't changed."
    # NOTE: ks无对应，直译
    "另一方面，{p]他的表情和眼神都没变。"

# game/Welcome Party.rpy:1567
translate chinese_simplified sit_with_kyoutarou_4bce1285:

    # "I can't tell if they're open,\nbut when I look into them,\nI'm filled with a calm feeling."
    # NOTE: ks无对应，直译
    "虽然看不出是否坦率，{p]但看着他的眼睛，{p]心中涌起一股平静。"

# game/Welcome Party.rpy:1568
translate chinese_simplified sit_with_kyoutarou_1a2f8443:

    # "They are gentle eyes."
    # NOTE: ks无对应，直译
    "那是双温柔的眼睛。"

# game/Welcome Party.rpy:1569
translate chinese_simplified sit_with_kyoutarou_f042e9e6:

    # fn "「...Of course you've changed.{p} \ I have a feeling that you're more mature now. 」"
    # NOTE: ks无对应，直译
    fn "「……你当然变了。{p]我觉得你现在更成熟了。」"

# game/Welcome Party.rpy:1570
translate chinese_simplified sit_with_kyoutarou_74e9db8e:

    # ky "「...Really? 」"
    # NOTE: ks无对应，直译
    ky "「……真的吗？」"

# game/Welcome Party.rpy:1571
translate chinese_simplified sit_with_kyoutarou_b6b4f78e:

    # fn "「Yeah, you're almost...{p} \ like a father... 」"
    # NOTE: ks无对应，直译
    fn "「嗯，你简直……{p]像个父亲一样……」"

# game/Welcome Party.rpy:1575
translate chinese_simplified sit_with_kyoutarou_09067cb2:

    # ky "「Heheh, just be honest and say I'm old. 」"
    # NOTE: ks无对应，直译
    ky "「呵呵，直接说我老了不就好了。」"

# game/Welcome Party.rpy:1576
translate chinese_simplified sit_with_kyoutarou_d85ff99e:

    # fn "「Haha, you got me! 」"
    # NOTE: ks无对应，直译
    fn "「哈哈，被你看穿了！」"

# game/Welcome Party.rpy:1582
translate chinese_simplified sit_with_kyoutarou_3ca558d4:

    # ky "「...But to be honest,\n \ I'm really glad to hear that.{p} \ Thanks. 」"
    # NOTE: ks无对应，直译
    ky "「……不过说实话，{p}听到你这么说我很开心。{p}谢谢。」"

# game/Welcome Party.rpy:1583
translate chinese_simplified sit_with_kyoutarou_472d8eed:

    # "Kyouji rubs his nose in embarrassment.{p}\"Dad\" and I cook our meat,\nand put it on our plates."
    # NOTE: ks无对应，直译
    "京慈不好意思地挠了挠鼻子。{p}「父亲」和[fn]烤着肉，{p]放到盘子里。"

# game/Welcome Party.rpy:1584
translate chinese_simplified sit_with_kyoutarou_851fe1c4:

    # "I start eating without hesitation.{p}...The taste of meat spreads onto my tongue."
    # NOTE: ks无对应，直译
    "[fn]毫不犹豫地开始吃。{p}……肉的味道在舌尖蔓延。"

# game/Welcome Party.rpy:1585
translate chinese_simplified sit_with_kyoutarou_867c933a:

    # fn "「Mmm...{p} \ this is great! 」"
    # NOTE: ks无对应，直译
    fn "「嗯……{p]真好吃！」"

# game/Welcome Party.rpy:1586
translate chinese_simplified sit_with_kyoutarou_c2a803f0:

    # ky "「Haha, it's the best!{p} \ Tarou, is everything all right for you? 」"
    # NOTE: ks无对应，直译
    ky "「哈哈，最棒了！{p]宗，你那边还好吗？」"

# game/Welcome Party.rpy:1590
translate chinese_simplified sit_with_kyoutarou_e96acc2f:

    # so "「Yeah!{p} \ After all, eating with company,\n \ always makes it better. 」"
    # NOTE: ks无对应，直译
    so "「嗯！{p]毕竟大家一起吃，{p]总是更好吃的。」"

# game/Welcome Party.rpy:1594
translate chinese_simplified sit_with_kyoutarou_b972235e:

    # ky "「That's right.{p} \ You're still growing,\n \ are you eating enough? 」"
    # NOTE: ks无对应，直译
    ky "「是啊。{p]你还在长身体，{p]有好好吃饭吗？」"

# game/Welcome Party.rpy:1598
translate chinese_simplified sit_with_kyoutarou_3d906e41:

    # so "「Ehehehe,\n \ you spoil me too much. 」"
    # NOTE: ks无对应，直译
    so "「嘿嘿嘿，{p]你太宠我了。」"

# game/Welcome Party.rpy:1599
translate chinese_simplified sit_with_kyoutarou_790ac751:

    # "Soutarou-kun looks shy as he says that,\nand stretches out his chopsticks again."
    # NOTE: ks无对应，直译
    "宗太郎说着这话显得有些害羞，{p]再次伸出了筷子。"

# game/Welcome Party.rpy:1605
translate chinese_simplified sit_with_kyoutarou_696f9824:

    # ky "「[fn], if you want to,\n \ would you like to see us practice? 」"
    # NOTE: ks无对应，直译
    ky "「[fn]，如果你愿意，{p]想来看看我们练习吗？」"

# game/Welcome Party.rpy:1606
translate chinese_simplified sit_with_kyoutarou_e37729bf:

    # fn "「Huh? Both of you practice? 」"
    # NOTE: ks无对应，直译
    fn "「诶？你们两个一起练习吗？」"

# game/Welcome Party.rpy:1607
translate chinese_simplified sit_with_kyoutarou_c08fc55c:

    # ky "「We're a relatively open club,\n \ so anybody can come and watch.{p} \ Surely our teammates would have no problem. 」"
    # NOTE: ks无对应，直译
    ky "「我们社团比较开放，{p]谁都可以来看。{p]队友们肯定也没意见。」"

# game/Welcome Party.rpy:1608
translate chinese_simplified sit_with_kyoutarou_c283ec61:

    # fn "「I see...{p} \ If that's the case,\n \ maybe I'll stop by if you guys don't mind. 」"
    # NOTE: ks无对应，直译
    fn "「这样啊……{p]既然如此，{p]如果你们不介意的话，我可能会去看看。」"

# game/Welcome Party.rpy:1609
translate chinese_simplified sit_with_kyoutarou_666825f5:

    # fn "「Oh, where do you guys practice? 」"
    # NOTE: ks无对应，直译
    fn "「哦，你们在哪里练习？」

# game/Welcome Party.rpy:1610
translate chinese_simplified sit_with_kyoutarou_d1c45ac4:

    # ky "「The neighboring town's high school grounds.{p} \ I go there just about every day.{p} \ Why don't we do it tomorrow? 」"
    # NOTE: ks无对应，直译
    ky "「隔壁镇的高中操场。{p]我几乎每天都去。{p]明天怎么样？」"

# game/Welcome Party.rpy:1611
translate chinese_simplified sit_with_kyoutarou_04db70a9:

    # fn "「Eh? T-tomorrow? 」"
    # NOTE: ks无对应，直译
    fn "「诶？明、明天？」"

# game/Welcome Party.rpy:1612
translate chinese_simplified sit_with_kyoutarou_a227859c:

    # ky "「No no, I was just speaking figuratively.{p} \ But if you change your mind,\n \ would that be too much for you? 」"
    # NOTE: ks无对应，直译
    ky "「不不，我只是打个比方。{p]不过如果你改变主意了，{p]会不会太麻烦你了？」"

# game/Welcome Party.rpy:1613
translate chinese_simplified sit_with_kyoutarou_caa9be70:

    # ky "「You must be tired from your long trip,\n \ you should just relax. 」"
    # NOTE: ks无对应，直译
    ky "「长途跋涉你一定累了，{p]还是好好休息吧。」"

# game/Welcome Party.rpy:1614
translate chinese_simplified sit_with_kyoutarou_529f8664:

    # fn "「Y-yeah, I guess you're right. 」"
    # NOTE: ks无对应，直译
    fn "「也、也是呢。」"

# game/Welcome Party.rpy:1615
translate chinese_simplified sit_with_kyoutarou_c16d027d:

    # "I give an uncertain response to Kyouji,\nbut because I'm his friend,\nI'll definitely do it."
    # NOTE: ks无对应，直译
    "[fn]给了京慈一个不确定的答复，{p]但既然是朋友，{p][fn]一定会去的。"

# game/Welcome Party.rpy:1616
translate chinese_simplified sit_with_kyoutarou_6ce1fc57:

    # "...I'll head to bed early tonight."
    # NOTE: ks无对应，直译
    "……今晚得早点睡。"

# game/Welcome Party.rpy:1617
translate chinese_simplified sit_with_kyoutarou_7b664e17:

    # ky "「Oh, is that so, [fn]? 」"
    # NOTE: ks无对应，直译
    ky "「哦，是吗，[fn]？」"

# game/Welcome Party.rpy:1618
translate chinese_simplified sit_with_kyoutarou_43d0bc29:

    # "Kyouji turns over the meat.{p}As if he remembered something,\nhe opens his mouth to speak."
    # NOTE: ks无对应，直译
    "京慈翻动着烤肉。{p]像是想起了什么，{p]开口说道。"

# game/Welcome Party.rpy:1619
translate chinese_simplified sit_with_kyoutarou_eb85cdff:

    # ky "「This is your first time meeting Soutarou, right?{p} \ You don't know him very well,\n \ so this would be a good chance to catch up. 」"
    # NOTE: ks无对应，直译
    ky "「这是你第一次见宗太郎吧？{p]你对他还不太熟，{p]这是个好好聊聊的好机会。」"

# game/Welcome Party.rpy:1620
translate chinese_simplified sit_with_kyoutarou_080309bf:

    # ky "「That is, a chance to strengthen your friendship. 」"
    # NOTE: ks无对应，直译
    ky "「也就是，加深友谊的机会。」"

# game/Welcome Party.rpy:1621
translate chinese_simplified sit_with_kyoutarou_2fba0806:

    # fn "「Oh, you're right. 」"
    # NOTE: ks无对应，直译
    fn "「哦，你说得对。」"

# game/Welcome Party.rpy:1622
translate chinese_simplified sit_with_kyoutarou_791aaccb:

    # "The whole time I've been sitting here,\nI've been acting like Soutarou-kun wasn't here."
    # NOTE: ks无对应，直译
    "[fn]坐在这里的时候，{p]表现得好像宗太郎不在场一样。"

# game/Welcome Party.rpy:1623
translate chinese_simplified sit_with_kyoutarou_39f53450:

    # "Besides, when he introduced himself he said,\n\"I've heard lots of interesting things about you.\""
    # NOTE: ks无对应，直译
    "而且，他自我介绍时说，{p]“我听说过很多关于你的趣事”。"

# game/Welcome Party.rpy:1624
translate chinese_simplified sit_with_kyoutarou_51772bc4:

    # "The \"interesting\" part has been on my mind..."
    # NOTE: ks无对应，直译
    "那个“趣事”的部分，{p]一直让[fn]很在意……"

# game/Welcome Party.rpy:1631
translate chinese_simplified sit_with_kyoutarou_8f6be895:

    # so "「Eh, but that's...\n \ You're kind of forcing me here... 」"
    # NOTE: ks无对应，直译
    so "「诶，但是那个……{p]你这是在勉强我吧……」"

# game/Welcome Party.rpy:1632
translate chinese_simplified sit_with_kyoutarou_1c7ace3f:

    # ky "「Hm, but when we talked about [fn],\n \ you said many times you wanted to meet him,\n \ didn't you? 」"
    # NOTE: ks无对应，直译
    ky "「嗯，但我们聊到[fn]的时候，{p]你不是说过好几次想见他吗？{p]不是吗？」"

# game/Welcome Party.rpy:1636
translate chinese_simplified sit_with_kyoutarou_ffba68a1:

    # so "「Huh?! Y-yeah, but... 」"
    # NOTE: ks无对应，直译
    so "「哈？！是、是啊，但是……」"

# game/Welcome Party.rpy:1637
translate chinese_simplified sit_with_kyoutarou_0877afec:

    # ky "「Hey, don't be so shy. 」"
    # NOTE: ks无对应，直译
    ky "「喂，别那么害羞嘛。」"

# game/Welcome Party.rpy:1641
translate chinese_simplified sit_with_kyoutarou_34dde87b:

    # "When Kyouji pushes him,\nSoutarou-kun looks away in embarrassment.{p}I guess he's the shy type..."
    # NOTE: ks无对应，直译
    "京慈这么一说，{p}宗太郎不好意思地移开了视线。{p]看来他是害羞型的……"

# game/Welcome Party.rpy:1642
translate chinese_simplified sit_with_kyoutarou_f9f322dd:

    # "If that's the case,\nmaybe I should say something to break the ice..."
    # NOTE: ks无对应，直译
    "既然如此，{p]也许[fn]该说点什么打破僵局……"

# game/Welcome Party.rpy:1648
translate chinese_simplified sit_with_kyoutarou_89ef30e1:

    # ta "「O-oh,\n \ is this a marriage interview? 」"
    # NOTE: ks无对应，直译
    ta "「哦——哦，{p]这是在相亲吗？」"

# game/Welcome Party.rpy:1649
translate chinese_simplified sit_with_kyoutarou_19c4ee0f:

    # fn "「A what? 」"
    # NOTE: ks无对应，直译
    fn "「什么？」

# game/Welcome Party.rpy:1650
translate chinese_simplified sit_with_kyoutarou_442951b5:

    # "As I was worrying about what to say,\nTatsu-nii's drunken voice shouts from behind."
    # NOTE: ks无对应，直译
    "[fn]正烦恼着该说什么，{p]身后传来了辰兄醉醺醺的声音。"

# game/Welcome Party.rpy:1651
translate chinese_simplified sit_with_kyoutarou_4038d181:

    # "At \"marriage interview,\"\neverybody's chopsticks abruptly stop moving.{p}All eyes in the restaurant gather on me."
    # NOTE: ks无对应，直译
    "听到“相亲”，{p]大家的筷子都停住了。{p]餐厅里所有的目光都集中在[fn]身上。"

# game/Welcome Party.rpy:1652
translate chinese_simplified sit_with_kyoutarou_6724339b:

    # "...Wh-what's with this atmosphere..."
    # NOTE: ks无对应，直译
    "……这气氛是怎么回事……"

# game/Welcome Party.rpy:1653
translate chinese_simplified sit_with_kyoutarou_169f88e1:

    # fn "「T-Tatsu-nii,\n \ have you been drinking too much? 」"
    # NOTE: ks无对应，直译
    fn "「辰、辰兄，{p]你是不是喝太多了？」"

# game/Welcome Party.rpy:1657
translate chinese_simplified sit_with_kyoutarou_ec52dc68:

    # ta "「H-hm?{p} \ I'm not drunk at a-all... 」"
    # NOTE: ks无对应，直译
    ta "「嗯——？{p]我才没醉呢……」"

# game/Welcome Party.rpy:1658
translate chinese_simplified sit_with_kyoutarou_ee48c566:

    # "I don't think so,\nhe's having trouble with his words."
    # NOTE: ks无对应，直译
    "[fn]可不这么觉得，{p]他说话都含糊不清了。"

# game/Welcome Party.rpy:1662
translate chinese_simplified sit_with_kyoutarou_72b2ce0f:

    # ta "「So, [fn] and S-Soutarou...{p} \ Isn't today the first time y-you've met?{p} \ It's also the f-first time you're dining together! 」"
    # NOTE: ks无对应，直译
    ta "「所以，[fn]和宗……{p]今天不是你们第一次见面吗？{p]也是你们第一次一起吃饭吧！」"

# game/Welcome Party.rpy:1663
translate chinese_simplified sit_with_kyoutarou_4586326a:

    # ta "「All the more reason for a-a marriage interview! 」"
    # NOTE: ks无对应，直译
    ta "「那就更有理由进行相亲了！」"

# game/Welcome Party.rpy:1664
translate chinese_simplified sit_with_kyoutarou_0481c6ab:

    # "I-I think it's called group dating...{p}Oh... group dating is probably...{p}something not known too well here."
    # NOTE: ks无对应，直译
    "我……我想那叫联谊吧……{p}哦……联谊在这里可能……{p}不是什么众所周知的东西。"

# game/Welcome Party.rpy:1668
translate chinese_simplified sit_with_kyoutarou_47a834d2:

    # ta "「Ah, and is Kyouji the matchmaker? 」"
    # NOTE: ks无对应，直译
    ta "「啊，京二是媒人吗？」"

# game/Welcome Party.rpy:1672
translate chinese_simplified sit_with_kyoutarou_89b8cdf8:

    # ky "「Well... you could say I am. 」"
    # NOTE: ks无对应，直译
    ky "「嗯……算是吧。」"

# game/Welcome Party.rpy:1676
translate chinese_simplified sit_with_kyoutarou_eca58181:

    # so "「S-Senpai!{p} \ What're you talking about?! 」"
    # NOTE: ks无对应，直译
    so "「前……前辈！{p} \ 你在说什么呢？！」"

# game/Welcome Party.rpy:1677
translate chinese_simplified sit_with_kyoutarou_84281f7d:

    # "This is starting to get out of hand,\nKyouji's going along with Tatsu-nii..."
    # NOTE: ks无对应，直译
    "事情开始变得不可收拾了，\n京二居然跟着龙兄一起起哄……"

# game/Welcome Party.rpy:1681
translate chinese_simplified sit_with_kyoutarou_19935a98:

    # ta "「They're both so innocent...{p} \ A-as the senior here,\n \ should I teach them a-about... 」"
    # NOTE: ks无对应，直译
    ta "「他们两个都那么天真……{p} \ 作……作为这里的大前辈，\n \ 我是不是该教教他们……」"

# game/Welcome Party.rpy:1682
translate chinese_simplified sit_with_kyoutarou_f34e6238:

    # ta "「...intimate relationships? 」"
    # NOTE: ks无对应，直译
    ta "「……男女关系？」"

# game/Welcome Party.rpy:1683
translate chinese_simplified sit_with_kyoutarou_d10207f1:

    # fn "「W-wait, Tatsu-nii,\n \ why don't you do someone else's,\n \ \"marriage interview\"... 」"
    # NOTE: ks无对应，直译
    fn "「等……等等，龙兄，\n \ 你干嘛不给别人也弄个\n \ \"相亲\"啊……」"

# game/Welcome Party.rpy:1687
translate chinese_simplified sit_with_kyoutarou_05dae666:

    # ta "「Don't be shy, don't b-be shy.{p} \ Everybody's n-nervous the first time... 」"
    # NOTE: ks无对应，直译
    ta "「别害羞嘛，别……别害羞了。{p} \ 大家第一次都会紧……紧张的嘛……」"

# game/Welcome Party.rpy:1688
translate chinese_simplified sit_with_kyoutarou_1ed39ab4:

    # "Tatsu-nii grabs my shoulders,\nand whispers it into my ears.{p}H-his breath reeks of alcohol..."
    # NOTE: ks无对应，直译
    "龙兄抓住我的肩膀，\n在我耳边低声说着。{p}他……他的呼吸满是酒味……"

# game/Welcome Party.rpy:1689
translate chinese_simplified sit_with_kyoutarou_b5f36401:

    # ky "「Tatsuki-san, they haven't even been on a date,\n \ so let's not overdo it.{p} \ For now, leave the matchmaking to me. 」"
    # NOTE: ks无对应，直译
    ky "「龙贵先生，他们连约会都还没去过呢，\n \ 所以别太急了。{p} \ 现在就把牵线的事交给我吧。」"

# game/Welcome Party.rpy:1690
translate chinese_simplified sit_with_kyoutarou_32a17ec9:

    # ta "「I see, I-I see...{p} \ {nw}"
    # NOTE: ks无对应，直译
    ta "「这样啊，这……这样啊……{p} \ {nw}"

# game/Welcome Party.rpy:1692
translate chinese_simplified sit_with_kyoutarou_9f8f2527:

    # extend "I'll leave them to you,\n \ don't let me down! 」"
    # NOTE: ks无对应，直译
    extend "就交给你了，\n \ 别让我失望啊！」"

# game/Welcome Party.rpy:1694
translate chinese_simplified sit_with_kyoutarou_cb3f9fb5:

    # ky "「Eh, please look forward to it! 」"
    # NOTE: ks无对应，直译
    ky "「嗯，请放心吧！」"

# game/Welcome Party.rpy:1698
translate chinese_simplified sit_with_kyoutarou_983d20e5:

    # "At Kyouji's honest reply,\nTatsu-nii finally moves away from us."
    # NOTE: ks无对应，直译
    "听到京二诚实的回答，\n龙兄终于从我们身边走开了。"

# game/Welcome Party.rpy:1699
translate chinese_simplified sit_with_kyoutarou_27a4fdd7:

    # "...I guess Kyouji knows how to deal with his...{p}drunkenness."
    # NOTE: ks无对应，直译
    "……看来京二知道怎么应付他……{p}喝醉的样子。"

# game/Welcome Party.rpy:1700
translate chinese_simplified sit_with_kyoutarou_b7aa88b5:

    # "I let out a deep sigh of relief."
    # NOTE: ks无对应，直译
    "我深深地松了一口气。"

# game/Welcome Party.rpy:1708
translate chinese_simplified sit_with_kyoutarou_259c5b8a:

    # so "「Aah, my heart was pounding... 」"
    # NOTE: ks无对应，直译
    so "「啊——，我的心跳得好快……」"

# game/Welcome Party.rpy:1709
translate chinese_simplified sit_with_kyoutarou_a7ed124e:

    # fn "「Kyouji...{p} \ Why did you have to play along like that? 」"
    # NOTE: ks无对应，直译
    fn "「京二……{p} \ 你干嘛要跟着他一起起哄啊？」"

# game/Welcome Party.rpy:1710
translate chinese_simplified sit_with_kyoutarou_9be2e686:

    # ky "「Heheh, I just wanted you two to...{p} \ get a little flustered. 」"
    # NOTE: ks无对应，直译
    ky "「嘿嘿，我只是想看看你们两个……{p} \ 慌张的样子。」"

# game/Welcome Party.rpy:1711
translate chinese_simplified sit_with_kyoutarou_72053348:

    # ky "「Besides, you seem like a perfect match,{p} \ don't you think? 」"
    # NOTE: ks无对应，直译
    ky "「而且，你们看起来很般配呢，{p} \ 不觉得吗？」"

# game/Welcome Party.rpy:1712
translate chinese_simplified sit_with_kyoutarou_b22eff13:

    # fn "「What!?{p} \ A-a perfect match...? 」"
    # NOTE: ks无对应，直译
    fn "「什么？！{p} \ 般……般配……？」"

# game/Welcome Party.rpy:1713
translate chinese_simplified sit_with_kyoutarou_e8795d9a:

    # "When he's so explicit about it,\nit's difficult to respond!"
    # NOTE: ks无对应，直译
    "被他这么直白地说出来，\n都不知道该怎么回应了！"

# game/Welcome Party.rpy:1714
translate chinese_simplified sit_with_kyoutarou_fd1bf47f:

    # ky "「At last, my time has come, Tarou.{p} \ We must be separated! 」"
    # NOTE: ks无对应，直译
   ky "「终于到了这一步了，太郎。{p} \ 我们必须分开了！」"

# game/Welcome Party.rpy:1715
translate chinese_simplified sit_with_kyoutarou_41bd0883:

    # ky "「It's complex, but I'm happy as your senpai. 」"
    # NOTE: ks无对应，直译
    ky "「虽然心情很复杂，但作为你的前辈我很欣慰。」"

# game/Welcome Party.rpy:1719
translate chinese_simplified sit_with_kyoutarou_d679897e:

    # so "「T-that's...{p} \ That's not something for you to decide!{p} \ You're awful, senpai... 」"
    # NOTE: ks无对应，直译
    so "「那……那个……{p} \ 这不是由你来决定的事！{p} \ 太过分了，前辈……」"

# game/Welcome Party.rpy:1720
translate chinese_simplified sit_with_kyoutarou_28f432ff:

    # "Soutarou-kun's face looks sad,\nand he droops his ears.{p}Is he taking Kyouji's little show seriously?"
    # NOTE: ks无对应，直译
    "宗太郎的表情看起来很伤心，\n耳朵也耷拉下来了。{p}他是不是把京二的小剧场当真了？"

# game/Welcome Party.rpy:1721
translate chinese_simplified sit_with_kyoutarou_c48e428d:

    # ky "「Haha, I'm just kidding, just kidding!{p} \ Sorry, Tarou. 」"
    # NOTE: ks无对应，直译
    ky "「哈哈，开玩笑的啦，开玩笑的！{p} \ 抱歉，太郎。」"

# game/Welcome Party.rpy:1725
translate chinese_simplified sit_with_kyoutarou_77c288ca:

    # so "「R-really...? 」"
    # NOTE: ks无对应，直译
    so "「真……真的吗……？」"

# game/Welcome Party.rpy:1726
translate chinese_simplified sit_with_kyoutarou_6160192b:

    # ky "「Ah, is matchmaking really this simple? 」"
    # NOTE: ks无对应，直译
    ky "「啊，牵线搭桥原来这么简单吗？」"

# game/Welcome Party.rpy:1727
translate chinese_simplified sit_with_kyoutarou_77ea6a54:

    # "As he says that,\nKyouji gently strokes Soutarou-kun's mane."
    # NOTE: ks无对应，直译
    "说着，京二轻轻抚摸着宗太郎的鬃毛。"

# game/Welcome Party.rpy:1731
translate chinese_simplified sit_with_kyoutarou_8410a43e:

    # so "「...S-senpai... 」"
    # NOTE: ks无对应，直译
    so "「……前……前辈……」"

# game/Welcome Party.rpy:1732
translate chinese_simplified sit_with_kyoutarou_dbc5f5e6:

    # "He seems to like it when he does that.{p}While his mane is being stroked,\nSoutarou-kun's expression relaxes a little."
    # NOTE: ks无对应，直译
    "他好像很喜欢被这么抚摸。{p}被抚摸着鬃毛的时候，\n宗太郎的表情放松了一点。"

# game/Welcome Party.rpy:1733
translate chinese_simplified sit_with_kyoutarou_f03efa33:

    # "I can see why Kyouji...{p}plays around with him like that."
    # NOTE: ks无对应，直译
    "我能理解为什么京二……{p}会那样逗他了。"

# game/Welcome Party.rpy:1734
translate chinese_simplified sit_with_kyoutarou_4b85ab8d:

    # ky "「We'll have an official interview another time. 」"
    # NOTE: ks无对应，直译
    ky "「下次再正式相亲吧。」"

# game/Welcome Party.rpy:1735
translate chinese_simplified sit_with_kyoutarou_b653f275:

    # fn "「K-Kyouji...{p} \ that's... 」"
    # NOTE: ks无对应，直译
    fn "「京……京二……{p} \ 那个……」"

# game/Welcome Party.rpy:1736
translate chinese_simplified sit_with_kyoutarou_14dbbf2d:

    # ky "「Haha, I know.{p} \ I'll let you two go steady first,\n \ then a marriage interview. 」"
    # NOTE: ks无对应，直译
    ky "「哈哈，我知道。{p} \ 先让你们两个交往，\n \ 然后再相亲。」"

# game/Welcome Party.rpy:1737
translate chinese_simplified sit_with_kyoutarou_30c464b1:

    # ky "「Are you friends now? 」"
    # NOTE: ks无对应，直译
    ky "「你们现在是朋友了吧？」"

# game/Welcome Party.rpy:1738
translate chinese_simplified sit_with_kyoutarou_874fd3d1:

    # fn "「Yeah, of course.{p} \ Nice to meet you, Soutarou-kun! 」"
    # NOTE: ks无对应，直译
    fn "「嗯，当然了。{p} \ 请多指教，宗太郎！」"

# game/Welcome Party.rpy:1742
translate chinese_simplified sit_with_kyoutarou_6b7473e1:

    # so "「Oh yeah! Same here,\n \ nice to meetcha! 」"
    # NOTE: ks无对应，直译
    so "「哦对了！彼此彼此，\n \ 请多指教啦！」"

# game/Welcome Party.rpy:1743
translate chinese_simplified sit_with_kyoutarou_8c79f24c:

    # "As I talk to Soutarou-kun,\nmy mind recovers."
    # NOTE: ks无对应，直译
    "和宗太郎聊着聊着，\n我的心情也恢复了。"

# game/Welcome Party.rpy:1744
translate chinese_simplified sit_with_kyoutarou_c260481c:

    # "I hate to say it but,\nthanks to Tatsu-nii,\nthe distance between Soutarou and I has shortened."
    # NOTE: ks无对应，直译
    "虽然不想这么说，但多亏了龙兄，\n我和宗太郎之间的距离拉近了。"

# game/Welcome Party.rpy:1753
translate chinese_simplified sit_with_juuichi_62298971:

    # "I return from the bathroom,\nthere's a pile of meat and vegetables on the table.{p}The first thing I hear is Torahiko's whining."
    # NOTE: ks无对应，直译
    "我从洗手间回来，\n桌上已经堆满了肉和蔬菜。{p}首先听到的是虎虎的抱怨声。"

# game/Welcome Party.rpy:1757
translate chinese_simplified sit_with_juuichi_34b74b88:

    # to "「[fn], sit down! 」"
    # NOTE: ks无对应，直译
    to "「[fn]，快坐下！」"

# game/Welcome Party.rpy:1761
translate chinese_simplified sit_with_juuichi_2f595024:

    # si "「...You know,\n \ the guest of honor being late to his own party\n \ is a grave situation. 」"
    # NOTE: ks无对应，直译
    si "「……你知道吗，\n \ 主角在自己的派对上迟到\n \ 可是个严重的问题。」"

# game/Welcome Party.rpy:1762
translate chinese_simplified sit_with_juuichi_ee1d0f35:

    # fn "「Ahaha, sorry, sorry. 」"
    # NOTE: ks无对应，直译
    fn "「啊哈哈，抱歉抱歉。」"

# game/Welcome Party.rpy:1763
translate chinese_simplified sit_with_juuichi_e268db8b:

    # "I look around restlessly.{p}Hmm, where should I sit...{p}As I'm struggling think, Torahiko yells again."
    # NOTE: ks无对应，直译
    "我四处张望着。{p}嗯，坐哪里好呢……{p}我正犹豫着，虎虎又喊了起来。"

# game/Welcome Party.rpy:1768
translate chinese_simplified sit_with_juuichi_76d42ccd:

    # to "「Hey [fn], sit over here! 」"
    # NOTE: ks无对应，直译
    to "「嘿[fn]，坐这边！」"

# game/Welcome Party.rpy:1769
translate chinese_simplified sit_with_juuichi_629e22f0:

    # "He's patting an extremely narrow space,\nnext to Juuichi-san.{p}Wa-wait a minute, nobody could fit there!"
    # NOTE: ks无对应，直译
    "他拍着十一大旁边一个极其狭窄的空间。{p}等……等一下，谁也坐不下那里吧！"

# game/Welcome Party.rpy:1773
translate chinese_simplified sit_with_juuichi_bdf0676c:

    # ka "「That'll be too much trouble for [fn].{p} \ Stop asking him to do stupid things. 」"
    # NOTE: ks无对应，直译
    ka "「那样会给[fn]添麻烦的。{p} \ 别让他做蠢事了。」"

# game/Welcome Party.rpy:1774
translate chinese_simplified sit_with_juuichi_b22f9e4f:

    # "It would be a lot of trouble for me,\nI'm glad Kouya's helping me out here."
    # NOTE: ks无对应，直译
    "确实会给我添不少麻烦，\n还好小空帮我说话了。"

# game/Welcome Party.rpy:1775
translate chinese_simplified sit_with_juuichi_5f18d5b8:

    # "If it wasn't for him,\nI wouldn't have noticed right away."
    # NOTE: ks无对应，直译
    "要不是他，\n我可能还没反应过来。"

# game/Welcome Party.rpy:1779
translate chinese_simplified sit_with_juuichi_31993ce3:

    # to "「Heh, did \"big Kouya-sensei\",\n \ save a spot for that special someone? 」"
    # NOTE: ks无对应，直译
    to "「嘿嘿，\"空大医生\"，\n \ 该不会是特意给某人留的位置吧？」"

# game/Welcome Party.rpy:1780
translate chinese_simplified sit_with_juuichi_de6e97b5:

    # to "「Is that why you don't want him to sit there? 」"
    # NOTE: ks无对应，直译
    to "「所以你才不想让他坐那里吗？」"

# game/Welcome Party.rpy:1785
translate chinese_simplified sit_with_juuichi_c7d6f640:

    # "SLAM!{p}Kouya stands up without saying a word.{p}D-did he always have such a low boiling point?"
    # NOTE: ks无对应，直译
    "砰！{p}小空一句话不说地站了起来。{p}他……他以前脾气这么暴躁吗？"

# game/Welcome Party.rpy:1789
translate chinese_simplified sit_with_juuichi_e27bc185:

    # "His body responds to what's on his mind,\nthat shaking fist carries his message pretty well.{p}Kouya gives Torahiko a fierce glare."
    # NOTE: ks无对应，直译
    "他的身体表达着内心的想法，\n那颤抖的拳头很好地传达了他的意思。{p}小空狠狠地瞪着虎虎。"

# game/Welcome Party.rpy:1790
translate chinese_simplified sit_with_juuichi_03f80979:

    # "With a clack of his chair,{p}Torahiko stands up too.{p}Sparks silently fly between them."
    # NOTE: ks无对应，直译
    "虎虎也随着椅子的响声站了起来。{p}两人之间无声地擦出火花。"

# game/Welcome Party.rpy:1791
translate chinese_simplified sit_with_juuichi_fd56bb88:

    # "Back then,\nthey would get in fights all the time.{p}It looks like that hasn't changed."
    # NOTE: ks无对应，直译
    "以前他们就经常吵架。{p}看来这点到现在也没变。"

# game/Welcome Party.rpy:1792
translate chinese_simplified sit_with_juuichi_2ad55b0a:

    # "I just sigh in resignation."
    # NOTE: ks无对应，直译
    "我只好无奈地叹气。"

# game/Welcome Party.rpy:1793
translate chinese_simplified sit_with_juuichi_dee28ac7:

    # "THUMP."
    # NOTE: ks无对应，直译
    "咚！"

# game/Welcome Party.rpy:1800
translate chinese_simplified sit_with_juuichi_1ae64f18:

    # to "{size=+15}「GYAAAAA!! 」"
    # NOTE: ks无对应，直译
    to "{size=+15}「嘎啊啊啊！！」"

# game/Welcome Party.rpy:1801
translate chinese_simplified sit_with_juuichi_1a998cfc:

    # "Suddenly, Torahiko cries out in a strange voice.{p}I look closely, and I can see Juuichi-san."
    # NOTE: ks无对应，直译
    "虎虎突然发出一声怪叫。{p}我仔细一看，看到了十一的身影。"

# game/Welcome Party.rpy:1802
translate chinese_simplified sit_with_juuichi_faad8fce:

    # "He's tightly grasping the base of Torahiko's tail.{p}Torahiko's stripes look funny when his fur stands up"
    # NOTE: ks无对应，直译
    "他紧紧抓住了虎虎尾巴的根部。{p}虎虎的毛竖起来时，条纹看起来很好笑。"

# game/Welcome Party.rpy:1806
translate chinese_simplified sit_with_juuichi_11c6cd3f:

    # ju "「You are being very bad right now. 」"
    # NOTE: ks无对应，直译
    ju "「你现在很不乖。」"

# game/Welcome Party.rpy:1807
translate chinese_simplified sit_with_juuichi_a0271865:

    # "In a considerably low voice,\nJuuichi-san scolds Torahiko."
    # NOTE: ks无对应，直译
    "十一用相当低沉的声音训斥着虎虎。"

# game/Welcome Party.rpy:1811
translate chinese_simplified sit_with_juuichi_1ce12940:

    # to "「B-but... 」"
    # NOTE: ks无对应，直译
    to "「但……但是……」"

# game/Welcome Party.rpy:1812
translate chinese_simplified sit_with_juuichi_423103be:

    # "After several strange meows,\nTorahiko collapses to the floor."
    # NOTE: ks无对应，直译
    "虎虎发出几声奇怪的叫声后，\n瘫倒在了地上。"

# game/Welcome Party.rpy:1823
translate chinese_simplified sit_with_juuichi_5259ef9a:

    # "Since I don't have a tail,\nI'm not sure how that would feel."
    # NOTE: ks无对应，直译
    "因为我没有尾巴，\n不太清楚那是什么感觉。"

# game/Welcome Party.rpy:1824
translate chinese_simplified sit_with_juuichi_79e15634:

    # "But judging by the looks on everyone's faces..."
    # NOTE: ks无对应，直译
    "但看大家的表情……"

# game/Welcome Party.rpy:1832
translate chinese_simplified sit_with_juuichi_53930c08:

    # "It wouldn't be too hard to make a guess."
    # NOTE: ks无对应，直译
    "应该不难想象。"

# game/Welcome Party.rpy:1838
translate chinese_simplified sit_with_juuichi_3a1575f6:

    # "Torahiko's carefree presence was shut down,\nwith only one hand, too."
    # NOTE: ks无对应，直译
    "虎虎那无忧无虑的存在感，\n仅凭一只手就被压制了。"

# game/Welcome Party.rpy:1839
translate chinese_simplified sit_with_juuichi_26fa3c35:

    # "As expected of Juuichi-san.{p}His title of martial artist isn't just for show..."
    # NOTE: ks无对应，直译
    "不愧是十一。{p}他武术家的称号可不是浪得虚名……"

# game/Welcome Party.rpy:1840
translate chinese_simplified sit_with_juuichi_269a10c3:

    # ju "「...Kouya, sit. 」"
    # NOTE: ks无对应，直译
    ju "「……小空，坐下。」"

# game/Welcome Party.rpy:1844
translate chinese_simplified sit_with_juuichi_0bb655cf:

    # ka "「O-okay. 」"
    # NOTE: ks无对应，直译
    ka "「好……好的。」"

# game/Welcome Party.rpy:1845
translate chinese_simplified sit_with_juuichi_a30a42da:

    # "Kouya obediently sits down as soon as he is told.{p}After seeing such an amazing show of force,\nI wouldn't have expected him to do anything else."
    # NOTE: ks无对应，直译
    "小空被一说就乖乖坐下了。{p}见识了这么惊人的武力展示后，\n我也不觉得他还能做什么了。"

# game/Welcome Party.rpy:1846
translate chinese_simplified sit_with_juuichi_b9792880:

    # "Meanwhile, Torahiko is still twitching on the floor.{p}...Looks like he's taken some substantial damage."
    # NOTE: ks无对应，直译
    "与此同时，虎虎还在地上抽搐着。{p}……看来受到了不小的伤害。"

# game/Welcome Party.rpy:1847
translate chinese_simplified sit_with_juuichi_a99e6a01:

    # ju "「[ln], how long do you plan on standing there? 」"
    # NOTE: ks无对应，直译
    ju "「[ln]，你打算站到什么时候？」"

# game/Welcome Party.rpy:1848
translate chinese_simplified sit_with_juuichi_2518afc8:

    # fn "「S-sorry! 」"
    # NOTE: ks无对应，直译
    fn "「对……对不起！」"

# game/Welcome Party.rpy:1849
translate chinese_simplified sit_with_juuichi_19e5ec8e:

    # "He suddenly calls out my name.{p}I was so on edge that I tensed right up."
    # NOTE: ks无对应，直译
    "他突然叫了我的名字。{p}我紧张得全身都绷紧了。"

# game/Welcome Party.rpy:1850
translate chinese_simplified sit_with_juuichi_a8cc9120:

    # "I think for just a bit,\nthen sit down next to him.{p}Juuichi-san stares right at my face."
    # NOTE: ks无对应，直译
    "我想了想，\n然后坐到了他旁边。{p}十一直直地盯着我的脸。"

# game/Welcome Party.rpy:1851
translate chinese_simplified sit_with_juuichi_6b5fb3da:

    # ju "「...Is here all right? 」"
    # NOTE: ks无对应，直译
    ju "「……坐这里可以吗？」"

# game/Welcome Party.rpy:1852
translate chinese_simplified sit_with_juuichi_da9a5ec8:

    # fn "「Yeah, it's okay. 」"
    # NOTE: ks无对应，直译
    fn "「嗯，没关系。」"

# game/Welcome Party.rpy:1853
translate chinese_simplified sit_with_juuichi_4e63b005:

    # ju "「Good. 」"
    # NOTE: ks无对应，直译
    ju "「那就好。」"

# game/Welcome Party.rpy:1857
translate chinese_simplified sit_with_juuichi_defd71c1:

    # "Juuichi-san quickly looks away."
    # NOTE: ks无对应，直译
    "十一很快把视线移开了。"

# game/Welcome Party.rpy:1863
translate chinese_simplified sit_with_juuichi_5b11ae20:

    # ta "「Ah, ahem. 」"
    # NOTE: ks无对应，直译
    ta "「啊，咳咳。」"

# game/Welcome Party.rpy:1864
translate chinese_simplified sit_with_juuichi_1b77e4e7:

    # "In an attempt to improve the mood,\nTatsuki clears his throat loudly."
    # NOTE: ks无对应，直译
    "为了缓和气氛，\n龙贵大声地清了清嗓子。"

# game/Welcome Party.rpy:1868
translate chinese_simplified sit_with_juuichi_ecd4f606:

    # ta "「Anyway, we should have a toast. 」"
    # NOTE: ks无对应，直译
    ta "「总之，我们先干杯吧。」"

# game/Welcome Party.rpy:1872
translate chinese_simplified sit_with_juuichi_29219c46:

    # ko "「Y-you're right. 」"
    # NOTE: ks无对应，直译
    ko "「是……是啊。」"

# game/Welcome Party.rpy:1876
translate chinese_simplified sit_with_juuichi_ec094ef7:

    # "Having smoothed over the situation,\nKounosuke raises his glass into the air.{p}Everybody else folllows."
    # NOTE: ks无对应，直译
    "光之助将气氛缓和下来后，\n举起了杯子。{p}其他人也纷纷跟着举杯。"

# game/Welcome Party.rpy:1877
translate chinese_simplified sit_with_juuichi_0d043c7c:

    # "Oh, with one exception.{p}Torahiko remains down on the floor."
    # NOTE: ks无对应，直译
    "哦，除了一个人。{p}虎虎还在地上趴着。"

# game/Welcome Party.rpy:1883
translate chinese_simplified sit_with_juuichi_4fac55ca:

    # su "「Uh, umm...{p} \ Torahiko-san is still... 」"
    # NOTE: ks无对应，直译
    su "「那个……{p} \ 虎虎先生他还……」"

# game/Welcome Party.rpy:1884
translate chinese_simplified sit_with_juuichi_7a6a6ff3:

    # "Shun-kun timidly points at Torahiko."
    # NOTE: ks无对应，直译
    "小瞬怯生生地指着虎虎。"

# game/Welcome Party.rpy:1888
translate chinese_simplified sit_with_juuichi_47b34507:

    # si "「You'll have to wait until sunset before he recovers. 」"
    # NOTE: ks无对应，直译
    si "「你得等到太阳下山他才能恢复。」"

# game/Welcome Party.rpy:1892
translate chinese_simplified sit_with_juuichi_9e983432:

    # ta "「Leave him alone for now.{p} \ He'll be up and running again soon enough. 」"
    # NOTE: ks无对应，直译
    ta "「先别管他了。{p} \ 他很快就会恢复活力的。」"

# game/Welcome Party.rpy:1896
translate chinese_simplified sit_with_juuichi_3fcb8e36:

    # su "「Hmmm...{p} \ will he really be all right? 」"
    # NOTE: ks无对应，直译
    su "「嗯……{p} \ 他真的会没事吗？」"

# game/Welcome Party.rpy:1897
translate chinese_simplified sit_with_juuichi_7017e8b0:

    # "Even after hearing their reassurances,\nShun-kun turns his head in doubt."
    # NOTE: ks无对应，直译
    "即使听到了他们的保证，\n小瞬还是疑惑地歪着头。"

# game/Welcome Party.rpy:1903
translate chinese_simplified sit_with_juuichi_6aaa21a5:

    # ko "「...So what should we toast to? 」"
    # NOTE: ks无对应，直译
    ko "「……那么干杯词说什么好呢？」"

# game/Welcome Party.rpy:1904
translate chinese_simplified sit_with_juuichi_3f6cdf07:

    # "Kounosuke eagerly waits for an answer.{p}I just want this to be over ASAP."
    # NOTE: ks无对应，直译
    "光之助急切地等待着回答。{p}我只想赶快结束这一切。"

# game/Welcome Party.rpy:1905
translate chinese_simplified sit_with_juuichi_baeb1b7d:

    # "Well, in Kounosuke's case,\nI just want him to hurry up so he'll move.{p}I'm not prepared for his barrage of questions."
    # NOTE: ks无对应，直译
    "嘛，就光之助的情况来说，\n我只想让他快点走开。{p}我可没准备好接受他的连环追问。"

# game/Welcome Party.rpy:1909
translate chinese_simplified sit_with_juuichi_907ab8b4:

    # ka "「That should be obvious. 」"
    # NOTE: ks无对应，直译
    ka "「这不是显而易见的吗。」"

# game/Welcome Party.rpy:1913
translate chinese_simplified sit_with_juuichi_951668b9:

    # ko "「Huh? 」"
    # NOTE: ks无对应，直译
    ko "「嗯？」"

# game/Welcome Party.rpy:1917
translate chinese_simplified sit_with_juuichi_4b849c8a:

    # "Kounosuke's mouth hangs open.{p}Kouya shakes his head in disappointment."
    # NOTE: ks无对应，直译
    "光之助张大了嘴巴。{p}小空失望地摇了摇头。"

# game/Welcome Party.rpy:1921
translate chinese_simplified sit_with_juuichi_067000e2:

    # ky "「We're toasting to [fn]'s return,\n \ of course. 」"
    # NOTE: ks无对应，直译
    ky "「当然是为了庆祝[fn]的归来。」"

# game/Welcome Party.rpy:1925
translate chinese_simplified sit_with_juuichi_9246bac1:

    # ko "「Oh, that's right... 」"
    # NOTE: ks无对应，直译
    ko "「哦，对哦……」"

# game/Welcome Party.rpy:1926
translate chinese_simplified sit_with_juuichi_16a7d04a:

    # "Everyone lowers their glasses.{p}Kounosuke hasn't changed a bit."
    # NOTE: ks无对应，直译
    "大家都放下了杯子。{p}光之助一点都没变。"

# game/Welcome Party.rpy:1932
translate chinese_simplified sit_with_juuichi_fe24564b:

    # ta "「So, are we gonna drink soon?{p} \ Is everybody ready? 」"
    # NOTE: ks无对应，直译
    ta "「那么，差不多该喝了吧？{p} \ 大家都准备好了吗？」"

# game/Welcome Party.rpy:1936
translate chinese_simplified sit_with_juuichi_bedafc05:

    # "As Tatsu-nii said that,\nI straightened myself up."
    # NOTE: ks无对应，直译
    "听到龙兄这么说，\n我端正了坐姿。"

# game/Welcome Party.rpy:1937
translate chinese_simplified sit_with_juuichi_33d36f22:

    # ta "「There are a lot of things I could talk about,\n \ but let's push that aside for now.{p} \ All right, you guys ready? 」"
    # NOTE: ks无对应，直译
    ta "「有很多想说的话，\n \ 但先放一边吧。{p} \ 好了，大家准备好了吗？」"

# game/Welcome Party.rpy:1938
translate chinese_simplified sit_with_juuichi_bc02e3c2:

    # ta "「To [fn]'s return! 」"
    # NOTE: ks无对应，直译
    ta "「为了[fn]的归来！」"

# game/Welcome Party.rpy:1941
translate chinese_simplified sit_with_juuichi_7d5b5a68:

    # ta "{size=+30}「CHEERS!! 」"
    # NOTE: ks无对应，直译
    ta "{size=+30}「干杯！！」"

# game/Welcome Party.rpy:1945
translate chinese_simplified sit_with_juuichi_bd5bf800:

    # everybody "{size=+30}「CHEERS!! 」"
    # NOTE: ks无对应，直译
    everybody "{size=+30}「干杯！！」"

# game/Welcome Party.rpy:1950
translate chinese_simplified sit_with_juuichi_a6bce3d5:

    # "After the toast,\nI gulp down the contents of my glass."
    # NOTE: ks无对应，直译
    "干杯之后，\n我大口喝下了杯中的饮料。"

# game/Welcome Party.rpy:1957
translate chinese_simplified sit_with_juuichi_8f756f13:

    # "Once everybody's glasses are empty,\nthey start cheering loudly."
    # NOTE: ks无对应，直译
    "大家的杯子一空，\n就开始大声欢呼起来。"

# game/Welcome Party.rpy:1958
translate chinese_simplified sit_with_juuichi_0ff41df9:

    # "...Well, I'm just drinking juice.{p}That's all I'll ask the old man for, for now."
    # NOTE: ks无对应，直译
    "……嘛，我只是在喝果汁而已。{p}目前就只向老板要了这个。"

# game/Welcome Party.rpy:1963
translate chinese_simplified sit_with_juuichi_c9bf5cb1:

    # "I casually look over and see Juuichi-san.{p}He's silently arranging the food on his plate.{p}His glass is already empty."
    # NOTE: ks无对应，直译
    "我无意中看向十一。{p}他默默地整理着盘子里的食物。{p}他的杯子已经空了。"

# game/Welcome Party.rpy:1964
translate chinese_simplified sit_with_juuichi_f180dfb7:

    # "Juuichi-san finished his drink quicker than me...{p}He's terrible."
    # NOTE: ks无对应，直译
    "十一比我还快喝完……{p}他太厉害了。"

# game/Welcome Party.rpy:1965
translate chinese_simplified sit_with_juuichi_ff737dd2:

    # fn "「Juuichi-san,\n \ are you gonna get more to drink? 」"
    # NOTE: ks无对应，直译
    fn "「十一，\n \ 你要再喝点吗？」"

# game/Welcome Party.rpy:1969
translate chinese_simplified sit_with_juuichi_5120abc8:

    # ju "「Hmm, yeah... 」"
    # NOTE: ks无对应，直译
    ju "「嗯，是啊……」"

# game/Welcome Party.rpy:1970
translate chinese_simplified sit_with_juuichi_c0f0fc53:

    # "He grabs some meat with his chopsticks,\nthen stops to ponder something."
    # NOTE: ks无对应，直译
    "他用筷子夹了一些肉，\n然后停下来想了想什么。"

# game/Welcome Party.rpy:1974
translate chinese_simplified sit_with_juuichi_d6473db8:

    # ju "「Some tea would be nice... 」"
    # NOTE: ks无对应，直译
    ju "「喝点茶就好了……」"

# game/Welcome Party.rpy:1975
translate chinese_simplified sit_with_juuichi_45657c5c:

    # "Just as I'm about to say something,\nTatsu-nii wobbles over,\nwith a mug full of a golden-colored liquid."
    # NOTE: ks无对应，直译
    "我正要说什么的时候，\n龙兄晃晃悠悠地走了过来，\n手里拿着一个装满金色液体的大杯。"

# game/Welcome Party.rpy:1979
translate chinese_simplified sit_with_juuichi_87e43079:

    # ta "「Hey, hey wait a sec.{p} \ [fn]'s back, right?{p} \ You should be celebrating with beer! 」"
    # NOTE: ks无对应，直译
    ta "「嘿，等一下。{p} \ [fn]回来了对吧？{p} \ 要用啤酒庆祝才对！」"

# game/Welcome Party.rpy:1983
translate chinese_simplified sit_with_juuichi_42583eef:

    # ju "「Tatsu-san, alcohol isn't recommended for minors... 」"
    # NOTE: ks无对应，直译
    ju "「龙先生，未成年人不建议饮酒……」"

# game/Welcome Party.rpy:1984
translate chinese_simplified sit_with_juuichi_f9bf77d1:

    # ta "「Heh, you can't be a minor,\n \ with a huge body like that! 」"
    # NOTE: ks无对应，直译
    ta "「嘿，你这么大的块头，\n \ 怎么可能是未成年人！」"

# game/Welcome Party.rpy:1985
translate chinese_simplified sit_with_juuichi_f7dcce74:

    # "Tatsu-nii pats Juuichi-san's shoulders.{p}He's already completely drunk..."
    # NOTE: ks无对应，直译
    "龙兄拍着十一的肩膀。{p}他已经完全喝醉了……"

# game/Welcome Party.rpy:1986
translate chinese_simplified sit_with_juuichi_ac40133e:

    # "The law is different for dragons.{p}They can start drinking when they turn 16."
    # NOTE: ks无对应，直译
    "龙族的法律规定不同。{p}他们16岁就可以开始喝酒了。"

# game/Welcome Party.rpy:1987
translate chinese_simplified sit_with_juuichi_3d325aa2:

    # "...At least that's what Tatsu-nii told me,\nso there's not much credibility."
    # NOTE: ks无对应，直译
    "……至少龙兄是这么跟我说的，\n所以可信度不高。"

# game/Welcome Party.rpy:1988
translate chinese_simplified sit_with_juuichi_213a1c7d:

    # ju "「It's all right for you, but I can't. 」"
    # NOTE: ks无对应，直译
    ju "「你可以喝，但我不行。」"

# game/Welcome Party.rpy:1992
translate chinese_simplified sit_with_juuichi_8a087104:

    # ta "「Heh, still hardheaded as ever... 」"
    # NOTE: ks无对应，直译
    ta "「嘿，还是那么死脑筋……」"

# game/Welcome Party.rpy:1993
translate chinese_simplified sit_with_juuichi_043e964d:

    # "For a moment he looks disappointed, but then,\nan expression of lust appears on his face."
    # NOTE: ks无对应，直译
    "他一瞬间看起来有些失望，但随即，\n脸上露出了欲望的表情。"

# game/Welcome Party.rpy:1997
translate chinese_simplified sit_with_juuichi_fa56f714:

    # ta "「...Could the source of that hardheadedness...{p} \ be from here...? 」"
    # NOTE: ks无对应，直译
    ta "「……那死脑筋的原因……{p} \ 该不会是来自这里吧……？」"

# game/Welcome Party.rpy:1998
translate chinese_simplified sit_with_juuichi_8f1b89a2:

    # "As soon as he said that,\nTatsu-nii moves his hand to Juuichi-san's crotch.{p}{nw}"
    # NOTE: ks无对应，直译
    "话音刚落，\n龙兄就把手伸向了十一的胯下。{p}{nw}"

# game/Welcome Party.rpy:2000
translate chinese_simplified sit_with_juuichi_a65edbbf:

    # extend "A little \"sproing\" sound plays in my head."
    # NOTE: ks无对应，直译
    extend "我脑子里响起了\"叮\"的一声。"

# game/Welcome Party.rpy:2002
translate chinese_simplified sit_with_juuichi_84bdd94d:

    # "Tatsu-nii, I think you've crossed the line..."
    # NOTE: ks无对应，直译
    "龙兄，我觉得你越界了……"

# game/Welcome Party.rpy:2003
translate chinese_simplified sit_with_juuichi_9ee0ca05:

    # "Tatsu-nii is grinning and laughing,\nbut Juuichi-san is just staring at him quietly."
    # NOTE: ks无对应，直译
    "龙兄嘻嘻哈哈地笑着，\n但十一只是静静地盯着他。"

# game/Welcome Party.rpy:2007
translate chinese_simplified sit_with_juuichi_1cc29e94:

    # ta "「...Hm? What are you doing? 」"
    # NOTE: ks无对应，直译
    ta "「……嗯？你在干什么？」"

# game/Welcome Party.rpy:2008
translate chinese_simplified sit_with_juuichi_acd157bf:

    # "Suddenly, movement."
    # NOTE: ks无对应，直译
    "突然，一个动作。"

# game/Welcome Party.rpy:2012
translate chinese_simplified sit_with_juuichi_54ab2df4:

    # ju "「...Hmph!! 」"
    # NOTE: ks无对应，直译
    ju "「……哼！！」"

# game/Welcome Party.rpy:2021
translate chinese_simplified sit_with_juuichi_20e4343a:

    # "One moment, Tatsu-nii's talking.{p}The next, he's on the ground."
    # NOTE: ks无对应，直译
    "前一秒龙兄还在说话。{p}下一秒，他就倒在地上了。"

# game/Welcome Party.rpy:2022
translate chinese_simplified sit_with_juuichi_b93bf79e:

    # "He makes a loud \"GUH!\" sound.{p}He lets out a small moan."
    # NOTE: ks无对应，直译
    "他发出了一声\"咕！\"的声音。{p}呻吟着。"

# game/Welcome Party.rpy:2023
translate chinese_simplified sit_with_juuichi_20b47d63:

    # "Juuichi-san breathes heavily,\ngiving an imposing stance."
    # NOTE: ks无对应，直译
    "十一大口喘着气，\n摆出了威严的架势。"

# game/Welcome Party.rpy:2024
translate chinese_simplified sit_with_juuichi_a6feadd0:

    # "I know it's called self-defense,\nbut I think he may've gone a little too far..."
    # NOTE: ks无对应，直译
    "我知道这叫正当防卫，\n但我觉得他可能有点过分了……"

# game/Welcome Party.rpy:2025
translate chinese_simplified sit_with_juuichi_f1bcfa31:

    # fn "「J-Juuichi-san!{p} \ Cool down! 」"
    # NOTE: ks无对应，直译
    fn "「十……十一！{p} \ 冷静点！」"

# game/Welcome Party.rpy:2026
translate chinese_simplified sit_with_juuichi_4801b0dc:

    # "He pulls the cuffs of his blue jersey down."
    # NOTE: ks无对应，直译
    "他拉了拉蓝色运动衫的袖口。"

# game/Welcome Party.rpy:2030
translate chinese_simplified sit_with_juuichi_678aa0aa:

    # ju "「...Sorry, I was distracted. 」"
    # NOTE: ks无对应，直译
    ju "「……抱歉，刚才走神了。」"

# game/Welcome Party.rpy:2031
translate chinese_simplified sit_with_juuichi_07db27ed:

    # "With a thump, Juuichi-san sits back down.{p}It's not a very comfortable seat,\nso he moves around a bit, then sits again."
    # NOTE: ks无对应，直译
    "十一\"咚\"的一声坐了回去。{p}座位不太舒服，\n他挪了挪身子，又坐了下来。"

# game/Welcome Party.rpy:2032
translate chinese_simplified sit_with_juuichi_7196f5d8:

    # fn "「I wonder if Tatsu-nii will be okay...{p} \ Now I'm 100%% sure he's not okay,\n \ judging from those terrible sounds he's making. 」"
    # NOTE: ks无对应，直译
    fn "「龙兄他没事吧……{p} \ 从他发出的那些惨叫声来判断，\n \ 我现在100%%确定他不好。」"

# game/Welcome Party.rpy:2033
translate chinese_simplified sit_with_juuichi_41c87a53:

    # "I catch a glimpse of Tatsu-nii.{p}He's still twitching on the floor."
    # NOTE: ks无对应，直译
    "我瞥了一眼龙兄。{p}他还在地上抽搐着。"

# game/Welcome Party.rpy:2037
translate chinese_simplified sit_with_juuichi_a93ab975:

    # ju "「Usually I hold back a little, but...{p} \ Tatsu-san has a sturdy body, he'll be fine. 」"
    # NOTE: ks无对应，直译
    ju "「平时我会手下留情的，但是……{p} \ 龙先生身体结实，应该没事。」"

# game/Welcome Party.rpy:2038
translate chinese_simplified sit_with_juuichi_db34476e:

    # "If this is something that's common,\nthen I'll have to watch what I say,\nfor my own sake."
    # NOTE: ks无对应，直译
    "如果这是家常便饭的话，\n为了自己的安全，\n我说话得小心点了。"

# game/Welcome Party.rpy:2039
translate chinese_simplified sit_with_juuichi_e4c1c5c4:

    # "Spending my Summer in a hospital,\nis something I don't want."
    # NOTE: ks无对应，直译
    "我可不想在医院度过夏天。"

# game/Welcome Party.rpy:2040
translate chinese_simplified sit_with_juuichi_fb234eb4:

    # "Come to think of it,\ndid Juuichi-san just do a one-armed shoulder throw?"
    # NOTE: ks无对应，直译
    "话说回来，\n十一刚才是不是来了个单臂过肩摔？"

# game/Welcome Party.rpy:2041
translate chinese_simplified sit_with_juuichi_bedca324:

    # "If I remember correctly,\nhe practiced judo when he was younger."
    # NOTE: ks无对应，直译
    "如果没记错的话，\n他小时候练过柔道。"

# game/Welcome Party.rpy:2042
translate chinese_simplified sit_with_juuichi_ac7592ec:

    # "Is he still doing it?"
    # NOTE: ks无对应，直译
    "他现在还在练吗？"

# game/Welcome Party.rpy:2043
translate chinese_simplified sit_with_juuichi_1efcb43a:

    # "I ask Juuichi-san what's on my mind."
    # NOTE: ks无对应，直译
    "我把心里的疑问问了十一。"

# game/Welcome Party.rpy:2044
translate chinese_simplified sit_with_juuichi_3e0b6306:

    # ju "「...I am still doing judo. 」"
    # NOTE: ks无对应，直译
    ju "「……我现在还在练柔道。」"

# game/Welcome Party.rpy:2045
translate chinese_simplified sit_with_juuichi_bc8b9d5a:

    # fn "「Have you been in any matches? 」"
    # NOTE: ks无对应，直译
    fn "「有参加过比赛吗？」"

# game/Welcome Party.rpy:2046
translate chinese_simplified sit_with_juuichi_e6114c16:

    # ju "「Yeah. 」"
    # NOTE: ks无对应，直译
    ju "「嗯。」"

# game/Welcome Party.rpy:2047
translate chinese_simplified sit_with_juuichi_0fc71251:

    # fn "「And...? 」"
    # NOTE: ks无对应，直译
    fn "「然后呢……？」"

# game/Welcome Party.rpy:2048
translate chinese_simplified sit_with_juuichi_7b0a7e1d:

    # ju "「I have a winning streak...{p} \ and nothing but.{p} \ It's okay, I guess. 」"
    # NOTE: ks无对应，直译
    ju "「我一直连胜……{p} \ 也只有连胜了。{p} \ 还行吧，我想。」"

# game/Welcome Party.rpy:2049
translate chinese_simplified sit_with_juuichi_d330e3e5:

    # fn "「Whoa, that's amazing! 」"
    # NOTE: ks无对应，直译
    fn "「哇，好厉害！」"

# game/Welcome Party.rpy:2050
translate chinese_simplified sit_with_juuichi_6232100f:

    # ju "「...It's nothing deserving of praise. 」"
    # NOTE: ks无对应，直译
    ju "「……这没什么值得称赞的。」"

# game/Welcome Party.rpy:2051
translate chinese_simplified sit_with_juuichi_936eb58e:

    # fn "「...Come on.{p} \ I bet that you were secretly hoping that,\n \ I'd give you some kind of compliment. 」"
    # NOTE: ks无对应，直译
    fn "「……得了吧。{p} \ 我打赌你其实暗暗希望着，\n \ 我能夸你几句。」"

# game/Welcome Party.rpy:2052
translate chinese_simplified sit_with_juuichi_0df3a204:

    # "When I said that,{nw}"
    # NOTE: ks无对应，直译
    "当我说完这句话，{nw}"

# game/Welcome Party.rpy:2054
translate chinese_simplified sit_with_juuichi_a683670c:

    # extend "Juuichi-san's mouth curved into a small smile.{nw}"
    # NOTE: ks无对应，直译
    extend "十一的嘴角微微上扬。{nw}"

# game/Welcome Party.rpy:2056
translate chinese_simplified sit_with_juuichi_e1f385a7:

    # extend ""
    # NOTE: ks无对应，直译
    extend ""

# game/Welcome Party.rpy:2058
translate chinese_simplified sit_with_juuichi_4a837150:

    # "That reminds me,\nI haven't seen him smile at all today."
    # NOTE: ks无对应，直译
    "说起来，\n我今天还没见他笑过。"

# game/Welcome Party.rpy:2059
translate chinese_simplified sit_with_juuichi_581aad9b:

    # "Until now he's been but a \"grumpy bear,\"{p}literally."
    # NOTE: ks无对应，直译
    "到现在为止他就是个\"暴躁熊\"，{p}字面意义上的。"

# game/Welcome Party.rpy:2063
translate chinese_simplified sit_with_juuichi_9c33bc98:

    # "As I look at him and think about that,\nJuuichi-san scratches his face with his finger,\nand asks me a question."
    # NOTE: ks无对应，直译
    "我看着他这么想着，\n十一用手指挠了挠脸，\n然后问了我一个问题。"

# game/Welcome Party.rpy:2064
translate chinese_simplified sit_with_juuichi_91c61dd7:

    # ju "「Hm, is there something wrong with my face? 」"
    # NOTE: ks无对应，直译
    ju "「嗯，我脸上有什么东西吗？」"

# game/Welcome Party.rpy:2065
translate chinese_simplified sit_with_juuichi_0a777f47:

    # fn "「...No, that's not why I'm looking at you. 」"
    # NOTE: ks无对应，直译
    fn "「……没有，不是因为这个在看你。」"

# game/Welcome Party.rpy:2066
translate chinese_simplified sit_with_juuichi_4ce5daf0:

    # ju "「That kind of answer just worries me... 」"
    # NOTE: ks无对应，直译
    ju "「这种回答反而更让人担心……」"

# game/Welcome Party.rpy:2067
translate chinese_simplified sit_with_juuichi_67bb9dfc:

    # "Even though Juuichi-san is my friend,\nI can't just ask him, \"Are you in a bad mood?\"{p}Hmm, I'll have to break the ice."
    # NOTE: ks无对应，直译
    "虽然十一是我的朋友，\n但我不能直接问他\"你是不是心情不好\"，{p}嗯，我得想个办法打破僵局。"

# game/Welcome Party.rpy:2068
translate chinese_simplified sit_with_juuichi_232462e0:

    # "I guess I'll employ more...{p}subtle tactics instead."
    # NOTE: ks无对应，直译
    "我想我还是用更……{p}委婉的方式吧。"

# game/Welcome Party.rpy:2069
translate chinese_simplified sit_with_juuichi_cf0b33d5:

    # fn "「...Juuichi-san,\n \ is there something wrong with...{p} \ your body...? 」"
    # NOTE: ks无对应，直译
    fn "「……十一，\n \ 你身上……{p} \ 是不是有什么问题……？」"

# game/Welcome Party.rpy:2073
translate chinese_simplified sit_with_juuichi_2469d9b1:

    # ju "「...No, there's nothing wrong...{p} \ Do you think there is...? 」"
    # NOTE: ks无对应，直译
    ju "「……没有，没什么问题……{p} \ 你觉得有什么问题吗……？」"

# game/Welcome Party.rpy:2074
translate chinese_simplified sit_with_juuichi_eb8f9a78:

    # "Uh-oh, might be digging my own grave here."
    # NOTE: ks无对应，直译
    "糟糕，可能会弄巧成拙。"

# game/Welcome Party.rpy:2075
translate chinese_simplified sit_with_juuichi_64930f10:

    # fn "「Err, well, you see,\n \ I was thinking that...{p} \ your facial expressions don't seem too happy. 」"
    # NOTE: ks无对应，直译
    fn "「那个，嗯，怎么说呢，\n \ 我在想……{p} \ 你的表情看起来不太高兴。」"

# game/Welcome Party.rpy:2079
translate chinese_simplified sit_with_juuichi_08a2ca10:

    # ju "「...Hm, really? 」"
    # NOTE: ks无对应，直译
    ju "「……嗯，真的吗？」"

# game/Welcome Party.rpy:2080
translate chinese_simplified sit_with_juuichi_732558e8:

    # "Juuichi-san's head tilts in contemplation."
    # NOTE: ks无对应，直译
    "十一歪着头若有所思。"

# game/Welcome Party.rpy:2081
translate chinese_simplified sit_with_juuichi_58574792:

    # "Kyouji-senpai,\nwho was in front of us talking to Soutarou-kun,\nsuddenly joins in on our conversation."
    # NOTE: ks无对应，直译
    "正在前面和宗太郎聊天的\n京二前辈，\n突然加入了我们的对话。"

# game/Welcome Party.rpy:2085
translate chinese_simplified sit_with_juuichi_3ebf37ea:

    # ky "「Oh, Mikazuki is always like that.{p} \ Don't worry about him, [fn]. 」"
    # NOTE: ks无对应，直译
    ky "「哦，三月一向如此。{p} \ 别担心他，[fn]。」"

# game/Welcome Party.rpy:2089
translate chinese_simplified sit_with_juuichi_fda71633:

    # ju "「...Hey, what do you mean by that? 」"
    # NOTE: ks无对应，直译
    ju "「……喂，你什么意思？」"

# game/Welcome Party.rpy:2090
translate chinese_simplified sit_with_juuichi_08a7baf4:

    # ky "「It's nothing.{p} \ You should just work on improving your...{p} \ social graces, is all. 」"
    # NOTE: ks无对应，直译
    ky "「没什么。{p} \ 你只是应该多注意改善你的……{p} \ 社交能力，仅此而已。」"

# game/Welcome Party.rpy:2091
translate chinese_simplified sit_with_juuichi_94742943:

    # ky "「With that sour look,\n \ anybody would think you're not in a good mood. 」"
    # NOTE: ks无对应，直译
    ky "「就那张臭脸，\n \ 谁都会觉得你现在心情不好吧。」"

# game/Welcome Party.rpy:2092
translate chinese_simplified sit_with_juuichi_cc243a46:

    # "..I didn't say a word,\nhow did he know what I was thinking?"
    # NOTE: ks无对应，直译
    "……我一句话都没说，\n他是怎么知道我在想什么的？"

# game/Welcome Party.rpy:2093
translate chinese_simplified sit_with_juuichi_37a81fc1:

    # "And he was just talking to Soutarou-kun,\nbut he heard our conversation too."
    # NOTE: ks无对应，直译
    "而且他明明在和宗太郎说话，\n却也听到了我们的对话。"

# game/Welcome Party.rpy:2094
translate chinese_simplified sit_with_juuichi_13c32fb6:

    # "Kyouji-senpai's evil, I mean, err...{p}observant eyes are frightening."
    # NOTE: ks无对应，直译
    "京二前辈真是恶魔般……不对，是说……{p}洞察力敏锐的眼睛真可怕。"

# game/Welcome Party.rpy:2095
translate chinese_simplified sit_with_juuichi_45a6f42c:

    # ky "「Didn't you make a child cry the other day? 」"
    # NOTE: ks无对应，直译
    ky "「你不是前几天把小孩子弄哭了吗？」"

# game/Welcome Party.rpy:2099
translate chinese_simplified sit_with_juuichi_54f45c63:

    # ju "「...You saw that? 」"
    # NOTE: ks无对应，直译
    ju "「……你看到了？」"

# game/Welcome Party.rpy:2100
translate chinese_simplified sit_with_juuichi_3e325dfe:

    # ky "「I just happened to be passing by. 」"
    # NOTE: ks无对应，直译
    ky "「我只是刚好路过而已。」"

# game/Welcome Party.rpy:2101
translate chinese_simplified sit_with_juuichi_186fb70e:

    # "Not only does Juuichi-san have a stern face,\nbut he's pretty tall as well."
    # NOTE: ks无对应，直译
    "十一不仅有一张严厉的脸，\n而且还相当高。"

# game/Welcome Party.rpy:2102
translate chinese_simplified sit_with_juuichi_06530a84:

    # "Tatsu-nii has him beat,\nbut he's has to still be around 2 meters."
    # NOTE: ks无对应，直译
    "虽然龙兄比他高，\n但他也差不多有两米左右吧。"

# game/Welcome Party.rpy:2103
translate chinese_simplified sit_with_juuichi_ba80d2b3:

    # "...I'm only average,\nbut I'm not envious about what Kyouji-senpai said."
    # NOTE: ks无对应，直译
    "……我只是普通身高，\n但对京二前辈说的话并不羡慕。"

# game/Welcome Party.rpy:2104
translate chinese_simplified sit_with_juuichi_959df683:

    # "Even if I had a body like that,\nI wouldn't want to scare small children."
    # NOTE: ks无对应，直译
    "就算我也有那样的身材，\n也不想吓哭小孩子。"

# game/Welcome Party.rpy:2105
translate chinese_simplified sit_with_juuichi_10aaa221:

    # "His voice is also lower than I remember it."
    # NOTE: ks无对应，直译
    "他的声音也比记忆中的要低沉。"

# game/Welcome Party.rpy:2109
translate chinese_simplified sit_with_juuichi_9087134d:

    # ju "「[ln]...{p} \ does it really look like I'm in...{p} \ a bad mood? 」"
    # NOTE: ks无对应，直译
    ju "「[ln]……{p} \ 我看起来真的像……{p} \ 心情不好吗？」"

# game/Welcome Party.rpy:2110
translate chinese_simplified sit_with_juuichi_ba81f40a:

    # fn "「...Well, yeah. 」"
    # NOTE: ks无对应，直译
    fn "「……嗯，是啊。」"

# game/Welcome Party.rpy:2111
translate chinese_simplified sit_with_juuichi_b084a082:

    # "Well, there's no use hiding it.{p}I nod to Juuichi-san's words."
    # NOTE: ks无对应，直译
    "嗯，藏着掖着也没用。{p}我点头回应十一的话。"

# game/Welcome Party.rpy:2112
translate chinese_simplified sit_with_juuichi_94f1aab5:

    # ju "「...I see. You worry about me too much.{p} \ It's a bad habit, I'll try to fix it... 」"
    # NOTE: ks无对应，直译
    ju "「……这样啊。你太担心我了。{p} \ 这是个坏习惯，我会努力改的……」"

# game/Welcome Party.rpy:2113
translate chinese_simplified sit_with_juuichi_2ba46b56:

    # ky "「Incidentally,\n \ he's actually in a good mood today. 」"
    # NOTE: ks无对应，直译
    ky "「说起来，\n \ 他今天其实心情挺好的。」"

# game/Welcome Party.rpy:2114
translate chinese_simplified sit_with_juuichi_c0c81785:

    # "...What, with that kind of face!?{p}The words in my head almost slip out,\nbut I frantically swallow them."
    # NOTE: ks无对应，直译
    "……什么，就那张脸！？{p}我脑子里的话差点脱口而出，\n但还是拼命咽了回去。"

# game/Welcome Party.rpy:2115
translate chinese_simplified sit_with_juuichi_6f95842f:

    # ky "「Actually, he's like you, [fn].{p} \ When Mikazuki's emotions change,\n \ I can notice it immediately. 」"
    # NOTE: ks无对应，直译
    ky "「其实他和一样，[fn]。{p} \ 三月的情绪一有变化，\n \ 我就能立刻察觉到。」"

# game/Welcome Party.rpy:2116
translate chinese_simplified sit_with_juuichi_2fb14215:

    # ky "「In other words,\n \ His behavior is easy to understand. 」"
    # NOTE: ks无对应，直译
    ky "「换句话说，\n \ 他的行为很容易理解。」"

# game/Welcome Party.rpy:2117
translate chinese_simplified sit_with_juuichi_8ea2b363:

    # fn "「I-I see... 」"
    # NOTE: ks无对应，直译
    fn "「原……原来如此……」"

# game/Welcome Party.rpy:2118
translate chinese_simplified sit_with_juuichi_2101a4dc:

    # "I steal a glance at his face,\nit's still as stern as it was before.{p}Is he really in a good mood...?"
    # NOTE: ks无对应，直译
    "我偷偷瞥了一眼他的脸，\n还是和之前一样严厉。{p}他真的心情好吗……？"

# game/Welcome Party.rpy:2119
translate chinese_simplified sit_with_juuichi_649b5b46:

    # ju "「If you ask me,\n \ Takahara is the one who's,\n \ \"hard to understand.\" 」"
    # NOTE: ks无对应，直译
    ju "「要我说的话，\n \ 高原才是那个\n \ \"难以理解\"的人。」"

# game/Welcome Party.rpy:2120
translate chinese_simplified sit_with_juuichi_386fca3d:

    # "Juuichi-san mutters,\nwhile getting a small plate of meat."
    # NOTE: ks无对应，直译
    "十一一边嘀咕着，\n一边拿了一小盘肉。"

# game/Welcome Party.rpy:2121
translate chinese_simplified sit_with_juuichi_596eb654:

    # ky "「Hahaha! 」"
    # NOTE: ks无对应，直译
    ky "「哈哈哈！」"

# game/Welcome Party.rpy:2122
translate chinese_simplified sit_with_juuichi_21b9a094:

    # "Kyouji-senpai laughs a little.{p}Juuichi-san gives a bitter smile."
    # NOTE: ks无对应，直译
    "京二前辈笑了一点。{p}十一露出苦笑。"

# game/Welcome Party.rpy:2123
translate chinese_simplified sit_with_juuichi_8f874576:

    # "It seems like the two are good friends.{p}Pretty sure they're the same age, too.{p}They probably do things together on a daily basis."
    # NOTE: ks无对应，直译
    "这两个人看起来很要好。{p}应该还是同龄人吧。{p}可能每天都会一起行动。"

# game/Welcome Party.rpy:2124
translate chinese_simplified sit_with_juuichi_e775346c:

    # ju "「Here's your portion, [fn]. 」"
    # NOTE: ks无对应，直译
    ju "「这是你的那份，[fn]。」"

# game/Welcome Party.rpy:2125
translate chinese_simplified sit_with_juuichi_a7062291:

    # "A small plate of food is placed in front of me.{p}Ah, this must be mine."
    # NOTE: ks无对应，直译
    "一小盘食物被放在了我面前。{p}啊，这一定是我的那份。"

# game/Welcome Party.rpy:2126
translate chinese_simplified sit_with_juuichi_d2aac32b:

    # "Juuichi-san expresses his gratitude,\nthen puts some meat into his mouth."
    # NOTE: ks无对应，直译
    "十一表达了感谢，\n然后往嘴里塞了一些肉。"

# game/Welcome Party.rpy:2127
translate chinese_simplified sit_with_juuichi_26900209:

    # "Oh, this is delicious.{p}The meat itself is pretty good,"
    # NOTE: ks无对应，直译
    "哦，真好吃。{p}肉本身就很好吃，"

# game/Welcome Party.rpy:2128
translate chinese_simplified sit_with_juuichi_b20b4385:

    # "but being surrounded by old friends,\nonly makes it better."
    # NOTE: ks无对应，直译
    "再加上被老朋友们环绕，\n味道更好了。"

# game/Welcome Party.rpy:2129
translate chinese_simplified sit_with_juuichi_99339930:

    # "While thinking, I leisurely eat."
    # NOTE: ks无对应，直译
    "一边想着，一边悠闲地吃着。"

# game/Welcome Party.rpy:2130
translate chinese_simplified sit_with_juuichi_b9908887:

    # "Hey!{p}I'm still unfinished,\nbut there's more meat!"
    # NOTE: ks无对应，直译
    "嘿！{p}我还没吃完呢，\n又有更多的肉上来了！"

# game/Welcome Party.rpy:2134
translate chinese_simplified sit_with_juuichi_47d91c28:

    # su "「[fn]-san, please have some! 」"
    # NOTE: ks无对应，直译
    su "「[fn]先生，请用！」"

# game/Welcome Party.rpy:2135
translate chinese_simplified sit_with_juuichi_0e8febe0:

    # "Shun-kun politely holds out another serving for me.{p}Of course he's providing this service with a smile.{p}I can't refuse, so I say thanks and take it."
    # NOTE: ks无对应，直译
    "小瞬礼貌地又给我递了一份。{p}他当然是带着微笑服务的。{p}无法拒绝，我道了谢然后收下了。"

# game/Welcome Party.rpy:2139
translate chinese_simplified sit_with_juuichi_72fb3b92:

    # so "「Senpai, you have some, too! 」"
    # NOTE: ks无对应，直译
    so "「前辈，你也吃啊！」"

# game/Welcome Party.rpy:2140
translate chinese_simplified sit_with_juuichi_5889d9f1:

    # "Every time Shun-kun serves something,\nSoutarou-kun does the same.{p}...Is this like an infinite loop"
    # NOTE: ks无对应，直译
    "每当小瞬递东西，\n宗太郎也会跟着做。{p}……这该不会是无限循环吧"

# game/Welcome Party.rpy:2141
translate chinese_simplified sit_with_juuichi_28dab296:

    # "Well, for now I'll just concentrate on eating.{p}All I'll think about is the piles of meat,\nlining up in front of me."
    # NOTE: ks无对应，直译
    "嘛，现在还是专心吃吧。{p}脑子里只想着一件事，\n就是面前堆成山的肉。"

# game/Welcome Party.rpy:2152
translate chinese_simplified sit_with_shun_50d82d06:

    # "With orange juice in front of him,\nShun-kun is perched on his chair.{p}Suddenly, I feel as if I'm back in those days."
    # NOTE: ks无对应，直译
    "小瞬面前放着橙汁，\n坐在椅子上。{p}突然，我有种回到了那时候的感觉。"

# game/Welcome Party.rpy:2153
translate chinese_simplified sit_with_shun_6689ab3c:

    # fn "「Is it okay if I sit next to you? 」"
    # NOTE: ks无对应，直译
    fn "「我坐你旁边可以吗？」"

# game/Welcome Party.rpy:2157
translate chinese_simplified sit_with_shun_2d498478:

    # su "「[fn]-san! Of course it is. 」"
    # NOTE: ks无对应，直译
    su "「[fn]先生！当然可以。」"

# game/Welcome Party.rpy:2158
translate chinese_simplified sit_with_shun_ed7af7a9:

    # "This wolf with big round eyes,\nhe's my childhood friend Shun Kodori.{p}He greets me with a brilliant smile."
    # NOTE: ks无对应，直译
    "这只有着圆圆大眼睛的狼，\n是我的青梅竹马小瞬洸。{p}他用灿烂的笑容跟我打招呼。"

# game/Welcome Party.rpy:2162
translate chinese_simplified sit_with_shun_35fd3cc8:

    # su "「...Hehe. 」"
    # NOTE: ks无对应，直译
    su "「……嘿嘿。」"

# game/Welcome Party.rpy:2163
translate chinese_simplified sit_with_shun_61ad30c9:

    # "His chopsticks and meat are flying about,\nit almost looks like a battleground around him.{p}...Hmm, should I start eating?"
    # NOTE: ks无对应，直译
    "他的筷子和肉飞来飞去，\n他周围简直像战场一样。{p}……嗯，我是不是也该开始吃了？"

# game/Welcome Party.rpy:2164
translate chinese_simplified sit_with_shun_3ed764ac:

    # fn "「Shun-kun? Here,\n \ did you lose some of your meat? 」"
    # NOTE: ks无对应，直译
    fn "「小瞬？喂，\n \ 你是掉了肉吗？」"

# game/Welcome Party.rpy:2172
translate chinese_simplified sit_with_shun_337c633b:

    # su "「Ah, thanks! Hehe. 」"
    # NOTE: ks无对应，直译
    su "「啊，谢谢！嘿嘿。」"

# game/Welcome Party.rpy:2176
translate chinese_simplified sit_with_shun_f0efcf11:

    # su "「You came back, I'm so happy!{p} \ Everybody's glad... I am too. 」"
    # NOTE: ks无对应，直译
    su "「你回来了，我好开心！{p} \ 大家都很高兴……我也是。」"

# game/Welcome Party.rpy:2177
translate chinese_simplified sit_with_shun_3960dbe5:

    # fn "「R-really? I feel kind of awkward...{p} \ Here, you eat too. 」"
    # NOTE: ks无对应，直译
    fn "「真……真的吗？有点不好意思……{p} \ 来，你也吃。」"

# game/Welcome Party.rpy:2178
translate chinese_simplified sit_with_shun_68ff2047:

    # su "「Okay! 」"
    # NOTE: ks无对应，直译
    su "「好！」"

# game/Welcome Party.rpy:2182
translate chinese_simplified sit_with_shun_43864755:

    # "He nods his head,\nthen picks up his chopsticks and bowl."
    # NOTE: ks无对应，直译
    "他点了点头，\n然后拿起了筷子和碗。"

# game/Welcome Party.rpy:2183
translate chinese_simplified sit_with_shun_9a17d093:

    # "While asking a hectic barrage of questions,\nShun-kun watches my every move."
    # NOTE: ks无对应，直译
    "一边问着连珠炮般的问题，\n小瞬一边注视着我的每一个动作。"

# game/Welcome Party.rpy:2184
translate chinese_simplified sit_with_shun_9dbc5f36:

    # "Nom.{p}Munch-munch.{p}Gulp."
    # NOTE: ks无对应，直译
    "吃。{p}嚼嚼嚼。{p}咕。"

# game/Welcome Party.rpy:2188
translate chinese_simplified sit_with_shun_b1b02d1d:

    # su "「Really? 」"
    # NOTE: ks无对应，直译
    su "「真的吗？」"

# game/Welcome Party.rpy:2192
translate chinese_simplified sit_with_shun_9dbc5f36_1:

    # "Nom.{p}Munch-munch.{p}Gulp."
    # NOTE: ks无对应，直译
    "吃。{p}嚼嚼嚼。{p}咕。"

# game/Welcome Party.rpy:2196
translate chinese_simplified sit_with_shun_82a0e852:

    # su "「I don't have that. 」"
    # NOTE: ks无对应，直译
    su "「我没有那个。」"

# game/Welcome Party.rpy:2200
translate chinese_simplified sit_with_shun_7bfd7b13:

    # "He swallows a big mouthful,\nthen continues talking."
    # NOTE: ks无对应，直译
    "他大口吞下，\n然后继续说话。"

# game/Welcome Party.rpy:2201
translate chinese_simplified sit_with_shun_66961307:

    # "A big mouthful again,\nthen the same as before.{p}Somtimes I can't keep up with the conversation."
    # NOTE: ks无对应，直译
    "又是大口，\n然后和之前一样。{p}有时候我跟不上对话的节奏。"

# game/Welcome Party.rpy:2202
translate chinese_simplified sit_with_shun_09c2115a:

    # "He doesn't have very good manners,\nmaybe I should teach him some."
    # NOTE: ks无对应，直译
    "他吃相不太好看，\n也许我该教教他。"

# game/Welcome Party.rpy:2203
translate chinese_simplified sit_with_shun_a9154256:

    # "There's a difference between how he eats,\nand how everyone else does."
    # NOTE: ks无对应，直译
    "他吃的样子和其他人完全不一样。"

# game/Welcome Party.rpy:2204
translate chinese_simplified sit_with_shun_bb384860:

    # "I'd like to to tell him how to carry his food,\nor how to evenly break his chopsticks."
    # NOTE: ks无对应，直译
    "我想教教他怎么夹菜，\n还有怎么整齐地掰开筷子。"

# game/Welcome Party.rpy:2208
translate chinese_simplified sit_with_shun_ee61e441:

    # su "「Ah, [fn]-san,\n \ a grain of rice. 」"
    # NOTE: ks无对应，直译
    su "「啊，[fn]先生，\n \ 一粒米饭。」"

# game/Welcome Party.rpy:2209
translate chinese_simplified sit_with_shun_0ebd19ac:

    # fn "「Hm? 」"
    # NOTE: ks无对应，直译
    fn "「嗯？」"

# game/Welcome Party.rpy:2210
translate chinese_simplified sit_with_shun_2206a2cf:

    # "Shun-kun gently sets his dish down,\nstretches his hand out to my cheek,\nand picks up the rice with his finger."
    # NOTE: ks无对应，直译
    "小瞬轻轻放下盘子，\n伸出手到我的脸颊边，\n用手指捡起了那粒米饭。"

# game/Welcome Party.rpy:2214
translate chinese_simplified sit_with_shun_a2f50b00:

    # "He wraps it in a nearby napkin."
    # NOTE: ks无对应，直译
    "他用旁边的纸巾把它包了起来。"

# game/Welcome Party.rpy:2215
translate chinese_simplified sit_with_shun_6f02cf81:

    # "I felt a little humiliated.{p}\"Oh, it's not a big deal.\" he says.{p}Well, if he says so."
    # NOTE: ks无对应，直译
    "我有点丢脸的感觉。{p}\"哦，没什么大不了的。\"他说道。{p}嘛，他都这么说了。"

# game/Welcome Party.rpy:2216
translate chinese_simplified sit_with_shun_a4244732:

    # "Should I have just licked it off?"
    # NOTE: ks无对应，直译
    "我是不是该直接舔掉算了？"

# game/Welcome Party.rpy:2220
translate chinese_simplified sit_with_shun_92ce234e:

    # su "「[fn]-san, you've gotten so much bigger! 」"
    # NOTE: ks无对应，直译
    su "「[fn]先生，你长大了好多啊！」"

# game/Welcome Party.rpy:2221
translate chinese_simplified sit_with_shun_9ace05a7:

    # fn "「You think so?{p} \ Shun-kun, you've... 」"
    # NOTE: ks无对应，直译
    fn "「是吗？{p} \ 小瞬，你……」"

# game/Welcome Party.rpy:2225
translate chinese_simplified sit_with_shun_8a810275:

    # "I take a good look at him.{p}From head to toe,\nno matter how hard I try to convince myself,"
    # NOTE: ks无对应，直译
    "我好好打量了他一番。{p}从头到脚，\n不管怎么说服自己，"

# game/Welcome Party.rpy:2226
translate chinese_simplified sit_with_shun_d1155757:

    # "Shun-kun just hasn't changed that much."
    # NOTE: ks无对应，直译
    "小瞬真的没怎么变。"

# game/Welcome Party.rpy:2227
translate chinese_simplified sit_with_shun_b8d51501:

    # fn "「Shun-kun, I guess you're growing...? 」"
    # NOTE: ks无对应，直译
    fn "「小瞬，你是在长身体吗……？」"

# game/Welcome Party.rpy:2228
translate chinese_simplified sit_with_shun_9ccb2ffc:

    # "I try to make my words vague."
    # NOTE: ks无对应，直译
    "我尽量说得委婉一些。"

# game/Welcome Party.rpy:2232
translate chinese_simplified sit_with_shun_ff06dbe9:

    # su "「That makes me happy,\n \ not a lot of people say that to me. 」"
    # NOTE: ks无对应，直译
    su "「这让我很开心，\n \ 不太有人这么对我说。」"

# game/Welcome Party.rpy:2233
translate chinese_simplified sit_with_shun_3f7eb4bf:

    # "It's been 5 years,\nI wonder if anybody's said something about...{p}his height as well."
    # NOTE: ks无对应，直译
    "已经5年了，\n不知道有没有人说过……{p}关于他的身高的事。"

# game/Welcome Party.rpy:2237
translate chinese_simplified sit_with_shun_f69c0de4:

    # "The party goes on.{p}The sound of this familiar hustle and bustle,\nit tickles my ears."
    # NOTE: ks无对应，直译
    "派对继续着。{p}这熟悉的喧闹声，\n撩动着我的耳畔。"

# game/Welcome Party.rpy:2238
translate chinese_simplified sit_with_shun_b4b73504:

    # "I had no choice but to loosen my cheeks.{p}Time stopped, then started.{p}That's what it feels like."
    # NOTE: ks无对应，直译
    "我不禁放松了脸颊。{p}时间仿佛静止，又重新流动。{p}就是这种感觉。"

# game/Welcome Party.rpy:2239
translate chinese_simplified sit_with_shun_d3299059:

    # "Has Shun-kun really not gotten any taller...?"
    # NOTE: ks无对应，直译
    "小瞬真的没有长高吗……？"

# game/Welcome Party.rpy:2248
translate chinese_simplified sit_with_shin_229961ba:

    # fn "「Is it all right if I sit next to you? 」"
    # NOTE: ks无对应，直译
    fn "「我坐你旁边可以吗？」"

# game/Welcome Party.rpy:2252
translate chinese_simplified sit_with_shin_04e16874:

    # si "「...Go ahead. 」"
    # NOTE: ks无对应，直译
    si "「……坐吧。」"

# game/Welcome Party.rpy:2253
translate chinese_simplified sit_with_shin_de0e0ed4:

    # "His reply is half-hearted,\nbut it's not to the point of being unsocial."
    # NOTE: ks无对应，直译
    "他的回答有些敷衍，\n但还不至于到不合群的地步。"

# game/Welcome Party.rpy:2254
translate chinese_simplified sit_with_shin_35d8952e:

    # "This is my childhood friend speaking like this,\nbut I'd feel uncomfortable if it was anyone else."
    # NOTE: ks无对应，直译
    "这是我的青梅竹马在说话，\n但如果换作别人我肯定会很不自在。"

# game/Welcome Party.rpy:2258
translate chinese_simplified sit_with_shin_8ad1f6d0:

    # ka "「Shin, are you like, anxious or something? 」"
    # NOTE: ks无对应，直译
    ka "「心，你怎么了，紧张吗？」"

# game/Welcome Party.rpy:2259
translate chinese_simplified sit_with_shin_4e2aa2ec:

    # si "「Not particularly... 」"
    # NOTE: ks无对应，直译
    si "「没什么……」"

# game/Welcome Party.rpy:2263
translate chinese_simplified sit_with_shin_146fcfe3:

    # ka "「Yeah, you're saying that, but...{p} \ you got here even earlier than I did.{p} \ Isn't there something you wanted to say to him? 」"
    # NOTE: ks无对应，直译
    ka "「你说得倒轻巧……{p} \ 但你来得比我还早啊。{p} \ 是不是有什么想跟他说的？」"

# game/Welcome Party.rpy:2264
translate chinese_simplified sit_with_shin_3df965c4:

    # fn "「Huh? Is that true? 」"
    # NOTE: ks无对应，直译
    fn "「诶？是真的吗？」"

# game/Welcome Party.rpy:2265
translate chinese_simplified sit_with_shin_9278a85b:

    # ka "「Yeah. 」"
    # NOTE: ks无对应，直译
    ka "「嗯。」"

# game/Welcome Party.rpy:2266
translate chinese_simplified sit_with_shin_b3cfa8db:

    # si "「I just didn't want to be late.{p} \ So I got here ahead of time. 」"
    # NOTE: ks无对应，直译
    si "「我只是不想迟到而已。{p} \ 所以就早到了一点。」"

# game/Welcome Party.rpy:2270
translate chinese_simplified sit_with_shin_f1e653d5:

    # ka "「Is that really it? 」"
    # NOTE: ks无对应，直译
    ka "「真的是这样吗？」"

# game/Welcome Party.rpy:2274
translate chinese_simplified sit_with_shin_ef470178:

    # ko "「Hah, doubt it. 」"
    # 无直接对应（直译）
    ko "「哈，我才不信。」"

# game/Welcome Party.rpy:2278
translate chinese_simplified sit_with_shin_583fa551:

    # si "「... 」"
    # 无直接对应（直译）
    si "「……」"

# game/Welcome Party.rpy:2279
translate chinese_simplified sit_with_shin_45e8259b:

    # "Kounosuke cuts in from the side.{p}Shin-kun tries to keep his cool.{p}His cheeks are red, is he embarrassed?"
    # KS:3697-3699（符合）
    "孝之助也从旁插嘴，{p}深君不高兴地闭上了嘴。{p}脸颊微微发红，难道是害羞了？"

# game/Welcome Party.rpy:2280
translate chinese_simplified sit_with_shin_052b203a:

    # "Come to think of it,\nShin-kun was never a very social person.{p}I see what's going on here."
    # KS:3701-3702（符合）
    "说起来，深君从以前开始就很不擅长与人相处。{p}原来如此，确实是这样呢。"

# game/Welcome Party.rpy:2281
translate chinese_simplified sit_with_shin_9015f594:

    # fn "「Shin-kun, have you been thinking about me? 」"
    # KS:3705-3706（符合）
    fn "「深君～。就这么挂念着我吗？」"

# game/Welcome Party.rpy:2282
translate chinese_simplified sit_with_shin_80514554:

    # "I tease him a little,\nand put my hand on his shoulder.{p}A little fooling around will brighten the mood."
    # 无直接对应（直译）
    "稍微逗弄他一下，{p}把手搭在他的肩上。{p}稍微打打闹闹，气氛也会轻松些。"

# game/Welcome Party.rpy:2286
translate chinese_simplified sit_with_shin_a5a86972:

    # si "「...It would be stupid...{p} \ for me to think about things like that. 」"
    # KS:3712（符合）
    si "「……别说那种蠢话好吗。」"

# game/Welcome Party.rpy:2287
translate chinese_simplified sit_with_shin_6bbab0f6:

    # "Guh!{p}As expected, my teasing has no effect."
    # KS:3717-3718（符合）
    "咕叭！{p}看来是使坏得有些过火了。"

# game/Welcome Party.rpy:2288
translate chinese_simplified sit_with_shin_7971e153:

    # "He roughly brushes my hand off his shoulder,\nand glances at me with a look of contempt.{p}I quickly look away from him."
    # KS:3720-3722（符合）
    "搭在他肩上的手，被粗暴地甩开了。{p}用鄙视的眼神瞪了我一眼，{p}深君就生气地把头别向一边了。"

# game/Welcome Party.rpy:2289
translate chinese_simplified sit_with_shin_36a0be59:

    # fn "「S-Shin-kun.{p} \ It was just a hand on the shoulder,\n \ I'm just messing with you. 」"
    # KS:3724-3727（符合）
    fn "「深、深君。{p} \ 只是想碰碰你而已……{p} \ 开玩笑而已……」"

# game/Welcome Party.rpy:2290
translate chinese_simplified sit_with_shin_aa71c890:

    # si "「I know. 」"
    # KS:3732（符合）
    si "「是么」"

# game/Welcome Party.rpy:2297
translate chinese_simplified sit_with_shin_746e6b96:

    # ko "「Uh-oh. 」"
    # KS:3741（符合）
    ko "「啊——啊」"

# game/Welcome Party.rpy:2301
translate chinese_simplified sit_with_shin_9772480b:

    # "Apparently, I've completely offended him.{p}Before I know it,\nKouya and Kounosuke withdraw from the conversation."
    # KS:3745-3747（符合）
    "看来，是完全地惹毛他了呢。{p}孝之助和洸哉也一副「我什么也不知道」的模样，回避开了。"

# game/Welcome Party.rpy:2302
translate chinese_simplified sit_with_shin_43af86e3:

    # "Tension arises between Shin-kun and me.{p}However, everyone else is asking me many questions.{p}Food and drink arrive at the same time."
    # KS:3751-3753（符合）
    "正在我和深君之间流动着这般微妙的气氛之时，{p}来自四面八方的询问向我袭来，{p}肉和饮料也跟着上来了。"

# game/Welcome Party.rpy:2303
translate chinese_simplified sit_with_shin_3f69680e:

    # "We didn't have to wait long,\nprobably because we've rented the place out."
    # KS:3755-3757（符合）
    "点了菜和饮品后不久，肉就已经摆了满桌，每个人也都拿到了自己点的饮料。"

# game/Welcome Party.rpy:2304
translate chinese_simplified sit_with_shin_6c8165f0:

    # "The meat is served to each table,\nand the drinks are served as well.{p}Then, Tatsu-nii stands up."
    # KS:3755+3759（符合）
    "肉已经摆了满桌，{p}每个人也都拿到了自己点的饮料。{p}辰兄看准时机，站了起来。"

# game/Welcome Party.rpy:2310
translate chinese_simplified sit_with_shin_e9f5f634:

    # ta "「So then, this time we're celebrating our reunion!{p} \ Cheers! 」"
    # KS:3768-3769（符合）
    ta "「诶，既然差不多齐了，为庆祝与[博行]的再会，{p} \ 干杯！」"

# game/Welcome Party.rpy:2311
translate chinese_simplified sit_with_shin_efed3345:

    # "{size=+30}「CHEERS! 」"
    # KS:3771（符合）
    "{size=+30}「干杯！」"

# game/Welcome Party.rpy:2317
translate chinese_simplified sit_with_shin_241ce3e1:

    # "With a beer in each hand,\nTatsu-nii raises them for a toast."
    # KS:3774-3776（符合）
    "随着辰兄举起啤酒，其他人也拿起自己的杯子，彼此干杯。{p}深君也低调地举起了蜜瓜苏打。"

# game/Welcome Party.rpy:2318
translate chinese_simplified sit_with_shin_ada30ca9:

    # "Shin-kun is a little more conservative.{p}He raises his melon soda."
    # KS:3776（符合）
    "深君则比较低调。{p}他举起了蜜瓜苏打。"

# game/Welcome Party.rpy:2322
translate chinese_simplified sit_with_shin_c44c3d8e:

    # ta "「Glug, glug, bwah! 」"
    # KS:3781（符合）
    ta "「咕嗯咕嗯，呼嘎！」"

# game/Welcome Party.rpy:2323
translate chinese_simplified sit_with_shin_1b4f1e41:

    # "Right after the toast,\nTatsu-nii chugs down both his drinks."
    # 无直接对应（直译）
    "干杯之后，辰兄一口气喝光了两杯酒。"

# game/Welcome Party.rpy:2327
translate chinese_simplified sit_with_shin_205f34b2:

    # ta "「[fn], hurry up and eat!{p} \ There's no need to hold back! 」"
    # KS:3787-3788（符合）
    ta "「[博行]也快吃啊！{p} \ 不要客气。」"

# game/Welcome Party.rpy:2328
translate chinese_simplified sit_with_shin_27cde776:

    # fn "「Yeah, I will. 」"
    # KS:3791（符合）
    fn "「嗯，好的。」"

# game/Welcome Party.rpy:2332
translate chinese_simplified sit_with_shin_c8f44083:

    # "While holding his alcohol with vigor,\nTatsu-nii throws some meat onto his plate."
    # 无直接对应（直译）
    "辰兄借着酒劲，兴奋地把肉也分铺到了铁板上。"

# game/Welcome Party.rpy:2333
translate chinese_simplified sit_with_shin_5be53839:

    # "The sizzle of cooking meat,\nand the smell of it as well,\ncarries itself throughout the restaurant."
    # 无直接对应（直译）
    "一瞬间，烤肉的声音和味道，在店中扩散开来。"

# game/Welcome Party.rpy:2334
translate chinese_simplified sit_with_shin_08146a58:

    # "Tatsu-nii grabs lumps of meat,\nwhile Shin-kun neatly takes pieces,\none by one."
    # 无直接对应（直译）
    "身边的深君把辰兄摆在上面的肉，一片片地分散排列开来。"

# game/Welcome Party.rpy:2335
translate chinese_simplified sit_with_shin_6f3a90b8:

    # "Enchanted by the smell and sound,\nmy stomach is already begging for some.{p}I decide to go for it."
    # KS:3801-3802（符合）
    "被肉的香味引诱起来，{p}我的肚子似乎一下子变得饿了起来。"

# game/Welcome Party.rpy:2339
translate chinese_simplified sit_with_shin_da2a8cb2:

    # si "「Wait, it hasn't cooked yet. 」"
    # KS:3807（符合）
    si "「那些，还没烤好。」"

# game/Welcome Party.rpy:2340
translate chinese_simplified sit_with_shin_ebfea1e7:

    # fn "「Huh? 」"
    # KS:3810（符合）
    fn "「诶？」"

# game/Welcome Party.rpy:2341
translate chinese_simplified sit_with_shin_e4f92f87:

    # si "「I turned it over a little bit ago.{p} \ This way it will cook slowly. 」"
    # KS:3815-3816（符合）
    si "「因为我才刚给翻过来。{p} \ 这边这些才是差不多烤好的。」"

# game/Welcome Party.rpy:2342
translate chinese_simplified sit_with_shin_aa47d18f:

    # fn "「Th-thanks. 」"
    # KS:3819（符合）
    fn "「呀，谢谢」"

# game/Welcome Party.rpy:2343
translate chinese_simplified sit_with_shin_2175c87c:

    # "He points to the meat as he explains.{p}It certainly is going to be cooked well,\nbut half my life will be gone before that."
    # 无直接对应（直译）
    "他指着肉解释着。{p}确实烤得相当不错了，{p}但对我来说，五成熟便好了。"

# game/Welcome Party.rpy:2344
translate chinese_simplified sit_with_shin_9be20ed5:

    # si "「Half a lifetime isn't good for digestion. 」"
    # KS:3826（符合）
    si "「五成熟对消化不好」"

# game/Welcome Party.rpy:2345
translate chinese_simplified sit_with_shin_88b88ef8:

    # "Shin-kun adds,\nas if he heard what I was saying in my head."
    # 无直接对应（直译）
    "似乎是听到了我小声的嘟嚷，{p}深君说了这么一句话。"

# game/Welcome Party.rpy:2346
translate chinese_simplified sit_with_shin_7dedbea0:

    # si "「Or would you rather have it medium rare? 」"
    # KS:3834（符合）
    si "「还是说，想吃四成熟的？」"

# game/Welcome Party.rpy:2347
translate chinese_simplified sit_with_shin_2a9d64c5:

    # fn "「No, I'd say well done would be better. 」"
    # KS:3837（符合）
    fn "「不是，我喜欢吃全熟的。」"

# game/Welcome Party.rpy:2348
translate chinese_simplified sit_with_shin_2cdd8098:

    # si "「All right then... 」"
    # KS:3840（符合）
    si "「是么」"

# game/Welcome Party.rpy:2349
translate chinese_simplified sit_with_shin_3d600cf3:

    # "After I say that,\nShin-kun returns to working on the meat."
    # 无直接对应（直译）
    "只是这样应答一句，深君又继续开始他的排肉工作了。"

# game/Welcome Party.rpy:2350
translate chinese_simplified sit_with_shin_1202aaa6:

    # fn "「Are you going to eat? 」"
    # KS:3845（符合）
    fn "「深君不吃么？」"

# game/Welcome Party.rpy:2351
translate chinese_simplified sit_with_shin_67707b1d:

    # si "「I will. 」"
    # KS:3850（符合）
    si "「吃」"

# game/Welcome Party.rpy:2352
translate chinese_simplified sit_with_shin_df0fdc1d:

    # "Although he says that,\nShin-kun has just been poking around with his food.{p}I haven't been able to get a plate for myself."
    # 无直接对应（直译）
    "虽然他这样说，{p}但是从刚才开始深君就一直只是在排列肉和菜而已，{p}完全没有把它们夹来自己吃的意思。"

# game/Welcome Party.rpy:2353
translate chinese_simplified sit_with_shin_715d2c52:

    # fn "「But it's been so long. 」"
    # 无直接对应（直译）
    fn "「不过，从刚才开始就一直……」"

# game/Welcome Party.rpy:2354
translate chinese_simplified sit_with_shin_b028a703:

    # si "「Hm? Oh. 」"
    # KS:3860（符合）
    si "「嗯？ 啊——」"

# game/Welcome Party.rpy:2355
translate chinese_simplified sit_with_shin_26768997:

    # "Without much reaction,\nShin-kun shifts from arranging his food to eating it.{p}Maybe he's still mad at me?"
    # 无直接对应（直译）
    "也根本没有什么反应，{p}深君继续排着肉。{p}完全不考虑自己的碟子。"

# game/Welcome Party.rpy:2356
translate chinese_simplified sit_with_shin_4c944285:

    # si "「Is something wrong?{p} \ It looks like you stopped moving your chopsticks. 」"
    # KS:3871（符合）
    si "「怎么了？{p} \ 你怎么不吃了。」"

# game/Welcome Party.rpy:2357
translate chinese_simplified sit_with_shin_4f259867:

    # fn "「N-no, it's nothing... 」"
    # 无直接对应（直译）
    fn "「不、不，没什么……」"

# game/Welcome Party.rpy:2358
translate chinese_simplified sit_with_shin_7221e9d1:

    # "I-I don't understand.{p}I really have no idea what he's thinking.{p}Is he not angry...?"
    # KS:3876-3878 无直接对应，直译
    "完全……搞不懂。{p}完全搞不懂他在想什么。{p}不是在生气么……？"

# game/Welcome Party.rpy:2362
translate chinese_simplified sit_with_shin_2d18f4bb:

    # ta "「Heeey, you!{p} \ Are you eating right? 」"
    # KS:3883
    ta "「喂，那边的。{p} \ 有好好的吃么——」"

# game/Welcome Party.rpy:2363
translate chinese_simplified sit_with_shin_e78b373a:

    # si "「Eh, err. Well... 」"
    # KS:3888-3889
    si "「诶，唉唉。{p} \ 嘛」"

# game/Welcome Party.rpy:2367
translate chinese_simplified sit_with_shin_84f890c5:

    # ta "「Hmm, w-what's the matter Shin?{p} \ You've been w-waiting so long for...{p} \ [fn] to be at y-your side, 」"
    # KS:3893-3894
    ta "「嗯嗯，这样可不行啊，深。{p} \ 难得他在你身边，可不能这么阴沉沉的。」"

# game/Welcome Party.rpy:2368
translate chinese_simplified sit_with_shin_250d07a9:

    # ta "「but you still look down. 」"
    # KS:3893-3894 无直接对应，直译
    ta "「不能这么阴沉沉的。」"

# game/Welcome Party.rpy:2370
translate chinese_simplified sit_with_shin_8d156def:

    # si "「It's nothing, this is how I usually am. 」"
    # KS:3900
    si "「没有，我很平常。」"

# game/Welcome Party.rpy:2374
translate chinese_simplified sit_with_shin_f1cd73cf:

    # ta "「I know you can be picky.{p} \ Go on. M-make sure you're eating right,\n \ and as much as y-ya can, too! 」"
    # KS:3905-3906
    ta "「而且你这家伙，又——偏食了。{p} \ 这可不行～～呐，什么都要多多地吃才对！」"

# game/Welcome Party.rpy:2375
translate chinese_simplified sit_with_shin_c2292078:

    # si "「Ah!? 」"
    # KS:3911-3912
    si "「啊！？」"

# game/Welcome Party.rpy:2379
translate chinese_simplified sit_with_shin_8762d7b7:

    # ta "「[fn], you should eat more v-veggies, too!{p} \ If you only e-eat meat you'll get fat. 」"
    # KS:3919-3920
    ta "「你也多吃一些蔬菜！{p} \ 光吃肉的话，可是会变胖的。」"

# game/Welcome Party.rpy:2380
translate chinese_simplified sit_with_shin_f12f230d:

    # "While saying that,\nTatsu-nii fills up my plate with veggies."
    # KS:3922
    "辰兄一边这样说，一边不由分说地夹了一堆蔬菜到我的盘子里。"

# game/Welcome Party.rpy:2384
translate chinese_simplified sit_with_shin_b4e95277:

    # ta "「Hey, little kids!{p} \ Are you eating right? 」"
    # KS:3927
    ta "「喂～。{p} \ 小伙子们～。{p} \ 有好好地吃东西吗～」"

# game/Welcome Party.rpy:2385
translate chinese_simplified sit_with_shin_c88f3cca:

    # su "「Yes, I am. 」"
    # KS:3932
    su "「是——的～」"

# game/Welcome Party.rpy:2386
translate chinese_simplified sit_with_shin_f089970d:

    # ta "「You're not eating anything at all are you?{p} \ You're not g-going to grow at this rate! 」"
    # KS:3935-3936
    ta "「我看完全就没有吃啊～。{p} \ 就是因为这样，所以才一直长不大哦～」"

# game/Welcome Party.rpy:2387
translate chinese_simplified sit_with_shin_98063f13:

    # su "「Whawhawhawha!?{p} \ I-I can't eat that much! 」"
    # KS:3939
    su "「哈啊啊啊啊——！？{p} \ 那、那么多根本吃不完啦——！」"

# game/Welcome Party.rpy:2388
translate chinese_simplified sit_with_shin_2bd2111b:

    # so "「M-Midoriya-senpai!{p} \ There's no way I could eat all that! 」"
    # KS:3942-3943
    so "「翠、翠屋前辈！{p} \ 是不是有点儿太多了！」"

# game/Welcome Party.rpy:2389
translate chinese_simplified sit_with_shin_011631a2:

    # "H-he's completely drunk...{p}And keeps finding little games to get involved in."
    # KS:3945-3946 无直接对应，直译
    "完全喝高了吧，辰兄。{p}他又抓到新的「猎物」，然后纠缠不休起来。"

# game/Welcome Party.rpy:2390
translate chinese_simplified sit_with_shin_99acee6b:

    # "With a bitter smile on my face,\nI return to eating for the second time."
    # KS:3948-3949 无直接对应，直译
    "对于这种情景，一边苦笑着一边准备接着吃，{p}但是面对自己碟子里堆积如山的蔬菜，又不知道该如何是好。"

# game/Welcome Party.rpy:2391
translate chinese_simplified sit_with_shin_55291c9b:

    # "I can use my chopsticks again,\nnow that he stopped using them to get food."
    # KS:3951-3952 无直接对应，直译
    "肉已经放不进来了，{p}这些菜还不能放回去……。"

# game/Welcome Party.rpy:2392
translate chinese_simplified sit_with_shin_a5991ca1:

    # "I can't get to the meat like this.{p}Still, I don't want to return it..."
    # KS:3954 无直接对应，直译
    "肉已经放不进来了，{p}这些菜还不能放回去……。"

# game/Welcome Party.rpy:2393
translate chinese_simplified sit_with_shin_79bcfc81:

    # si "「[fn], wait. 」"
    # KS:3957
    si "「博行，来一下」"

# game/Welcome Party.rpy:2394
translate chinese_simplified sit_with_shin_465703d0:

    # "I think about asking someone for help,\nbut Shin-kun speaks out."
    # KS:3959-3960 无直接对应，直译
    "正考虑要不要向别人求助，{p}深君的声音响起来。"

# game/Welcome Party.rpy:2395
translate chinese_simplified sit_with_shin_f88ed2d1:

    # fn "「What's the matter? 」"
    # KS:3963
    fn "「怎么了？」"

# game/Welcome Party.rpy:2396
translate chinese_simplified sit_with_shin_312a0373:

    # si "「...You can have my meat. 」"
    # KS:3968
    si "「……这些肉，可以帮我吃掉么？」"

# game/Welcome Party.rpy:2397
translate chinese_simplified sit_with_shin_4f63700d:

    # fn "「Huh? Th-thanks, but why? 」"
    # KS:3971
    fn "「诶？{p} \ 倒是可以……不过，为什么？」"

# game/Welcome Party.rpy:2398
translate chinese_simplified sit_with_shin_f2349218:

    # "Shin-kun holds out his plate.{p}There's a sharp contrast between\nthe amount of meat on our plates."
    # KS:3973-3974 无直接对应，直译
    "深君递过来的碟子与我的形成了鲜明的对比，{p}堆满了肉。"

# game/Welcome Party.rpy:2399
translate chinese_simplified sit_with_shin_df1c63f7:

    # si "「I don't like beef.{p} \ It's too greasy... 」"
    # KS:3979
    si "「牛肉は、苦手なんだ。{p} \ 脂っこくて……」"

# game/Welcome Party.rpy:2400
translate chinese_simplified sit_with_shin_eac434a6:

    # "With him and his high class ways,\nI was expecting something like,"
    # KS:3981-3982 无直接对应，直译
    "本来还以为会说「便宜肉好难吃」之类的话呢，{p}没想到却是比想象要普通得多的这样一个回答。"

# game/Welcome Party.rpy:2401
translate chinese_simplified sit_with_shin_38d8158f:

    # "\"This cheap meat isn't suitable for me.\"{p}But his answer was surprisingly... Normal."
    # KS:3981-3982 无直接对应，直译
    "「这便宜肉我可吃不惯」之类的话呢，{p}没想到得到的回答却是意外地普通……。"

# game/Welcome Party.rpy:2402
translate chinese_simplified sit_with_shin_086db145:

    # "Come to think of it,\nShin-kun was eating meat a little bit ago."
    # KS:3984-3985 无直接对应，直译
    "说起来，从刚才开始，深君拿的肉貌似都是鸡肉呢，{p}难道和辰兄一样，有健康饮食的习惯？"

# game/Welcome Party.rpy:2403
translate chinese_simplified sit_with_shin_eb21e291:

    # "It was chicken, though.{p}Does he have the same nutritious, healthy,\neating habits as Tatsu-nii?"
    # KS:3984/3986 无直接对应，分开直译
    "说起来，从刚才开始，深君拿的肉貌似都是鸡肉呢。{p}难道和辰兄一样，有健康饮食的习惯？"

# game/Welcome Party.rpy:2404
translate chinese_simplified sit_with_shin_cf4431fe:

    # fn "「Would you like to switch with mine? 」"
    # KS:3988
    fn "「啊，那么的话，我也拜托你一件事可以么？」"

# game/Welcome Party.rpy:2405
translate chinese_simplified sit_with_shin_b5d0ae33:

    # si "「It doesn't matter. 」"
    # KS:3994
    si "「不介意。」"

# game/Welcome Party.rpy:2406
translate chinese_simplified sit_with_shin_1c6759e0:

    # "Yes!{p}Now that Tatsu-nii is bothering Torahiko,\nwe secretly swap plates."
    # KS:3996-3998 无直接对应，直译
    "太好了！{p}辰兄正在纠缠着那边的虎彦，{p}趁他没注意这边，偷偷地把碟子交换吧。"

# game/Welcome Party.rpy:2407
translate chinese_simplified sit_with_shin_64602ba5:

    # "It's yakiniku, so of course there should be meat.{p}But was forcing all of that on him... Rude?"
    # KS:4000-4001 无直接对应，直译
    "既然是烤肉，那就当然要多吃肉才行。{p}不过把蔬菜全给了深君……不会有点儿亏待他了吧？"

# game/Welcome Party.rpy:2408
translate chinese_simplified sit_with_shin_7fc83ff9:

    # "I check my thoughts with Shin-kun,\nbut he's already shoveling them into his mouth,\none after another."
    # KS:4003-4005 无直接对应，直译
    "一边这样想着，一边不安地望向深君，{p}看着他不断把蔬菜送到口中的侧脸，{p}似乎露出一种难以名状的高兴的模样。"

# game/Welcome Party.rpy:2409
translate chinese_simplified sit_with_shin_3bb4b5c4:

    # "I think he's almost smiling."
    # KS:4005 无直接对应，直译
    "似乎露出一种难以名状的高兴的模样。"

# game/Welcome Party.rpy:2413
translate chinese_simplified sit_with_shin_f348fcc4:

    # si "「Ah, onion... 」"
    # 无直接对应（直译）
    si "「啊，洋葱……」"

# game/Welcome Party.rpy:2414
translate chinese_simplified sit_with_shin_71d32d06:

    # "He stops his chopsticks.{p}The way he whispers to himself is... Funny."
    # 无直接对应（直译）
    "筷子突然停了下来，{p}轻声地说了这么一句，样子变得好生奇怪。"

# game/Welcome Party.rpy:2428
translate chinese_simplified sit_with_kounosuke_8ccf347a:

    # fn "「Kounosuke, is here all right? 」"
    # KS:4031（符合）
    fn "「孝之助，坐这里可以吗？」"

# game/Welcome Party.rpy:2432
translate chinese_simplified sit_with_kounosuke_33765553:

    # ko "「Go ahead, go ahead. 」"
    # KS:4036（符合）
    ko "「请坐请坐～」"

# game/Welcome Party.rpy:2433
translate chinese_simplified sit_with_kounosuke_b0fb96b3:

    # "Even though he says that,\nhe's stuffed in there."
    # 无直接对应（直译）
    "一边这样说着，孝之助一边向里面挤去。"

# game/Welcome Party.rpy:2437
translate chinese_simplified sit_with_kounosuke_24e4315f:

    # ju "「Kounosuke, there's not enough room. 」"
    # KS:4043（符合）
    ju "「孝之助，挤死了。」"

# game/Welcome Party.rpy:2441
translate chinese_simplified sit_with_kounosuke_950708fd:

    # ko "「Ah, sorry. 」"
    # KS:4048（符合）
    ko "「啊，抱歉。」"

# game/Welcome Party.rpy:2445
translate chinese_simplified sit_with_kounosuke_8aabbd81:

    # to "「Why are you going over there? 」"
    # KS:4053（符合）
    to "「为啥坐在那边啊？！」"

# game/Welcome Party.rpy:2446
translate chinese_simplified sit_with_kounosuke_5905efc5:

    # fn "「Well, it looked like there was space... 」"
    # KS:4056（符合）
    fn "「也没啥，就是看这边有空位……」"

# game/Welcome Party.rpy:2447
translate chinese_simplified sit_with_kounosuke_4c442517:

    # to "「If it wasn't so packed there would be. 」"
    # KS:4059（符合）
    to "「坐在我这边然后反过来往那边挤挤的话，也可以有空位的。」"

# game/Welcome Party.rpy:2451
translate chinese_simplified sit_with_kounosuke_35fcddf6:

    # ko "「You're being bossy, Torahiko.{p} \ He can sit wherever he wants,\n \ it's not a big deal. 」"
    # KS:4063-4064（符合）
    ko "「真的是，虎彦你好吵啊。{p} \ 这种事情怎样都无所谓吧，他喜欢坐哪就坐哪。」"

# game/Welcome Party.rpy:2452
translate chinese_simplified sit_with_kounosuke_4eedf3e1:

    # to "「Well yeah, but... 」"
    # KS:4067（符合）
    to "「嘛，话倒是这么说……」"

# game/Welcome Party.rpy:2453
translate chinese_simplified sit_with_kounosuke_1b1c2239:

    # "Now that I think about it,\nTorahiko did say he wanted to sit next to me,\nwhen he greeted me."
    # 无直接对应（直译）
    "这么说来，刚才虎彦好像有邀请我去他那边坐来的。{p}而且在车站接我的人也是他，{p}一定是非常期待与我的见面吧？"

# game/Welcome Party.rpy:2454
translate chinese_simplified sit_with_kounosuke_2e699aed:

    # "I guess he was really excited to see me..."
    # 无直接对应（直译）
    "如果真是这样的话，那还真是对不起他了。"

# game/Welcome Party.rpy:2455
translate chinese_simplified sit_with_kounosuke_7c336b3f:

    # "If that's the case, sorry Torahiko."
    # 无直接对应（直译）
    "如果真是这样的话，那还真是对不起他了。"

# game/Welcome Party.rpy:2460
translate chinese_simplified sit_with_kounosuke_1c9d4538:

    # ko "「By the way, [fn]... 」"
    # KS:4079（符合）
    ko "「话说哦，[博行]」"

# game/Welcome Party.rpy:2461
translate chinese_simplified sit_with_kounosuke_8f4993b4:

    # "Here it comes, I'm prepared for this.{p}That's why I sat here.{p}The assault of questions begins."
    # 无直接对应（直译）
    "来了。{p}早就有了这样的心理准备……{p}或者可以说，正是为了这个目的才选择坐在这里，{p}为了迎击孝之助的问题大轰炸。"

# game/Welcome Party.rpy:2462
translate chinese_simplified sit_with_kounosuke_5caff36e:

    # "I wanted to talk with everyone else,\nbut I was mostly answering his questions."
    # 无直接对应（直译）
    "我也虽然也想和大家说说话，{p}但是估计就算那样，也几乎都是孝之助抢问吧。"

# game/Welcome Party.rpy:2466
translate chinese_simplified sit_with_kounosuke_4940713f:

    # ta "「H-hey, guys, d-did you get something to drink? 」"
    # KS:4091（符合）
    ta "「喂，你们，要什么喝的东西吗？」"

# game/Welcome Party.rpy:2470
translate chinese_simplified sit_with_kounosuke_3a997cf6:

    # ko "「I have a Coke.{p} \ Anyway, let's continue... 」"
    # KS:4095-4096（符合）
    ko "「我要可乐。{p} \ 那么我们继续吧――」"

# game/Welcome Party.rpy:2474
translate chinese_simplified sit_with_kounosuke_50f56877:

    # ta "「Hey, hey, let h-him rest a bit.{p} \ You've been interrogating him for a while,\n \ haven't you? 」"
    # KS:4100-4101（符合）
    ta "「喂喂，稍微让博行喘口气啊。{p} \ 你刚才就一直在盘问他，是吗？」"

# game/Welcome Party.rpy:2478
translate chinese_simplified sit_with_kounosuke_d1becda8:

    # ko "「It's not like that!{p} \ Right [fn]? 」"
    # KS:4104-4105
    ko "「才不是，对吧？{p} \ 博行」"

# game/Welcome Party.rpy:2479
translate chinese_simplified sit_with_kounosuke_954b4cf9:

    # fn "「Err, I'd like to order something...{p} \ I think... 」"
    # KS:4108-4109
    fn "「呃——可以的话，我也想在被问个没完之前，点个喝的东西……{p} \ 我是这样想的……」"

# game/Welcome Party.rpy:2484
translate chinese_simplified sit_with_kounosuke_7565f71e:

    # ta "「I don't have all day. 」"
    # KS:4115
    ta "「看吧看吧。」"

# game/Welcome Party.rpy:2488
translate chinese_simplified sit_with_kounosuke_462bf7e2:

    # ko "「Hmm, sorry.{p} \ I didn't mean to do that. 」"
    # KS:4120-4121
    ko "「嗯——抱歉。{p} \ 其实我也没打算问个没完的……」"

# game/Welcome Party.rpy:2489
translate chinese_simplified sit_with_kounosuke_5a59f52b:

    # fn "「No, no, it's all right. 」"
    # KS:4123
    fn "「不，别在意。」"

# game/Welcome Party.rpy:2490
translate chinese_simplified sit_with_kounosuke_6d2c45d6:

    # "He doesn't mean any harm,\nbut he is a little obstinate.{p}Kounosuke really hasn't changed."
    # KS:4125-4126 无直接对应，直译
    "嘛，其实我知道他是没有恶意的，但是确实又让人束手无策。{p}还是老样子啊。孝之助。"

# game/Welcome Party.rpy:2494
translate chinese_simplified sit_with_kounosuke_4828d5fa:

    # "I ask for the oolong tea.{p}I was going to order some meat but,\nsince we've rented the place out,"
    # KS:4130-4132 无直接对应，直译
    "于是我点了乌龙茶来喝。{p}虽然也有想是否需要再加点些肉，{p}但是看到大家这扫荡一般的点菜，便作罢了。"

# game/Welcome Party.rpy:2495
translate chinese_simplified sit_with_kounosuke_57304349:

    # "everything's already ordered and set."
    # KS:4136 无直接对应，直译
    "厉害啊——这个是不是……某种梦想成真了？{p}以前好像幻想过有朝一日试着把烤肉店的每种菜品都点一遍。{p}没想到这个荒唐的想法居然在现在实现了，我可真是幸福。"

# game/Welcome Party.rpy:2496
translate chinese_simplified sit_with_kounosuke_c3ef31d2:

    # "Awesome, it's like a dream come true.{p}It's like ordering everything at a yakiniku stand.{p}It's every high schooler's dream, I'm happy."
    # KS:4136 无直接对应，直译
    "厉害啊——这个是不是……某种梦想成真了？{p}以前好像幻想过有朝一日试着把烤肉店的每种菜品都点一遍。{p}没想到这个荒唐的想法居然在现在实现了，我可真是幸福。"

# game/Welcome Party.rpy:2497
translate chinese_simplified sit_with_kounosuke_0f5ebaf4:

    # "Right when I order my drink,\nthe already prepared food is brought out.{p}Finally, each drink is raised for the toast."
    # KS:4138-4142 无直接对应，直译
    "点好喝的东西之后，{p}各种饮料和肉都接二连三地上来了。{p}最后大家都拿起了自己的杯子，干了杯。"

# game/Welcome Party.rpy:2498
translate chinese_simplified sit_with_kounosuke_efed3345:

    # "{size=+30}「CHEERS! 」"
    # KS:4142
    "{size=+30}「干杯——」"

# game/Welcome Party.rpy:2502
translate chinese_simplified sit_with_kounosuke_547be672:

    # "At that signal,\nthe aroma and sound of cooking meat spreads."
    # KS:4145-4146 无直接对应，直译
    "以此作为信号，烤肉的声音和香味，{p}在店内扩散开来。"

# game/Welcome Party.rpy:2503
translate chinese_simplified sit_with_kounosuke_34b8b6f8:

    # "I set out the meat the way I like it,\nthen wait for it to turn a good color."
    # KS:4148-4149 无直接对应，直译
    "我也适时地将肉摊开，{p}一边观察肉的颜色，一边伺机翻转。"

# game/Welcome Party.rpy:2509
translate chinese_simplified sit_with_kounosuke_d2363789:

    # ko "「[fn], could you pass the sauce? 」"
    # KS:4158
    ko "「博行，酱油拿过来好吗？」"

# game/Welcome Party.rpy:2510
translate chinese_simplified sit_with_kounosuke_1e609736:

    # fn "「Oh, sure. 」"
    # KS:4161
    fn "「啊，好」"

# game/Welcome Party.rpy:2514
translate chinese_simplified sit_with_kounosuke_14d03149:

    # ko "「Thanks. 」"
    # KS:4166
    ko "「谢啦」"

# game/Welcome Party.rpy:2515
translate chinese_simplified sit_with_kounosuke_ebfea1e7:

    # fn "「Huh? 」"
    # KS:4169
    fn "「咦？」"

# game/Welcome Party.rpy:2516
translate chinese_simplified sit_with_kounosuke_66f4b418:

    # "I pass the sauce and return my eyes to my plate.{p}My salted tongue has disappeared!"
    # KS:4171-4172 无直接对应，直译
    "把酱油递给孝之助之后，{p}我才才发现，刚才我重点烤制的盐舌居然没了。"

# game/Welcome Party.rpy:2520
translate chinese_simplified sit_with_kounosuke_c9ec38a9:

    # ko "「What's wrong? 」"
    # KS:4177
    ko "「怎么了？」"

# game/Welcome Party.rpy:2521
translate chinese_simplified sit_with_kounosuke_51334728:

    # fn "「My salted tongue is gone... 」"
    # KS:4180
    fn "「那个……我的盐舌……」"

# game/Welcome Party.rpy:2525
translate chinese_simplified sit_with_kounosuke_ed5f708b:

    # ko "「Was it the one right over there? 」"
    # KS:4184
    ko "「难道是刚才在那里的那个？」"

# game/Welcome Party.rpy:2526
translate chinese_simplified sit_with_kounosuke_c9528641:

    # fn "「...Yeah. 」"
    # KS:4187
    fn "「嗯」"

# game/Welcome Party.rpy:2530
translate chinese_simplified sit_with_kounosuke_78f30654:

    # ko "「Ah, sorry! I ate it... 」"
    # KS:4192
    ko "「啊，抱歉。{p} \ 我吃了。」"

# game/Welcome Party.rpy:2531
translate chinese_simplified sit_with_kounosuke_c4c2ffe6:

    # fn "「What!? 」"
    # KS:4195
    fn "「什么！」"

# game/Welcome Party.rpy:2532
translate chinese_simplified sit_with_kounosuke_8c844d67:

    # "He's saying that while eating some beef ribs."
    # KS:4197 无直接对应，直译
    "话说，他一边说着话，一边往嘴里送的那个肋肉不也是……"

# game/Welcome Party.rpy:2533
translate chinese_simplified sit_with_kounosuke_18df1760:

    # fn "「Aaaugh....{p} \ And I was the one who made it, too! 」"
    # KS:4200
    fn "「啊啊啊，那个也是我刚才重点烤制的！」"

# game/Welcome Party.rpy:2534
translate chinese_simplified sit_with_kounosuke_47430b09:

    # "I just turned it over not too long ago,\nso it still needed more time to cook."
    # KS:4202-4203 无直接对应，直译
    "而且刚刚才翻过一次而已，{p}明明另一边还没怎么烤过呢。"

# game/Welcome Party.rpy:2538
translate chinese_simplified sit_with_kounosuke_faf1de78:

    # ko "「Don't worry about something so small,\n \ we've still got plenty. 」"
    # KS:4208-4209
    ko "「这种小事就别放在心上嘛。{p} \ 反正还有很多咧。」"

# game/Welcome Party.rpy:2539
translate chinese_simplified sit_with_kounosuke_0792cf80:

    # ko "「Besides, when it comes to yakiniku,\n \ it's first-come-first-served.{p} \ Survival of the fittest. 」"
    # KS:4209 无直接对应，直译
    ko "「吃烤肉的时候，快者胜才是王道，弱肉强食嘛。」"

# game/Welcome Party.rpy:2540
translate chinese_simplified sit_with_kounosuke_a0e16d90:

    # fn "「Hmph. 」"
    # KS:4212
    fn "「咕」"

# game/Welcome Party.rpy:2541
translate chinese_simplified sit_with_kounosuke_6f4d53de:

    # "The world of yakiniku has harsh laws."
    # KS:4214 无直接对应，直译
    "这难道就是传说中的烤肉界的法则么。"

# game/Welcome Party.rpy:2545
translate chinese_simplified sit_with_kounosuke_e19a382b:

    # ko "「Hey, that's my wiener! 」"
    # KS:4219
    ko "「啊，我的维也纳肠！！」"

# game/Welcome Party.rpy:2546
translate chinese_simplified sit_with_kounosuke_6a4bc87e:

    # fn "「You're too soft, Kounosuke.{p} \ Yakiniku is survival of the fittest,\n \ after all. 」"
    # KS:4222-4223
    fn "「嘿嘿，太嫩了啊，孝之助。{p} \ 烤肉界是弱肉强食的哦。」"

# game/Welcome Party.rpy:2550
translate chinese_simplified sit_with_kounosuke_4de95821:

    # ko "「Hmph. 」"
    # KS:4228
    ko "「呜咕……」"

# game/Welcome Party.rpy:2551
translate chinese_simplified sit_with_kounosuke_6a534590:

    # fn "「Ah! My salted tongue!{p} \ That's two times now! 」"
    # KS:4231
    fn "「啊！我的盐舌！{p} \ 这可是第二块啦！！」"

# game/Welcome Party.rpy:2555
translate chinese_simplified sit_with_kounosuke_9fb35f51:

    # ko "「Survival of the fittest! 」"
    # KS:4236
    ko "「弱肉強食～」"

# game/Welcome Party.rpy:2559
translate chinese_simplified sit_with_kounosuke_801786cb:

    # ko "「Ah! You took my wiener again! 」"
    # KS:4241
    ko "「啊！{p} \ 维也纳肠又被抢走了！」"

# game/Welcome Party.rpy:2560
translate chinese_simplified sit_with_kounosuke_eb318be7:

    # fn "「Oh crap, I was aiming for that... 」"
    # KS:4246
    fn "「啊，可恶，明明盯上的是那一个的。」"

# game/Welcome Party.rpy:2564
translate chinese_simplified sit_with_kounosuke_25efb95a:

    # ko "「That's my sagari meat! 」"
    # KS:4250
    ko "「我的牛腹肉！」"

# game/Welcome Party.rpy:2565
translate chinese_simplified sit_with_kounosuke_c30ff545:

    # fn "「My salted tongue!{p} \ That's the third time! 」"
    # KS:4253
    fn "「不要啊！{p} \ 第三块盐舌了啊！」"

# game/Welcome Party.rpy:2569
translate chinese_simplified sit_with_kounosuke_87b9cff2:

    # ko "「Wiener get! 」"
    # KS:4257
    ko "「维也纳肠终于入手～」"

# game/Welcome Party.rpy:2570
translate chinese_simplified sit_with_kounosuke_ba18d180:

    # fn "「I got a salted tongue! 」"
    # KS:4260
    fn "「盐舌——GET！！」"

# game/Welcome Party.rpy:2575
translate chinese_simplified sit_with_kounosuke_6959125a:

    # si "「Can't you guys eat a little more quietly? 」"
    # KS:4266
    si "「你们不会安静地吃么？」"

# game/Welcome Party.rpy:2579
translate chinese_simplified sit_with_kounosuke_b01a1680:

    # su "「You guys have bad manners... 」"
    # KS:4271
    su "「真是……有点儿失礼呢。」"

# game/Welcome Party.rpy:2580
translate chinese_simplified sit_with_kounosuke_5b679af4:

    # "Kounosuke and I continued...{p}Our fierce yakiniku war waged on and on."
    # KS:4277-4278 无直接对应，直译
    "我与孝之助的烤肉夺还战，{p}就这样一直持续到了最后。"

# game/Welcome Party.rpy:2589
translate chinese_simplified sit_with_torahiko_ff0b1940:

    # "I decide to sit with Torahiko."
    # KS:4286 无直接对应，直译
    "我决定坐在虎彦旁边。"

# game/Welcome Party.rpy:2593
translate chinese_simplified sit_with_torahiko_2b441ef4:

    # to "「Oh, [fn]!{p} \ Over here! Over here! 」"
    # KS:4291
    to "「喂，博行！{p} \ 这边这边！」"

# game/Welcome Party.rpy:2594
translate chinese_simplified sit_with_torahiko_2c29da5d:

    # "Torahiko bangs on an empty seat,\nand cheerfully beckons me over."
    # KS:4293-4294 无直接对应，直译
    "虎彦空出了刚好可以坐一个人的位置，啪啪地敲打着。充满元气地向我招手。"

# game/Welcome Party.rpy:2595
translate chinese_simplified sit_with_torahiko_4db632ea:

    # fn "「Well then, excuse me. 」"
    # KS:4297
    fn "「那么，打扰了。」"

# game/Welcome Party.rpy:2599
translate chinese_simplified sit_with_torahiko_ce0aa67f:

    # to "「Heh heh, of course you'd sit next to me! 」"
    # KS:4301
    to "「嘿嘿，果然还是俺旁边最好了吧。」"

# game/Welcome Party.rpy:2600
translate chinese_simplified sit_with_torahiko_424e60d4:

    # "Torahiko rubs up on me, looks like he's happy.{p}He always loved physical contact,\nI can see that hasn't changed."
    # KS:4303-4304 无直接对应，直译
    "虎彦勾着我的肩膀，看起来心情似乎非常好。{p}喜欢通过身体接触来传达心意的习惯，还是和以前一样啊。"

# game/Welcome Party.rpy:2601
translate chinese_simplified sit_with_torahiko_b89beb54:

    # fn "「Stupid, there just happened to be a spot. 」"
    # KS:4307
    fn "「笨蛋，只是这里刚好空着而已。」"

# game/Welcome Party.rpy:2605
translate chinese_simplified sit_with_torahiko_c9be568a:

    # to "「Dahaha, you're just being shy!{p} \ I'll be the yakiniku magistrate,\n \ since you're the honored guest today! 」"
    # KS:4311-4312
    to "「哒～哈哈，嘛，不用害羞的！{p} \ 烤肉的重任就交给我了，因为今天的你是主宾哦！」"

# game/Welcome Party.rpy:2609
translate chinese_simplified sit_with_torahiko_016bd28f:

    # ju "「Don't burn it, or take it all for yourself. 」"
    # KS:4317
    ju "「能吃多少就烤多少，别自己一个人独自霸占。」"

# game/Welcome Party.rpy:2613
translate chinese_simplified sit_with_torahiko_83c2faee:

    # to "「You don't trust me, Senpai? 」"
    # KS:4321
    to "「前辈，你就这么不相信俺啊？」"

# game/Welcome Party.rpy:2614
translate chinese_simplified sit_with_torahiko_de18fbc8:

    # ju "「Yes, your gold-medal gluttony is a blight.{p} \ Not only on Minasato Village,\n \ but to the whole nation. 」"
    # KS:4330-4331
    ju "「那是当然，因为你是水乡村最贪吃的家伙，{p} \ 不，即使在全日本，恐怕也是金牌级别的。」"

# game/Welcome Party.rpy:2620
translate chinese_simplified sit_with_torahiko_68b8e642:

    # to "「Don't worry, you'll get your share.{p} \ {nw}"
    # KS:4335-4336
    to "「不用担心，我也会好好地分给柔一君的。{p} \ {nw}"

# game/Welcome Party.rpy:2622
translate chinese_simplified sit_with_torahiko_8a9a2c95:

    # extend "But I'll get you lots of veggies,\n \ because you've been looking plump lately. 」"
    # KS:4336 无直接对应，直译
    extend "啊，不过最近柔一好像变胖了，所以多给你吃些蔬菜吧！」"

# game/Welcome Party.rpy:2625
translate chinese_simplified sit_with_torahiko_887f88cf:

    # ju "「Dahahaha{nw}"
    # KS:4342 无直接对应
    ju "「哒——」"

# game/Welcome Party.rpy:2631
translate chinese_simplified sit_with_torahiko_240b441f:

    # extend "DAAA! 」"
    # KS:4342
    extend "哈！哈！！哈！！」"

# game/Welcome Party.rpy:2633
translate chinese_simplified sit_with_torahiko_57c642bc:

    # "I hear a loud blunt sound down by our feet.{p}Under the table,\nthere seems to have been a violent impact."
    # KS:4346-4347 无直接对应，直译
    "沉重的巨响，从脚边传来。{p}看来在桌子下面似乎发生了剧烈的冲击事件。"

# game/Welcome Party.rpy:2637
translate chinese_simplified sit_with_torahiko_a35af554:

    # ju "「This isn't fat, it's muscle.{p} \ An equal amount of meat and vegetables,\n \ will be fine, Tora. 」"
    # KS:4352-4353
    ju "「这不是脂肪，这是肌肉。{p} \ 所以，菜和肉要均衡提供，虎」"

# game/Welcome Party.rpy:2641
translate chinese_simplified sit_with_torahiko_bcd1d262:

    # to "「Fuwah... fuwah...{p} \ Th-that was my shin, my shin... 」"
    # KS:4357-4358
    to "「系……系的……{p} \ [fsma]腿、小腿不可以这样的，腿啊啊……」"

# game/Welcome Party.rpy:2642
translate chinese_simplified sit_with_torahiko_9862b939:

    # "As he curls his body in agony,\ntears start to form in Torahiko's eyes."
    # KS:4362 无直接对应，直译
    "虎彦含泪地倒了下来，身体整个都卷了起来。"

# game/Welcome Party.rpy:2643
translate chinese_simplified sit_with_torahiko_312e308b:

    # "Well, it looks like...{p}Juuichi and Torahiko are as comical as ever."
    # KS:4364-4365 无直接对应，直译
    "唉呀唉呀，虎彦和柔一君的吐槽秀，{p}现在依旧璀璨啊……。"

# game/Welcome Party.rpy:2647
translate chinese_simplified sit_with_torahiko_42065394:

    # om "「Yo, what are you waiting for?{p} \ There's plenty here!{p} \ So don't be afraid to eat as much as you want! 」"
    # KS:4369-4370
    om "「哟，久等了！一切都准备OK了。{p}所以不用客气，尽管放开地吃吧！」"

# game/Welcome Party.rpy:2648
translate chinese_simplified sit_with_torahiko_516ec097:

    # "The old man yells vigorously,\nas he comes out of the kitchen.{p}He brings out a platter, full of meat and veggies."
    # KS:4372-4373 无直接对应，直译
    "从厨房那边，传来了大叔气势十足的声音，{p}装满了菜和肉的盘子，接二连三地上了桌。"

# game/Welcome Party.rpy:2649
translate chinese_simplified sit_with_torahiko_fe8877ad:

    # "Suddenly, cheers can be heard,\nthroughout the restaurant."
    # KS:4375 无直接对应，直译
    "大家也爆发出了「哦——」的欢呼声。"

# game/Welcome Party.rpy:2654
translate chinese_simplified sit_with_torahiko_d724c7a0:

    # to "「Oh yeah!{p} \ Today I'm gonna eat and eat! 」"
    # KS:4380
    to "「好极了！{p} \ 今天要大吃特吃啰！」"

# game/Welcome Party.rpy:2655
translate chinese_simplified sit_with_torahiko_b8cc814c:

    # "Just a bit ago he had a tortured look on his face,\nbut now it seems that\nthe mountain of meat has stolen his heart."
    # KS:4382-4383 无直接对应，直译
    "刚才那痛苦的表情不知道一下子丢到哪里去了。{p}虎彦的心似乎一下子被肉山给夺走了。"

# game/Welcome Party.rpy:2656
translate chinese_simplified sit_with_torahiko_64d79393:

    # "That was a hasty recovery."
    # KS:4385 无直接对应，直译
    "恢复得可真够快的啊。"

# game/Welcome Party.rpy:2660
translate chinese_simplified sit_with_torahiko_472bdd68:

    # to "「Well then, I'll start cooking.{p} \ I think I'll roast it, then eat it up fast! 」"
    # KS:4389-4390
    to "「那么，开始烤了哦。{p} \ 差不多烤好的话，就放开了吃吧！」"

# game/Welcome Party.rpy:2664
translate chinese_simplified sit_with_torahiko_8d4707f4:

    # to "「Ah, Shun.{p} \ Could you set the heat on maximum? 」"
    # KS:4394-4395
    to "「啊，峻。{p} \ 那边的火力调到最大！」"

# game/Welcome Party.rpy:2668
translate chinese_simplified sit_with_torahiko_68ff2047:

    # su "「Okay! 」"
    # KS:4399
    su "「啊，是！」"

# game/Welcome Party.rpy:2669
translate chinese_simplified sit_with_torahiko_ce76d7db:

    # "Here and there,\nI hear the sound of cooking meat and vegetables."
    # KS:4401-4402 无直接对应，直译
    "整个屋子，到处都充斥着烤肉的声音。{p}烤肉浓郁的香味四处扩散。食欲难以抗拒地暴涨。"

# game/Welcome Party.rpy:2670
translate chinese_simplified sit_with_torahiko_c4eefa9d:

    # "The delicious smell of cooking meat,\nstirs up my appetite."
    # KS:4401-4403 无直接对应，直译
    "整个屋子，到处都充斥着烤肉的声音。{p}烤肉浓郁的香味四处扩散。{p}食欲难以抗拒地暴涨。"

# game/Welcome Party.rpy:2671
translate chinese_simplified sit_with_torahiko_d8c47308:

    # "Everybody is sitting,\nand happily talking to each other.{p}I like this kind of atmosphere."
    # KS:4405-4406 无直接对应，直译
    "大家也快乐地天南海北地聊着。{p}真是惬意呢，这种气氛。"

# game/Welcome Party.rpy:2676
translate chinese_simplified sit_with_torahiko_f6b97e77:

    # to "「I'm always impatient,\n \ when it comes to cooking meat. 」"
    # KS:4411
    to "「在肉烤好之前的漫长等待，真是令人焦躁不安呢。」"

# game/Welcome Party.rpy:2680
translate chinese_simplified sit_with_torahiko_0fd70924:

    # ju "「At times like this,\n \ I make some sauce. 」"
    # KS:4415
    ju "「我一般会在这样的时候，去弄酱汁。」"

# game/Welcome Party.rpy:2681
translate chinese_simplified sit_with_torahiko_71e9f148:

    # "As he says that,\nJuuichi-san mixes sweet and spicy sauces,\nto make his own."
    # KS:4417-4419 无直接对应，直译
    "一边这样说着，柔一桑一边摆弄着，{p}甜味的、辣味的……把各种各样的酱汁混合在一起，{p}制成了独一无二的柔一专用酱汁。"

# game/Welcome Party.rpy:2682
translate chinese_simplified sit_with_torahiko_f4472ea0:

    # "When he is satisfied with the combination,\nJuuichi-san takes a bottle out of his pocket.{p}It's full of a yellow liquid, and he adds it."
    # KS:4421-4423 无直接对应，直译
    "调制过后，{p}柔一君把装有黄色液体的瓶子取出来，{p}轻轻地倒在酱汁之上。"

# game/Welcome Party.rpy:2683
translate chinese_simplified sit_with_torahiko_8b02b206:

    # "What is that?{p}I think it's lemon juice or vinegar but...{p}It's coming out all syrupy..."
    # KS:4426-4427 无直接对应，直译
    "（那个到底是什么呢，柠檬汁？醋？……{p}不对，比那些都粘稠得多。）"

# game/Welcome Party.rpy:2687
translate chinese_simplified sit_with_torahiko_cb6df443:

    # ju "「There, that's good... 」"
    # KS:4431
    ju "「嗯，不错……」"

# game/Welcome Party.rpy:2688
translate chinese_simplified sit_with_torahiko_d77392fb:

    # "After completing his special sauce,\nJuuichi-san tastes a light sample of it.{p}He nods with a satisfied look on his face."
    # KS:4433-4434 无直接对应，直译
    "弄好了特制酱汁，稍稍地尝了一下，{p}然后脸上浮现出了满意的神情。"

# game/Welcome Party.rpy:2692
translate chinese_simplified sit_with_torahiko_e03c9df0:

    # "Stuck on the bottle is a small bee sticker."
    # KS:4438 无直接对应，直译
    "小小的黄色液体瓶放了下来，发现上面贴了画着蜜蜂的标签纸。"

# game/Welcome Party.rpy:2693
translate chinese_simplified sit_with_torahiko_735f1614:

    # "It's yellow, comes out syrupy,\nhas a bee sticker, and he's a bear...{p}Seriously!?"
    # KS:4441-4442 无直接对应，直译
    "（黄色的、粘稠浑浊的，还贴有蜜蜂图案的标签……{p}熊……难道是……）"

# game/Welcome Party.rpy:2694
translate chinese_simplified sit_with_torahiko_93d00926:

    # "Upon realizing what the yellow liquid is,\nI almost spit out my tea."
    # KS:4444-4445 无直接对应，直译
    "我终于明白那是什么东西了，{p}喝一半的乌龙茶差点儿喷了出来。"

# game/Welcome Party.rpy:2695
translate chinese_simplified sit_with_torahiko_84a2ad03:

    # "I-it's honey sauce... for yakiniku?{p}Juuichi-san... no matter how good it is,\nI should have expected that."
    # KS:4447-4448 无直接对应，直译
    "烤、肉的时候居然在酱汁中加蜂蜜？{p}柔一君……就算再喜欢吃蜂蜜，但是加在烤肉酱汁里这实在是……"

# game/Welcome Party.rpy:2699
translate chinese_simplified sit_with_torahiko_fe373919:

    # to "「Juuichi-senpai still has a sweet tooth...{p} \ It can get out of hand. 」"
    # KS:4452
    to "「柔一前辈真是喜欢吃甜呢……已经可以说是嗜甜如命了。」"

# game/Welcome Party.rpy:2700
translate chinese_simplified sit_with_torahiko_0ba97e19:

    # fn "「Juuichi-san showing his true character...{p} \ It can be amazing, sometimes. 」"
    # KS:4458-4459
    fn "「柔一君虽然性格认真，{p} \ 但是也有惊人的孩子气的一面呢……」"

# game/Welcome Party.rpy:2701
translate chinese_simplified sit_with_torahiko_36710f30:

    # ju "「Did you say something? 」"
    # KS:4465
    ju "「说我什么呢？」"

# game/Welcome Party.rpy:2702
translate chinese_simplified sit_with_torahiko_409a10a7:

    # "Juuichi-san gives us a sharp glare.{p}Torahiko and I cringe in fear."
    # KS:4467-4468 无直接对应，直译
    "被柔一君锐利的眼神一瞪，{p}我和虎彦立刻动弹不得。"

# game/Welcome Party.rpy:2706
translate chinese_simplified sit_with_torahiko_63d7a24e:

    # to "「N-nothing! L-look! The meat's burning!{p} \ The salted tongue will...{p} \ go well with your special sauce! 」"
    # KS:4472-4473
    to "「没，什么也没！！{p} \ 看、看啊，那个烤肉已经差不多了啦。{p} \ 前辈的特酱汁一定会和那美味的盐舌十分相配！」"

# game/Welcome Party.rpy:2710
translate chinese_simplified sit_with_torahiko_078b1f0e:

    # ju "「...You don't need to tell me that. 」"
    # KS:4477
    ju "「……识货啊。」"

# game/Welcome Party.rpy:2711
translate chinese_simplified sit_with_torahiko_a2007d4b:

    # "Looks like he's back in a good mood..."
    # KS:4480 无直接对应，直译
    "（似乎，心情一下子变得相当不错的样子……）"

# game/Welcome Party.rpy:2712
translate chinese_simplified sit_with_torahiko_da78d3f0:

    # "Torahiko passes out the food for everybody."
    # KS:4485 无直接对应，直译
    "虎彦动作灵活地将肉和蔬菜分到大家的碟子中。"

# game/Welcome Party.rpy:2717
translate chinese_simplified sit_with_torahiko_e86d8155:

    # to "「[fn], hurry up and eat! 」"
    # KS:4490
    to "「博行也尽量多吃啊！」"

# game/Welcome Party.rpy:2718
translate chinese_simplified sit_with_torahiko_76c745ad:

    # "With the essentials passed out,\nwe start grilling all of the meat and veggies."
    # KS:4493 无直接对应，直译
    "娴熟地将烤好的肉和菜分给大家之后，{p}他又迅速地在铁板上铺上一层新的生肉生菜。"

# game/Welcome Party.rpy:2722
translate chinese_simplified sit_with_torahiko_b9160244:

    # su "「Torahiko-san, there's so much I have to cook,\n \ I won't have time to eat. 」"
    # KS:4497-4498
    su "「虎彦君，也不要那样一直烤啦，{p} \ 会吃不过来的。」"

# game/Welcome Party.rpy:2726
translate chinese_simplified sit_with_torahiko_da66ff39:

    # to "「Ah, sorry, sorry.{p} \ I have a habit of getting preoccupied.{p} \ All right let's eat, thank you for the meal! 」"
    # KS:4502-4504
    to "「啊，抱歉、抱歉。{p} \ 坏毛病又犯了，情不自禁地就沉浸在其中了。{p} \ 那么，大家吃吧！开动了！」"

# game/Welcome Party.rpy:2730
translate chinese_simplified sit_with_torahiko_024ca5f0:

    # "Torahiko's love of cooking and skill,\ncomes from him being his family's only son."
    # KS:4507-4508 无直接对应，直译
    "虎彦这娴熟烤肉的技巧和爱管闲事的习惯，{p}大概由于他是旅店的儿子的缘故吧。"

# game/Welcome Party.rpy:2731
translate chinese_simplified sit_with_torahiko_4b51d665:

    # fn "「That reminds me,\n \ are you still helping out at the inn? 」"
    # KS:4511
    fn "「说起来，现在也有在继续帮旅店做事么？」"

# game/Welcome Party.rpy:2735
translate chinese_simplified sit_with_torahiko_6a2040bb:

    # to "「Hm? Oh yeah. 」"
    # KS:4515
    to "「嗯？哦。」"

# game/Welcome Party.rpy:2739
translate chinese_simplified sit_with_torahiko_1deef8ef:

    # to "「After starting junior high,\n \ I had to work more and more.{p} \ It got pretty serious! 」"
    # KS:4519-4520
    to "「上了中学之后，可以交给我的事情就更多了，{p} \ 变得更加忙碌了呢。」"

# game/Welcome Party.rpy:2740
translate chinese_simplified sit_with_torahiko_085cc290:

    # fn "「Really, I can see things haven't changed. 」"
    # KS:4523
    fn "「这样啊，看来还是老样子呢。」"

# game/Welcome Party.rpy:2741
translate chinese_simplified sit_with_torahiko_23b3f942:

    # "Torahiko's family owns the Ooshima Inn."
    # KS:4525 无直接对应，直译
    "虎彦是经营着「大岛」旅店的老板的独生儿子。"

# game/Welcome Party.rpy:2742
translate chinese_simplified sit_with_torahiko_c414e3d1:

    # "In elementary school,\nhis parents were always busy.{p}Because of this, he had to do some of the work."
    # KS:4527-4529 无直接对应，直译
    "小学生的时候，就经常帮助忙碌的双亲工作，{p}帮忙去做菜、买东西、洗衣服、打扫卫生之类的，{p}小小的孩子就帮助家人减轻工作负担……确实有些这样的印象。"

# game/Welcome Party.rpy:2743
translate chinese_simplified sit_with_torahiko_62c7c37c:

    # "He had to go shopping, do the laundry, clean, etc.{p}I remember even as a child,\nhis family put some of the burden on him."
    # KS:4527-4529 无直接对应，直译
    "小学生的时候，就经常帮助忙碌的双亲工作，{p}帮忙去做菜、买东西、洗衣服、打扫卫生之类的，{p}小小的孩子就帮助家人减轻工作负担……确实有些这样的印象。"

# game/Welcome Party.rpy:2747
translate chinese_simplified sit_with_torahiko_604f529b:

    # to "「Man... I have to work without getting paid...{p} \ They're so stingy.{p} \ {nw}"
    # KS:4533-4535
    to "「真是的……替他们做了那么多工作，却完全没有工资，{p} \ 真是不划算呢。{p} \ {nw}"

# game/Welcome Party.rpy:2749
translate chinese_simplified sit_with_torahiko_d4c215dc:

    # extend "Ah, old man! Let's get some more rice 」!"
    # KS:4535 无直接对应
    extend "啊，大叔～麻烦要一碗米饭！」"

# game/Welcome Party.rpy:2751
translate chinese_simplified sit_with_torahiko_70b45955:

    # "Ooshima Inn is the town's only inn.{p}It's not the best place,\nbut the villagers stop by for its hot springs."
    # KS:4540-4542 无直接对应，直译
    "「大岛」是水乡村唯一的一间旅店，{p}虽然并不是什么特别豪华的酒店，{p}但是却是提供纯天然温泉供人休憩的好去处。"

# game/Welcome Party.rpy:2752
translate chinese_simplified sit_with_torahiko_bdfeee46:

    # "If I remember correctly,\nhis father's cooking was the reason for its success.{p}Many people would travel from afar to have it."
    # KS:4544-4546 无直接对应，直译
    "他父亲的料理技术也堪称一绝，{p}慕名而来的远方客人也相当多呢。{p}号称旅客们口口相传的最佳秘密住所。"

# game/Welcome Party.rpy:2753
translate chinese_simplified sit_with_torahiko_721d9171:

    # "It went from being an inn for those in the know,\nto a reputable, well-established place."
    # KS:4546 无直接对应，直译
    "号称旅客们口口相传的最佳秘密住所。"

# game/Welcome Party.rpy:2754
translate chinese_simplified sit_with_torahiko_a19bc23b:

    # "Torahiko would treat me to dinner at his house.{p}His father would make a meat and potato stew.{p}The flavor would stick with me even when I got home."
    # KS:4548-4550 无直接对应，直译
    "曾经去虎彦家玩过，{p}并在那里有幸品尝到他父亲的土豆炖肉，{p}实在是人间极道之美味。"

# game/Welcome Party.rpy:2755
translate chinese_simplified sit_with_torahiko_81feb798:

    # "I would always ask my mom to make it."
    # KS:4552-4553 无直接对应，直译
    "被感动得回去之后也让妈妈做土豆来吃。{p}这类的小事还依稀记得。"

# game/Welcome Party.rpy:2756
translate chinese_simplified sit_with_torahiko_a26069be:

    # fn "「I want to eat your dad's cooking again... 」"
    # KS:4556
    fn "「你老爸做的料理，还想再吃一次呢。」"

# game/Welcome Party.rpy:2760
translate chinese_simplified sit_with_torahiko_886d7392:

    # to "「If you want, I could make something.{p} \ I could show you a little of my cooking,\n \ to see how confident I am. 」"
    # KS:4560-4561
    to "「既然这样，不如让俺来给你做诶。{p} \ 别看我这样，但是我对料理相当有自信哦。」"

# game/Welcome Party.rpy:2764
translate chinese_simplified sit_with_torahiko_590e42ea:

    # su "「Torahiko-san's dad has been teaching him. 」"
    # KS:4565
    su "「虎彦君，从父亲那里将料理技术传承下来的呢。」"

# game/Welcome Party.rpy:2768
translate chinese_simplified sit_with_torahiko_b473bae7:

    # to "「Yeah, my dad's passing down his recipes!{p} \ Food is my forte now. 」"
    # KS:4569-4570
    to "「是啊，老爸秘传的特级土豆炖肉！{p} \ 现在已经是俺的拿手好菜了。」"

# game/Welcome Party.rpy:2769
translate chinese_simplified sit_with_torahiko_16f247dc:

    # "I'm a little skeptical about Torahiko's cooking.{p}I wonder what the hell it'd taste like..."
    # KS:4572-4573 无直接对应，直译
    "看起来这样粗犷的虎彦做的菜，{p}不知道味道会是怎样的呢……。"

# game/Welcome Party.rpy:2770
translate chinese_simplified sit_with_torahiko_8beb4f2d:

    # "While I was thinking about that,\nthe meat on the grill has cooked,\nto just the right condition."
    # KS:4575-4576 无直接对应，直译
    "正想着这种事的工夫，{p}铁板上的肉已经烤好了。"

# game/Welcome Party.rpy:2774
translate chinese_simplified sit_with_torahiko_90f6fadd:

    # to "「Here, take some more of the meat!{p} \ If you don't,\n \ it's gonna disappear quickly. 」"
    # KS:4580-4581
    to "「来吧，尽量夹肉吃吧！{p} \ 再不夹一会儿就没啦」"

# game/Welcome Party.rpy:2775
translate chinese_simplified sit_with_torahiko_2f08acdc:

    # "Shun-kun stares at a piece of cooked meat."
    # KS:4583 无直接对应，直译
    "峻君一直直勾勾地盯着某一块肉。"

# game/Welcome Party.rpy:2779
translate chinese_simplified sit_with_torahiko_5c366755:

    # su "「I'll get that one. 」"
    # KS:4587
    su "「那就不客气了！」"

# game/Welcome Party.rpy:2783
translate chinese_simplified sit_with_torahiko_9656a143:

    # to "「...(Munch, munch.) 」"
    # KS:4591
    to "「……（夹起，吃掉）」"

# game/Welcome Party.rpy:2784
translate chinese_simplified sit_with_torahiko_250e0ffb:

    # su "「... 」"
    # KS:4594
    su "「……」"

# game/Welcome Party.rpy:2785
translate chinese_simplified sit_with_torahiko_4d00490f:

    # "It doesn't look like he got it...{p}He pulls himself together,\nand reaches out for another piece."
    # KS:4596-4597 无直接对应，直译
    "峻君看上去有点儿小不满，{p}但是马上就重新振作起来，向另一块肉发起冲锋。"

# game/Welcome Party.rpy:2789
translate chinese_simplified sit_with_torahiko_7d018bde:

    # su "「All right then, this one. 」"
    # KS:4601
    su "「不客气了！」"

# game/Welcome Party.rpy:2793
translate chinese_simplified sit_with_torahiko_0dba8f11:

    # to "「...(Om, nom.) 」"
    # KS:4605
    to "「……（夹起，吃掉）」"

# game/Welcome Party.rpy:2797
translate chinese_simplified sit_with_torahiko_6a1c9a8b:

    # su "「...Aww. 」"
    # KS:4609
    su "「……」"

# game/Welcome Party.rpy:2798
translate chinese_simplified sit_with_torahiko_596d6122:

    # "With lowered ears and sad, pleading eyes,\nhe stares at Torahiko."
    # KS:4611-4612 无直接对应，直译
    "耳朵耷拉了起来，{p}用带着恳求的眼神望着虎彦。"

# game/Welcome Party.rpy:2802
translate chinese_simplified sit_with_torahiko_c7d8abdd:

