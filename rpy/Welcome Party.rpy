# game/Welcome Party.rpy:1748

translate chinese_simplified sit_with_kyoutarou_71ffad76:

    # so "「Oh yeah! Same here,\n nice to meetcha!」"
    # [旧版翻译] 来源: オープニング.ks
    so "「哦对了！彼此彼此，\\n \\ 请多指教啦！」"

# game/Welcome Party.rpy:1749

translate chinese_simplified sit_with_kyoutarou_8c79f24c:

    # "As I talk to Soutarou-kun,\nmy mind recovers."
    # [旧版翻译] 来源: オープニング.ks
