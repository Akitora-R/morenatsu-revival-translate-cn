# game/Welcome Party.rpy:60

translate chinese_simplified begin_2ba89812:

    # "The trees rustling in the gentle breeze, \nand the faces of my childhood friends, \nas we played until sunset."
    # [旧版翻译] 来源: オープニング.ks
