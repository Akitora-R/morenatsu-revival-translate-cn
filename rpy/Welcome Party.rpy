# game/Welcome Party.rpy:2829
translate chinese_simplified sit_with_torahiko_9f7c41fb:

    # "Those two still haven't taken a bite..."
    # KS:4639 无直接对应，直译
    "这两个人却还没开始吃……"

# game/Welcome Party.rpy:2833
translate chinese_simplified sit_with_torahiko_acfd3f55:

    # su "「Torahiko-san, I won't lose! 」"
    # KS:4643
    su "「虎彦君，我不会输的！」"

# game/Welcome Party.rpy:2834
translate chinese_simplified sit_with_torahiko_6fcdeb41:

    # "With his new-found resolve,\nShun is a completely different person."
    # KS:4645 无直接对应，直译
    "带着新获得的决心，{p}峻君的表现简直像是变了一个人。"

# game/Welcome Party.rpy:2835
translate chinese_simplified sit_with_torahiko_bf819154:

    # "His chopsticks move with great speed,\nback and forth from the iron plate."
    # KS:4647 无直接对应，直译
    "他的筷子飞速移动，{p}在铁板和嘴巴之间来回穿梭。"

# game/Welcome Party.rpy:2839
translate chinese_simplified sit_with_torahiko_9df69cd7:

    # su "「Hiyaa! 」"
    # KS:4649 无直接对应
    su "「看招！」"

# game/Welcome Party.rpy:2843
translate chinese_simplified sit_with_torahiko_9462b38d:

    # to "「Oh! Don't think I'll let you win! 」"
    # KS:4653
    to "「哦！别以为我会让你赢！」"

# game/Welcome Party.rpy:2844
translate chinese_simplified sit_with_torahiko_ce6c346e:

    # to "「Om, nom, om, nom, om, nom. 」"
    # KS:4657 无直接对应
    to "「吧唧，吧唧，吧唧，吧唧，吧唧。」"

# game/Welcome Party.rpy:2848
translate chinese_simplified sit_with_torahiko_4699ba53:

    # su "「...Oooooh. 」"
    # KS:4661 无直接对应
    su "「……哦哦……」"

# game/Welcome Party.rpy:2852
translate chinese_simplified sit_with_torahiko_c4fb4056:

    # to "「Come on, concentrate...{p} \ {nw}"
    # KS:4665
    to "「来，专注一点……{p} \ {nw}"

# game/Welcome Party.rpy:2854
translate chinese_simplified sit_with_torahiko_9608d407:

    # extend "Dahaha...{p} \ {nw}"
    # KS:4669 无直接对应
    extend "哒——……{p} \ {nw}"

# game/Welcome Party.rpy:2858
translate chinese_simplified sit_with_torahiko_5ba5a8d9:

    # extend "DAAAAA!! 」"
    # KS:4669 无直接对应
    extend "哒啊啊啊——！！」"

# game/Welcome Party.rpy:2860
translate chinese_simplified sit_with_torahiko_d53e43ba:

    # "At that time I hear a strong impact under the table.{p}Torahiko holds his shin in pain."
    # KS:4673 无直接对应，直译
    "我不时听到桌子底下传来的一记重击。{p}虎彦捉着自己的小腿，一脸痛苦。"

# game/Welcome Party.rpy:2864
translate chinese_simplified sit_with_torahiko_45a2b5da:

    # ju "「...Tora.{p} \ Stealing is not something to be admired. 」"
    # KS:4677-4678
    ju "「……虎。{p} \ 偷窃可不是什么值得赞扬的行为。」"

# game/Welcome Party.rpy:2865
translate chinese_simplified sit_with_torahiko_43c4bb38:

    # to "「A-all right, I won't steal... 」"
    # KS:4683
    to "「好、好，我不再偷了……」"

# game/Welcome Party.rpy:2866
translate chinese_simplified sit_with_torahiko_9a5bc569:

    # "Jeez, 10 minutes haven't even passed.{p}I didn't think I'd see that happen again..."
    # KS:4685 无直接对应，直译
    "话说，还没到10分钟呢。{p}没想到还能再次看到这番光景啊……"

# game/Welcome Party.rpy:2872
translate chinese_simplified sit_with_torahiko_06437538:

    # ky "「Don't worry about it too much, [fn]. 」"
    # KS:4689
    ky "「不用太在意，博行。」"

# game/Welcome Party.rpy:2876
translate chinese_simplified sit_with_torahiko_37b41478:

    # ka "「Ah, we see this happen all the time. 」"
    # KS:4693
    ka "「啊，我们已经习惯了。」"

# game/Welcome Party.rpy:2880
translate chinese_simplified sit_with_torahiko_ed0b9c64:

    # so "「Usually Ooshima-senpai will mess with Shun-kun,{p} \ then Juuichi-san will punish him.{p} \ It's a regular pattern. 」"
    # KS:4697-4699
    so "「通常都是大岛前辈捉弄峻君，{p} \ 然后柔一前辈就会教训他。{p} \ 这是惯例了。」"

# game/Welcome Party.rpy:2881
translate chinese_simplified sit_with_torahiko_bc0083ed:

    # ky "「Haha. Oh, Mikazuki.{p} \ It looks painful,\n \ but he's going easy on him. 」"
    # KS:4703-4704
    ky "「哈哈。哦，三日月。{p} \ 看起来很疼，{p} \ 但他其实已经脚下留情了。」"

# game/Welcome Party.rpy:2882
translate chinese_simplified sit_with_torahiko_8ea2b363:

    # fn "「I-I see... 」"
    # KS:4707
    fn "「是、是这样啊……」"

# game/Welcome Party.rpy:2883
translate chinese_simplified sit_with_torahiko_3360ec52:

    # "Compared to Torahiko,\nI wouldn't stand a chance."
    # KS:4709 无直接对应，直译
    "跟虎彦比起来，{p}我肯定也会一下子就被打趴在地上吧。"

# game/Welcome Party.rpy:2884
translate chinese_simplified sit_with_torahiko_0db78160:

    # "I'd probably fall down in surprise,\nand wouldn't be able to move..."
    # KS:4711 无直接对应，直译
    "估计会吃惊得直接瘫在地上，{p}然后完全无法动弹吧……"

# game/Welcome Party.rpy:2892
translate chinese_simplified sit_with_torahiko_e1e952ec:

    # to "「A... a kick can't go...{p} \ in the same place consecutively! 」"
    # KS:4715-4716
    to "「连……连续踢同一个地方……{p} \ 是不可能的吧！」"

# game/Welcome Party.rpy:2896
translate chinese_simplified sit_with_torahiko_6898b9a8:

    # su "「T-Torahiko-san...{p} \ are you okay...? 」"
    # KS:4719-4720
    su "「虎、虎彦前辈……{p} \ ……没事吧……？」"

# game/Welcome Party.rpy:2900
translate chinese_simplified sit_with_torahiko_a9835774:

    # to "「Sh-Shun... 」"
    # KS:4725
    to "「峻、峻……」"

# game/Welcome Party.rpy:2901
translate chinese_simplified sit_with_torahiko_e77fda73:

    # ju "「Shun, go get some vegetables for Tora.{p} \ The vitamins and minerals you get from them,\n \ are important for nutrition. 」"
    # KS:4729-4730
    ju "「峻，给虎拿点蔬菜来吧。{p} \ 维生素和矿物质等营养成分，{p} \ 都是很重要的。」"

# game/Welcome Party.rpy:2905
translate chinese_simplified sit_with_torahiko_dd4c37c6:

    # su "「Roger that! 」"
    # KS:4733
    su "「收到！」"

# game/Welcome Party.rpy:2909
translate chinese_simplified sit_with_torahiko_1b576b6c:

    # to "「Dohoho... 」"
    # KS:4737 无直接对应
    to "「朵荷荷……」"

# game/Welcome Party.rpy:2910
translate chinese_simplified sit_with_torahiko_a9ae5dd8:

    # "Torahiko's getting what he deserves."
    # KS:4739 无直接对应，直译
    "虎彦这就是自作自受啊。"

# game/Welcome Party.rpy:2914
translate chinese_simplified sit_with_torahiko_42153a2a:

    # "We're getting right into the middle of the party,\nand my stomach is nice and full."
    # KS:4743 无直接对应，直译
    "派对正热闹地进行着，{p}我的肚子也吃得鼓鼓的。"

# game/Welcome Party.rpy:2915
translate chinese_simplified sit_with_torahiko_a702b3c5:

    # "But we're still at the age where we eat a lot,\nso everybody is still at it."
    # KS:4745 无直接对应，直译
    "但大家都是正在长身体的年纪，{p}所以都还在继续吃着。"

# game/Welcome Party.rpy:2916
translate chinese_simplified sit_with_torahiko_2571136d:

    # "Even Shin-kun, with his small appetite,\nis having a good time.{p}He's happily moving his chopsticks along."
    # KS:4747-4748 无直接对应，直译
    "即使是饭量很小的深君，{p}也正开心地吃着。{p}看起来他正愉快地动着筷子。"

# game/Welcome Party.rpy:2920
translate chinese_simplified sit_with_torahiko_7a9c3ab9:

    # om "「Oh, you're waiting on more meat!{p} \ Your appetite is the same as ever, Tora! 」"
    # KS:4751
    om "「哦，还要等肉上来啊！{p} \ 你的胃口还是一如既往的好啊，虎！」"

# game/Welcome Party.rpy:2924
translate chinese_simplified sit_with_torahiko_79f8e5f5:

    # to "「Yep, I'm eatin' nonstop! 」"
    # KS:4755
    to "「嗯，我在不停地吃！」"

# game/Welcome Party.rpy:2929
translate chinese_simplified sit_with_torahiko_c1f860fb:

    # ky "「Ooshima sure is fast.{p} \ There's plenty of time,\n \ so don't rush yourselves. 」"
    # KS:4759-4760
    ky "「大岛吃得可真快。{p} \ 还有的是时间，{p} \ 所以不用那么着急。」"

# game/Welcome Party.rpy:2933
translate chinese_simplified sit_with_torahiko_1ec265d7:

    # ju "「Don't eat too much.{p} \ Your meet is coming up soon. 」"
    # KS:4765
    ju "「不要吃太多了。{p} \ 比赛快到了吧。」"

# game/Welcome Party.rpy:2937
translate chinese_simplified sit_with_torahiko_1c615405:

    # to "「Heh heh, since it's [fn]'s welcoming party,\n \ it's all right not to hold back,\n \ so there's no need to say that, senpai. 」"
    # KS:4769-4770
    to "「嘿嘿，既然是博行的欢迎会，{p} \ 不用客气也没关系，{p} \ 所以前辈你就不用操心了。」"

# game/Welcome Party.rpy:2941
translate chinese_simplified sit_with_torahiko_4e517598:

    # ju "「Don't use [fn] as an excuse, damn it...{p} \ Also, there's not going to be enough meat for him. 」"
    # KS:4775-4776
    ju "「别拿博行当借口啊，可恶……{p} \ 而且，这样他会吃不到足够多的肉的。」"

# game/Welcome Party.rpy:2942
translate chinese_simplified sit_with_torahiko_440ab732:

    # fn "「Don't worry, I'm eating at my own pace. 」"
    # KS:4779
    fn "「不用担心，我按自己的节奏吃呢。」"

# game/Welcome Party.rpy:2946
translate chinese_simplified sit_with_torahiko_2479f14d:

    # to "「Hey, hey, [fn]'s all right with it! 」"
    # KS:4783
    to "「喂喂，博行自己都说没问题了！」"

# game/Welcome Party.rpy:2950
translate chinese_simplified sit_with_torahiko_a3faa8cb:

    # ju "「You... just settled that because...{p} \ you're just being coy! 」"
    # KS:4787-4788
    ju "「你这家伙……只是因为这个原因就这么算了……{p} \ 你只是不好意思拒绝而已！」"

# game/Welcome Party.rpy:2951
translate chinese_simplified sit_with_torahiko_11b364b5:

    # "This isn't turning out good."
    # KS:4791 无直接对应，直译
    "这下可不太妙啊。"

# game/Welcome Party.rpy:2952
translate chinese_simplified sit_with_torahiko_fe013311:

    # "Before that happens a third time,\nI think of something to change to topic."
    # KS:4793 无直接对应，直译
    "在第三次之前，我想了个办法来转移话题。"

# game/Welcome Party.rpy:2953
translate chinese_simplified sit_with_torahiko_165f693a:

    # "Come to think of it,\nJuuichi-san did mention that a meet was coming up..."
    # KS:4795 无直接对应，直译
    "说起来，柔一前辈之前确实有提过比赛的事情……"

# game/Welcome Party.rpy:2957
translate chinese_simplified sit_with_torahiko_5fec934b:

    # fn "「A little bit ago,\n \ Juuichi-san said something about a swim meet.{p} \ Are you entering, Torahiko? 」"
    # KS:4797-4798
    fn "「之前，{p} \ 柔一前辈好像提到过有关比赛的事情。{p} \ 虎彦你要参加吗？」"

# game/Welcome Party.rpy:2961
translate chinese_simplified sit_with_torahiko_c67de90f:

    # to "「Ah, I haven't told you yet.{p} \ I'm in the swimming club. 」"
    # KS:4801-4802
    to "「啊，我还没告诉你吧。{p} \ 我加入了游泳部。」"

# game/Welcome Party.rpy:2962
translate chinese_simplified sit_with_torahiko_965224fd:

    # "Back in elementary school,\nTorahiko was a very fast swimmer."
    # KS:4804 无直接对应，直译
    "回想小学的时候，{p}虎彦可是一个非常快的游泳选手。"

# game/Welcome Party.rpy:2963
translate chinese_simplified sit_with_torahiko_6abea584:

    # fn "「Back then you were always the fastest.{p} \ And now you're in the swimming club. 」"
    # KS:4806-4807
    fn "「那时候你就总是最快的。{p} \ 现在又加入了游泳部。」"

# game/Welcome Party.rpy:2967
translate chinese_simplified sit_with_torahiko_50555482:

    # su "「You're amazing, Torahiko-san!{p} \ All the best swimmers are gonna be there,\n \ from all around the country, it's gonna be big! 」"
    # KS:4811-4812
    su "「虎彦前辈好厉害！{p} \ 全国最优秀的游泳选手都会来，{p} \ 真是规模宏大的比赛啊！」"

# game/Welcome Party.rpy:2968
translate chinese_simplified sit_with_torahiko_2f2e24a8:

    # "Shun-kun takes the words right out of my mouth."
    # KS:4814 无直接对应，直译
    "峻君说出了我想说的话。"

# game/Welcome Party.rpy:2969
translate chinese_simplified sit_with_torahiko_4b87be6f:

    # fn "「That is really amazing, isn't it? 」"
    # KS:4817
    fn "「真的很厉害呢。」"

# game/Welcome Party.rpy:2973
translate chinese_simplified sit_with_torahiko_163f1ce7:

    # ko "「In your first year you,\n \ won the prize at the rookie match, didn't you? 」"
    # KS:4821-4822
    ko "「你一年级的时候，{p} \ 在新人赛上拿了奖吧？」"

# game/Welcome Party.rpy:2974
translate chinese_simplified sit_with_torahiko_893ef06e:

    # ko "「You're something of a celebrity,\n \ in the world of high school swimming. 」"
    # KS:4825-4826
    ko "「你在高中游泳界，{p} \ 也算得上是名人了。」"

# game/Welcome Party.rpy:2978
translate chinese_simplified sit_with_torahiko_29297eb5:

    # to "「Heh heh, when that sort of talent is born,\n \ that's the kind of result you would expect,\n \ or something like that, at least. 」"
    # KS:4831-4832
    to "「嘿嘿，有那种天赋的话，{p} \ 那样的结果也是可以预期的，{p} \ 或者说是理所当然的吧。」"

# game/Welcome Party.rpy:2979
translate chinese_simplified sit_with_torahiko_178fb496:

    # "Torahiko triumphantly puffs his chest out with pride."
    # KS:4834 无直接对应，直译
    "虎彦得意洋洋地挺起胸膛。"

# game/Welcome Party.rpy:2983
translate chinese_simplified sit_with_torahiko_b94071fb:

    # ta "「Toraa, you're usually so carefree,\n \ but when you decide to snap into it,\n \ you look really... Awesome... 」"
    # KS:4838-4839
    ta "「虎呀，你平时看起来那么吊儿郎当，{p} \ 但一认真起来的话，看起来真的很……{p} \ 很厉害啊……」"

# game/Welcome Party.rpy:2984
translate chinese_simplified sit_with_torahiko_e56fb1b2:

    # "Somehow, Tatsu-nii appeared from the side.{p}His eyes keep looking all around Torahiko,\nand stayed like that as he continued talking."
    # KS:4841-4842 无直接对应，直译
    "不知什么时候，辰兄从旁边冒了出来。{p}他的视线在虎彦身上转来转去，{p}然后继续说着话。"

# game/Welcome Party.rpy:2988
translate chinese_simplified sit_with_torahiko_aee9985f:

    # to "「Whoa, when did you get here!? 」"
    # KS:4845
    to "「哇，你什么时候来的！？」"

# game/Welcome Party.rpy:2992
translate chinese_simplified sit_with_torahiko_36ae06bb:

    # ta "「Torahiko, get fired up!{p} \ Banshaaaaaaaai...! 」"
    # KS:4849-4850
    ta "「虎彦，拿出干劲来！{p} \ 万岁……！」"

# game/Welcome Party.rpy:2996
translate chinese_simplified sit_with_torahiko_4d967407:

    # to "「Th-thanks...? 」"
    # KS:4855
    to "「那、谢谢……？」"

# game/Welcome Party.rpy:3000
translate chinese_simplified sit_with_torahiko_5e1ef098:

    # ta "「Toraa... I was just thinking of something earlier!{p} \ You're a man among men! 」"
    # KS:4859-4860
    ta "「虎呀……我刚才想到了！{p} \ 你真是好男儿啊！」"

# game/Welcome Party.rpy:3004
translate chinese_simplified sit_with_torahiko_f0ffa5c0:

    # to "「Hey hey, there's no need for that much...{p} \ Err... Flattery. 」"
    # KS:4865-4866
    to "「喂喂，不用做到那份上……{p} \ 呃……是奉承吧。」"

# game/Welcome Party.rpy:3005
translate chinese_simplified sit_with_torahiko_7a3f22a4:

    # "Torahiko is being humble,\nwhile giving a troubled, wry smile."
    # KS:4868 无直接对应，直译
    "虎彦一边苦笑着，{p}一边表现得非常谦虚。"

# game/Welcome Party.rpy:3006
translate chinese_simplified sit_with_torahiko_427031d3:

    # "Without any care,\nTatsu-nii continues to stare at Torahiko,\nhis expression as blank as ever."
    # KS:4871 无直接对应，直译
    "辰兄毫不在意地继续盯着虎彦，{p}表情一如既往地平淡。"

# game/Welcome Party.rpy:3007
translate chinese_simplified sit_with_torahiko_a59aef56:

    # "He's looking really strange..."
    # KS:4873 无直接对应，直译
    "他看起来真的很奇怪……"

# game/Welcome Party.rpy:3011
translate chinese_simplified sit_with_torahiko_62c3f76d:

    # ta "「You're so cute... 」"
    # KS:4877
    ta "「你好可爱啊……」"

# game/Welcome Party.rpy:3015
translate chinese_simplified sit_with_torahiko_77e1e78f:

    # to "「Eh? 」"
    # KS:4881
    to "「诶？」"

# game/Welcome Party.rpy:3017
translate chinese_simplified sit_with_torahiko_20126fa8:

    # ta "「When you hide your embarrassment like that,\n \ it's really cute, Toraa...\n \ Mm, {nw}"
