# game/Welcome Party.rpy:1874

translate chinese_simplified sit_with_juuichi_5e03d958:

    # ta "「Anyway, we should have a toast.」"
    # [旧版翻译] 来源: オープニング.ks
    ta "「总之，我们先干杯吧。」"

# game/Welcome Party.rpy:1878

translate chinese_simplified sit_with_juuichi_23f350f9:

    # ko "「Y-you're right.」"
    # [旧版翻译] 来源: オープニング.ks
    ko "「是……是啊。」"

# game/Welcome Party.rpy:1882

translate chinese_simplified sit_with_juuichi_ec094ef7:

    # "Having smoothed over the situation,\nKounosuke raises his glass into the air.{p}Everybody else folllows."
