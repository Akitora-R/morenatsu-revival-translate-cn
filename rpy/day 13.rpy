translate chinese_simplified tatsuki13_outside_5af68c5a:

    # to "「What a pain... Guess we just have to do it.」"
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 221-222)
    to "\n「真麻烦啊……既然是接下来的活，没办法」"

