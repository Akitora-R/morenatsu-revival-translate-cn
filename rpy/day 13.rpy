# game/day 13.rpy:394
translate chinese_simplified shun13_carpenters_dbb4bb82:

    # "With the way things are going, they're going to\nforget our original purpose for being up here..."
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 646-647)
    "就这个样子忘记当初上来的目的……\n"

# game/day 13.rpy:398
translate chinese_simplified shun13_carpenters_b574d084:

    # ta "「Okay! Now [fn], watch.」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 650-651)
