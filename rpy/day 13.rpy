# game/day 13.rpy:738
translate chinese_simplified tatsuki13_ce32018d:

    # farmer "「Thanks, Sensei. You've finally come.{p} I'm counting on you, everyone.」"
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 133-135)
    farmer "\n「哎呀哎呀老师，来的正好。\n请大家多多指教了。」"

# game/day 13.rpy:742
translate chinese_simplified tatsuki13_e8999c97:

    # bo "「No no, no need for thanks.{p} It's good exercise for these guys, anyway.{p} Okay everyone. Listen carefully, and work hard.」"
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 138-141)
    bo "\n「不不不，这点小事没什么大不了的啦。\n而且对于这群家伙来说应该也是很好的运动。\n听好了，你们要好好听他的话努力点工作哦」"

# game/day 13.rpy:743
translate chinese_simplified tatsuki13_3fe386fe:

    # everyone "「Yes, Sensei!」"
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 143)
    everyone "「是，请多多指教」"

# game/day 13.rpy:744
