# game/day 13.rpy:338
translate chinese_simplified shun13_carpenters_240b4519:

    # su "「Woah! Is that true?」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 540-541)
    su "「哇！　真的吗？」"

# game/day 13.rpy:342
translate chinese_simplified shun13_carpenters_b27060df:

    # ta "「Yep! Dragons, bears, \n and elephants are all safe!」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 545-547)
