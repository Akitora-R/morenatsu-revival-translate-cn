# game/day 13.rpy:414
translate chinese_simplified shun13_carpenters_40310dd1:

    # su "「Hyan!」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 676-677)
    su "「啊！」"

# game/day 13.rpy:418
translate chinese_simplified shun13_carpenters_9f228256:

    # ta "「See, it's completely safe.」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 681-682)
    ta "「你看，完全没问题吧。」"

# game/day 13.rpy:419
translate chinese_simplified shun13_carpenters_3253b58c:

    # fn "「Y-{w=.2}Yeah, I get it,{w=.2}\n so let's stop already Tatsu-nii...」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 684-685)
