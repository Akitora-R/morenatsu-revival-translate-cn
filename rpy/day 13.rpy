# game/day 13.rpy:297
translate chinese_simplified shun13_carpenters_61bb40ff:

    # fn "「This porch sure is long, isn't it?」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 448-449)
    fn "「这个走廊，很长呢。」"

# game/day 13.rpy:301
translate chinese_simplified shun13_carpenters_83b8a8bf:

    # su "「It is. Cleaning it is kind of hard...」"
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 454-455)
    su "「是啊，打扫时实在是有些费力呢。」"

# game/day 13.rpy:302
translate chinese_simplified shun13_carpenters_a793e41b:

    # "It's a shame that I'm sitting looking small\nand quiet on the end of 3 people."
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 457)
