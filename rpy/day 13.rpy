    # to "「Oh, you're in a good mood, [fn].」"
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 241-242)
    to "\n「喔，[漏れ]起劲了呢」"

# game/day 13.rpy:808
translate chinese_simplified tatsuki13_outside_66ebb71f:

    # ta "「Interesting. I won't lose.」"
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 245-246)
