# game/day 13.rpy:762
translate chinese_simplified tatsuki13_outside_e60ddf6f:

    # fn "「I can still do the physical stuff.」"
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 175-176)
    fn "\n「[漏れ]就算看上去这样，其实也是挺有力气的哦」"

# game/day 13.rpy:763
translate chinese_simplified tatsuki13_outside_6167b20e:

    # "Old man, please don't make fun of me..."
    # [旧版翻译] 来源: extract/orig/辰樹_s_04.ks (KS 178)
