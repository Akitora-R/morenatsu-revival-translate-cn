# game/day 13.rpy:399
translate chinese_simplified shun13_carpenters_7036b745:

    # "Tatsu-nii takes a deep breath,\nthen gently hops up with both legs."
    # [旧版翻译] 来源: extract/orig/峻_s_01.ks (KS 653-655)
