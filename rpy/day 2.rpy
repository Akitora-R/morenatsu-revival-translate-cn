# game/day 2.rpy:1271
translate chinese_simplified river02_story_time_4e3f9e89:

    # ka "「[fn]...」"
    # [旧版翻译]
    ka "「[fn]……」"

# game/day 2.rpy:1275
translate chinese_simplified river02_story_time_8f5ac8a2:

    # su "「[fn]-san...」"
    # [旧版翻译]
    su "「[fn]……」"

# game/day 2.rpy:1276
translate chinese_simplified river02_story_time_1c1f25f3:

    # "They look at me like I'm something pitiful."
    # [旧版翻译]
    "啊啊，那种充满了怜悯的眼神！"

# game/day 2.rpy:1277
translate chinese_simplified river02_story_time_c268f881:

    # fn "「W-what?{w} What's up with you guys, seriously...{p} S-stop looking at me like that!{p} {nw}"
    # [旧版翻译]
    fn "「怎、怎么了？你们两个人怎么……。别、别这样啦。[qxv][se freeze04]别用那种眼神看[fn]啦！」"

# game/day 2.rpy:1280
translate chinese_simplified river02_story_time_a29088b3:

    # extend "Seriously, cut it out, guys!」"
    # [旧版翻译]
    extend "别用那种眼神看[fn]啦！」"

# game/day 2.rpy:1285
translate chinese_simplified river02_story_time_cdcef35a:

    # ka "「...That time was a big surprise, Shun.」"
    # [旧版翻译]
    ka "「……不过，那时候真的很惊险呢，峻。」"

# game/day 2.rpy:1289
translate chinese_simplified river02_story_time_660ca966:

    # su "「...It really was.{p} I was wondering what was going to happen to me,{p} and I got really scared, and I felt hopeless.」"
    # [旧版翻译]
    su "「……就是说啊――不知道自己会变成怎样，太害怕了结果什么都做不了的说――」"

# game/day 2.rpy:1290
translate chinese_simplified river02_story_time_5d62c2e4:

    # "What? Are they talking about something\nthat happened when I wasn't even around?"
    # [旧版翻译]
    "呃？彷彿从一开始[fn]就不存在一样地自己开始聊起来了？这样不会很奇怪吗？BGM也是什么时候变回来的？"

# game/day 2.rpy:1291
translate chinese_simplified river02_story_time_46d16d4e:

    # "Isn't that funny?{p}And the BGM came back before I realized too."
    # [旧版翻译]
    "这算什么，唔，等等啊……。好可怕……好可怕的疏离感！这就是被欺负的小孩的感觉！？"

# game/day 2.rpy:1293
translate chinese_simplified river02_story_time_87a8b682:

    # "What is this? Hey, wait...{p}Awful, awful alienation!{p}Is this what it feels like to be bullied!?"
    # [旧版翻译]
    "这算什么，唔，等等啊……。好可怕……好可怕的疏离感！这就是被欺负的小孩的感觉！？"

# game/day 2.rpy:1294
translate chinese_simplified river02_story_time_aa061b7f:

    # "Tch, if that's how it is, then...{p}I'll get back at you with a comeback!{p}And it'll be smooth!"
    # [旧版翻译]
    "啧，他们要那么做的话，那就算被说是闹别扭，[fn]也要回到对话里给他们看。而且要自然地！"

# game/day 2.rpy:1295
translate chinese_simplified river02_story_time_f6eca6f8:

    # "I'll search for that memory with all my body and soul.{p}I'll definitely be able to find it. That one memory!"
    # [旧版翻译]
    "[fn]全心全意地将搜索之手伸向大脑内部的抽屉。不管如何，[fn]一定要找出来。那份记忆啊！"

# game/day 2.rpy:1301
translate chinese_simplified river02_story_time_7fe09321:

    # fn "「{size=+15}{cps=5}Oooooooaaaaaagh」!{nw}"
    # [旧版翻译]
    fn "{size=+15}{cps=5}「呜喔喔喔喔喔！」{nw}"

# game/day 2.rpy:1304
translate chinese_simplified river02_story_time_8e82cba1:

    # "The signals run through my brain.{p}Like a computer,{w} I make a frantic search\nthrough the database of my mind."
    # [旧版翻译]
    "来回奔驰的电子信号。迸发而出的脑内啡。不断鼓动的太阳穴。"

# game/day 2.rpy:1305
translate chinese_simplified river02_story_time_ac2b5e0e:

    # "Now, with all my power... {cps=10}raaagh!"
    # [旧版翻译]
    "现在，用[fn]的全力将那份记忆[wdm]喔喔喔喔！[rd]"

# game/day 2.rpy:1306
translate chinese_simplified river02_story_time_2530e6b4:

    # fn "「{cps=10}...{nw}"
    # [旧版翻译]
    fn "「[wds]――[SE play=freeze07][randomse_stop]！[rd]"

# game/day 2.rpy:1309
translate chinese_simplified river02_story_time_a551c693:

    # extend "!」"
    # [旧版翻译]
    extend "！[rd]"

# game/day 2.rpy:1313
translate chinese_simplified river02_story_time_cff84561:

    # "I see! I see it!{p}It was in the 53rd cycle!"
    # [旧版翻译]
    "找到了！[fn]找到了！它就放在第五十三号抽屉里面！"

# game/day 2.rpy:1314
translate chinese_simplified river02_story_time_4742c9d0:

    # fn "「That time really was a huge shock.」"
    # [旧版翻译]
    fn "「真的，那时候吓了好大一跳呢」"

# game/day 2.rpy:1315
translate chinese_simplified river02_story_time_aa146bc3:

    # "All right, I've got it now, right!?{p}If I get on this current,{p}I can get back into the conversation."
    # [旧版翻译]
    "好，这样插话应该没问题吧！？能这样顺势前进的话，就可以回到话题中了。"

# game/day 2.rpy:1316
translate chinese_simplified river02_story_time_daf49a36:

    # "Okay, [fn]. Don't screw this up again."
    # [旧版翻译]
    "这样[fn]的（虽然[fn]自己也不太确定）失言也就跟没有一样了！"

# game/day 2.rpy:1317
translate chinese_simplified river02_story_time_5de1b0aa:

    # "...Still, it really was a shock. That time was..."
    # [旧版翻译]
    "――但，那时候真的被吓了好大一跳。[wds]那个时候――[rd]"

# game/day 2.rpy:1330
translate chinese_simplified river02_memory_005cbad5:

    # "On that day, it was as hot as it was today."
    # [旧版翻译]
    "那天，也是跟今天一样的炎热。"

# game/day 2.rpy:1331
translate chinese_simplified river02_memory_dfd825c8:

    # to "「Let's all go play in the river!」"
    # [旧版翻译]
    to "「我们大家一起去河边玩吧！」"

# game/day 2.rpy:1332
translate chinese_simplified river02_memory_5e70b02a:

    # "Just like that, Torahiko made the suggestion."
    # [旧版翻译]
    "就这样，虎彦提出了去玩水的建议。"

# game/day 2.rpy:1333
translate chinese_simplified river02_memory_2295df60:

    # "It was sudden,{p}but as it was so hot, everyone agreed.{p}That way we could play and cool down a bit."
    # [旧版翻译]
    "虽然非常地突然，但是的确太热了，所以大家都同意了这个很棒的建议。[fn]们可以边玩水边消暑。"

# game/day 2.rpy:1334
translate chinese_simplified river02_memory_d10788e2:

    # "Everyone went back to their homes,{p}got their swimsuits, and came back."
    # [旧版翻译]
    "每个人都先回家了一趟，准备好泳装，然后再度地回到这里。"

# game/day 2.rpy:1335
translate chinese_simplified river02_memory_2b6beb88:

    # "After that, we faced the river,{p}and we all raced to be the first one to jump in."
    # [旧版翻译]
    "之后，彷佛比赛似地冲向河边，抢着跳进水里。"

# game/day 2.rpy:1342
translate chinese_simplified river02_memory_254d08f8:

    # who "「Oh, this feels great!」"
    # [旧版翻译]
    who "「呜哦ー，好舒服啊ー！」"

# game/day 2.rpy:1343
translate chinese_simplified river02_memory_ef996dac:

    # "That's what the one who got in first said.{p}All of us behind him, me included, picked up the pace,{p}and hurried into the water."
    # [旧版翻译]
    "这是第一个跳进去地家伙说的。[fn]们所有人包括[fn]自己也加快了脚步，争先恐后地纵身跳入水中。"

# game/day 2.rpy:1344
translate chinese_simplified river02_memory_49c50a52:

    # "All at once the pleasantly cool feeling,{p}wrapped up around us.{p}It felt amazingly good."
    # [旧版翻译]
    "凉意瞬间包覆了整个身体。真的非常地舒服。"

# game/day 2.rpy:1345
translate chinese_simplified river02_memory_e5b5d2c5:

    # "After we all got in, we had a blast."
    # [旧版翻译]
    "大家都下水了之后，玩的非常尽兴。"

# game/day 2.rpy:1346
translate chinese_simplified river02_memory_14a8e51e:

    # "We splashed each other, had stone-skipping contests,{p}and competed to see who could hold their breath the longest."
    # [旧版翻译]
    "彼此泼着水、拿石头比赛谁打水漂的次数比较多、还有谁能在水里潜比较久等等。"

# game/day 2.rpy:1347
translate chinese_simplified river02_memory_5d8c8f3e:

    # "The fun times always go by too fast."
    # [旧版翻译]
    "欢乐地时光，总是过得特别地快。"

# game/day 2.rpy:1348
translate chinese_simplified river02_memory_d0e67b4b:

    # "But eventually, we ran out of things to do."
    # [旧版翻译]
    "但是，[fn]们迟早会把全部的东西给玩完。"

# game/day 2.rpy:1349
translate chinese_simplified river02_memory_38c8e5a0:

    # "Everyone was wondering what to play next."
    # [旧版翻译]
    "每个人都在伤脑筋，『那么接下来玩什么好？』。"

# game/day 2.rpy:1353
translate chinese_simplified river02_memory_37e45468:

    # ko "「How about we go a bit deeper?」"
    # [旧版翻译]
    ko "「要不要到更深一点的地方？」"

# game/day 2.rpy:1354
translate chinese_simplified river02_memory_29e7c43a:

    # "After thinking it over, Kounosuke said that."
    # [旧版翻译]
    "想到最后，孝之助这么说道。"

# game/day 2.rpy:1355
translate chinese_simplified river02_memory_9e4c64b4:

    # "But we were a bit hesitant."
    # [旧版翻译]
    "但是大家有点犹豫。"

# game/day 2.rpy:1356
translate chinese_simplified river02_memory_82d59526:

    # "Going towards the center of the river,{p}the water would get deeper and the current faster.{p}Adults always told us it was dangerous."
    # [旧版翻译]
    "往河中央走去，水不只会变深，而且流速也变得很快。大人总是说「河中央很危险不可以过去」，每次都讲到嘴巴酸了还不厌其烦地唠叨着。"

# game/day 2.rpy:1357
translate chinese_simplified river02_memory_90e5e27a:

    # fn "「But it's dangerous, shouldn't we not go?」"
    # [旧版翻译]
    fn "「可是很危险耶，不要去会不会比较好？」"

# game/day 2.rpy:1358
translate chinese_simplified river02_memory_65b0571f:

    # "I said that, and some others agreed."
    # [旧版翻译]
    "[fn]这么说着，有些人也是这么认为。"

# game/day 2.rpy:1359
translate chinese_simplified river02_memory_1f3c17d2:

    # to "「That's true. But still, I kinda want to.」"
    # [旧版翻译]
    to "「话是没错啦。但是果然，还是会想去嘛」"

# game/day 2.rpy:1360
translate chinese_simplified river02_memory_0e3e2a7b:

    # "Sure, even as I said that,{p}I was still pretty curious."
    # [旧版翻译]
    "确实，在[fn]这么说地同时，其实还是抱有不少兴趣。"

# game/day 2.rpy:1364
translate chinese_simplified river02_memory_80e2e5d9:

    # "The place adults said \"don't go\"."
    # [旧版翻译]
    "大人们口中所谓的「不可以去」的场所。"

# game/day 2.rpy:1365
translate chinese_simplified river02_memory_4b3a8d5c:

    # "We thought we knew it was dangerous.{p}But that only made our curiosity grow."
    # [旧版翻译]
    "[fn]们以为[fn]们都知道，那是危险的。但也因此让我们的好奇心不断茁壮。"

# game/day 2.rpy:1366
translate chinese_simplified river02_memory_5e2b6c8d:

    # "Maybe there's just one spot where the current is fast.{p}Maybe there's just one spot where we can't touch the bottom."
    # [旧版翻译]
    "说不定只有仅仅一处，水流是很快很急的。说不定只有仅仅一处，是我们的脚踩不到底部的。"

# game/day 2.rpy:1367
translate chinese_simplified river02_memory_2a7f9e1b:

    # "Even so, it'd definitely be more fun than here."
    # [旧版翻译]
    "即使如此，也一定比这里还要有趣是不会错的。"

# game/day 2.rpy:1368
translate chinese_simplified river02_memory_6d3c8a4e:

    # "In the end, curiosity won out."
    # [旧版翻译]
    "结果，[fn]们就这样被好奇心战胜了。"

# game/day 2.rpy:1369
translate chinese_simplified river02_memory_9f1b5d7a:

    # "We slowly made our way deeper.{p}The water sank lower and lower."
    # [旧版翻译]
    "大家缓缓地向深处前进着。身体一点一点地下沉。"

# game/day 2.rpy:1370
translate chinese_simplified river02_memory_3e8c2b6d:

    # "The current got faster and faster,{p}even standing still took some effort."
    # [旧版翻译]
    "水流一点一点地变得越来越快，即使[fn]们只是站着，都需要一点力气来维持。"

# game/day 2.rpy:1371
translate chinese_simplified river02_memory_7a4d9e1c:

    # "But we didn't stop, and kept going deeper."
    # [旧版翻译]
    "但我们并没有因此停下，继续走向更深处。"

# game/day 2.rpy:1372
translate chinese_simplified river02_memory_5b2f8c3e:

    # "\"Oh wow, the current's so fast!\" everyone cheered.{p}We loved these little adventures."
    # [旧版翻译]
    "「呜哦ー，水流好快啊！」大家一起欢呼着，[fn]们很喜欢这样的小冒险。"

# game/day 2.rpy:1373
translate chinese_simplified river02_memory_1d6a9e4b:

    # "Before long, one of the older kids leading the way said:"
    # [旧版翻译]
    "不一会儿，其中一个在前面带头的高年级组说："

# game/day 2.rpy:1374
translate chinese_simplified river02_memory_8c3e7d2a:

    # "\"Alright, let's go even deeper in one go!\""
    # [旧版翻译]
    "「唔哦，就这样一口气走到更深的地方吧！」"

# game/day 2.rpy:1375
translate chinese_simplified river02_memory_4f9b1e6c:

    # "Everyone's excited cheers mixed with joy and surprise."
    # [旧版翻译]
    "大家兴奋地叫喊混杂着欢乐与惊喜。"

# game/day 2.rpy:1376
translate chinese_simplified river02_memory_2a7d8c5e:

    # "And then."
    # [旧版翻译]
    "就在这时候。"

# game/day 2.rpy:1382
translate chinese_simplified river02_memory_6e3b9d1a:

    # su "「Wah!?」"
    # [旧版翻译]
    su "「呜啊！？」"

# game/day 2.rpy:1383
translate chinese_simplified river02_memory_9c4e7f2b:

    # "Shun slipped in the river."
    # [旧版翻译]
    "峻在河中不小心滑倒了。"

# game/day 2.rpy:1384
translate chinese_simplified river02_memory_5d8a1c6e:

    # "Being the smallest in height and weight,{p}Shun lost his footing and fell straight into the water."
    # [旧版翻译]
    "不管是身高还是体重都最幼小的峻一没踩好，就这么整只掉到水里面。"

# game/day 2.rpy:1385
translate chinese_simplified river02_memory_7b3e9d4a:

    # "The sound of splashing water rang in everyone's ears."
    # [旧版翻译]
    "水花飞溅的声音在每个人耳边响起。"

# game/day 2.rpy:1386
translate chinese_simplified river02_memory_1c6f8e2d:

    # "Everyone couldn't help but shout out."
    # [旧版翻译]
    "全员都忍不住大喊了出来。"

# game/day 2.rpy:1387
translate chinese_simplified river02_memory_4e9a7b3c:

    # "--Crap, we need to do something fast."
    # [旧版翻译]
    "――惨了，不快点做些什么的话。"

# game/day 2.rpy:1388
translate chinese_simplified river02_memory_8d2c5e1a:

    # "Everyone was thinking the same thing.{p}But our minds went completely blank.{p}In the end, nobody knew what to do."
    # [旧版翻译]
    "大家都在思考着同样一件事情。但是脑内完全一片空白。结果，到底该怎么办，没有人知道。"

# game/day 2.rpy:1389
translate chinese_simplified river02_memory_3f7b9d6e:

    # "So for now, we just shouted at Shun."
    # [旧版翻译]
    "所以总之，[fn]们朝着峻大喊。"

# game/day 2.rpy:1390
translate chinese_simplified river02_memory_6a4e8c1d:

    # "But even so, Shun was getting swept further away.{p}We panicked, not knowing what to do."
    # [旧版翻译]
    "但是即使这样峻依然被水越冲越远。大家慌了手脚，不知道该怎么办才好。"

# game/day 2.rpy:1391
translate chinese_simplified river02_memory_9b5d7e3a:

    # who "「What are you kids doing!」"
    # [旧版翻译]
    who "「你们这些家伙在搞什么！」"

# game/day 2.rpy:1392
translate chinese_simplified river02_memory_2c8f6d4b:

    # "At the last moment,{p}an adult's angry voice came from the riverbed--"
    # [旧版翻译]
    "千钧一发之际，[wds]从河滩传来了大人的怒斥声――[rd]"

# game/day 2.rpy:1398
translate chinese_simplified river02_memory_5e9a7c3d:

    # ka "「In the end, Shun was saved safely,{p}and we all got a good scolding.」"
    # [旧版翻译]
    ka "「结果，峻平安无事地被救了出来，而我们全员被痛骂了一顿。」"

# game/day 2.rpy:1399
translate chinese_simplified river02_memory_1d6b8e4a:

    # fn "「Yeah, that's right.{p} I remember that now.」"
    # [旧版翻译]
    fn "「嗯，对呀。说起来的确有这么样的一件事呢。」"

# game/day 2.rpy:1400
translate chinese_simplified river02_memory_7c3e9d2b:

    # "Come to think of it, why did I forget such a memorable event?"
    # [旧版翻译]
    "话说回来印象这么深刻的事件，为什么[fn]会把它忘了？"

# game/day 2.rpy:1404
translate chinese_simplified river02_memory_4f8a6e1c:

    # su "「Yeah, I was wondering what would happen to me back then...」"
    # [旧版翻译]
    su "「是啊，那时候还在想我会变成怎么样呢……」"

# game/day 2.rpy:1405
translate chinese_simplified river02_memory_9b2d7c5e:

    # ka "「Shun couldn't swim back then.{p}I was scared watching him, not knowing what would happen.」"
    # [旧版翻译]
    ka "「峻在那个时候还不会游泳。我看着也很害怕不知道会变怎样。」"

# game/day 2.rpy:1406
translate chinese_simplified river02_memory_3e6a8d1b:

    # fn "「Yeah.{p} After that, for a little while,{p}nobody dared to suggest going to the river again.」"
    # [旧版翻译]
    fn "「嗯。在那之后的一小段时间里，都没有人敢再提议去河边呢。」"

# game/day 2.rpy:1410
translate chinese_simplified river02_memory_6c9e4d7a:

    # su "「But, I can swim now.{p}So going to the deeper part is no problem.」"
    # [旧版翻译]
    su "「但是，现在已经会游泳了。所以往深的地方去也没有问题喔。」"

# game/day 2.rpy:1411
translate chinese_simplified river02_memory_2d8f5e3c:

    # fn "「Nah, even if we go to the center now, we won't get swept away.」"
    # [旧版翻译]
    fn "「啊不，现在的话就算走到河中央也不会被冲走的啦。」"

# game/day 2.rpy:1412
