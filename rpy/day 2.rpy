translate chinese_simplified tatsuki02_e4611513:

    # extend "Gahahaha!」"
    # [旧版翻译]
    extend "哈哈哈……」"

# game/day 2.rpy:1594
translate chinese_simplified tatsuki02_9817701c:

    # fn "「Sorry, I was just thinking about...{p} how I missed the old times.」"
    # [旧版翻译]
    fn "「抱歉抱歉，觉得有些怀念而已。」"

# game/day 2.rpy:1595
translate chinese_simplified tatsuki02_1a81779e:

    # fn "「And speaking of which, back then,\n they wouldn't let me into the workplace.」"
    # [旧版翻译]
    fn "「不过话说回来，要在以前，这个地方，别说进来，连接近都不允许吧？」"

# game/day 2.rpy:1596
translate chinese_simplified tatsuki02_effcd467:

    # fn "「You said that it\n \"wasn't a place for kids to play around in\"...」"
    # [旧版翻译]
    fn "「就连辰兄的在这里也只算是个小孩子吧。只是因为[fn]来帮忙，所以就随便进来参观什么的，大人们不会允许吧。」"

# game/day 2.rpy:1597
translate chinese_simplified tatsuki02_7e07183f:

    # fn "「And I couldn't help,\n even with you watching me.」"
    # [旧版翻译]
    fn "「就连辰兄的在这里也只算是个小孩子吧。只是因为[fn]来帮忙，所以就随便进来参观什么的，大人们不会允许吧。」"

# game/day 2.rpy:1601
translate chinese_simplified tatsuki02_27c8bb0c:

    # ta "「It's dangerous with the tools lying about.{p} Even then, the guys were just hanging around.」"
    # [旧版翻译]
    ta "「因为这里有锐器之类的东西所以才危险嘛。作为学徒的孩子们不允许在这里闲逛。这里可不是半桶水的家伙来玩的地方。」"

# game/day 2.rpy:1605
translate chinese_simplified tatsuki02_891d6a57:

    # ta "「This isn't a good place to hang out, anyway.{p} They wouldn't let me start as an\n apprentice until I graduated.」"
    # [旧版翻译]
    ta "「到了能够独当一面以后，才让会他们做一些收拾打扫之类的事情。」"

# game/day 2.rpy:1609
translate chinese_simplified tatsuki02_01cb3eaa:

    # ta "「It's only recently that I was able\n to start learning as an apprentice.」"
    # [旧版翻译]
    ta "「我可是好不容易才捱到现在的，大人们才开始终于肯教我做一些实习工的工作。」"

# game/day 2.rpy:1610
translate chinese_simplified tatsuki02_03cf916c:

    # fn "「That's too bad.{p} In that case, I'd be no use if I tried to help...」"
    # [旧版翻译]
    fn "「这么严厉啊！那[fn]现在进来岂不是很槽糕吗……」"

# game/day 2.rpy:1614
translate chinese_simplified tatsuki02_a1033492:

    # ta "「Nah, since this is the garden,\n you've been watching me a lot.{p} My old man's been getting soft on ya.」"
    # [旧版翻译]
    ta "「没事的，这里是庭院前面，应该不会怪罪[fn]的。我老爸对[fn]很和善的。」"

# game/day 2.rpy:1615
translate chinese_simplified tatsuki02_406183df:

    # fn "「Huh, really?{p} I can't picture him as anything\n but mad and scary.」"
    # [旧版翻译]
    fn "「呃，真是这样吗？在[fn]的印象里，他似乎只会对我生气，很恐怖啊。」"

# game/day 2.rpy:1619
translate chinese_simplified tatsuki02_0fd5b98b:

    # ta "「Well, about that,\n it's because you and Tora\n were always messing around.」"
    # [旧版翻译]
    ta "「那是因为你总是和虎一起调皮捣蛋才会那样啦。就算那样，比起对待我，已经十分温和了。」"

# game/day 2.rpy:1620
translate chinese_simplified tatsuki02_f7da02d8:

    # ta "「But if I were him,\n I'd be a lot nicer for sure.」"
    # [旧版翻译]
    ta "「比如你把我家堆放的木材弄倒的时候，还有偷我老爸工具的时候，我吓得心脏都要停止了。」"

# game/day 2.rpy:1621
translate chinese_simplified tatsuki02_350494ab:

    # ta "「If you needed me to fix something,\n I'd take out my tools,\n and do it in a heartbeat!」"
    # [旧版翻译]
    ta "「比如你把我家堆放的木材弄倒的时候，还有偷我老爸工具的时候，我吓得心脏都要停止了。」"

# game/day 2.rpy:1622
translate chinese_simplified tatsuki02_0aff75c7:

    # ta "「Besides, don't remind me of those...\n shenanigans you and Tora got into.」"
    # [旧版翻译]
    ta "「别告诉我你忘了。你搞的那些恶作剧，都能流传千古了。」"

# game/day 2.rpy:1623
translate chinese_simplified tatsuki02_a4886bef:

    # fn "「You think I'd mess around like that?!」"
    # [旧版翻译]
    fn "「那种事也是我做的吗？」"

# game/day 2.rpy:1627
translate chinese_simplified tatsuki02_de09650c:

    # ta "「Don't tell me you forgot.{p} All those pranks you did ended up\n being passed down as the stuff of legends!」"
    # [旧版翻译]
    ta "「别告诉我你忘了。你搞的那些恶作剧，都能流传千古了。」"

# game/day 2.rpy:1631
translate chinese_simplified tatsuki02_67dff24b:

    # ta "「My Pa might have taken an interest\n because your family is so well known.」"
    # [旧版翻译]
    ta "「尤其是我老爸最中意的……你拿了我家代代相传的刨刀，一边说笑，一边扔着玩的那件事。」"

# game/day 2.rpy:1632
translate chinese_simplified tatsuki02_67d84362:

    # ta "「You know, sometimes,\n he still talks about you guys.」"
    # [旧版翻译]
    ta "「那简直堪称杰作了。那时我爷爷还在世，好像是用了『空手夺白刃』的看家本事抓住刀，这才没事。」"

# game/day 2.rpy:1633
translate chinese_simplified tatsuki02_6a961686:

    # fn "「What, and you didn't pull your\n fair share of childhood pranks, too?」"
    # [旧版翻译]
    fn "「我爷爷拼了命使出了Sliding Catch，才接住的。就连哲叔都要昏过去了，你到底是怎么从戒备森严的工房把刀拿出来的？」"

# game/day 2.rpy:1637
translate chinese_simplified tatsuki02_087bc1f4:

    # ta "「Well, I'm not gonna lie.{p} I pulled some pretty awesome pranks, too.{p} I remember some of the stuff I did was crazy.」"
    # [旧版翻译]
    ta "「那次真是惊心动魄啊。」"

# game/day 2.rpy:1638
translate chinese_simplified tatsuki02_a20aff14:

    # fn "「Oh, really...」"
    # [旧版翻译]
    fn "「是这样么……」"

# game/day 2.rpy:1639
translate chinese_simplified tatsuki02_4545b339:

    # "I've forgotten everything I've done,\nbut if I remembered any of that stuff...{p}Man, I wouldn't be too happy."
    # [旧版翻译]
    "说起来不止是在翠屋組，我记得在村子里也做过其他类似的什么事。不过当时我们还是小孩子，现在那些事全都忘了。"

# game/day 2.rpy:1643
translate chinese_simplified tatsuki02_c9fb4d28:

    # who "「Oh, you two messing around again?」"
    # [旧版翻译]
    who "「喂，你们又在商量搞什么恶作剧了吗？」"

# game/day 2.rpy:1650
translate chinese_simplified tatsuki02_52fe192e:

    # fn "「G-good afternoon...{p} It's been a while, h-hasn't it?」"
    # [旧版翻译]
    fn "「啊，你好，好久不见了」"

# game/day 2.rpy:1651
translate chinese_simplified tatsuki02_0401d930:

    # tp "「Long time no see, kid.{p} Heard ya came back from the city.{p} It's your old home town, relax.」"
    # [旧版翻译]
    tp "「小子，好久不见了啊。你回来的事情已经从小鬼那里听到了。真是好久没有回故乡来看看了呢。」"

# game/day 2.rpy:1652
translate chinese_simplified tatsuki02_ebac2ecd:

    # "That sharp voice,\nthat piercing, determined gaze...{p}No doubt about it, it's Tappei-san."
    # [旧版翻译]
    "这个洪亮的声音，这犀利的眼神……没错，是辰平叔。"

# game/day 2.rpy:1656
translate chinese_simplified tatsuki02_c2d10b59:

    # "His hair's gotten thinner since I last saw him.{p}Does he still have his favorite pipe?"
    # [旧版翻译]
    "比起以前似乎头发少了一些。不知道他现在吸烟是不是还用他那心爱烟袋。"

# game/day 2.rpy:1657
translate chinese_simplified tatsuki02_64aaf443:

    # "I can smell pipe tobacco.{p}He's still a little scary.\nIt doesn't help that he looks bigger all around."
    # [旧版翻译]
    "从他身上闻到了一丝淡淡的旱烟味道。体格非常巨大，比辰兄还要大上一圈。"

# game/day 2.rpy:1658
translate chinese_simplified tatsuki02_8a0add55:

    # "I think he weighs more than Tatsu-nii.{p}They still look alike, though."
    # [旧版翻译]
    "不过，长得跟辰兄真的很像呢。以前都没有过这种想法，五年后的现在再看，两人真是一摸一样。"

# game/day 2.rpy:1659
translate chinese_simplified tatsuki02_95cb4e47:

    # "Once I think about it,\nif Tatsu-nii were to grow older,\nhe'd look like Tappei-san."
    # [旧版翻译]
    "也就是说，尖尖头的辰兄也上年纪了么……咦？感觉情况有点奇怪？"

# game/day 2.rpy:1660
translate chinese_simplified tatsuki02_2516ac1f:

    # "Hmm... strange."
    # [旧版翻译]
    "也就是说，尖尖头的辰兄也上年纪了么……咦？感觉情况有点奇怪？"

# game/day 2.rpy:1664
translate chinese_simplified tatsuki02_2cf4c1b7:

    # tp "「Hey, can't an apprentice\n be done with the clean up?」"
    # [旧版翻译]
    tp "「喂，当个实习工连打扫整理的事情都做不来吗？居然让人家客人来做帮手？」"

# game/day 2.rpy:1665
translate chinese_simplified tatsuki02_d69c14c9:

    # tp "「If a guest has to help,\n then anybody could be teaching you.」"
    # [旧版翻译]
    tp "「喂，当个实习工连打扫整理的事情都做不来吗？居然让人家客人来做帮手？」"

# game/day 2.rpy:1669
translate chinese_simplified tatsuki02_1f22f06a:

    # ta "「T-that's...」"
    # [旧版翻译]
    ta "「那、那是因为……」"

# game/day 2.rpy:1670
translate chinese_simplified tatsuki02_3ae32fde:

    # fn "「H-hold on,\n I forced him into letting me help.{p} I-I'm sorry.」"
    # [旧版翻译]
    fn "「请等一下。是[fn]非要帮忙的。真的很抱歉」"

# game/day 2.rpy:1674
translate chinese_simplified tatsuki02_c28e3bf7:

    # ta "「This is is my responsibility.{p} You don't need to apologize.」"
    # [旧版翻译]
    ta "「不，这是我的责任，你不必道歉」"

# game/day 2.rpy:1675
translate chinese_simplified tatsuki02_95d49f96:

    # fn "「But...」"
    # [旧版翻译]
    fn "「但是……」"

# game/day 2.rpy:1676
translate chinese_simplified tatsuki02_31b3e478:

    # "So he really is a scary guy.{p}Clean up is also a big job,\nso I shouldn't have put my hands into it."
    # [旧版翻译]
    "果然还是那么恐怖。打扫整理也是件很重要的工作，[fn]似乎真不应该提出要帮忙什么的。"

# game/day 2.rpy:1677
translate chinese_simplified tatsuki02_5ae7f8df:

    # "I got Tatsu-nii into trouble,\nNow Tappei-san's angry..."
    # [旧版翻译]
    "这样似乎就给辰兄添了麻烦，辰平叔也好像很生气的样子……怎么在笑？"

# game/day 2.rpy:1681
translate chinese_simplified tatsuki02_555873e4:

    # "Wait, he's laughing?"
    # [旧版翻译]
    "这样似乎就给辰兄添了麻烦，辰平叔也好像很生气的样子……怎么在笑？"

# game/day 2.rpy:1685
translate chinese_simplified tatsuki02_105f4410:

    # tp "「Gahahahaha, I'm kidding!{p} Why so serious with that look on your face?」"
    # [旧版翻译]
    tp "「嘎哈哈哈哈，开玩笑的啦。你们别当真啊，看你们一脸严肃的表情。」"

# game/day 2.rpy:1686
translate chinese_simplified tatsuki02_220e4635:

    # fn "「Huh? But, you said that...{p} I got in the way of work.」"
    # [旧版翻译]
    fn "「诶？可是，[fn]妨碍了这里的工作。」"

# game/day 2.rpy:1690
translate chinese_simplified tatsuki02_20d4f5c6:

    # tp "「Work? we're just running errands today.{p} The guys and I work in the late afternoon.」"
    # [旧版翻译]
    tp "「工作？今天已经下班啦。员工只在太阳下山前工作，这是老规矩了。」"

# game/day 2.rpy:1691
translate chinese_simplified tatsuki02_93713d02:

    # tp "「If you wanna do some work that much,\n why don't you get a job yourself?」"
    # [旧版翻译]
    tp "「下午五点后再冒出来什么家伙的话，想加入打工的话，非常欢迎。」"

# game/day 2.rpy:1692
translate chinese_simplified tatsuki02_87b3043d:

    # "While Tappei-san can be scary when he's mad,\nhe's usually a playful, old guy."
    # [旧版翻译]
    "虽然辰平叔在平时工作时发怒是很恐怖的，但平时还是一个温柔的，爱开玩笑的大叔。"

# game/day 2.rpy:1693
translate chinese_simplified tatsuki02_bfbfa4e3:

    # "His temper left a strong impression.{p}I recall his tantrums first..."
    # [旧版翻译]
    "现在仔细回想，除了他令人印象深刻的可怕样子以外，让人有印象的还有，他似乎也曾经和我还有虎彦一起玩耍过呢。"

# game/day 2.rpy:1694
translate chinese_simplified tatsuki02_f6495153:

    # "But there were also times\nwhen he would play with us too."
    # [旧版翻译]
    "现在仔细回想，除了他令人印象深刻的可怕样子以外，让人有印象的还有，他似乎也曾经和我还有虎彦一起玩耍过呢。"

# game/day 2.rpy:1695
translate chinese_simplified tatsuki02_b4b6ffdb:

    # "Hell, he even got along with Torahiko,\nwhen he was at his worst, that is."
    # [旧版翻译]
    "现在仔细回想，除了他令人印象深刻的可怕样子以外，让人有印象的还有，他似乎也曾经和我还有虎彦一起玩耍过呢。"

# game/day 2.rpy:1696
translate chinese_simplified tatsuki02_dfea2734:

    # "With that said, him being mad...{p}it's weird, isn't it?"
    # [旧版翻译]
    "呃，刚刚他是不是说了什么了不得的事情？"

# game/day 2.rpy:1700
translate chinese_simplified tatsuki02_1959ab85:

    # tp "「I didn't ask you to work here today.{p} It's all right as you've got free time,\n and you've been cleaning up since last night.」"
    # [旧版翻译]
    tp "「打工的话，也没必要一大早就过来。闲暇的时候就可以，就像今天傍晚过来打扫之类的，帮忙整理工作场所之类的不是挺不错吗？」"

# game/day 2.rpy:1701
translate chinese_simplified tatsuki02_671adc26:

    # tp "「So how about you help out,\n with a little organizing here?」"
    # [旧版翻译]
    tp "「在这段时间也得需要钱吧， 我会付给你打工钱的。」"

# game/day 2.rpy:1705
translate chinese_simplified tatsuki02_10b8f6c4:

    # tp "「Earning a buck never hurts, right?{p} You can get started with a part-time wage.」"
    # [旧版翻译]
    tp "「真的只要闲暇时间就行了。不喜欢干活，只要来报个到就行了。来这里喝茶吃点心就能拿到工钱。」"

# game/day 2.rpy:1706
translate chinese_simplified tatsuki02_55787126:

    # fn "「Huh? What are you saying all of a sudden...」"
    # [旧版翻译]
    fn "「可是，就算你突然这么说…………」"

# game/day 2.rpy:1711
translate chinese_simplified tatsuki02_1948f3e8:

    # tp "「Free time sure is great.{p} If you hate working,\n you can just show your face around here too.」"
    # [旧版翻译]
    tp "「再不行，就是来做的别的事情也没问题……。你那份工钱也会给你……」"

# game/day 2.rpy:1712
translate chinese_simplified tatsuki02_e9655f6b:

    # tp "「Let's see... The tools need to be put back...{p} There's some lumber that needs stacking...」"
    # [旧版翻译]
    tp "「辰平叔……。这不就是所谓的「援助交际」了吗？"

# game/day 2.rpy:1713
translate chinese_simplified tatsuki02_59197af1:

    # tp "「At that rate you'll make a decent amount.」"
    tp ""

# game/day 2.rpy:1714
translate chinese_simplified tatsuki02_59fa660d:

    # "Tappei-san...{p}You aren't the type to go on...{p}Paid days off, are you?"
    ""

# game/day 2.rpy:1718
translate chinese_simplified tatsuki02_477062f7:

    # ta "「That's enough, Pa!{p} Using me like that, jeez.」"
    # [旧版翻译]
    ta "「适可而止吧，老爸！别这样擅自就做决定。[fn]别理他！」"

# game/day 2.rpy:1719
translate chinese_simplified tatsuki02_bbef1004:

    # ta "「[fn], trust me.{p} Don't hang out with this guy.」"
    ta ""

# game/day 2.rpy:1723
translate chinese_simplified tatsuki02_b0fdfbb3:

    # tp "「Shut up!{p} Don't shoot your mouth off\n at the work of craftsmen!」"
    # [旧版翻译]
    tp "「吵死啦！！！是个好员工的话，工作时就别乱插嘴！！！闭嘴干活！」"

# game/day 2.rpy:1727
translate chinese_simplified tatsuki02_f81ae6aa:

    # ta "「(That makes no difference...)」"
    # [旧版翻译]
    ta "「（那个不觉得有什么不对劲的么……）」"

# game/day 2.rpy:1728
translate chinese_simplified tatsuki02_592c8583:

    # tp "「Listen, I'm saying this for your own sake.{p} Understand, son?」"
    # [旧版翻译]
    tp "「你给我听好了，我之所以这样说，可是为了你。难得[fn]他回来了一次，我这可是为了一心工作连玩耍也不顾的儿子着想的。」"

# game/day 2.rpy:1729
translate chinese_simplified tatsuki02_55f49ce0:

    # tp "「Even after [fn] came back after so long,\n I thought you were the kind of son\n who'd finish work before going to play.」"
    tp ""

# game/day 2.rpy:1733
translate chinese_simplified tatsuki02_af19eb27:

    # tp "「Your father has a smart plan after all.{p} You oughta thank me.」"
    # [旧版翻译]
    tp "「你的超级坏脾气的老爸，也想帮你做些什么啊。感谢我吧。」"

# game/day 2.rpy:1737
translate chinese_simplified tatsuki02_b72f240d:

    # ta "「Oh, sorry Pa. Thanks after all.」"
    # [旧版翻译]
    ta "「抱歉，谢谢老爸……」"

# game/day 2.rpy:1741
translate chinese_simplified tatsuki02_9c24e1f3:

    # ta "「What? Is that what you wanted to hear?{p} Yeah, like I'd actually say that!{p} You're totally doing this all for yourself.」"
    # [旧版翻译]
    ta "「你觉得我会我会这么说吗！！谁都能看出来老爸是为了自己才说的。不用说，你肯定在想着些损人利己的事吧。」"

# game/day 2.rpy:1745
translate chinese_simplified tatsuki02_713e8460:

    # "Hmm, but it's true I'm running low on cash."
    # [旧版翻译]
    "唔，不过现在钱的确很紧张。"

# game/day 2.rpy:1746
translate chinese_simplified tatsuki02_f5ab0214:

    # "I could do it while I'm free,\nand if it's during the evening,\nthen it won't affect any plans..."
    # [旧版翻译]
    "既然辰平叔说了有空时候就可以来，只是在傍晚去帮忙干活的话，也不会影响其他的安排。"

# game/day 2.rpy:1750
translate chinese_simplified tatsuki02_9ca4e9e1:

    # fn "「Well if it's all right,\n when my hands are empty,\n then please let me help.」"
    # [旧版翻译]
    fn "「那么，什么时候闲着的话，我就过来帮忙。」"

# game/day 2.rpy:1754
translate chinese_simplified tatsuki02_7c704c4a:

    # ta "「Are you serious?{p} You don't have to force yourself.」"
    # [旧版翻译]
    ta "「你说真的？不要勉强啊。」"

# game/day 2.rpy:1755
translate chinese_simplified tatsuki02_c0bcbca7:

    # fn "「Yeah, of course I am.{p} It'll be tough with the money I have now.{p} I have to pay for souvenirs, travel fees...」"
    # [旧版翻译]
    fn "「恩，说真的哦，只靠我带的那点儿钱真的不够用呢。来这里不买些土产品的话，就太遗憾了。还有路费也……」"

# game/day 2.rpy:1756
translate chinese_simplified tatsuki02_e58151a3:

    # fn "「And besides,\n I've been wanting to hang out with you.」"
    # [旧版翻译]
    fn "「不过其实，……更主要的是，想和辰兄一起玩。」"

# game/day 2.rpy:1760
translate chinese_simplified tatsuki02_a72d3d5b:

    # ta "「Idiot. You're coming over to play,\n not to work.」"
    # [旧版翻译]
    ta "「笨蛋！你在这里是工作，没法和你玩。」"

# game/day 2.rpy:1764
translate chinese_simplified tatsuki02_d9f6afdf:

    # tp "「Well then. It's decided.{p} If that's how it goes,\n I have to explain the work to you.」"
    # [旧版翻译]
    tp "「好就这么定了。既然这样，不如早点说明一下工作的相关事宜，好久没来了，就在我家吃饭吧。」"

# game/day 2.rpy:1765
translate chinese_simplified tatsuki02_c4917987:

    # tp "「And after that,\n we can grab a bite to eat.」"
    tp ""

# game/day 2.rpy:1766
translate chinese_simplified tatsuki02_e87acba0:

    # "Looks like I'll have a great time.{p}Hanging with Tatsu-nii and everyone\nis always a lot of fun."
    # [旧版翻译]
    "以前辰兄和大家一起玩到太阳下山的话，辰平叔也经常对我们这么说，「好久没来了，就在我家吃饭吧」。"

# game/day 2.rpy:1767
translate chinese_simplified tatsuki02_abf04b39:

    # "Tappei will probably scold us for being late,\nlike he always does when we're out."
    # [旧版翻译]
    "那时候经常玩的到很晚还弄得一身脏乎乎，他会让我们在他家洗澡。"

# game/day 2.rpy:1768
translate chinese_simplified tatsuki02_4d6b974d:

    # "If it gets to be late,\nand I get to be a little dirty,\nI wonder if I can wash up here."
    # [旧版翻译]
    "然后大家围坐到一起吃饭，那时真的很开心。"

# game/day 2.rpy:1769
translate chinese_simplified tatsuki02_0e87a765:

    # "After that, we'll all gather for dinner...{p}Sounds like a plan."
    tp ""

# game/day 2.rpy:1773
translate chinese_simplified tatsuki02_1bf3fcb2:

    # ta "「Sorry Pa, but [fn] and I are going out,\n and actually having a good time.」"
    # [旧版翻译]
    ta "「抱歉啊老爸，等一下我们要出去玩呢。我把剩下的收拾完，就和[fn]一起出去。」"

# game/day 2.rpy:1774
translate chinese_simplified tatsuki02_be7c6ed4:

    # ta "「Just a little more to do,\n and then we can leave, all right?」"
    ta ""

# game/day 2.rpy:1775
translate chinese_simplified tatsuki02_4363b5e7:

    # "We promised to hang out today but,\nat this rate it wouldn't be bad\nto have a dinner with Tappei and company."
    # [旧版翻译]
    "虽然约定好了一起出去玩不过在在翠屋组这样的大屋里吃晚饭，其实也不错呢……"

# game/day 2.rpy:1789
translate chinese_simplified tatsuki02_hangout_b1d54573:

    # fn "「Hmm, it's tempting...{p} but for a while now,\n I've wanted to spend time with Tatsu-nii.」"
    # [旧版翻译]
    fn "「虽然难得辰平邀请，但还是更期待和辰兄一起外出，所以还是拒绝了。」"

# game/day 2.rpy:1790
translate chinese_simplified tatsuki02_hangout_eebf5831:

    # "I've been looking forward to it,\nso I guess I'll have to turn down Tappei-san."
    # [旧版翻译]
    "叫上虎彦，像以前一样三个人一起大吵大闹吧。"

# game/day 2.rpy:1791
translate chinese_simplified tatsuki02_hangout_4935c6fb:

    # "Maybe I can call over Torahiko,\nand the three of us can horse around,\njust like old times..."
    # [旧版翻译]
    "呃，不过已经不是小孩子了，还那样吵闹的话，太丢脸了，叫个别的人也不错。"

# game/day 2.rpy:1792
translate chinese_simplified tatsuki02_hangout_4f953f9f:

    # "We're not kids anymore though, so...{p}acting like one is a no-no.{p}Wonder who else I can call..."
    fn ""

# game/day 2.rpy:1793
translate chinese_simplified tatsuki02_hangout_473d14ef:

    # fn "「Ehehe, I haven't started work yet,\n and I've already made a promise with Tatsu-nii.」"
    # [旧版翻译]
    fn "「哦呵呵，今天没有干什么活……而且和辰兄有事先约好了，所以吃饭还是下次吧。等下次再有机会的吧。」"

# game/day 2.rpy:1794
translate chinese_simplified tatsuki02_hangout_2c6a7fd1:

    # fn "「We'll relax and eat together another time.{p} The fun's just getting started...」"
    tp ""

# game/day 2.rpy:1798
translate chinese_simplified tatsuki02_hangout_4e000bd9:

    # tp "「Is that so...{p} Well then boys, see you later.」"
    # [旧版翻译]
    tp "「这样啊。那再见了，真的要来帮忙哦。我很忙，得赶紧走了。」"

# game/day 2.rpy:1799
translate chinese_simplified tatsuki02_hangout_a8551986:

    # tp "「Be sure to come back on time for work.{p} I'm gonna need some help tonight.」"
    tp ""

# game/day 2.rpy:1805
translate chinese_simplified tatsuki02_hangout_b4e8c3fe:

    # "Huh, for a second he looked lonely...{p}Was that my imagination?"
    # [旧版翻译]
    "啊？一瞬间似乎他看到有些失落……是错觉么？"

# game/day 2.rpy:1809
translate chinese_simplified tatsuki02_hangout_eba449c5:

    # ta "「\"Gonna need some help,\" my ass.{p} Jeez... He was eating earlier,\n and he even gave that excuse.」"
    # [旧版翻译]
    ta "「老爸真是的，什么很忙啊，刚刚不是还说吃饭啊，工作上的事宜啊什么的么？究竟想干什么……」"

# game/day 2.rpy:1810
translate chinese_simplified tatsuki02_hangout_40fcb6a3:

    # ta "「What the hell is he getting at?」"
    fn ""

# game/day 2.rpy:1811
translate chinese_simplified tatsuki02_hangout_7355f68a:

    # fn "「Hey, at least Tappei-san seems lively.{p} My dad isn't that much fun...」"
    # [旧版翻译]
    fn "「辰平叔看上去也很精神，人也很有趣。真希望[fn]的老爸也像辰平叔那样呢。」"

# game/day 2.rpy:1812
translate chinese_simplified tatsuki02_hangout_71bd4018:

    # "A bigger, bolder,\nlivelier middle aged dragonman.{p}If I had a father like that..."
    # [旧版翻译]
    "高大、健壮又豪爽的中年龙人，如果有这样的父亲的话……。"

# game/day 2.rpy:1816
translate chinese_simplified tatsuki02_hangout_ef98f0e5:

    # ta "「You're kidding me, right?{p} There's nothing good about living with him.{p} That damned old man...」"
    # [旧版翻译]
    ta "「得了吧，跟他在一起才不会是什么好事。那样的混蛋老爸。」"

# game/day 2.rpy:1820
translate chinese_simplified tatsuki02_hangout_838ef241:

    # ta "「When it comes to work,\n he can be strict like a demon.{p} I guess that's why he's so successful.」"
    # [旧版翻译]
    ta "「而且只要是和工作有关的事情，就会变得鬼一样严格，你知道吗？嘛，应该说是，只有工作的方面做得还算像个样儿。」"

# game/day 2.rpy:1821
translate chinese_simplified tatsuki02_hangout_35e00acf:

    # fn "「Huh, so you do respect your dad.」"
    # [旧版翻译]
    fn "「唔，看来辰兄对父亲很尊敬呢。」"

# game/day 2.rpy:1825
translate chinese_simplified tatsuki02_hangout_b9fb1f91:

    # ta "「Whaa!? No way that's true.{p} I recognize him as a craftsman,\n but how could I respect him?」"
    # [旧版翻译]
    ta "「啊！？那么可能？作为工作上的员工来说的话，虽然很赏识他，但尊敬什么的才不会。」"

# game/day 2.rpy:1826
translate chinese_simplified tatsuki02_hangout_14ee9629:

    # "What a bad lie.{p}You're getting all red and bashful.{p}It's cute even if you're so big..."
    # [旧版翻译]
    "辰兄不会说谎呢，脸都红了。可爱的大个子。"

# game/day 2.rpy:1827
translate chinese_simplified tatsuki02_hangout_c8d37672:

    # ta "「What are you smiling about?{p} Anyway, get ready.」"
    # [旧版翻译]
    ta "「傻笑什么啊。呐，我去稍微准备一下。」"

# game/day 2.rpy:1834
translate chinese_simplified tatsuki02_eat_538f3965:

    # "Since all the workers live\nand work around the house,\nit could be fun joining them."
    # [旧版翻译]
    "在辰兄家里，在这里工作的人都住在一起，于是，围坐在饭桌前就像一家人一样，让人觉得很温馨。而且基本全都是雄性兽人的说。"

# game/day 2.rpy:1835
translate chinese_simplified tatsuki02_eat_886f946d:

    # "It's almost like an extended family.{p}Nothing but buff beastmen,\ngathered around the dinner table..."
    fn ""

# game/day 2.rpy:1836
translate chinese_simplified tatsuki02_eat_6df4664f:

    # fn "「Ah, it's been so long...{p} I want to have dinner with the gang.{p} I want to hear some stories about work, too.」"
    # [旧版翻译]
    fn "「好久没来了，想在翠屋組里热闹地吃晚饭呢，顺便了解一下工作方面的事情。」"

# game/day 2.rpy:1837
translate chinese_simplified tatsuki02_eat_f4cfa4ef:

    # tp "「Right, aren't you quick to pick up on things.」"
    # [旧版翻译]
    tp "「就是说嘛，就知道你大概也不清楚工作之类的事情。」"

# game/day 2.rpy:1838
translate chinese_simplified tatsuki02_eat_5217fea1:

    # ta "「But isn't Ma not here today?{p} Wouldn't that mean we'd have to make dinner?」"
    # [旧版翻译]
    ta "「不过今天，妈妈不是不在家吗？她还说今天的晚饭让我们随便找个地方凑合吧。」"

# game/day 2.rpy:1839
translate chinese_simplified tatsuki02_eat_61a292d3:

    # tp "「We can still talk about work, at least.{p} [fn], when you're done, we'll eat at Raimon.」"
    # [旧版翻译]
    tp "「不过有关工作的事还是应该说一下，[fn]，忙活完之后就来雷门吧，我请你吃饭。」"

# game/day 2.rpy:1843
translate chinese_simplified tatsuki02_eat_e316aff3:

    # ta "「Pa... You don't have money now, do you?{p} Ma asked me to watch over you,\n so that you don't go crazy with your cash.」"
    # [旧版翻译]
    ta "「老爸，你现在没有带钱吧。而且妈妈吩咐过要我好好看着你，不让你对别人动手动脚的说。」"

# game/day 2.rpy:1847
translate chinese_simplified tatsuki02_eat_becdf094:

    # tp "「What!? Geh, I'm gonna empty my wallet then.{p} This is work-related, so...{p} It wouldn't concern Ma.」"
    # [旧版翻译]
    tp "「什么？呃，钱包真的空了。工作之类的事和你老妈没关系吧，管个毛线啊。」"

# game/day 2.rpy:1848
translate chinese_simplified tatsuki02_eat_a0cbfdce:

    # ta "「So we're going to Raimon?」"
    # [旧版翻译]
    ta "「都去了雷门了，还算哪门子工作的事了？」"

# game/day 2.rpy:1852
translate chinese_simplified tatsuki02_eat_2ab7167c:

    # tp "「Still!」"
    # [旧版翻译]
    tp "「可是！」"

# game/day 2.rpy:1856
translate chinese_simplified tatsuki02_eat_8fb72fbe:

    # ta "「'Still' my ass!{p} Old people should pipe down and be good.{p} I'm not the only one watching you today.」"
    # [旧版翻译]
    ta "「可是啥！真是没法子，上了年纪就老实点吧。今天负责监视老爸的可不止我一个哦。」"

# game/day 2.rpy:1860
translate chinese_simplified tatsuki02_eat_a4f37782:

    # tp "「Keh... It's all right if I'm good, right.{p} Staying at home by myself is all right,\n for a guy like me.」"
    # [旧版翻译]
    tp "「哼……。那我就表现老实一点，总可以了吧，像我这样的家伙，就在家里寂寞地呆到爆吧。」"

# game/day 2.rpy:1864
translate chinese_simplified tatsuki02_eat_55cc6c12:

    # ta "「No worries, Pa.\n It's a large family here, you won't be alone.」"
    # [旧版翻译]
    ta "「放心吧老爸，我们这种大户人家又不只你一个人看家，不会寂寞的。」"

# game/day 2.rpy:1868
translate chinese_simplified tatsuki02_eat_55baa0b9:

    # tp "「You're starting to act like your mother.{p} Fine, I'll stay at home.」"
    # [旧版翻译]
    tp "「你渐渐变得和那家伙一样了。好了好了，我待在家里就是啦。」"

# game/day 2.rpy:1869
translate chinese_simplified tatsuki02_eat_b0f50808:

    # tp "「Hey, [fn], hurry back for work.{p} If you come, next time I'll take you for a drink.{p} Keep that a secret, yeah?」"
    # [旧版翻译]
    tp "「喂，[fn]。真的要来干活哦，我等你！来了的话就带你去喝上几杯，其他人谁也不带。拜拜～」"

# game/day 2.rpy:1875
translate chinese_simplified tatsuki02_eat_c2b8bad6:

    # ta "「Sigh... How did he become a father?」"
    # [旧版翻译]
    ta "「哈啊……。为什么我会有这样的老爸呢。」"

# game/day 2.rpy:1876
translate chinese_simplified tatsuki02_eat_7355f68a:

    # fn "「Hey, at least Tappei-san seems lively.{p} My dad isn't that much fun...」"
    # [旧版翻译]
    fn "「辰平叔看上去也很精神，人也很有趣。真希望[fn]的老爸也像辰平叔那样呢。」"

# game/day 2.rpy:1877
translate chinese_simplified tatsuki02_eat_71bd4018:

    # "A bigger, bolder,\nlivelier middle aged dragonman.{p}If I had a father like that..."
    # [旧版翻译]
    "高大、健壮又豪爽的中年龙人，如果有这样的父亲的话……。"

# game/day 2.rpy:1881
translate chinese_simplified tatsuki02_eat_ef98f0e5:

    # ta "「You're kidding me, right?{p} There's nothing good about living with him.{p} That damned old man...」"
    # [旧版翻译]
    ta "「得了吧，跟他在一起才不会是什么好事。那样的混蛋老爸。」"

# game/day 2.rpy:1885
translate chinese_simplified tatsuki02_eat_111e427b:

    # ta "「When it comes to work,\n he can be strict like a demon.{p} Guess that's why he succeeds so well.」"
    # [旧版翻译]
    ta "「而且只要是和工作有关的事情，就会变得鬼一样严格，你知道吗？嘛，应该说是，只有工作的方面做得还算像个样儿。」"

# game/day 2.rpy:1886
translate chinese_simplified tatsuki02_eat_d3331f27:

    # fn "「Huh, so you do respect your father.」"
    # [旧版翻译]
    fn "「唔，看来辰兄对父亲很尊敬呢。」"

# game/day 2.rpy:1890
translate chinese_simplified tatsuki02_eat_b9fb1f91:

    # ta "「Whaa!? No way that's true.{p} I recognize him as a craftsman,\n but how could I respect him?」"
    # [旧版翻译]
    ta "「啊！？那么可能？作为工作上的员工来说的话，虽然很赏识他，但尊敬什么的才不会。」"

# game/day 2.rpy:1891
translate chinese_simplified tatsuki02_eat_14ee9629:

    # "What a bad lie.{p}You're getting all red and bashful.{p}It's cute even if you're so big..."
    # [旧版翻译]
    "辰兄不会说谎呢，脸都红了。可爱的大个子。"

# game/day 2.rpy:1892
translate chinese_simplified tatsuki02_eat_c8d37672:

    # ta "「What are you smiling about?{p} Anyway, get ready.」"
    # [旧版翻译]
    ta "「傻笑什么啊。呐，我去稍微准备一下。」"

# game/day 2.rpy:1907
translate chinese_simplified tatsuki02_coworkers_1eace712:

    # "Even so, was Tappei-san that kind of person?{p}He's kind, and has a playful side to him,\nbut I get the feeling he's changed a lot."
    # [旧版翻译]
    "话虽如此，辰平叔是那样的人么？虽然他的温柔和诙谐一如既往，却还是感觉变了好多。"

# game/day 2.rpy:1908
translate chinese_simplified tatsuki02_coworkers_4586e84c:

    # "Like he's positively excellent, or something...{p}I've made him mad a lot,\nso I had an impression of him as a scary guy..."
    # [旧版翻译]
    "似乎变得非常积极，从某种方面来说……因为他以前经常大发雷霆当时只觉得他是『很恐怖的人』，"

# game/day 2.rpy:1909
translate chinese_simplified tatsuki02_coworkers_b04c2f4e:

    # "But maybe he was always like this."
    # [旧版翻译]
    "难道说，他以前其实就是这样的人么。"

# game/day 2.rpy:1913
translate chinese_simplified tatsuki02_coworkers_40d6db13:

    # horse "「Hm? Who are you?{p} You don't look like a customer.」"
    # [旧版翻译]
    who "「恩？你是哪位？看上去不是客人啊。」"

# game/day 2.rpy:1914
translate chinese_simplified tatsuki02_coworkers_bc555ef6:

    # horse "「This place is dangerous,\n so outsiders shouldn't come in.」"
    # [旧版翻译]
    who "「这里很危险的，非工作人员不许进来的。」"

# game/day 2.rpy:1915
translate chinese_simplified tatsuki02_coworkers_f1e6ed65:

    # fn "「No, I'm not anyone suspicious.」"
    # [旧版翻译]
    fn "「不，[fn]不是可疑的人。」"

# game/day 2.rpy:1916
translate chinese_simplified tatsuki02_coworkers_064e859c:

    # "What am I saying.{p}Why did he suddenly talk to me all irritated?"
    # [旧版翻译]
    "哎？[fn]在说什么呐？为什么和他搭话会突然紧张起来？"

# game/day 2.rpy:1920
translate chinese_simplified tatsuki02_coworkers_939318f4:

    # horse "「What are you saying?{p} That's not what I'm asking you.」"
    # [旧版翻译]
    who "「你说什么呢。我又没有问你那样的事。」"

# game/day 2.rpy:1924
translate chinese_simplified tatsuki02_coworkers_f0e697fd:

    # horse "「Coming onto the premises,\n mumbling to yourself, and nothing?{p} So suspicious...」"
    # [旧版翻译]
    who "「进来吧。自说自话的家伙，难道说你还有什么别的事吗？真是可疑啊……」"

# game/day 2.rpy:1925
translate chinese_simplified tatsuki02_coworkers_57f4fefe:

    # "I got myself into a suspicious mess.{p}And even I'm not doing anything wrong.{p}Hey, wait. Who is this guy?"
    # [旧版翻译]
    "被彻底怀疑了，[fn]明明什么都没有做啊。不对，等一下。这个人是谁？"

# game/day 2.rpy:1926
translate chinese_simplified tatsuki02_coworkers_15a1fd70:

    # "If he's a member of the Midoriya Group,\nhe should be wearing the provided uniform,\nand he looks about the same age as me..."
    # [旧版翻译]
    "他没有穿翠屋组的工作服，看起来与[fn]年纪相仿，却完全没有任何印象。"

# game/day 2.rpy:1927
translate chinese_simplified tatsuki02_coworkers_f1af88fa:

