# game/day 2.rpy:1938
translate chinese_simplified tatsuki02_coworkers_32ef339d:

    # extend "whose taste is in beastmen..."
    # [旧版翻译]
    extend "却控着兽人的"

# game/day 2.rpy:1940
translate chinese_simplified tatsuki02_coworkers_b12ce4b3:

    # "His name is...{p}{nw}"
    # [旧版翻译]
    "名侦探——[fn]。"

# game/day 2.rpy:1942
translate chinese_simplified tatsuki02_coworkers_9a39303a:

    # extend "The Great Detective [fn]!{p}{size=+15}The suspicious one...{nw}"
