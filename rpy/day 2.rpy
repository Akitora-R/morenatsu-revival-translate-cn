# game/day 2.rpy:1945
translate chinese_simplified tatsuki02_coworkers_974bb3cd:

    # extend "Is YOU!"
    # [旧版翻译]
    extend "可疑的人就是你！"

# game/day 2.rpy:1949
translate chinese_simplified tatsuki02_coworkers_b1c3912c:

    # horse "「No.」"
    # [旧版翻译]
    who "「不是。」"

# game/day 2.rpy:1950
translate chinese_simplified tatsuki02_coworkers_abd6ca9a:

    # "Hey watch, as I take him to the office,\nand prepare for Tappei-san to give him...{p}an intense chastisement."
    # [旧版翻译]
    "把他带到办公室去，让辰平叔好好的教训你一顿，觉悟吧。"

# game/day 2.rpy:1954
translate chinese_simplified tatsuki02_coworkers_048197c0:

    # horse "「I'm still an apprentice.{p} I received the work clothes,\n but we're free to wear what we'd like.」"
    # [旧版翻译]
    who "「我只是个实习工而已。领了工作服，但穿不穿不是都可以吗，而且我本来在别的地方工作，所以没穿。」"

# game/day 2.rpy:1955
translate chinese_simplified tatsuki02_coworkers_ae80d231:

    # horse "「Originally, I was working elsewhere,\n so I'm not wearing the clothes here.」"
    who ""

# game/day 2.rpy:1959
translate chinese_simplified tatsuki02_coworkers_17991f06:

    # "That can't be!?{p}My thinking was wrong..."
    # [旧版翻译]
    "不是吧！？[fn]的推理居然出错了么……。"

# game/day 2.rpy:1962
translate chinese_simplified tatsuki02_coworkers_48045a3a:

    # horse "「Are you done?{p} If so, come with me to the office.{p} We'll listen to your story there.」"
    # [旧版翻译]
    who "「满意了吗？要不要和我去办公室。辩解的话到那里再说吧，"

# game/day 2.rpy:1963
translate chinese_simplified tatsuki02_coworkers_86c7f628:

    # horse "「Though I guess only the boss will.」"
    # [旧版翻译]
    who "「只不过，听你辩解的不过是一个木匠师傅而已。」"

# game/day 2.rpy:1967
translate chinese_simplified tatsuki02_coworkers_9bce86af:

    # fn "「Uh, I...{p} Hey, hey wait.」"
    # [旧版翻译]
    fn "「诶，[fn]是那个……等、等一下！」"

# game/day 2.rpy:1968
translate chinese_simplified tatsuki02_coworkers_38c1b19f:

    # "An apprentice, huh.{p}He looks rich, but he's fairly strong."
    # [旧版翻译]
    "就算是实习的也算是员工吧。虽然这个人看上去挺苗条，力气却出乎意料的大。"

# game/day 2.rpy:1969
translate chinese_simplified tatsuki02_coworkers_7862362d:

    # "If Tappei-san came out,\nhe probably won't get mad,\nbut he might laugh about it. Tatsu-nii would..."
    # [旧版翻译]
    "虽然说去打扰辰平叔倒不至于让他生气，但是估计也会戏谑我一顿吧。连辰兄也说不定趁机……。"

# game/day 2.rpy:1973
translate chinese_simplified tatsuki02_coworkers_79cd8e54:

    # rat "「What're you doin', Senpai?{p} Hn?{p} {nw}"
    # [旧版翻译]
    who "「干什么呢前辈。诶？"

# game/day 2.rpy:1975
translate chinese_simplified tatsuki02_coworkers_e04902f4:

    # extend "Could you be... [fn]-san?"
    # [旧版翻译]
    extend "难道你就是那个……[fn]君？"

# game/day 2.rpy:1976
translate chinese_simplified tatsuki02_coworkers_f62504d2:

    # fn "「Yes, that's right...」"
    # [旧版翻译]
    fn "「恩，是的……」"

# game/day 2.rpy:1985
translate chinese_simplified tatsuki02_coworkers_cac9dd1b:

    # cu "「It's the real thing for sure!{p} I'm an apprentice for the Midoriya Group.\n Name's Chuukichi.」"
    # [旧版翻译]
    cu "「真的是耶！我是翠屋组的实习生，我名字叫忠吉。太棒了，没想到居然和传说中的[fn]见面，真是太高兴了。」"

# game/day 2.rpy:1991
translate chinese_simplified tatsuki02_coworkers_b4fae3f1:

    # cu "「Sweet, it's an honor to think that I'd be able\n to meet the legendary [fn]-san.」"
    cu ""

# game/day 2.rpy:1995
translate chinese_simplified tatsuki02_coworkers_b0324cd2:

    # horse "「Oh, that [fn]-kun.{p} If that was the case,\n you should've said something earlier.」"
    # [旧版翻译]
    who "「啊啊，原来是[fn]君啊。既然这样就早点说出来嘛。」"

# game/day 2.rpy:1999
translate chinese_simplified tatsuki02_coworkers_7c19e313:

    # ni "「I'm Akira Nikaidou.{p} As I've told you earlier,\n I'm an apprentice here.」"
    # [旧版翻译]
    ni "「我叫二阶堂 明，刚刚我也说了，也是在这儿实习的。」"

# game/day 2.rpy:2000
translate chinese_simplified tatsuki02_coworkers_6a8d298d:

    # "Legendary? How do you know me?{p}If it was 'legend,'\nthen it would have to be..."
    # [旧版翻译]
    "那个…我们是第一次见面吧？为什么知道[fn]的事情？还什么「传说中的」……难道是……。"

# game/day 2.rpy:2004
translate chinese_simplified tatsuki02_coworkers_be963833:

    # cu "「Not only within the Midoriya Group,\n but in the village, too...」"
    # [旧版翻译]
    cu "「不仅是在翠屋組里，在村子里做出各种伟大事迹……"

# game/day 2.rpy:2005
translate chinese_simplified tatsuki02_coworkers_76336a01:

    # cu "「I've gotten so much respect for you,\n since I've heard the stories 'bout you.」"
    # [旧版翻译]
    cu "「我，自从听说这些事，就对你很崇拜呢。」"

# game/day 2.rpy:2009
translate chinese_simplified tatsuki02_coworkers_ff94c799:

    # cu "「In town, there isn't anyone like that.{p} Can I call you Aniki?」"
    # [旧版翻译]
    cu "「而且，村里也没有像你这么有气势的家伙。那个，我可以称呼你为『大哥』吗？」"

# game/day 2.rpy:2010
translate chinese_simplified tatsuki02_coworkers_a92f5727:

    # "What are you asking..."
    # [旧版翻译]
    "他到底听说了什么……"

# game/day 2.rpy:2014
translate chinese_simplified tatsuki02_coworkers_4bc83fa1:

    # ni "「Did you come over to play?{p} Then I'll call him over.」"
    # [旧版翻译]
    ni "「今天就是来玩的吗？那样的话我帮你把人叫出来吧。」"

# game/day 2.rpy:2015
translate chinese_simplified tatsuki02_coworkers_a1063825:

    # "I should have greeted them,\nby saying that I was an apprentice."
    # [旧版翻译]
    "既然是实习工的话，下次来工作时候，再好好地打招呼吧。"

# game/day 2.rpy:2016
translate chinese_simplified tatsuki02_coworkers_89a1f750:

    # "I was surprised there were people here,\nwho were my age and working."
    # [旧版翻译]
    "不过居然是和同龄人在一起干活，以前根本没想过呢。"

# game/day 2.rpy:2017
translate chinese_simplified tatsuki02_coworkers_a8dfa636:

    # fn "「Oh, I've already talked with Tatsu-nii,\n and he already left.」"
    # [旧版翻译]
    fn "「啊，已经和辰兄说过了，现在去叫他没关系。拜托你了。」"

# game/day 2.rpy:2018
translate chinese_simplified tatsuki02_coworkers_90670a8f:

    # fn "「So it's okay, thanks.{p} I came over to hang out today,\n but after this I'll be helping out with work.」"
    # [旧版翻译]
    fn "「虽然今天是来玩的，但是下次再来的时候，就也是这里的实习工了。还是请多多指教。」"

# game/day 2.rpy:2019
translate chinese_simplified tatsuki02_coworkers_4cc17a6f:

    # fn "「So I look forward to working with you.」"
    cu ""

# game/day 2.rpy:2023
translate chinese_simplified tatsuki02_coworkers_52f6f1d5:

    # cu "「F'real!? Working together wit' Aniki,\n is gonna be like a dream come true.{p} Looking forward to working with you.」"
    # [旧版翻译]
    cu "「真的吗！？能和大哥一起工作就像做梦一样呢。请多多指教。」"

# game/day 2.rpy:2024
translate chinese_simplified tatsuki02_coworkers_fb4cf5b4:

    # "So I've already become Aniki...{p}between Tatsu-nii and Tappei-san,\nI wonder..."
    # [旧版翻译]
    "唔，已经成「大哥」了吗。到底是辰兄还是辰平叔，哪个长舌的把我的那些事乱说的。"

# game/day 2.rpy:2025
translate chinese_simplified tatsuki02_coworkers_af230504:

    # "Which of them inspires more weird things?{p}Probably Tappei-san? But Tatsu-nii has...{p}more unknown points."
    # [旧版翻译]
    "辰平叔么？不过有些事应该只有辰兄知道。"

# game/day 2.rpy:2026
translate chinese_simplified tatsuki02_coworkers_2bf1709f:

    # fn "「Hey, Chuukichi-kun.{p} Who did you hear about me from?」"
    # [旧版翻译]
    fn "「那个，忠吉君。[fn]的事是从谁那里听来的？」"

# game/day 2.rpy:2030
translate chinese_simplified tatsuki02_coworkers_fc321ecd:

    # cu "「Just Chuukichi is fine.{p} I heard a lot 'bout you from Master,\n and Young Master.」"
    # [旧版翻译]
    cu "「叫我小吉就行啦。大哥的事，经常听老爷和大少爷说哦。」"

# game/day 2.rpy:2031
translate chinese_simplified tatsuki02_coworkers_5d137b9c:

    # "Which one..."
    # [旧版翻译]
    "他们两个都有乱说啊……"

# game/day 2.rpy:2035
translate chinese_simplified tatsuki02_coworkers_c971c737:

    # ta "「Who's Young Master?{p} It's like you guys just heard,\n Pa forced him into a part time job here.」"
    # [旧版翻译]
    ta "「谁是大少爷啊？正如你刚刚听到的一样，[fn]是被我老爸强拉硬拽来这里工作的。许多事还要请你们多多指教。」"

# game/day 2.rpy:2036
translate chinese_simplified tatsuki02_coworkers_fd4ac23a:

    # ta "「And we'll be counting on him.」"
    cu ""

# game/day 2.rpy:2040
translate chinese_simplified tatsuki02_coworkers_789db452:

    # cu "「'kay.」"
    # [旧版翻译]
    cu "「嗯嗯。」"

# game/day 2.rpy:2044
translate chinese_simplified tatsuki02_coworkers_6e16594c:

    # ni "「It can't be helped, if the boss decided it.{p} I look forward to working with you.」"
    # [旧版翻译]
    ni "「木匠师傅决定的事，没办法啊。多多指教。」"

# game/day 2.rpy:2048
translate chinese_simplified tatsuki02_coworkers_38131ba6:

    # ni "「That said, don't get in the way,\n and I hope you'll keep me out of it\n if circumstances cause trouble.」"
    # [旧版翻译]
    ni "「不过，请你千万不要添乱。比如像以前那样给大家带来麻烦什么的……希望你还是饶了我吧。」"

# game/day 2.rpy:2049
translate chinese_simplified tatsuki02_coworkers_4ddcd530:

    # ni "「Like in the old stories.{p} I'm sure you've heard about them.」"
    ni ""

# game/day 2.rpy:2053
translate chinese_simplified tatsuki02_coworkers_cd73a95b:

    # ta "「Hey, don't say stuff like that.」"
    # [旧版翻译]
    ta "「喂喂，不用说成那样吧。」"

# game/day 2.rpy:2057
translate chinese_simplified tatsuki02_coworkers_cb144c03:

    # ni "「Hmph... still,\n it's more fun if work is bustling.{p} Do your best.」"
    # [旧版翻译]
    ni "「哼……不过，工作热闹点似乎也不赖。加油干吧。」"

# game/day 2.rpy:2061
translate chinese_simplified tatsuki02_coworkers_924f845e:

    # fn "「Am I hated all of a sudden...?」"
    # [旧版翻译]
    fn "「[fn]好像突然惹他讨厌了吗……」"

# game/day 2.rpy:2065
translate chinese_simplified tatsuki02_coworkers_d0179f30:

    # ta "「No way, that was more like a welcoming.{p} He's not a bad guy,\n but he sucks at expressing emotions.」"
    # [旧版翻译]
    ta "「也不是那样，他好像也是在欢迎你呢。他本性不坏的，只是不擅长表达自己的感情而已。」"

# game/day 2.rpy:2066
translate chinese_simplified tatsuki02_coworkers_ef487420:

    # fn "「Is that so?{p} He's a type like Shin-kun then.」"
    # [旧版翻译]
    fn "「这样啊，性格上和深君很像呢。」"

# game/day 2.rpy:2070
translate chinese_simplified tatsuki02_coworkers_8f2296b0:

    # ta "「Shin's not that docile,\n but that's not all.」"
    # [旧版翻译]
    ta "「虽然很内向，但也不至于到那个地步。多多交往之后就会明白的，他也是个很好说话的家伙呢，并没有想象中那么不友好。」"

# game/day 2.rpy:2071
translate chinese_simplified tatsuki02_coworkers_110a2139:

    # ta "「He doesn't understand relationships,\n but he's a guy who's easy to understand,\n and he's not bad at sociability.」"
    cu ""

# game/day 2.rpy:2075
translate chinese_simplified tatsuki02_coworkers_ea659530:

    # cu "「There're times where he gets into a bad mood,\n but he's an interestin' enough dude.」"
    # [旧版翻译]
    cu "「虽然也有惹人讨厌的地方，但也算是个很有趣的人吧。」"

# game/day 2.rpy:2076
translate chinese_simplified tatsuki02_coworkers_153f1f3b:

    # cu "「He's also got times\n where he gets snappy and selfish, tho'.」"
    fn ""

# game/day 2.rpy:2077
translate chinese_simplified tatsuki02_coworkers_5ad22cff:

    # fn "「Huh, in that case I can relax and work.」"
    # [旧版翻译]
    fn "「嗯，那样的话我就可以放心的工作了。」"

# game/day 2.rpy:2081
translate chinese_simplified tatsuki02_coworkers_f936b3e3:

    # ta "「Don't be so careless.」"
    # [旧版翻译]
    ta "「啊，别掉以轻心。」"

# game/day 2.rpy:2082
translate chinese_simplified tatsuki02_coworkers_93dbf064:

    # ta "「Pa would get strict,\n and Nikaidou can get like that too,\n so they won't go easy.」"
    # [旧版翻译]
    ta "「老爸是很严格的，再加上二阶堂那个样子，应该也是不会轻易放过你的。」"

# game/day 2.rpy:2083
translate chinese_simplified tatsuki02_coworkers_3bcb9d25:

    # "Uhh, suddenly I'm feeling uneasy..."
    # [旧版翻译]
    "唔唔，有点儿不安呐……。"

# game/day 2.rpy:2087
translate chinese_simplified tatsuki02_coworkers_3d5b2fa0:

    # ta "「Hehehe, don't feel that way.{p} Let's hurry up and go already.」"
    # [旧版翻译]
    ta "「呵呵呵，也别太介意这些啦。快点出去玩吧。」"

# game/day 2.rpy:2091
translate chinese_simplified tatsuki02_coworkers_ef1c71f8:

    # cu "「Where you goin'?{p} Take me along too please.」"
    # [旧版翻译]
    cu "「要去哪里吗？也把我带上吧。」"

# game/day 2.rpy:2095
translate chinese_simplified tatsuki02_coworkers_343066fc:

    # ta "「Wait, you aren't leaving the stuff,\n you still have to do, are you?」"
    # [旧版翻译]
    ta "「等下，你的工作不是还没做完吗？」"

# game/day 2.rpy:2099
translate chinese_simplified tatsuki02_coworkers_1226b1fe:

    # cu "「Ah, no good! This is bad,\n who knows what Master might do to me!」"
    # [旧版翻译]
    cu "「唉呀，糟糕！要被老板骂了。还有大姐也拜托我了一些事。那大少爷、大哥，祝你们玩好。」"

# game/day 2.rpy:2100
translate chinese_simplified tatsuki02_coworkers_7670a0e6:

    # cu "「Also, my big sis told me to do something for her.{p} In that case, Young Master, Aniki, good work!」"
    cu ""

# game/day 2.rpy:2107
translate chinese_simplified tatsuki02_coworkers_4771094c:

    # "Chuukichi-kun ran back to the office."
    # [旧版翻译]
    "忠吉君往工房的方向跑去了。"

# game/day 2.rpy:2108
translate chinese_simplified tatsuki02_coworkers_ad8b4c78:

    # fn "「Seems like a fun workplace.」"
    # [旧版翻译]
    fn "「看上去很有趣的木工厂呢。」"

# game/day 2.rpy:2112
translate chinese_simplified tatsuki02_coworkers_b7aeefe0:

    # ta "「Everyone's close since we all live together,\n but even with the fun times,\n there's a lot more tough times.」"
    # [旧版翻译]
    ta "「虽然大家都在一起，关系很好，但在工作中比起开心的事，还是辛苦的事更多呢。」"

# game/day 2.rpy:2113
translate chinese_simplified tatsuki02_coworkers_6c7b74d3:

    # fn "「Sounds like a real big pain,\n with Tatsu-nii as an apprentice too.{p} But I think that mood will pass.」"
    # [旧版翻译]
    fn "「真的很辛苦呢，辰兄也是实习工啊。不过辛苦什么的，在气氛上[fn]已经感觉出来了。」"

# game/day 2.rpy:2114
translate chinese_simplified tatsuki02_coworkers_18771a4c:

    # fn "「Everyone's bulking up,\n but your muscles are fairly brawny already.」"
    # [旧版翻译]
    fn "「以前个头就挺大的，现在又长出了很多结实的肌肉，角长得也很漂亮，看上去帅气得很啊。」"

# game/day 2.rpy:2115
translate chinese_simplified tatsuki02_coworkers_65155d62:

    # fn "「And I can see your horns growing larger,\n you're really turning into quite a handsome guy.{p} Your back and stomach look like they filled out.」"
    # [旧版翻译]
    fn "「肚子也挺起来了。」"

# game/day 2.rpy:2119
translate chinese_simplified tatsuki02_coworkers_9878a59d:

    # ta "「Like I said, this isn't fat,\n dragonmen are naturally like this.{p} Well, not all dragonmen.」"
    # [旧版翻译]
    ta "「不是说这不是肥了吗，龙人会自然长出来的。虽然不是所有龙人都这样。」"

# game/day 2.rpy:2120
translate chinese_simplified tatsuki02_coworkers_bc4db596:

    # fn "「Of course, I get it. So squishy.」"
    # [旧版翻译]
    fn "「当然知道了，又软又有弹性的嘛。」"

# game/day 2.rpy:2124
translate chinese_simplified tatsuki02_coworkers_7ab4b446:

    # ta "「Stop that, don't rub my stomach.{p} Ah, hey! Don't run off. Come back here!」"
    # [旧版翻译]
    ta "「别戳我肚子！啊喂，别逃。你给我站住！」"

# game/day 2.rpy:2125
translate chinese_simplified tatsuki02_coworkers_7714d8e4:

    # fn "「Hahaha, I've been waiting for you.{p} Let's hurry up and go.{p} It's a race to Torahiko's house!」"
    # [旧版翻译]
    fn "「哈哈哈，[fn]已经等不及了，快走吧。赛跑到虎彦的家吧！」"

# game/day 2.rpy:2129
translate chinese_simplified tatsuki02_coworkers_43a6ef48:

    # "A part time job with the Midoriya Group...\nI'm looking forward to it."
    # [旧版翻译]
    "在翠屋组打工的日子，越来越期待了呢。"

# game/day 2.rpy:2130
translate chinese_simplified tatsuki02_coworkers_47ca12b4:

    # "It's fun meeting up with everyone,\nbut this doesn't happen every day.{p}I have to do my best."
    # [旧版翻译]
    "这种体验相当难得啊。多多加油吧。"

# game/day 2.rpy:2131
translate chinese_simplified tatsuki02_coworkers_ad658925:

    # ta "「I said wait!\n If you weren't about to run off I've got a car!」"
    # [旧版翻译]
    ta "「不是说了等一下吗，根本不用跑，是要出门坐车的。！」"

# game/day 2.rpy:2150
translate chinese_simplified juuichi02_8cc5b2e9:

    # "The cicadas sing as a chorus.{p}The thunderheads overhead growing steadily larger.{p}The sun streaming down."
    # [旧版翻译]
    "蝉鸣声大合唱。又大又广的积雨云。灼热又刺眼的阳光。"

# game/day 2.rpy:2151
translate chinese_simplified juuichi02_75d0dd16:

    # "As I wipe the sweat off my brow,{w=.3}\nI'm reminded that this is\nwhat summer in the country is like."
    # [旧版翻译]
    "这就是标准乡下的夏天！ 大概是这种感觉。[fn]一边用指甲弹掉额头上的汗，一边这样想着。"

# game/day 2.rpy:2152
translate chinese_simplified juuichi02_9d0f0179:

    # "On both sides of the path,\nthe rice fields spread out endlessly."
    # [旧版翻译]
    "在道路的两旁是延绵不断的水田。"

# game/day 2.rpy:2153
translate chinese_simplified juuichi02_68ec8ad3:

    # "It looks like the rice hasn't finished growing yet:\nThe countless leaves growing towards the heavens\nare almost invisible."
    # [旧版翻译]
    "稻米现在正在成熟中。虽然几乎还看不到稻米，但仍然有无数的稻叶向天空伸展着。"

# game/day 2.rpy:2154
translate chinese_simplified juuichi02_7bd1869c:

    # "It looks like a green carpet has been rolled out.{w=.3}\nIt's a shame I won't be here for harvest this year."
    # [旧版翻译]
    "一片绿色的地毯铺展开来……宛如这样的感觉，眼前就是如此的景致。今年没办法在这里待到收成的时候真是可惜。"

# game/day 2.rpy:2155
translate chinese_simplified juuichi02_80a49c50:

    # "...Wait, I shouldn't be thinking things like that.{p}It'll spoil my long-awaited return.{p}I shake my head to clear these thoughts."
    # [旧版翻译]
    "……不过，现在还不需要去想回去时的事。难得的归乡可不能这样糟蹋了。[fn]为了甩开杂念而用力摇了摇头。"

# game/day 2.rpy:2156
translate chinese_simplified juuichi02_0f041a10:

    # "I only got back to Minasato yesterday.{p}Torahiko's violent welcoming is fresh in my mind."
    # [旧版翻译]
    "回到水乡村这里才只是昨天的事。而且，回来的时候还受到虎彦的盛大欢迎。"

# game/day 2.rpy:2167
translate chinese_simplified juuichi02_9a9d7666:

    # "Even though I've grown in the time I've been gone,{w=.3}\nI need to look up to make eye contact with Torahiko."
    # [旧版翻译]
    "明明在离开村子的时候是[fn]比较高的，这次见到虎彦时已经要抬头才看得到他的眼睛了。"

# game/day 2.rpy:2168
translate chinese_simplified juuichi02_2050740a:

    # "...I thought I'd grown a fair bit, though.{p}That makes me feel a bit down."
    # [旧版翻译]
    "……[fn]明明也是有长高的啊。虽然没办法但不知怎地还是有点气馁的感觉。"

# game/day 2.rpy:2173
translate chinese_simplified juuichi02_9b0dcfc1:

    # "Then, Torahiko told me about the welcoming party.{p}I didn't think they'd actually manage to plan that,\nso that was a surprise."
    # [旧版翻译]
    "而且，虎彦那时还跟[fn]说了为[fn]办的欢迎会的事。没想到他们竟然会办那样的活动，真的是让[fn]吓了一跳呢。"

# game/day 2.rpy:2174
translate chinese_simplified juuichi02_e2af0db5:

    # "I hadn't been keeping in touch with anybody at all.{w=.3}\nFor all I know, they could have forgotten about me."
    # [旧版翻译]
    "明明完全没有跟大家连络，他们却都没有忘记[fn]。"

# game/day 2.rpy:2175
translate chinese_simplified juuichi02_3557c75a:

    # "But they still welcomed me back as an old friend.{p}That made me really happy."
    # [旧版翻译]
    "而且还像以前一样自然地接受了[fn]。大家的心意，真的是让[fn]很高兴。"

# game/day 2.rpy:2180
translate chinese_simplified juuichi02_b91dc56d:

    # "As I recall yesterday's events one by one,{p}I can't help but smile."
    # [旧版翻译]
    "[fn]把昨天发生的事一件件照顺序回忆下来，结果不自觉地就笑了起来。"

# game/day 2.rpy:2181
translate chinese_simplified juuichi02_814f42c1:

    # "...Ahh, I really am back here.{p}The sun is really scorching,\nbut it's somewhat comfortable here."
    # [旧版翻译]
    "……啊啊，没想到[fn]真的回到这里了呢。就连阳光照下来的热度，都跟在那里的感觉不一样。不知怎地总觉得很舒畅。"

# game/day 2.rpy:2182
translate chinese_simplified juuichi02_dd2a33ef:

    # "My skin is going to be so dark\nby the time my vacation is over.{p}Oh well. It's kind of healthy to get a tan, right?"
    # [旧版翻译]
    "这样下去，在暑假结束时大概会被晒得很黑吧。稍微有点晒黑才是健康宝宝！ 这种感觉似乎也不错。"

# game/day 2.rpy:2184
translate chinese_simplified juuichi02_1633da91:

    # who "「Hey, [ln]. Are you okay?」"
    # [旧版翻译]
    who "「喂[西村]。你没事吧？」"

# game/day 2.rpy:2190
translate chinese_simplified juuichi02_c98da414:

    # fn "「...?!」"
    # [旧版翻译]
    fn "「……！？」"

# game/day 2.rpy:2191
translate chinese_simplified juuichi02_790c14b6:

    # "I jump as a voice calls my name from behind me.{p}It looks like I was lost daydreaming."
    # [旧版翻译]
    "背后突然出现的声音，吓得[fn]整个人都跳了起来。[fn]好像在不知不觉间陷进自己的世界了的样子。"

# game/day 2.rpy:2195
translate chinese_simplified juuichi02_d16a422f:

    # fn "「...Please don't scare me like that.」"
    # [旧版翻译]
    fn "「……请不要吓[fn]啦。」"

# game/day 2.rpy:2196
translate chinese_simplified juuichi02_0a97c63d:

    # "I speak to the owner of the voice as I turn around."
    # [旧版翻译]
    "[fn]转头跟刚刚叫[fn]的人说。"

# game/day 2.rpy:2197
translate chinese_simplified juuichi02_dea962d7:

    # "There's only one person in this village who\ncalls me by my last name."
    # [旧版翻译]
    "这村子里会用姓来叫[fn]的只有几个人而已。"

# game/day 2.rpy:2198
translate chinese_simplified juuichi02_b5ec270b:

    # "I heard this low voice yesterday, too.{p}There's no mistaking it."
    # [旧版翻译]
    "而且，这个低沉的声音[fn]昨天才听过，所以绝对不会弄错。"

# game/day 2.rpy:2204
translate chinese_simplified juuichi02_52af09a2:

    # "Just as I guessed, it's Juuichi-san."
    # [旧版翻译]
    "就跟[fn]想的一样，在那里的人是柔一。"

# game/day 2.rpy:2210
translate chinese_simplified juuichi02_c199e72c:

    # ju "「I think anybody would say something,\n if they saw their friend standing in the middle of\n the road with a dazed look on their face.」"
    # [旧版翻译]
    ju "「发现在道路正中央发呆的竟然是自己的熟人的话，我想不管是谁都会喊一下的吧。」"

# game/day 2.rpy:2211
translate chinese_simplified juuichi02_27ce4b62:

    # fn "「I guess you're right.」"
    # [旧版翻译]
    fn "「这话是没错啦，好吧。」"

# game/day 2.rpy:2212
translate chinese_simplified juuichi02_a2c2f3db:

    # "Since he spoke out of concern,\nI have no reason to complain.{p}...It was my fault for letting my mind wander."
    # [旧版翻译]
    "因为是担心[fn]所以才出声喊[fn]的，不感谢也就算了，绝对不可能抱怨什么的。……说起来，本来就是[fn]在路上发呆的错。"

# game/day 2.rpy:2216
translate chinese_simplified juuichi02_6240033b:

    # ju "「...Looks like it was nothing.{p} I thought for sure you'd gotten heat stroke.」"
    # [旧版翻译]
    ju "「……看来没什么事嘛。我刚刚还以为你是不是中暑了什么的呢。」"

# game/day 2.rpy:2217
translate chinese_simplified juuichi02_a5f13a65:

    # "Ooh, now I feel guilty.{p}I've been getting lost in thought a lot recently...{w=.3}Or maybe I should say I've been daydreaming."
    # [旧版翻译]
    "呜，感觉内心被罪恶感攻击了。想事情……应该说胡思乱想的时候就完全没在注意四周的坏习惯，"

# game/day 2.rpy:2218
translate chinese_simplified juuichi02_6c2bae39:

    # "I should really do something about that."
    # [旧版翻译]
    "不赶快改掉是不行了。"

# game/day 2.rpy:2222
translate chinese_simplified juuichi02_17d35980:

    # ju "「So,{w=.3} what are you doing out here, anyway?」"
    # [旧版翻译]
    ju "「说起来，你在这种地方是在做什么啊？」"

# game/day 2.rpy:2223
translate chinese_simplified juuichi02_46361306:

    # fn "「Oh, right.{w} I'm taking a walk through the village.」"
    # [旧版翻译]
    fn "「啊，是。是在村子里散步。」"

# game/day 2.rpy:2224
translate chinese_simplified juuichi02_5c73df95:

    # "I straighten my posture as I answer his question.{p}...There's nothing in particular to feel guilt about,{w=.3}but I remember what happened to Torahiko yesterday..."
    # [旧版翻译]
    "面对柔一的问题，[fn]立刻挺胸站直回答。……倒也不是因为内疚，而是一想到昨天虎彦的惨状，身体就忍不住自动反应了。"

# game/day 2.rpy:2225
translate chinese_simplified juuichi02_7e34cca8:

    # fn "「I haven't been here since elementary school,{w=.3}\n so I've forgotten about a lot of places.{p} I thought I'd remember them if I went for a walk.」"
    # [旧版翻译]
    fn "「小学之后就没有回来水乡村看过，有好多地方都记不太清楚了。[fn]想说四处看看就会自然地回想起来，这样。」"

# game/day 2.rpy:2226
translate chinese_simplified juuichi02_b4a8de0c:

    # "Some places come back to me quite easily,\nsuch as the candy store, and the Ooshima Inn."
    # [旧版翻译]
    "像是零食店或是大岛旅馆，那种以前常常会经过的地方马上就能回想起来。"

# game/day 2.rpy:2227
translate chinese_simplified juuichi02_e2b10ab9:

    # "On the other hand, places I didn't visit very often\nhave completely escaped me."
    # [旧版翻译]
    "反过来说，很少会去的地方或是没什么印象的地方，相关的记忆就很模糊。"

# game/day 2.rpy:2228
translate chinese_simplified juuichi02_50b70446:

    # "I thought I'd remember more...\nIt seems my memory is worse than I thought."
    # [旧版翻译]
    "虽然多少还想得起来一点……不过看来[fn]的记忆力差的程度比[fn]以为的还惨的样子。"

# game/day 2.rpy:2232
translate chinese_simplified juuichi02_556c1633:

    # ju "「...I see.{w} Forgetting things is a shame,\n but I guess there's not too much you can do about it.」"
    # [旧版翻译]
    ju "「……这样啊。虽然很可惜不过这也是没办法的事吧。」"

# game/day 2.rpy:2233
translate chinese_simplified juuichi02_326937a6:

    # fn "「Sorry...{p} But I'll be sure to have fun this summer,\n {w=.3}and make new memories to take with me!」"
    # [旧版翻译]
    fn "「唔，真抱歉……。不过正因此所以这个暑假要快乐地过，创造出最棒的回忆再回去才行！」"

# game/day 2.rpy:2237
translate chinese_simplified juuichi02_7bbe88e0:

    # ju "「That's true.{w=.3} You should have a rewarding vacation.」"
    # [旧版翻译]
    ju "「这样啊，如果能渡过充实的暑假就好了啊。」"

# game/day 2.rpy:2238
translate chinese_simplified juuichi02_5bb82190:

    # fn "「I will!{p} By the way,{w=.3} are you on your way home from practice?」"
    # [旧版翻译]
    fn "「是啊！说起来，柔一是练习完了要回家吗？」"

# game/day 2.rpy:2239
translate chinese_simplified juuichi02_3a835b32:

    # "I remember him talking a bit about judo yesterday,\n{w=.3}so I try to shift the topic of conversation."
    # [旧版翻译]
    "正好想起来昨天有稍微聊到柔道的话题，[fn]就试着对柔一问问看。"

# game/day 2.rpy:2243
translate chinese_simplified juuichi02_3eccf860:

    # ju "「Yes, I am.{p} There's a tournament coming up soon,\n {w=.3}so I've been training hard since this morning.」"
    # [旧版翻译]
    ju "「嗯，是啊。大会就要到了，所以从早上开始就在进行密集的训练。」"

# game/day 2.rpy:2244
translate chinese_simplified juuichi02_fd269435:

    # "Training hard since this morning...?{w} Knowing him,\nhe's probably got a pretty strict regimen.\nThere's no way that I would be able to stand that."
    # [旧版翻译]
    "早上就开始，吗……因为是柔一，想来应该是相当严格的训练内容吧。像[fn]这样的一般人应该是绝对撑不住的。"

# game/day 2.rpy:2245
translate chinese_simplified juuichi02_95b314d7:

    # fn "「Ah... You must be pretty worn out.{p} But a tournament? In the middle of summer vacation?{p} There aren't many sports I know of that do that.」"
    # [旧版翻译]
    fn "「啊……那真是辛苦了呢。不过，在暑假中还会有大会比赛啊？[fn]只有听说过甲子园那一类的比赛的说。」"

# game/day 2.rpy:2246
translate chinese_simplified juuichi02_1937f3d4:

    # ju "「Oh,{w=.3} the Kazenari Martial Arts League is hosting it,\n so it's not a regular event.」"
    # [旧版翻译]
    ju "「啊啊，是由风鸣武道联盟主办的，所以不是官方的比赛。"

# game/day 2.rpy:2250
translate chinese_simplified juuichi02_865ab4a0:

    # ju "「...I guess it is a bit like a regular event\n for those of us who live around here, though.」"
    # [旧版翻译]
    ju "「……不过，住在这附近的人大多会参加，所以对我们来说倒是没什么不同。」"

# game/day 2.rpy:2251
translate chinese_simplified juuichi02_316eab80:

    # fn "「Wow, really?{w} I guess I can't enter it then, huh.」"
    # [旧版翻译]
    fn "「咦――是这样啊。那就还是得加油了呢。」"

# game/day 2.rpy:2255
translate chinese_simplified juuichi02_6266845a:

    # ju "「You weren't planning on it to begin with.」"
    # [旧版翻译]
    ju "「一开始就是那么打算的。」"

# game/day 2.rpy:2256
translate chinese_simplified juuichi02_ad7281af:

    # "Juuichi-san shows his sharp canines as he says that.{p}I've never been particularly good at sports,\n{w=.3}so people who are look really cool to me."
    # [旧版翻译]
    "柔一说着露出了尖锐的犬齿。[fn]没有试着参加过什么运动，对于能够这样子回答的人总觉得很帅。"

# game/day 2.rpy:2257
translate chinese_simplified juuichi02_edd6571b:

    # "In Juuichi-san's case,{w=.3} he's not a show off.\nI really think he can win."
    # [旧版翻译]
    "不过是柔一的话，应该不会为了耍帅而这么说，是真的觉得这样这样下去能够拿到优胜的吧。"

# game/day 2.rpy:2258
translate chinese_simplified juuichi02_d1a14066:

    # "Torahiko, on the other hand, gets ahead of himself,\nand falls flat on his face too much...{p}I worry about him, sometimes."
    # [旧版翻译]
    "这话如果是由虎彦来说的话，肯定会在说之前就毫无意义地奋力猛衝不知道在干嘛吧……结果反而变得更让人担心。"

# game/day 2.rpy:2259
translate chinese_simplified juuichi02_b68317fc:

    # "Hmm, I wonder if coolness and wisdom come with age..."
    # [旧版翻译]
    "嗯――这大概就是成熟与否的差别吧。"

# game/day 2.rpy:2260
translate chinese_simplified juuichi02_240eb34c:

    # fn "「Umm...{w=.3} If it's all right with you,\n can I come and cheer for you?」"
    # [旧版翻译]
    fn "「那个……方便的话，[fn]可以去帮你加油吗？」"

# game/day 2.rpy:2261
translate chinese_simplified juuichi02_4ca5b439:

    # "I've finally come back to Minasato,\nso I want to see him in action with my own eyes."
    # [旧版翻译]
    "[fn]像是在请求许可似的向柔一问道。难得回到了水乡村，就想直接站在最前线欣赏柔一的勇姿。"

# game/day 2.rpy:2262
translate chinese_simplified juuichi02_2e07585d:

    # "Seeing him flinging his opponents away...{p}That would be an amazing spectacle."
    # [旧版翻译]
    "把比赛对手给一个个击飞……想必会是非常豪爽又痛快的光景吧。"

# game/day 2.rpy:2266
translate chinese_simplified juuichi02_9cb5bf4c:

    # ju "「I don't mind.{p} {nw}"
    # [旧版翻译]
    ju "「那倒是没问题。"

# game/day 2.rpy:2268
translate chinese_simplified juuichi02_ac78fb75:

    # extend "...Now I'll have to try not\n to be clumsy during the match.」"
    # [旧版翻译]
    extend "……这样比赛时可就不能丢脸了。」"

# game/day 2.rpy:2270
translate chinese_simplified juuichi02_aab20be5:

    # "Juuichi-san quietly mutters to himself.\nSomething about more training?"
    # [旧版翻译]
    "只好增加自主练习的时间了吗……柔一小声地低语着。"

# game/day 2.rpy:2271
translate chinese_simplified juuichi02_20d32154:

    # "For such a strong person to say that they actually\npractice impresses me quite a lot."
    # [旧版翻译]
    "越强的人越是需要更多的练习这种话果然是真的呢。在奇怪的地方莫名地感到安心了。"

# game/day 2.rpy:2272
translate chinese_simplified juuichi02_9ff47eb9:

    # "I remember being taught that you can\nbe great with just one talent.{p}I'm missing that last bit of the equation, though."
    # [旧版翻译]
    "确实努力也是一种才能，这样说是没错的呢。虽然遗憾但看来[fn]欠缺的就是这个部分了。"

# game/day 2.rpy:2273
translate chinese_simplified juuichi02_a275a6d8:

    # fn "「...You don't mind practicing during your free time?\n It's summer vacation, after all.」"
    # [旧版翻译]
    fn "「……不过，要把自己的自由时间拿来练习不会觉得不高兴吗？毕竟是难得的暑假的说。」"

# game/day 2.rpy:2277
translate chinese_simplified juuichi02_ec93a066:

    # ju "「If I do the same thing as other people,\n {w=.3}I'll only get the same result as those people.{p} In the end, I think that will make a difference.」"
    # [旧版翻译]
    ju "「如果只和别人做一样的事情，就只能做到和别人一样的结果。这之中的差别，就是影响成败的关键了，我是这么想的。」"

# game/day 2.rpy:2278
translate chinese_simplified juuichi02_00b00233:

    # fn "「...」"
    fn ""

# game/day 2.rpy:2279
translate chinese_simplified juuichi02_5c4b9dd9:

    # "What's with this heavily persuasive power?{p}He's only a year older than me...\n{w=.3}How is he able to think like that?"
    # [旧版翻译]
    "该怎么说呢，这个压倒性的说服力。明明年纪只差一岁的，为什么能够用这种方式思考呢。"

# game/day 2.rpy:2280
translate chinese_simplified juuichi02_6f7a5400:

    # "Juuichi-san and I might live in the same world,\nbut we have completely different\nways of looking at it."
    # [旧版翻译]
    "柔一和[fn]，就算活在同一个世界，看到的景色似乎也完全不同，[fn]忍不住开始这么想。"

# game/day 2.rpy:2281
translate chinese_simplified juuichi02_35670a0a:

    # fn "「...That's impressive.」"
    # [旧版翻译]
    fn "「……好厉害喔。」"

# game/day 2.rpy:2282
translate chinese_simplified juuichi02_6fbc12b0:

    # "I tried to say something clever,\n{w=.3}but that's all I could think of.{p}I'm a little disappointed in myself."
    # [旧版翻译]
    "虽然想要试着说些什么漂亮话，结果最后还是只能挤出这一句话来。这样的自己感觉好逊喔。"

# game/day 2.rpy:2286
translate chinese_simplified juuichi02_0b2ec3a7:

    # ju "「Not really.{p} Stronger guys who practice more than I do\n are a dime a dozen.」"
    # [旧版翻译]
    ju "「没这回事。比我做了更多练习、比我还强的家伙，随便找找都是。"

# game/day 2.rpy:2287
translate chinese_simplified juuichi02_1b628930:

    # ju "「There are even a few around here.」"
    # [旧版翻译]
    ju "「更不用说身边就有了。」"

# game/day 2.rpy:2288
translate chinese_simplified juuichi02_9d3d25f8:

    # "Wow, the world of sports must be tough.{p}But, if you ask me, I think Juuichi-san\nis strong enough for it."
    # [旧版翻译]
    "果然运动的世界是很严刻的吗。在[fn]看来柔一已经相当的强了说。"

# game/day 2.rpy:2289
translate chinese_simplified juuichi02_b2a37d26:

    # "...Wait,{w=.3} I've never watched any of his matches.\nIsn't it a bad idea for me to say that?"
    # [旧版翻译]
    "……不过，没有看过柔一比赛的样子的[fn]应该说什么都不准吧。"

# game/day 2.rpy:2290
translate chinese_simplified juuichi02_7a447caf:

    # ju "「Besides...{p} {nw}"
    # [旧版翻译]
    ju "「而且……"

# game/day 2.rpy:2292
translate chinese_simplified juuichi02_bf53bd91:

    # extend "If I'm going to do it,{w=.3} I want to win.」"
    # [旧版翻译]
    extend "不管怎么说，还是会想赢啊。」"

# game/day 2.rpy:2294
translate chinese_simplified juuichi02_b874ef8d:

    # "Juuichi speaks thoughtfully,\nscratching his chin with a thumb."
    # [旧版翻译]
    "柔一用姆指摸了摸下巴喃喃地低声说道。"

# game/day 2.rpy:2298
translate chinese_simplified juuichi02_f47904e5:

    # ju "「It's a difficult feeling to put into words...{p} {nw}"
    # [旧版翻译]
    ju "「有点难用言语来形容，不过……"

# game/day 2.rpy:2300
translate chinese_simplified juuichi02_9f846c3f:

    # extend "But that feeling of victory is unforgettable.\n {w=.3}It's probably why I do judo.」"
    # [旧版翻译]
    extend "取得一胜的时候，那种感觉真的很让人难忘。我可能是为了这个而练柔道的也不一定。」"

# game/day 2.rpy:2302
translate chinese_simplified juuichi02_d3ddd0d0:

    # "Juuichi-san speaks with his eyes partly closed.\nHe seems to have a different mood to earlier."
    # [旧版翻译]
    "眯起眼睛讲话的柔一，给人的感觉，不知怎地跟平常比起来总觉得有微妙的不同。"

# game/day 2.rpy:2303
translate chinese_simplified juuichi02_09d4e66d:

    # "I'm quite surprised to see him like this.{p}So he can make an expression like that, too..."
    # [旧版翻译]
    "看到那样子的[fn]不禁颤抖了一下。柔一竟然，也会露出那样的表情啊……"

# game/day 2.rpy:2307
translate chinese_simplified juuichi02_e36ea5d1:

    # ju "「...Sorry.{p} I'm not boring you, am I?」"
    # [旧版翻译]
    ju "「……抱歉。听我讲这种事应该一点都不有趣吧。」"

# game/day 2.rpy:2308
translate chinese_simplified juuichi02_33fcaed9:

    # fn "「Ah, no, not at all!{p} Juuichi-san,{w=.3} you really do like judo.」"
    # [旧版翻译]
    fn "「啊，不会的没这回事！柔一真的，非常喜欢柔道呢。」"

# game/day 2.rpy:2309
translate chinese_simplified juuichi02_93b599f7:

    # ju "「...Well,{w=.3} I wouldn't keep doing it if I didn't.」"
    # [旧版翻译]
    ju "「……哎，讨厌的话就不会继续练下去了吧。」"

# game/day 2.rpy:2310
translate chinese_simplified juuichi02_213831d7:

    # fn "「You know that's not what I meant...」"
    # [旧版翻译]
    fn "「[fn]知道不是那样的啦，你不用说也知道的，真的啦。」"

# game/day 2.rpy:2311
translate chinese_simplified juuichi02_32ba009b:

    # "At my objection,{nw}"
    # [旧版翻译]
    "对[fn]的抗议，"

# game/day 2.rpy:2313
translate chinese_simplified juuichi02_a71afbf7:

    # extend "{w=.3} Juuichi-san's face relaxes a bit."
    # [旧版翻译]
    extend "柔一的表情稍微缓和了下来。"

# game/day 2.rpy:2317
translate chinese_simplified juuichi02_a353fca0:

    # ju "「...Well,{w=.3} I should get going.」"
    # [旧版翻译]
    ju "「……那么，我也差不多该走了。」"

# game/day 2.rpy:2318
translate chinese_simplified juuichi02_0aa665ec:

    # fn "「Oh, sure.{p} Sorry about keeping you here.」"
    # [旧版翻译]
    fn "「啊，好的。不小心让你陪[fn]聊了起来真不好意思。」"

# game/day 2.rpy:2319
translate chinese_simplified juuichi02_141cf4f4:

    # "About 30 minutes have passed.{p}I'm not used to having long\ntalks in this sweltering heat."
    # [旧版翻译]
    "注意到的时候已经差不多过了三十分钟了。在这种被灼热的阳光直接晒到的地方，确实是不会想聊太久呢。"

# game/day 2.rpy:2320
translate chinese_simplified juuichi02_27b5a290:

    # ju "「Don't worry about it.{p} I started the conversation, after all.」"
    # [旧版翻译]
    ju "「别在意。毕竟一开始先搭话的人是我。」"

# game/day 2.rpy:2324
translate chinese_simplified juuichi02_c1e867a4:

    # "With that, and a wave of his hand,\n{w=.3}Juuichi-san turns his large back towards me.{p}{nw}"
    # [旧版翻译]
    "在把手举起来道别之后，柔一就转身背朝向[fn]离开了。"

# game/day 2.rpy:2326
translate chinese_simplified juuichi02_1fecd97f:

    # extend "The sound of his footsteps on the gravel get quieter."
    # [旧版翻译]
    extend "他巨大的身影就这么喀塔喀塔地，随着砾石地被踩的声音渐渐远去。"

# game/day 2.rpy:2328
translate chinese_simplified juuichi02_f299afdf:

    # "I think about where I should go next.{p}...After all, I did start this walk without\na particular destination in mind."
    # [旧版翻译]
    "[fn]也差不多该继续前进了，并开始想着接下来要去哪里比较好。……说起来，因为只是出来散步，一开始就没有想说特别要去哪里。"

# game/day 2.rpy:2329
translate chinese_simplified juuichi02_60b6e66c:

    # "I think I'll head to the candy store\nto get some ice cream while I think about it.\nI feel like cooling off in the shade now, anyway."
    # [旧版翻译]
    "哎，总而言之先到零食店去吃点冰再来慢慢想好了。现在只想先到某个阴凉的地方再说。"

# game/day 2.rpy:2330
translate chinese_simplified juuichi02_ee9cc9ca:

    # "...Ah, should I invite Juuichi-san, too?"
    # [旧版翻译]
    "……啊，这样的话要不要邀柔一一起去？"

# game/day 2.rpy:2331
translate chinese_simplified juuichi02_5a0ae190:

    # "When I turn to look for him, he's already gone.{p}Damn, too slow.{p}Oh well. I'm sure I'll get another chance."
    # [旧版翻译]
    "抬头一看柔一已经不见人影了。慢了一步总觉得有点后悔。没办法，只好下次再找机会了吧。"

# game/day 2.rpy:2332
translate chinese_simplified juuichi02_feae5eff:

    # "Summer vacation has just started, after all!{p}I start walking in the opposite direction\nJuuichi-san went."
    # [旧版翻译]
    "毕竟暑假现在才刚开始嘛！[fn]朝和柔一离开的方向相反的那一边开始踏步前进。"

