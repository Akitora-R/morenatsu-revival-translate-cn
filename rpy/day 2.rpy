# game/day 2.rpy:1929
translate chinese_simplified tatsuki02_coworkers_16c9e138:

    # fn "「I thought everyone here\n wears the same work clothes,\n but are you a craftsman here?」"
    # [旧版翻译]
    fn "「在这里工作的人，不是都会穿着同一种款式的工作服么？你是不是这里的工作人员呢？」"

# game/day 2.rpy:1930
translate chinese_simplified tatsuki02_coworkers_09993ddd:

    # "Heheheh, if my thinking is right,\nthen it should be different."
    # [旧版翻译]
    "唔唔唔，[fn]的推理没错的话，他应该不是这里的员工。"

# game/day 2.rpy:1934
translate chinese_simplified tatsuki02_coworkers_9291540c:

    # "The one who sees through the truth,\n{nw}"
