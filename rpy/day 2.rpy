translate chinese_simplified shin02_amaki_recipe_c5ff15f2:

    # fn "「Ah-!」"
    # [旧版翻译]
    fn "「啊！」"

# game/day 2.rpy:618
translate chinese_simplified shin02_amaki_recipe_fe582ddb:

    # "The ornament Torahiko threw hit\nKounosuke's head, then bounced out\nthe second story window."
    # [旧版翻译]
    "虎彦把摆饰丢过去，却撞到了孝之助的头，然后从这个二楼的窗户掉到了外面。"

# game/day 2.rpy:619
translate chinese_simplified shin02_amaki_recipe_92572766:

    # ko "「Oh man, Torahiko~」"
    # [旧版翻译]
    ko "「诶呦，虎彦～」"

# game/day 2.rpy:620
translate chinese_simplified shin02_amaki_recipe_20c8db02:

    # to "「I-{w=.3}It's your fault for not catching it!」"
    # [旧版翻译]
    to "「是、是你没有好好接着的关系！」"

# game/day 2.rpy:621
translate chinese_simplified shin02_amaki_recipe_452cd55d:

    # ko "「How could I ever catch that?」"
    # [旧版翻译]
    ko "「那样怎么可能接得到啊。」"

# game/day 2.rpy:622
translate chinese_simplified shin02_amaki_recipe_bef95801:

    # si "「...」"
    # [旧版翻译]
    si "「……」"

# game/day 2.rpy:623
translate chinese_simplified shin02_amaki_recipe_13c1f580:

    # "We all overdid it, and we quickly\nlooked at Shin-kun.{p}He said nothing as his shoulders quaked"
    # [旧版翻译]
    "[fn]们也发现做得太过火了，害怕地往深君的方向看过去的时候，却发现深君沉默着，肩膀不断抖动。"

# game/day 2.rpy:624
translate chinese_simplified shin02_amaki_recipe_a3cac969:

    # fn "「Shin-kun...?」"
    # [旧版翻译]
    fn "「深君……？」"

# game/day 2.rpy:625
translate chinese_simplified shin02_amaki_recipe_fe9aede2:

    # "At the same time I called out to him,\na large tear fell out of those big eyes."
    # [旧版翻译]
    "就在[fn]出声叫他的时候，眼泪从他张大的眼睛里滴了下来。"

# game/day 2.rpy:629
translate chinese_simplified shin02_amaki_recipe_53b1b05a:

    # "We tried to calm him down however we could,\nbut nothing we said to him had any effect."
    # [旧版翻译]
    "虽然[fn]们试着想要安抚他，但对开始大哭的深君来说已经说什么都没用了。"

# game/day 2.rpy:633
translate chinese_simplified shin02_amaki_recipe_35ca9e19:

    # "After that, Amaki-san brought us all together\ninto the living room.{w} By then Shin-kun\nstopped crying,{w=.3} but he still said nothing."
    # [旧版翻译]
    "后来天木先生出现，把[fn]们全员带到了客厅去。不过深君还一直在哭，什么话都没说。"

# game/day 2.rpy:634
translate chinese_simplified shin02_amaki_recipe_69d41a7d:

    # "The unbearable, awkward\nsilence for children continued,{w=.3}\nand as we trembled in fear of the biggest"
    # [旧版翻译]
    "对小孩子来说很难受的、尴尬的沉默不断持续着。就在[fn]们战战兢兢地担心会不会被骂的时候，"

# game/day 2.rpy:635
translate chinese_simplified shin02_amaki_recipe_1269a8d5:

    # "scolding of our lives,{w=.3}\nthere was some sweets in front of us."
    # [旧版翻译]
    "出现在[fn]们面前的，却是一盘饼干。"

# game/day 2.rpy:636
translate chinese_simplified shin02_amaki_recipe_6d63d756:

    # "We all ate them in bewilderment together with\nShin-kun, and while a bit of it was burned,\nit was really sweet and delicious."
    # [旧版翻译]
    "大家困惑地一起和深君吃着的饼干，虽然旁边有一点点焦掉，但还是非常甜非常好吃。"

# game/day 2.rpy:637
translate chinese_simplified shin02_amaki_recipe_c2ddf8ec:

    # "We apologized again afterwards, but as\nShin-kun only said {w=.3}\"I don't care anymore,\"{w=.3}\nwe weren't sure he really forgave us."
    # [旧版翻译]
    "后来[fn]们再次跟深君道歉，深君只是一脸不高兴地说着「不必了」，也不知道到底有没有原谅[fn]们。"

# game/day 2.rpy:638
translate chinese_simplified shin02_amaki_recipe_b054b118:

    # "We all felt uncomfortable,\nso after that we all went home.{p}Even so, we were in the wrong."
    # [旧版翻译]
    "于是大家心情都变得不太好，之后马上就回去了。明明不好的是[fn]们这边的说呢。"

# game/day 2.rpy:642
translate chinese_simplified shin02_amaki_recipe_ebcda814:

    # am "「Come again.」"
    # [旧版翻译]
    am "「有空再来玩喔。」"

# game/day 2.rpy:643
translate chinese_simplified shin02_amaki_recipe_e21e17cc:

    # "That gentle adult voice that called out to us\nas we left was the biggest forgiveness for us,"
    # [旧版翻译]
    "在回去时，天木先生那种大人的温柔语气，让[fn]们幼小的心灵觉得被原谅了，也正因此，"

# game/day 2.rpy:644
translate chinese_simplified shin02_amaki_recipe_f1875a05:

    # "so that's why{w=.3} we all felt\nas though we did something horrible."
    # [旧版翻译]
    "才发现自己似乎是做了很残酷的事。"

# game/day 2.rpy:651
translate chinese_simplified shin02_amaki_recipe_0c82733a:

    # "So after that apology, it was strained at first,\nbut we started being able to talk to one another."
    # [旧版翻译]
    "从那时的道歉开始，虽然起初还是有许多不顺利的地方，但后来也慢慢能和深君说上话了。"

# game/day 2.rpy:652
translate chinese_simplified shin02_amaki_recipe_dcb2c5d3:

    # "If we had just talked to him,\nnone of it would have happened."
    # [旧版翻译]
    "开始说上话后，就觉得没什么特别的。"

# game/day 2.rpy:653
translate chinese_simplified shin02_amaki_recipe_197382b2:

    # "He was the \"mysterious gloomy guy,\" but we\nwere children who didn't change anything."
    # [旧版翻译]
    "「不知道在想什么的阴暗家伙」什么的，对[fn]们来说也没什么不同，就是普通的小孩罢了。"

# game/day 2.rpy:654
translate chinese_simplified shin02_amaki_recipe_bbc95bc2:

    # "Before we realized,\nthat invisible wall we felt between us\nand Shin-kun{w=.5} disappeared."
    # [旧版翻译]
    "不知何时，原本感觉和深君之间的那种看不见的墙壁，也渐渐消失不见了。"

# game/day 2.rpy:655
translate chinese_simplified shin02_amaki_recipe_f092a679:

    # "There are parts we can't really understand,\nbut he wasn't a bad guy.{p}We all understood that."
    # [旧版翻译]
    "虽然确实不是很好亲近，但也不是无法亲近。大家渐渐了解了这一点。"

# game/day 2.rpy:656
translate chinese_simplified shin02_amaki_recipe_1680b31c:

    # "And so, we all became friends."
    # [旧版翻译]
    "于是，[fn]们便成为了朋友。"

# game/day 2.rpy:664
translate chinese_simplified shin02_amaki_recipe_97f16d8d:

    # fn "「D-do you remember?{w=.3}That one time we went to the river.」"
    # [旧版翻译]
    fn "「啊、还记得那件事吗？去河边时发生的事。」"

# game/day 2.rpy:665
translate chinese_simplified shin02_amaki_recipe_0065b13c:

    # si "「Why do you remember only those things...?」"
    # [旧版翻译]
    si "「为什么总是记住那种事情啊……」"

# game/day 2.rpy:666
translate chinese_simplified shin02_amaki_recipe_4357b577:

    # fn "「Well, because I can't forget them.」"
    # [旧版翻译]
    fn "「那个，因为很难忘嘛。」"

# game/day 2.rpy:670
translate chinese_simplified shin02_amaki_recipe_a7e7314e:

    # si "「My fear of water is 80%% your's\n and Torahiko's fault.」"
    # [旧版翻译]
    si "「我会讨厌水的原因，有八成都是你和虎彦害的呢。」"

# game/day 2.rpy:671
translate chinese_simplified shin02_amaki_recipe_8cf47747:

    # fn "「Huh?{w} Me too!?」"
    # [旧版翻译]
    fn "「咦？[fn]也算吗！？」"

# game/day 2.rpy:675
translate chinese_simplified shin02_amaki_recipe_bc6a17c8:

    # si "「You'd always sit back and watch quietly.{p} Same thing.」"
    # [旧版翻译]
    si "「你每次都在旁边默默地看着不是吗。所以同罪啊。」"

# game/day 2.rpy:676
translate chinese_simplified shin02_amaki_recipe_7e72fdb0:

    # fn "「Come on...」"
    # [旧版翻译]
    fn "「怎么这样～」"

# game/day 2.rpy:681
translate chinese_simplified shin02_amaki_recipe_7caa1562:

    # "Just when we reached a good stopping point,\nthe clock rung."
    # [旧版翻译]
    "当话题正好告一段落的时候，时钟响了起来。"

# game/day 2.rpy:682
translate chinese_simplified shin02_amaki_recipe_97c54eda:

    # "We looked over as if to fish something out,\nand the hand was much further\nalong than I expected."
    # [旧版翻译]
    "听到声音后[fn]往时钟看了一眼，才发现时针前进的比[fn]想像中还要多。"

# game/day 2.rpy:686
translate chinese_simplified shin02_amaki_recipe_1afe67c6:

    # si "「It's that time already?」"
    # [旧版翻译]
    si "「都已经这个时间了么。」"

# game/day 2.rpy:687
translate chinese_simplified shin02_amaki_recipe_60d1b524:

    # fn "「What?{w} Seriously?」"
    # [旧版翻译]
    fn "「哎？不会吧？」"

# game/day 2.rpy:688
translate chinese_simplified shin02_amaki_recipe_ac18c3d5:

    # "Before I realized it,\nthere was no more tea or snacks left."
    # [旧版翻译]
    "注意到的时候茶和饼干都已经吃完了。"

# game/day 2.rpy:689
translate chinese_simplified shin02_amaki_recipe_17e08dbf:

    # "We really have been reminiscing\nlonger than I thought."
    # [旧版翻译]
    "真的是聊了好多好多以前的事呢。"

# game/day 2.rpy:690
translate chinese_simplified shin02_amaki_recipe_e833856d:

    # si "「Now seems like a good place\n to stop for the day.」"
    # [旧版翻译]
    si "「差不多该是结束的时候了呢。」"

# game/day 2.rpy:691
translate chinese_simplified shin02_amaki_recipe_4ed21bbe:

    # fn "「Yeah,{w=.3} I have to get back soon.」"
    # [旧版翻译]
    fn "「嗯，[fn]也是不回去不行了。」"

# game/day 2.rpy:699
translate chinese_simplified shin02_amaki_recipe_aeed3d70:

    # fn "「Well see you later,{w=.3} Shin-kun.」"
    # [旧版翻译]
    fn "「那就再见啦，深。」"

# game/day 2.rpy:700
translate chinese_simplified shin02_amaki_recipe_cbdd2141:

    # si "「Later.」"
    # [旧版翻译]
    si "「再见。」"

# game/day 2.rpy:701
translate chinese_simplified shin02_amaki_recipe_00136d6b:

    # fn "「Can I come over again?」"
    # [旧版翻译]
    fn "「可以再来吗？」"

# game/day 2.rpy:702
translate chinese_simplified shin02_amaki_recipe_50a30531:

    # si "「Of course...」"
    # [旧版翻译]
    si "「当然[ch text=──]」"

# game/day 2.rpy:706
translate chinese_simplified shin02_amaki_recipe_258267c6:

    # si "「...not.{w} How does that feel?」"
    # [旧版翻译]
    si "「不行，如果我这样说的话呢？」"

# game/day 2.rpy:707
translate chinese_simplified shin02_amaki_recipe_6252366d:

    # fn "「Huh!?」"
    # [旧版翻译]
    fn "「诶诶！？」"

# game/day 2.rpy:708
translate chinese_simplified shin02_amaki_recipe_731fd80c:

    # si "「I'm kidding.{p} {nw}"
    # [旧版翻译]
    si "「开玩笑的。"

# game/day 2.rpy:710
translate chinese_simplified shin02_amaki_recipe_7477b835:

    # extend "I can't do any grand entertainments,\n but come over whenever you like.」"
    # [旧版翻译]
    extend "虽然没什么值得特别跑一趟的东西，不过随时欢迎。」"

# game/day 2.rpy:712
translate chinese_simplified shin02_amaki_recipe_da6a9dca:

    # fn "「Ah, okay...」"
    # [旧版翻译]
    fn "「啊，嗯……」"

# game/day 2.rpy:716
translate chinese_simplified shin02_amaki_recipe_4dff02e9:

    # si "「Well then,{w=.3} take care on your way back.」"
    # [旧版翻译]
    si "「那么，回去时路上小心。」"

# game/day 2.rpy:717
translate chinese_simplified shin02_amaki_recipe_9b75e8ea:

    # fn "「See you later.」"
    # [旧版翻译]
    fn "「再见喽。」"

# game/day 2.rpy:722
translate chinese_simplified shin02_amaki_recipe_45620797:

    # "Shin-kun hasn't changed much over these 5 years.{p}I mean that in a good way.{p}He feels a lot more gentler than I remember."
    # [旧版翻译]
    "深君在这五年间也变了呢。是好的变化。比记忆中的深君来得温柔了许多。"

# game/day 2.rpy:723
translate chinese_simplified shin02_amaki_recipe_17b9b3fb:

    # "As I walked back on the sunset-dyed road,\nI kept thinking about that."
    # [旧版翻译]
    "在回去的道路，这个被夕阳染上橙红的乡间小路上，[fn]一边走一边这样想着。"

# game/day 2.rpy:740
translate chinese_simplified kounosuke02_342f5257:

    # "While walking downtown,{p}passing by the stores and houses on the street,{p}makes me feel very nostalgic."
    # [旧版翻译]
    "走在商店街上，小镇的景色从身边过，有种怀念的感觉。"

# game/day 2.rpy:741
translate chinese_simplified kounosuke02_f0475369:

    # "It's no different than it was 5 years ago."
    # [旧版翻译]
    "和5年前相比并没有什么变化，"

# game/day 2.rpy:742
translate chinese_simplified kounosuke02_626f9de7:

    # "No, it's changed a little,{p}mainly the construction of stores on the streets."
    # [旧版翻译]
    "不，稍微还是有一点改变，主要是新建设了一些店铺和马路，"

# game/day 2.rpy:743
translate chinese_simplified kounosuke02_88a52b2a:

    # "But the atmosphere of Minasato,{p}is no different than it was in my memory."
    # [旧版翻译]
    "即使是这样，记忆中水乡村的氛围还是没变呢。"

# game/day 2.rpy:744
translate chinese_simplified kounosuke02_aeb4d72e:

    # "The only thing that looks different,{p}is the height-level from which I'm viewing things,{p}compared to when I was little."
    # [旧版翻译]
    "唯一不同的是，那些看向[fn]的目光的高度，还有小孩子们的身影。"

# game/day 2.rpy:745
translate chinese_simplified kounosuke02_83bb2975:

    # "It seems like there are less children...{p}running around on the streets than there used to be.{p}The population must be declining."
    # [旧版翻译]
    "在马路上乱跑的孩子们的数量，和过去相比变少了。所谓的，人口稀少化吗？"

# game/day 2.rpy:746
translate chinese_simplified kounosuke02_7a4f3974:

    # "The amount of people leaving Minasato,{p}to go to the city seems to be increasing every year.{p}I too did that to myself."
    # [旧版翻译]
    "包括[fn]在内，从水乡村去大城市的人数每年都在增加。"

# game/day 2.rpy:747
translate chinese_simplified kounosuke02_bc5103d6:

    # "I don't think this village is going to disappear,{p}but the way the bustling streets of Minasato,{p}from my memory have become so empty..."
    # [旧版翻译]
    "难道水乡村会就此消失吗，和记忆中水乡村的热闹相比，现在显得有几分寂寞，"

# game/day 2.rpy:748
translate chinese_simplified kounosuke02_e12b8751:

    # "makes me feel just a little sadness in my heart."
    # [旧版翻译]
    "心中有一点点哀愁。"

# game/day 2.rpy:756
translate chinese_simplified kounosuke02_b5319b3d:

    # fn "「Whew.」"
    # [旧版翻译]
    fn "「呼……」"

# game/day 2.rpy:757
translate chinese_simplified kounosuke02_a79643fc:

    # "As soon as I enter the store,{p}I feel the temperature suddenly drop."
    # [旧版翻译]
    "一进到店里面，周围的温度就降了下来。"

# game/day 2.rpy:758
translate chinese_simplified kounosuke02_02b4344e:

    # "The air is cooler and comfortable.{p}Correction. The air conditioning might...{p}be a little too cold."
    # [旧版翻译]
    "空调的冷气让人感到很舒服。……修正。空调稍微有点冷了。"

# game/day 2.rpy:759
translate chinese_simplified kounosuke02_f9444574:

    # "But compared to the scorching hell outside,{p}this is heaven on Earth."
    # [旧版翻译]
    "不过，和刚才炎热的地狱相比，现在可以说是天堂了。"

# game/day 2.rpy:760
translate chinese_simplified kounosuke02_4f5117f9:

    # "I lightly air out my shirt,{p}it had become sticky with sweat."
    # [旧版翻译]
    "汗马上就不往外冒了，塌了汗的衬衫也变得轻飘飘，不会粘身了。"

# game/day 2.rpy:761
translate chinese_simplified kounosuke02_b0090dcf:

    # "Hmm.{p}Long live the power of science?"
    # [旧版翻译]
    "嗯~科技万岁？"

# game/day 2.rpy:762
translate chinese_simplified kounosuke02_da1e989c:

    # "While looking around in the small store,{p}I find what I'm looking for in the corner.{p}Wait, it's old."
    # [旧版翻译]
    "环视了一下这间不怎么大的店，一个角落直直地闯入了[fn]的视线。这，好老旧……"

# game/day 2.rpy:763
translate chinese_simplified kounosuke02_3a5acb71:

    # "Even in a rural area like this,{p}the weekly publications are neatly stocked.{p}The problem is... they're all last week's issue."
    # [旧版翻译]
    "即使是这种乡下，也有各种周刊杂志呢。话是这么说啦，可问题是……这些都是上一期的。"

# game/day 2.rpy:764
translate chinese_simplified kounosuke02_249b5406:

    # "While recieving a bit of culture shock,{p}I think about returning home,{p}but decide not to because of the damned hot weather."
    # [旧版翻译]
    "尽管有些文化有些差异，但真的是受够了外面可恶的炎热天气，所以还是站着读一会杂志来消磨时间吧。"

# game/day 2.rpy:765
translate chinese_simplified kounosuke02_290df761:

    # "For now I'll just kill some time by browsing."
    # [旧版翻译]
    "店里摆放的书刊的数量与店铺的规模很相称，大多时候，翻阅到的杂志周刊全都是上一期的，单行本和新刊什么的统统没有。"

# game/day 2.rpy:766
translate chinese_simplified kounosuke02_d6d063a6:

    # "The assortment is like the size of the store.{p}Smaller."
    # [旧版翻译]
    "放在这的杂志都是以前的。"

# game/day 2.rpy:767
translate chinese_simplified kounosuke02_f8c9df4c:

    # "All the weekly magazines that I usually read,{p}are from last week."
    # [旧版翻译]
    "放在这的杂志都是以前的。"

# game/day 2.rpy:768
translate chinese_simplified kounosuke02_e7ea5555:

    # "There are no new publications."
    # [旧版翻译]
    "单行本和新刊什么的统统没有。"

# game/day 2.rpy:769
translate chinese_simplified kounosuke02_3b12c88f:

    # "I toss away an old magazine,{p}that looks like it's from the past decade."
    # [旧版翻译]
    "没办法，[fn]拿起一本杂志，这个还是可以稍微读一下的吧。"

# game/day 2.rpy:770
translate chinese_simplified kounosuke02_b5216440:

    # "Reluctantly, I pick up one that has more...{p}questionable content,{p}and I skim through it halfheartedly."
    # [旧版翻译]
    "没办法，[fn]拿起一本杂志，这个还是可以稍微读一下的吧。"

# game/day 2.rpy:771
translate chinese_simplified kounosuke02_bc1351a7:

    # "...Huh.{p}This is surprisingly interesting."
    # [旧版翻译]
    "……嘿，没想到啊。这个意外的有意思呢。"

# game/day 2.rpy:772
translate chinese_simplified kounosuke02_96b05aa8:

    # "Should I subscribe to it now?{p}No, that would hurt my wallet...{p}Maybe I should buy it when it comes out as a book."
    # [旧版翻译]
    "不如买回去看看吧？不行，钱包都瘪了……还是等出单行本之后再买吧。"

# game/day 2.rpy:777
translate chinese_simplified kounosuke02_d46526ce:

    # "I close the magazine and put it back where it was.{p}Looking at the clock in the store,{p}I see that 30 minutes haven't even passed yet."
    # [旧版翻译]
    "[fn]合上杂志，把它放回原来的地方。看看店里面的时钟，还有30分钟。"

# game/day 2.rpy:778
translate chinese_simplified kounosuke02_1f1a89da:

    # "I guess I'll browse a little more."
    # [旧版翻译]
    "还是再读会书吧。"

# game/day 2.rpy:779
translate chinese_simplified kounosuke02_24ddfa66:

    # "While looking for my next catch,{p}I see a familiar figure in the corner of my eye."
    # [旧版翻译]
    "正当[fn]打算找另一本杂志再看一会儿时，视线的角落里出现了一个熟悉的身影。"

# game/day 2.rpy:783
translate chinese_simplified kounosuke02_3ccef628:

    # "I turn my face to the side,{p}and see that it's Kounosuke."
    # [旧版翻译]
    "转过头一看，果然，站在那里的是孝之助。"

# game/day 2.rpy:784
translate chinese_simplified kounosuke02_731778a9:

    # "I wonder when he got here.{p}Or maybe he's been here the whole time?"
    # [旧版翻译]
    "他是什么时候进来的啊。或者是一开始就在那里的？"

# game/day 2.rpy:785
translate chinese_simplified kounosuke02_b2c154f5:

    # "I mean, Kounosuke's the one who usually...{p}finds me in public like that."
    # [旧版翻译]
    "不对啊，如果一开始就在那里的话，那之前就应该看到他了啊。"

# game/day 2.rpy:786
translate chinese_simplified kounosuke02_412c2980:

    # "With a magazine in one hand,{p}he reads an article,{p}completely glued to the spot."
    # [旧版翻译]
    "孝之助一边单手拿着杂志，一边目不转睛地看着记事本。"

# game/day 2.rpy:787
translate chinese_simplified kounosuke02_ae7d221f:

    # "I lightly wave my hand to the side,{p}but he shows no signs of noticing."
    # [旧版翻译]
    "即使把手放在他眼前摇晃，他都没有注意到。"

# game/day 2.rpy:788
translate chinese_simplified kounosuke02_633a0548:

    # "Oh, this reminds me,{p}when Kounosuke's engrossed like that,{p}he completely shuts out everything around him."
    # [旧版翻译]
    "啊啊，这么说起来，孝之助这家伙一旦聚精会神起来，就会把周围的事情完全无视掉了。"

# game/day 2.rpy:789
translate chinese_simplified kounosuke02_7b9db202:

    # "It's something he's known for."
    # [旧版翻译]
    "经常连大家在说什么都听不见。"

# game/day 2.rpy:790
translate chinese_simplified kounosuke02_39165d96:

    # fn "「Kounosu-」"
    # [旧版翻译]
    fn "「孝之——」"

# game/day 2.rpy:791
translate chinese_simplified kounosuke02_01ba5908:

    # "I try to approach and greet him,{p}but at almost exactly the same time,"
    # [旧版翻译]
    "几乎是在[fn]走近喊他的同时，"

# game/day 2.rpy:792
translate chinese_simplified kounosuke02_20833a9d:

    # "he raises face up from his magazine,{p}and passes right by me."
    # [旧版翻译]
    "孝之助抬起了头，从[fn]的身边走了过去。"

# game/day 2.rpy:796
translate chinese_simplified kounosuke02_88fbcca9:

    # fn "「Ke, ah...」{w} {nw}"
    # [旧版翻译]
    fn "「助，啊……」"

# game/day 2.rpy:798
translate chinese_simplified kounosuke02_f5dd4c90:

    # extend "{w=2.5}{nw}"
    # [旧版翻译]
    extend ""

# game/day 2.rpy:800
translate chinese_simplified kounosuke02_8f011a99:

    # clerk "「Thank you very much.」"
    # [旧版翻译]
    clerk "「多谢惠顾」"

# game/day 2.rpy:801
translate chinese_simplified kounosuke02_9ebf5e8a:

    # "Without stopping,{p}Kounosuke buys his magazine and leaves the store.{p}The clerk's dull voice is left in the store."
    # [旧版翻译]
    "话还没讲完，孝之助就已经拿着买的杂志出店了。店员那有气无力的声音，回响在空空的店里。"

# game/day 2.rpy:802
translate chinese_simplified kounosuke02_8ce95dc6:

    # "I couldn't get him to notice me at all...{p}While being thoroughly ignored,{p}my eyes meet with the clerk's."
    # [旧版翻译]
    "好像完全没有注意到[fn]嘛……就这样精神恍惚地穿了过去，[fn]和店员互看了一眼。"

# game/day 2.rpy:803
translate chinese_simplified kounosuke02_90b0b524:

    # "I hurriedly turn back to the magazine corner.{p}Come to think of it, what did Kounosuke buy?{p}It looked like he was really into it."
    # [旧版翻译]
    "连忙走向放杂志的角落。孝之助买了什么东西呢？竟然读得那么认真。"

# game/day 2.rpy:804
translate chinese_simplified kounosuke02_8015d6de:

    # "Just out of plain curiousity,{p}I move to the corner where Kounosuke was.{p}After randomly looking around the shelves, I find it."
    # [旧版翻译]
    "在[fn]看来这边没什么可看的东西，在放杂志的角落的一端，孝之助刚才站的地方，稍微找了一下，啊呀。"

# game/day 2.rpy:808
translate chinese_simplified kounosuke02_202df56c:

    # "I found it. I've found it.{p}Just next to the magazine corner,{p}left there messily,"
    # [旧版翻译]
    "找到了。找到了！在摆杂志的角落旁边，那个乱糟糟的色情书堆中放着的……"

# game/day 2.rpy:809
translate chinese_simplified kounosuke02_ad6f7aee:

    # "is the erotic book shelf."
    # [旧版翻译]
    "在摆杂志的角落旁边，那个乱糟糟的色情书堆中放着的……"

# game/day 2.rpy:810
translate chinese_simplified kounosuke02_af7728a4:

    # "『F-Men Mixture of Different Species Battle 』"
    # [旧版翻译]
    "『Ｆーｍｅｎ 異種混合戦』"

# game/day 2.rpy:811
translate chinese_simplified kounosuke02_67308ed1:

    # "No way, there's no way this is...{p}But no matter how many times I re-read the title,{p}it's always the same."
    # [旧版翻译]
    "难道，这个是，难道……这本书不管怎么看，"

# game/day 2.rpy:815
translate chinese_simplified kounosuke02_c9bf4082:

    # "This is THE beastmen's ultimate gay book...{p}There are numerous pages and,{p}it's almost twice as thick as the one next to it."
    # [旧版翻译]
    "都是兽人的同志本……它有其他书的2倍厚。"

# game/day 2.rpy:816
translate chinese_simplified kounosuke02_c6b27031:

    # "It's such an extreme representation of a niche genre.{p}This was the last the editing company sent out,{p}before it shut down forever."
    # [旧版翻译]
    "虽然说有些夸张，不过这本书是那个小型杂志社在倒闭之前，最后发售的"

# game/day 2.rpy:817
translate chinese_simplified kounosuke02_c1989698:

    # "It's an \"everything I want crammed into one\",{p}erotic book,{p}and it's not so easy to get your hands on it, either."
    # [旧版翻译]
    "\"倾尽了所有心血\"的梦幻的色情书！"

# game/day 2.rpy:818
translate chinese_simplified kounosuke02_e0a9c2e8:

    # "Every once in a while it shows up on a net auction,{p}for a ridiculous price however.{p}So what's it doing in a country bookstore like this?"
    # [旧版翻译]
    "那本在网上炒的巨火的幻之书，竟然会在这样的乡下书店里出现？"

# game/day 2.rpy:819
translate chinese_simplified kounosuke02_2ba0f164:

    # "With trembling fingers,{p}I pull it from the shelf."
    # [旧版翻译]
    "[fn]用颤抖的手指，把它从书架上拿下来。"

# game/day 2.rpy:820
translate chinese_simplified kounosuke02_5d794092:

    # "There's no doubting the intended genre,{p}just from the front cover."
    # [旧版翻译]
    "从封面上看，这毫无疑问就是[fn]想要的类型。"

# game/day 2.rpy:821
translate chinese_simplified kounosuke02_3d53aede:

    # "And its contents,{p}well you might say its contents are..."
    # [旧版翻译]
    "而且，这本书里面、里面的内容，简直就是……"

# game/day 2.rpy:826
translate chinese_simplified kounosuke02_ebe2fe59:

    # "{size=+15}ARCADIA."
    # [旧版翻译]
    "{size=+15}幻想乡！"

# game/day 2.rpy:831
translate chinese_simplified kounosuke02_50b89eb6:

    # "Taken aback, I look around the store.{p}There's the store clerk and me, just two people.{p}In other words, I'm the only customer."
    # [旧版翻译]
    "[fn]马上巡视了一下书店。现在店里面，只有[fn]和店员两个人。也就是说，只有[fn]一位客人。"

# game/day 2.rpy:832
translate chinese_simplified kounosuke02_318c9e21:

    # "This kind of situation...!{p}There's no doubt.{p}I need God's guidance!{w} {nw}"
    # [旧版翻译]
    "这，这种状况……！没错，这就是神的引导！"

# game/day 2.rpy:834
translate chinese_simplified kounosuke02_f5dd4c90_1:

    # extend "{w=2.5}{nw}"
    # [旧版翻译]
    extend ""

# game/day 2.rpy:836
translate chinese_simplified kounosuke02_8f011a99_1:

    # clerk "「Thank you very much.」"
    # [旧版翻译]
    clerk "「多谢惠顾。」"

# game/day 2.rpy:840
translate chinese_simplified kounosuke02_7be92598:

    # "This volume is way to big to read it,{p}all while standing in the store."
    # [旧版翻译]
    "这本书真是太厚了，胜于书店中其他任何一本。"

# game/day 2.rpy:841
translate chinese_simplified kounosuke02_30b49479:

    # "And it's full of... such juicy content.{p}There's no way I would do such a wasteful thing."
    # [旧版翻译]
    "而且其中是满满的激情和咸湿。"

# game/day 2.rpy:842
translate chinese_simplified kounosuke02_ac2cdd86:

    # "Thanks to this unexpected bounty,{p}my nights won't be lonely for a while."
    # [旧版翻译]
    "感谢这从天而降的恩赏，[fn]的夜晚将不再空虚。"

# game/day 2.rpy:846
translate chinese_simplified kounosuke02_a6b9d239:

    # "Thank you, Kounosuke!"
    # [旧版翻译]
    "太感谢了，孝之助！"

# game/day 2.rpy:878
translate chinese_simplified river02_aabe6dac:

    # fn "「It's so hot...!」"
    # [旧版翻译]
    fn "「好热――」"

# game/day 2.rpy:879
translate chinese_simplified river02_b9760e78:

    # "I don't really get why, but it's seriously hot.{p}When I look outside, the air looks all distorted."
    # [旧版翻译]
    "不知道是什么原因，竟然异常的热。往外看出去一点的话,就会发现那边的空气似乎都被扭曲了。"

# game/day 2.rpy:880
translate chinese_simplified river02_b644229f:

    # "It's called a heat haze,\nbut my head's feeling kind of weird,\nso I'm not too sure about that."
    # [旧版翻译]
    "那看起来就像阳炎一样扭曲着，总觉得看着看着自己的脑袋都变奇怪了，不过应该不是事实吧。"

# game/day 2.rpy:881
translate chinese_simplified river02_f17d0b59:

    # "It's been like this all morning:{p}A deep blue sky. Brilliantly pouring sunlight.{p}The cicadas are calling loudly enough to hurt my ears."
    # [旧版翻译]
    "今天从早上开始就是一直都是大太阳。湛蓝的天空。强烈的阳光照射下来。比平常还响亮的蝉声不停的折磨着[fn]的耳朵。"

# game/day 2.rpy:882
translate chinese_simplified river02_368bee00:

    # fn "「So... damn... hot!」"
    # [旧版翻译]
    fn "「好热啊――」"

# game/day 2.rpy:883
translate chinese_simplified river02_b41d98e8:

    # "I don't know for sure, but everywhere else is hot.{p}The temperature feels like it's rising quickly,\nso I don't bother to look at the thermometer."
    # [旧版翻译]
    "虽然不知道为什么，但到处都非常热。感受到的温度一定比体感温度再更高三度、毕竟天气预报也没有温度表可以看。"

# game/day 2.rpy:884
translate chinese_simplified river02_164fba33:

    # fn "「Hnngh...」"
    # [旧版翻译]
    fn "「呜咕咕咕」"

# game/day 2.rpy:885
translate chinese_simplified river02_04069554:

    # "I writhe in absolute misery as I groan."
    # [旧版翻译]
    "[fn]伸了个懒腰。"

# game/day 2.rpy:886
translate chinese_simplified river02_91d6b7a7:

    # "When did Minasato feel like such a tropical zone?{p}It at least felt better before I moved away...!"
    # [旧版翻译]
    "水乡到底是什么时候变成这种热带地区的啊。在[fn]搬走之前就算只有一点也肯定比现在好的啊……！！"

# game/day 2.rpy:887
translate chinese_simplified river02_daeea71a:

    # "Maybe it's that \"{cps=10}global warming{cps=40}\" thing,{p}or that \"{cps=10}greenhouse effect{cps=40}\" stuff."
    # [旧版翻译]
    "啊啊，是那个吧。最近流行在讲的那个对吧。『[wds]全球变暖[rd]』啦、『[wds]热岛效应[rd]』什么的没错吧。"

# game/day 2.rpy:888
translate chinese_simplified river02_8e3b39ef:

    # fn "「Yeah, those fads didn't need to continue...」"
    # [旧版翻译]
    fn "「这种流行不用跟也没关系啊……」"

# game/day 2.rpy:889
translate chinese_simplified river02_b60d88f0:

    # "Complaining wasn't going to drop the temperature.{p}But instead, it felt like it was doing the opposite,{p}I shouldn't really cry over it though..."
    # [旧版翻译]
    "就算再怎么悲叹，气温也不会下降。相反的，反而还越来越高的感觉。看来悲叹一点帮助都没有吗。"

# game/day 2.rpy:890
translate chinese_simplified river02_2c18c94a:

    # "Ahhhhhh!"
    # [旧版翻译]
    "啊啊啊啊啊！"

# game/day 2.rpy:891
translate chinese_simplified river02_64a9b19a:

    # "Gah, this town is trying to kill me!{p}Either I'll get dehydrated or I'll go crazy..."
    # [旧版翻译]
    "受够了，水乡村难道想用名为脱水症或者中暑来杀了[fn]吗！？"

# game/day 2.rpy:892
translate chinese_simplified river02_a7c6f17c:

    # "I'm at my breaking point right about now,{p}and if I don't get to somewhere that's cool soon..."
    # [旧版翻译]
    "不行了，快要到忍耐极限了。再不找个凉爽的地方逃亡的话――。"

# game/day 2.rpy:900
translate chinese_simplified river02_ebbf67ec:

    # fn "「Well, once you put it like that...{p} there's no place better than right here...」"
    # [旧版翻译]
    fn "「所以说，果然还是这边最适合消暑了。」"

# game/day 2.rpy:901
translate chinese_simplified river02_0a62740e:

    # "Here I am, out at the river bed."
    # [旧版翻译]
    "总算来到河边了。"

# game/day 2.rpy:902
translate chinese_simplified river02_8eb3bac2:

    # fn "「Ahh... this is great...!」"
    # [旧版翻译]
    fn "「呼，真凉啊。」"

# game/day 2.rpy:903
translate chinese_simplified river02_d74b6801:

    # "Somehow I feel like...{p}just having water around makes me cooler."
    # [旧版翻译]
    "觉得自己就像水的一部份才能感受到的凉爽…………。"

# game/day 2.rpy:904
translate chinese_simplified river02_f632868e:

    # "What the hell am I doing standing around!?{p}I am definitely cooling off, no doubt about it!"
    # [旧版翻译]
    "呃！？这样不行，这种消极的思考！一定会越来越凉爽的，对，没错！酷热 GOODBYE！HELLO COOL！"

# game/day 2.rpy:905
translate chinese_simplified river02_f2fbe3b4:

    # "Goodbye to the hot and hello to the cool!{p}Screw you, Mother Nature!"
    # [旧版翻译]
    "酷热 GOODBYE！HELLO COOL！"

# game/day 2.rpy:906
translate chinese_simplified river02_e4c38a4f:

    # "Ahh, that was close...{p}I was almost overcome by that...{p}'global warming' conspiracy crap."
    # [旧版翻译]
    "啊啊，好危险啊。差点就掉入了『全球暖化』的阴谋之中然后被这可怕的阴谋给吞噬！"

# game/day 2.rpy:907
translate chinese_simplified river02_ac10b1d4:

    # fn "「I bet taking a dip will cool me down...」"
    # [旧版翻译]
    fn "「总之，如果[fn]把脚泡在水中的话，肯定会很凉爽的。」"

# game/day 2.rpy:908
translate chinese_simplified river02_1547e506:

    # "Even then, it'd probably take three hours,{p}before I actually cooled down.{p}I can tough it out until then."
    # [旧版翻译]
    "嗯，不会错的。恐怕、到开始觉得凉要三个小时。虽然感觉很可惜，但也只能忍耐了。"

# game/day 2.rpy:909
translate chinese_simplified river02_cef8998b:

    # "The green grass covered the hill as I walked down,{p}and I drew closer to the sound of the running river."
    # [旧版翻译]
    "翠绿色的草掩盖着往下走的坡道，[fn]缓缓靠近那潺潺水流。"

# game/day 2.rpy:910
translate chinese_simplified river02_fa116786:

    # "The familiar hush of running water...{p}it gave me a feeling of nostalgia."
    # [旧版翻译]
    "翠绿色的草掩盖着往下走的坡道，[fn]缓缓靠近那潺潺水流。"

# game/day 2.rpy:911
translate chinese_simplified river02_1f50736b:

    # who "「Hmm? [fn]-san?」"
    # [旧版翻译]
    who "「咦？是[fn]吗？」"

# game/day 2.rpy:912
translate chinese_simplified river02_fe138567:

    # "All of a sudden, I hear a voice call out my name.{p}Instinctively, I look for the source."
    # [旧版翻译]
    "声音突然从旁边传来。反射性的抬头看向声音的来源。"

# game/day 2.rpy:920
translate chinese_simplified river02_394ac97c:

    # su "「Hey, it is you!{w} Hi, [fn]-san!」"
    # [旧版翻译]
    su "「啊、果然！你好啊、[fn]！」"

# game/day 2.rpy:924
translate chinese_simplified river02_da029ad4:

    # ka "「Yo, [fn].」"
    # [旧版翻译]
    ka "「唷、[fn]」"

# game/day 2.rpy:925
translate chinese_simplified river02_8070bcc1:

    # fn "「Well, look who it is.{p} What are you guys here for?」"
    # [旧版翻译]
    fn "「哎呀、这不是洸哉和峻吗。你们两个人怎么会在这里呢？」"

# game/day 2.rpy:929
translate chinese_simplified river02_a64fe54c:

    # su "「Uuu. We couldn't take the heat,\n so we came here to cool off a little.」"
    # [旧版翻译]
    su "「唔。天气太热有点受不了、所以就来这边稍微乘凉一下了。」"

# game/day 2.rpy:930
translate chinese_simplified river02_3250eaa1:

    # "If I had looked earlier,\n I'd have seen them already in the water."
    # [旧版翻译]
    "这么说起来的确是啊，两个人都把脚泡在水里。"

# game/day 2.rpy:934
translate chinese_simplified river02_9e5e6522:

    # ka "「Heh, what about you, [fn]?」"
    # [旧版翻译]
    ka "「这么说起来[fn]呢？」"

# game/day 2.rpy:935
translate chinese_simplified river02_9b355e8d:

    # fn "「Eh, it's the same for me.{p} I came out here to protect myself,\n from the horrors of global warming.」"
    # [旧版翻译]
    fn "「[fn]也一样哦。为了在全球暖化中保护自己以免被热死、所以就从自己的窝里爬出来避暑了。」"

# game/day 2.rpy:939
translate chinese_simplified river02_1857095f:

    # ka "「The hell is that?」"
    # [旧版翻译]
    ka "「这什么啊」"

# game/day 2.rpy:940
translate chinese_simplified river02_58f1fa8e:

    # "Kouya smiled as he said that."
    # [旧版翻译]
    "洸哉这么说着，微笑了起来。"

# game/day 2.rpy:941
translate chinese_simplified river02_94ff6c38:

    # su "「But today is even hotter than usual.{p} Isn't this the hottest it'll be all summer?{p} {cps=10}The highest temperature was...{nw}"
    # [旧版翻译]
    su "「今天真的是特别的热啊。就好像是这个夏天最热的一天啊。[wds]最高气温到……[rd]"

# game/day 2.rpy:946
translate chinese_simplified river02_6da9eba9:

    # extend "」"
    # [旧版翻译]
    extend "」"

# game/day 2.rpy:948
translate chinese_simplified river02_85b17a37:

    # fn "{cps=0}「Waaah! Don't say it!」"
    # [旧版翻译]
    fn "「哇啊啊啊啊！那不能说啊！」"

# game/day 2.rpy:952
translate chinese_simplified river02_605c07cb:

    # "Shun-kun's confused mouth was tightly held down."
    # [旧版翻译]
    "[fn]匆匆忙忙的压住峻的嘴巴并且紧紧的按住。"

# game/day 2.rpy:953
translate chinese_simplified river02_dc8c7114:

    # fn "「You can't say the temperature, man!{p} If you do, the devil will jump into your body,{p} and he'll change your body temperature!」"
    # [旧版翻译]
    fn "「不行啊峻、最高气温什么的千万不能说啊！那可是恶魔的话语啊！是禁断的咒语喔！？会突然受到足以笼罩全身的高热袭击的唷！」"

# game/day 2.rpy:954
translate chinese_simplified river02_45771f06:

    # fn "「It's a forbidden spell!{p} He'll make it so that you'll never cool down!」"
    # [旧版翻译]
    fn "「不行啊峻、最高气温什么的千万不能说啊！那可是恶魔的话语啊！是禁断的咒语喔！？会突然受到足以笼罩全身的高热袭击的唷！」"

# game/day 2.rpy:955
translate chinese_simplified river02_76788d6e:

    # su "「Mgh, mghhh!」"
    # [旧版翻译]
    su "「唔、呜ー！」"

# game/day 2.rpy:959
translate chinese_simplified river02_154a3c1a:

    # ka "「[fn].」"
    # [旧版翻译]
    ka "「[fn]」"

# game/day 2.rpy:960
translate chinese_simplified river02_038f6f97:

    # fn "「W-what, Kouya?」"
    # [旧版翻译]
    fn "「怎、怎么了洸哉？」"

# game/day 2.rpy:964
translate chinese_simplified river02_b464d990:

    # ka "「With the way you're holding him,\n he won't be able to breathe.」"
    # [旧版翻译]
    ka "「你那种压法、峻会不能呼吸喔。」"

# game/day 2.rpy:965
translate chinese_simplified river02_9add58e8:

    # "He says that with a shocked face.{p}I look at my hands."
    # [旧版翻译]
    "洸哉露出吃惊的表情。[fn]顺着他的目光往下看。"

# game/day 2.rpy:966
translate chinese_simplified river02_6d2f2aff:

    # "My arms are wrapped around Shun-kun's muzzle,{p}with both my hands clasped around his mouth.{p}That was pretty brutal, even for me."
    # [旧版翻译]
    "象是要把峻的吻部紧紧抱住似的伸出双臂、两手直接压在峻的嘴上。自己来说是有点那个，但这样真的很凶恶。"

# game/day 2.rpy:967
translate chinese_simplified river02_9950763e:

    # "Rather than saying I was holding him down,{p}it'd be more accurate to say\nthat I was pinning him beneath me."
    # [旧版翻译]
    "而且，要说是压住嘛，不如说是抱住比较正确吧。"

# game/day 2.rpy:968
translate chinese_simplified river02_b66cb2c8:

    # fn "「Wah! S-sorry, Shun-kun!」"
    # [旧版翻译]
    fn "「呃！？抱、抱歉啊峻！」"

# game/day 2.rpy:969
translate chinese_simplified river02_55f9cc9f:

    # "I let go of the panicking wolf."
    # [旧版翻译]
    "慌慌忙忙的放开了峻。"

# game/day 2.rpy:973
translate chinese_simplified river02_062e5dfb:

    # su "「Bwah!{w} You're so mean, [fn]-san...」"
    # [旧版翻译]
    su "「呼呜！太过分了啦[fn]……」"

# game/day 2.rpy:974
translate chinese_simplified river02_e69f1e7a:

    # "The teary look in Shun-kun's eyes shoot through me.{p}The cicadas couldn't compare to this...{w=.3} it hurt."
    # [旧版翻译]
    "被泛着泪水的峻看着的感觉好痛。连蝉鸣都无法比较的，惨痛。"

# game/day 2.rpy:975
translate chinese_simplified river02_de7ee07e:

    # fn "「I-I'm sorry! I wasn't paying attention...」"
    # [旧版翻译]
    fn "「抱、抱歉。身体自然的就……」"

# game/day 2.rpy:979
translate chinese_simplified river02_534d1616:

    # ka "「Seriously, bro? You were overdoing it...」"
    # [旧版翻译]
    ka "「你那种反应也太异常了吧，怎么回事啊」"

# game/day 2.rpy:980
translate chinese_simplified river02_3883a5a8:

    # "Both of their saddened gazes pierce through me.{p}It feels like I've been stabbed."
    # [旧版翻译]
    "两人的视线加起来，感觉更悲惨了。这种惨痛程度、绝对有着堪比原子弹爆炸的等级。"

# game/day 2.rpy:981
translate chinese_simplified river02_bb34e588:

    # "...Why does this have to be so awkward?"
    # [旧版翻译]
    "――啊啊，该不会现在这里其实有一道墙壁吧？"

# game/day 2.rpy:982
translate chinese_simplified river02_10c5b7fe:

    # fn "「N-not really...{w=.3} I mean... Uhh...{p} Even if hearing about the temperature\n doesn't actually make things hotter...」"
    # [旧版翻译]
    fn "「不、不是啦。要是去看最高气温有几度的话，虽然气温其实没变高，但不会觉得感觉上好像变热了吗？会吧会吧？」"

# game/day 2.rpy:983
translate chinese_simplified river02_cc025a4b:

    # fn "「I think... It'd make things feel like that.{p} R-right?」"
    # [旧版翻译]
    fn "「不、不是啦。要是去看最高气温有几度的话，虽然气温其实没变高，但不会觉得感觉上好像变热了吗？会吧会吧？」"

# game/day 2.rpy:984
translate chinese_simplified river02_eb9c73b7:

    # "I make an attempt to fix the situation quickly."
    # [旧版翻译]
    "眼前彷彿出现柏林围墙般，[fn]拼命地想要把墙拆掉，拉近[fn]们之间的距离。"

# game/day 2.rpy:985
translate chinese_simplified river02_3d142ec0:

    # fn "「I was trying to avoid the topic...{p} but I guess I got a little too worked up about it.{p} That's what I'm saying...」"
    # [旧版翻译]
    fn "「所以说会不想听到或看到今天的最高气温，那是身体的自然反应啦。是这样子的啦。」"

# game/day 2.rpy:986
translate chinese_simplified river02_05aa9eb2:

    # "The explanation doesn't seem to better the situation.{p}Their cold looks seem to strengthen."
    # [旧版翻译]
    "[fn]越是试着解释，他们的视线也变得越来越冷。"

# game/day 2.rpy:987
translate chinese_simplified river02_7b4367e5:

    # "That seems to be the only thing\ncooling me down right now.{p}Crap, I'm breaking out into a cold sweat."
    # [旧版翻译]
    "被讨厌了。明显是被讨厌了。咦，什么时候突然变得这么冷的？糟糕，好像开始流起冷汗了。"

# game/day 2.rpy:988
translate chinese_simplified river02_316e8551:

    # fn "「Ugh... Yes... This was all my fault.{p} I-I'm sorry...!」"
    # [旧版翻译]
    fn "「抱歉，全部都是我的不好。真的很对不起……」"

# game/day 2.rpy:992
translate chinese_simplified river02_7d3ee965:

    # ka "「Uhh... what?」"
    # [旧版翻译]
    ka "「我不是不知道你的感觉啦……」"

# game/day 2.rpy:993
translate chinese_simplified river02_1ccc0a96:

    # "He stares at me like I'm some kind of alien.{p}Those eyes of his are telling me I've gone overboard."
    # [旧版翻译]
    "但那双眼睛告诉我，你做的太过火了。"

# game/day 2.rpy:994
translate chinese_simplified river02_f16bef72:

    # "I think so too..."
    # [旧版翻译]
    "嘛……[fn]也是这么认为。"

# game/day 2.rpy:1000
translate chinese_simplified river02_04403c34:

    # su "「Oh well, let's cool down all together!」"
    # [旧版翻译]
    su "「算了啦，[fn]也一起来这边乘凉吧?」"

# game/day 2.rpy:1001
translate chinese_simplified river02_2a43ab6c:

    # "Shun-kun called out to me in his usual self.{p}This time, I'm tearing up from the kindness."
    # [旧版翻译]
    "不知道什么时候心情已经恢复了的峻正在叫我过去。这份温柔，真的是让[fn]好感动啊。"

# game/day 2.rpy:1002
translate chinese_simplified river02_601f2a4a:

    # "Oh, friendship, it's such a miracle..."
    # [旧版翻译]
    "啊啊，多么美妙的友情……！"

# game/day 2.rpy:1003
translate chinese_simplified river02_c5005ff0:

    # "I accept the offer, and into the water I go.{p}{nw}"
    # [旧版翻译]
    "顺着峻的意思、[fn]也脱掉鞋袜把脚放进水里。"

# game/day 2.rpy:1005
translate chinese_simplified river02_47b4f71c:

    # extend "A cool feeling spreads from my legs up to my body.{p}Exactly what I've been looking for all day..."
    # [旧版翻译]
    extend "清冽的感觉慢慢地从脚底蔓延到全身。"

# game/day 2.rpy:1006
translate chinese_simplified river02_840a6afb:

    # "And then, somehow, I feel at peace."
    # [旧版翻译]
    "总觉得、冷静了下来。"

# game/day 2.rpy:1007
translate chinese_simplified river02_1aa9f2d7:

    # fn "「Hey, now that I think about it,{p} you guys didn't hang out a lot before.{p} How did you guys get to be such good friends?」"
    # [旧版翻译]
    fn "「话说回来，你们会一起出来玩还挺难得的耶，感觉平常大家都是找感情好的人一起行动的不是吗？」"

# game/day 2.rpy:1008
translate chinese_simplified river02_5029ef57:

    # "I voice the thought in my head out loud."
    # [旧版翻译]
    "[fn]把想到的事情说了出来。"

# game/day 2.rpy:1009
translate chinese_simplified river02_7d0307ac:

    # "As far as I can remember,{p}Shun and Kouya weren't this close."
    # [旧版翻译]
    "[fn]所还记得的记忆里、并没有洸哉和峻很要好的印象。"

# game/day 2.rpy:1010
translate chinese_simplified river02_7b2dda4c:

    # "But when Kouya can even understand,{p}Shun's muffled words, that's the feeling I get."
    # [旧版翻译]
    "但是，看到了洸哉竟然能翻译峻的「姆咕――」的样子，就觉得他们之间好像特别亲密。"

# game/day 2.rpy:1011
translate chinese_simplified river02_4778cac6:

    # "When I was gone,{p}was there some kind of event\nthat brought them closer together?"
    # [旧版翻译]
    "在[fn]离开之后的这段时间里、是发生了什么事情让他们变亲密了吗？"

# game/day 2.rpy:1015
translate chinese_simplified river02_f270cd3c:

    # ka "「Ehh, it's complicated, I can't really explain it.{p} Shun knows more about it than I do...{p} B-but it's not like we came here together...」"
    # [旧版翻译]
    ka "「啊――你在意的点还挺怪的耶。确实我是比较常跟其他人聊天，但也不代表我们不能一起出来玩吧。」"

# game/day 2.rpy:1019
translate chinese_simplified river02_993ff40a:

    # ka "「U-uhh... right?」"
    # [旧版翻译]
    ka "「对吧？」"

# game/day 2.rpy:1020
translate chinese_simplified river02_75296173:

    # "Kouya nudges Shun for a response."
    # [旧版翻译]
    "洸哉这么说着，微笑了起来。"

# game/day 2.rpy:1024
translate chinese_simplified river02_dfccaf2d:

    # su "「Th-that's true!{w} I do remember something but...\n the reason why we're so close{cps=10}...\n {nw}"
    # [旧版翻译]
    su "「是啊ー。虽然是很常聊天没错啦，但要说到特别要好的话[wdt][wdm]――[rd]"

# game/day 2.rpy:1026
translate chinese_simplified river02_ed28882b:

    # extend "{cps=40}I don't really get it...」"
    # [旧版翻译]
    extend "我不知道啦ー」"

# game/day 2.rpy:1028
translate chinese_simplified river02_11a50163:

    # "Shun-kun blushes a bit as he says that."
    # [旧版翻译]
    "峻说着突然地有点脸红了起来。"

# game/day 2.rpy:1029
translate chinese_simplified river02_304eef33:

    # "But...{w=.3} Why is he blushing?"
    # [旧版翻译]
    "不过为什么脸红啊？"

# game/day 2.rpy:1033
translate chinese_simplified river02_414fc8ec:

    # ka "「Welp, that's the story for today.」"
    # [旧版翻译]
    ka "「哎，这话我只在这边说，但这只是我们恰巧想到同一件事情而已喔。」"

# game/day 2.rpy:1034
translate chinese_simplified river02_7af53c16:

    # fn "「Hmm, is that so?」"
    # [旧版翻译]
    fn "「哼嗯――是这样啊。」"

# game/day 2.rpy:1038
translate chinese_simplified river02_dc02fe09:

    # ka "「Yeah, it is.」"
    # [旧版翻译]
    ka "「就是这样。」"

# game/day 2.rpy:1043
translate chinese_simplified river02_93eab413:

    # "After he finished speaking,{p}Kouya crashes into the water, with his backside up."
    # [旧版翻译]
    "洸哉说完之后往身后躺去。"

# game/day 2.rpy:1044
translate chinese_simplified river02_3b3d99df:

    # "Shun-kun and I exchange glances,{p}and then, with smiles on our faces, follow suit."
    # [旧版翻译]
    "[fn]和峻同时转头相视微笑了一下、接着像洸哉那样躺了下来。"

# game/day 2.rpy:1049
translate chinese_simplified river02_6ddfc43d:

    # "The world above spread out in front of my eyes.{p}A piercing blue sky, with soft looking clouds."
    # [旧版翻译]
    "映入眼前的是一望无际的世界。无比清澈的青空，伴随着几朵白色的软云，是片非常漂亮的景色。"

# game/day 2.rpy:1050
translate chinese_simplified river02_2cd07a7c:

    # "The murmur of the river, the sound of the wind,{p}and the voices of the insects and birds.{p}They all harmonized into a natural anthem."
    # [旧版翻译]
    "身旁的流水潺潺、混杂着些许风声、虫鸣、以及不甘示弱的鸟鸣所融进这乐章之中，充分展现出村子的活力。"

# game/day 2.rpy:1051
translate chinese_simplified river02_46b6e836:

    # "It was impossible to find this kind of serenity in\nthe crowded city. It was like I was in another world.{p}This was what I missed about the country."
    # [旧版翻译]
    "这自然所交织而成的乐音和美景，深深地刻进了[fn]内心的深处。"

# game/day 2.rpy:1052
translate chinese_simplified river02_f7cdd5f6:

    # "The three of us lay there in silence,{p}but it didn't feel strange or awkward."
    # [旧版翻译]
    "[fn]们三人就这样无言地沉浸在这景色之中，很不可思议地，这份静默并没有让[fn]们感到尴尬。"

# game/day 2.rpy:1053
translate chinese_simplified river02_4cb92d86:

    # "Instead..."
    # [旧版翻译]
    "不如说，"

# game/day 2.rpy:1054
translate chinese_simplified river02_a9c37d88:

    # fn "「Maaan... this is great...」"
    # [旧版翻译]
    fn "「真好呢、就像这样……」"

# game/day 2.rpy:1055
translate chinese_simplified river02_377b0222:

    # "I murmur quietly."
    # [旧版翻译]
    "[fn]自言自语。"

# game/day 2.rpy:1056
translate chinese_simplified river02_fad35236:

    # "Being away from nature so long...{p}for me especially, this was refreshing."
    # [旧版翻译]
    "这是在都市没办法看见的光景、对[fn]来说还是很新鲜的。"

# game/day 2.rpy:1057
translate chinese_simplified river02_85c00937:

    # ka "「Can't get this where you live, eh, City-Boy?」"
    # [旧版翻译]
    ka "「在都市肯定不会做这种事对吧。」"

# game/day 2.rpy:1058
translate chinese_simplified river02_ba661672:

    # "Kouya spoke as though he could read my mind."
    # [旧版翻译]
    "象是读出了[fn]的内心一样，洸哉开口说道。"

# game/day 2.rpy:1059
translate chinese_simplified river02_6dd7a88c:

    # ka "「But don't you think this is awesome too?」"
    # [旧版翻译]
    ka "「但是，这样也不错对吧？」"

# game/day 2.rpy:1060
translate chinese_simplified river02_ae93d568:

    # "With a wry smile, I could sense him silently agreeing."
    # [旧版翻译]
    "嘛，虽然[fn]什么都还没说。洸哉苦笑了一下。但是所说的事就是这样。"

# game/day 2.rpy:1061
translate chinese_simplified river02_3c567b77:

    # fn "「Yeah... it really is...」"
    # [旧版翻译]
    fn "「嗯……是啊」"

# game/day 2.rpy:1062
translate chinese_simplified river02_30e30d34:

    # "I honestly concur."
    # [旧版翻译]
    "这点[fn]完全同意。"

# game/day 2.rpy:1063
translate chinese_simplified river02_0b59a4ba:

    # "Next to me, Shun-kun nods his head."
    # [旧版翻译]
    "峻也在旁边点点头。"

# game/day 2.rpy:1064
translate chinese_simplified river02_a5d07051:

    # "I'm having a lot of fun being back here again,{p}but something like this... taking in the nature...{p}it's a different kind of enjoyment."
    # [旧版翻译]
    "即使是在村子里，对现在的[fn]来说也有许多有趣的事。但是，就这样躺在河堤上什么也不做，也别有一番风味。"

# game/day 2.rpy:1065
translate chinese_simplified river02_1af652f5:

    # "But no matter what kind of experience it is,{p}it's always enjoyable."
    # [旧版翻译]
    "不过不管是哪一种，都让[fn]觉得心旷神怡。"

# game/day 2.rpy:1066
translate chinese_simplified river02_05805cf2:

    # "Maybe everyone else feels the same."
