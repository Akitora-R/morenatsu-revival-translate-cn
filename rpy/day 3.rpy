# game/day 3.rpy:619
translate chinese_simplified candy03_shin_18831539:

    # "How was it back then?{p}No wait, back then,\nShin-kun was even more reserved."
    # [旧版翻译] 来源: 深_s_01.ks (KS 624)
    "以前他们也是这样吗？"

# game/day 3.rpy:620
translate chinese_simplified candy03_shin_aa7dabb6:

    # "And he probably never had many settings\nwhere he talked with people."
    # [旧版翻译] 来源: 深_s_01.ks (KS 625)
    "不，以前深君比现在还要客气，"

# game/day 3.rpy:624
translate chinese_simplified candy03_shin_ce917278:

    # si "「I probably should have had a bit more grace.」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 632)
    si "「我要是能更懂得如何配合别人就好了。」"

# game/day 3.rpy:625
translate chinese_simplified candy03_shin_cd54e7d8:

    # fn "「No I think you're good there.」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 635)
    fn "「不，没这回事啦。」"

# game/day 3.rpy:626
translate chinese_simplified candy03_shin_42d37f94:

    # "I thought Shin-kun was the type to not consider others,\nbut he's surprisingly bothered by it."
    # [旧版翻译] 来源: 深_s_01.ks (KS 637)
    "以为深君是不太会在意其他人的类型，"

# game/day 3.rpy:627
translate chinese_simplified candy03_shin_756e4d69:

    # fn "「Oh, that aside, what did you buy?」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 641)
    fn "「啊，说起来，你买了哪些零食？」"

# game/day 3.rpy:631
translate chinese_simplified candy03_shin_43b4c73a:

    # si "「This.」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 647)
    si "「这些。」"

# game/day 3.rpy:632
translate chinese_simplified candy03_shin_d237a584:

    # "5 yen chocolate, cotton candy, starch syrup...\nIt really clashes with his stylish dress,\nhe has a bag stuffed full of cheap candies."
    # [旧版翻译] 来源: 深_s_01.ks (KS 649)
    "金币巧克力、绵花糖、麦芽糖……"

# game/day 3.rpy:636
translate chinese_simplified candy03_shin_f0bdfd5a:

    # si "「Want to have some while we walk?」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 657)
    si "「要不要一起吃，我们边走边聊？」"

# game/day 3.rpy:637
translate chinese_simplified candy03_shin_7ddc8694:

    # fn "「Huh? Is that okay?」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 660)
    fn "「诶？ 可以吗？」"

# game/day 3.rpy:638
translate chinese_simplified candy03_shin_47a29eff:

    # si "「Go ahead.」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 663)
    si "「请吧。」"

# game/day 3.rpy:639
translate chinese_simplified candy03_shin_f05ef085:

    # fn "「Thanks. Then I'll pick...」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 666)
    fn "「谢谢。嗯，那[漏れ]要这个[ch text=──]」"

# game/day 3.rpy:640
translate chinese_simplified candy03_shin_a160a5fd:

    # "Oh,{w=.3} yeah,{w=.3} huh,{w=.3} often times when we were all heading\nback, we'd share candy while walking like this.\nEven if we knew we'd get yelled at if found out."
    # [旧版翻译] 来源: 深_s_01.ks (KS 668)
    "对了对了，以前在放学的路上，"

# game/day 3.rpy:641
translate chinese_simplified candy03_shin_99a7216e:

    # "...{p}Wait, what?{p}But Shin-kun..."
    # [旧版翻译] 来源: 深_s_01.ks (KS 672)
    "……"

# game/day 3.rpy:642
translate chinese_simplified candy03_shin_bef95801_1:

    # si "「...」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 677)
    si "「……」"

# game/day 3.rpy:643
translate chinese_simplified candy03_shin_65531524:

    # "I looked at the profile of the one\nwalking along licking at the syrup.\nShin-kun didn't even do this back then though..."
    # [旧版翻译] 来源: 深_s_01.ks (KS 680)
    "深君以前明明是绝对不会在路上买东西吃的……"

# game/day 3.rpy:644
translate chinese_simplified candy03_shin_9d50412b:

    # si "「This is nice...」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 683)
    si "「真好吃呢。」"

# game/day 3.rpy:645
translate chinese_simplified candy03_shin_74bfdb43:

    # fn "「Y-yeah.」"
    # [旧版翻译] 来源: 深_s_01.ks (KS 686)
    fn "「嗯、嗯。」"

# game/day 3.rpy:646
translate chinese_simplified candy03_shin_6ad0d053:

    # "Could it be that he's always wanted to do this?"
    # [旧版翻译] 来源: 深_s_01.ks (KS 688)
    "该不会，他其实一直很想这么做吧？"

# game/day 3.rpy:647
translate chinese_simplified candy03_shin_0db0d8ca:

    # "As I saw that wide natural smile coming on that face,\nI felt like I glimpsed at the feelings\nof my moody childhood friend."
    # [旧版翻译] 来源: 深_s_01.ks (KS 689)
    "侧眼看着他放松的表情，[漏れ]总觉得有种"

# game/day 3.rpy:668
translate chinese_simplified shun03_1e7fcc8c:

    # su "「Uu......Unyu......」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 116)
    su "「呜……呜呜……」"

# game/day 3.rpy:670
translate chinese_simplified shun03_6c019e60:

    # "N-no!{p}I didn't mean to make you cry!{p}Aaah, if this keeps up I'll definitely..."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 118)
    "不、不是的！"

# game/day 3.rpy:675
translate chinese_simplified shun03_0724fb45:

    # "This story goes back to around noon."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 135)
    "这个故事要从午后说起。"

# game/day 3.rpy:680
translate chinese_simplified shun03_aaa2534e:

    # fn "「Ugh...」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 147)
    fn "「呃……」"

# game/day 3.rpy:681
translate chinese_simplified shun03_da0889f5:

    # "On the unpaved road, waves of heat rise up."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 149)
    "在没有铺过的小路上，一波波热浪升起。"

# game/day 3.rpy:682
translate chinese_simplified shun03_91edac77:

    # "I haven't been to my hometown for so long,\nI didn't take this into consideration\nfrom being so used to living in the city."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 150)
    "在习惯了城市的生活之后，[漏れ]都没有注意到，"

# game/day 3.rpy:683
translate chinese_simplified shun03_c68e921f:

    # "I'm only here for a month.\nUnlike my usual summer vacations,\nI won't waste it lying around!"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 153)
    "在这里只有1个月的时间，[漏れ]不能像以往的暑假一样，"

# game/day 3.rpy:684
translate chinese_simplified shun03_52f6d528:

    # "So I gathered my strength,{p}and used up my luck to head out just past noon."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 155)
    "所以[漏れ]拿出了气势和用尽的运气在午后踏出了家门。"

# game/day 3.rpy:685
translate chinese_simplified shun03_cef1dbfb:

    # "The endless blue sky.{p}From the thunderheads to the sunflowers,\nand the voices of the cicadas."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 157)
    "一眼望不到边的蓝天、积雨云和向日葵，还有蝉鸣声。"

# game/day 3.rpy:686
translate chinese_simplified shun03_053dad99:

    # "Even though I'm receiving this warm reception\nfrom the sun in the height of summer,\nmy awareness is only half there."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 158)
    "在接受了盛夏烈日的盛情款待之后，"

# game/day 3.rpy:687
translate chinese_simplified shun03_e1b67c42:

    # fn "「It's so hot...」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 162)
    fn "「真热啊……」"

# game/day 3.rpy:688
translate chinese_simplified shun03_45ed0324:

    # "Not only is my shirt soaking with sweat,{p}even down to my socks are too."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 164)
    "不仅是衬衫被汗浸湿，连袜子都粘粘糊糊了。"

# game/day 3.rpy:689
translate chinese_simplified shun03_d9961a0f:

    # "I didn't bring a hat and a towel.{p}I already want to go back."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 165)
    "连帽子和毛巾都没带来啊。"

# game/day 3.rpy:690
translate chinese_simplified shun03_ef8ac8c2:

    # "Huh? Somebody's running up from over there?{p}In this heat?"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 168)
    "呃，对面有谁跑过来了？"

# game/day 3.rpy:694
translate chinese_simplified shun03_31ce83cc:

    # su "「[fn]-saaan♪」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 175)
    su "「[博行]桑～」"

# game/day 3.rpy:695
translate chinese_simplified shun03_70b5e13b:

    # fn "「Aah. Shun-ku-, oof.」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 178)
    fn "「啊、是峻、呐。」"

# game/day 3.rpy:700
translate chinese_simplified shun03_41f87fc9:

    # su "「Hehee♪{w=.3} [fn]-san.」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 187)
    su "「嘿嘿，　[博行]桑～」"

# game/day 3.rpy:701
translate chinese_simplified shun03_1c613425:

    # "It's hot."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 189)
    "好热。"

# game/day 3.rpy:702
translate chinese_simplified shun03_785ab368:

    # "With an appearance that could be mistaken\nfor a child, my childhood friend,{w} tail wagging\nback and forth,{w} mercilessly clings to me."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 190)
    "摇着尾巴黏上来的是[漏れ]的幼驯染，"

# game/day 3.rpy:706
translate chinese_simplified shun03_a1fae1cd:

    # su "「Good afternoon♪」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 198)
    su "「下午好！」"

# game/day 3.rpy:707
translate chinese_simplified shun03_25d0baa4:

    # "Yeah, good afternoon.{w} I can't return his greeting\nas a higher body temperature is being transmitted\nfrom his tiny body, and is gradually heating me up."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 200)
    "是，下午好。连给[漏れ]这样回答的余地都没有，"

# game/day 3.rpy:708
translate chinese_simplified shun03_71c7854b:

    # "I-{w=.3}I'm being embraced by a beastman!{p}Except my patience to itch is unbearable."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 205)
    "这样子还要忍耐住不断上涨的兴奋感的话，"

# game/day 3.rpy:709
translate chinese_simplified shun03_38fcf626:

    # "I come to understand that this is limited to\na well air-conditioned environment."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 206)
    "据[漏れ]所知只有在良好的空调环境下。"

# game/day 3.rpy:710
translate chinese_simplified shun03_b9ebefe8:

    # "Fuaah, my brain seems to have become shoronpo.{p}His arms and muzzle are concealed in fur,{p}now I'm thinking of other cute things..."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 208)
    "哈啊啊、脑子似乎变得像小笼包一样。"

# game/day 3.rpy:714
translate chinese_simplified shun03_a0cf9a91:

    # su "「?{w=.3} [fn]-san?」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 216)
    su "「？　[博行]桑？」"

# game/day 3.rpy:715
translate chinese_simplified shun03_9f7b97a0:

    # fn "「Oh, uhh, good afternoon.」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 219)
    fn "「啊、啊、你好啊。」"

# game/day 3.rpy:716
translate chinese_simplified shun03_5b454e52:

    # "...But he is cute.{p}He anxiously looks up at me with his acorn eyes."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 221)
    "……峻用橡色的眼睛担心地看着[漏れ]。"

# game/day 3.rpy:717
translate chinese_simplified shun03_780cd1ba:

    # "When my moderately steamed brain\nis about to state its cheap thoughts,{p}Shun-kun releases me."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 224)
    "正当[漏れ]用如同被蒸过的大脑述说着简单感想的时，"

# game/day 3.rpy:723
translate chinese_simplified shun03_c202cfca:

    # su "「[fn]-san, are you out for a walk?」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 237)
    su "「[博行]桑是在散步吗？」"

# game/day 3.rpy:724
translate chinese_simplified shun03_8cd47c3e:

    # fn "「Yeah, I ended up here.{p} I'm going back soon though.」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 240)
    fn "「嗯，我是出来散步啦。"

# game/day 3.rpy:728
translate chinese_simplified shun03_27b4ca42:

    # su "「What!? Let's go play together!」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 245)
    su "「诶？和我一起去玩嘛！」"

# game/day 3.rpy:729
translate chinese_simplified shun03_9982ed45:

    # "My arm is being pulled."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 247)
    "峻把[漏れ]的手臂拉住了。"

# game/day 3.rpy:730
translate chinese_simplified shun03_896d6ccb:

    # "This cute, one-year-below-me wolf\nis getting all fired up,\ndespite the direct rays of the sun."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 248)
    "这个可爱的、比[漏れ]小一岁的狼人，"

# game/day 3.rpy:734
translate chinese_simplified shun03_152e4e03:

    # su "「So, [fn]-san?」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 255)
    su "「[博行]桑、呐？」"

# game/day 3.rpy:735
translate chinese_simplified shun03_20d27139:

    # "Guh, his whole face dazzles greater than the sun."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 259)
    "好像因为在这里遇到[漏れ]很高兴。"

# game/day 3.rpy:736
translate chinese_simplified shun03_c8994386:

    # "From the bottom of his heart,\nhe seems to be happy that he ran into me.{p}Shun-kun repeatedly invites me to go somewhere."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 260)
    "峻啾地露出不输给太阳的耀眼笑容，"

# game/day 3.rpy:740
translate chinese_simplified shun03_875b558a:

    # "The antenna above his head, possibly a feeler,{p}nowadays called an ahoge, shakes."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 265)
    "头上的天线，或是叫做触角，"

# game/day 3.rpy:741
translate chinese_simplified shun03_b6535d9f:

    # "Is that him expressing his joy\nof picking up my signal?"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 268)
    "这是在表现见到[漏れ]的喜悦吗？"

# game/day 3.rpy:742
translate chinese_simplified shun03_5fed7ac5:

    # "Or is it just blowing in the wind?{p}Maybe it was a hallucination."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 269)
    "还是说是被风吹的呢？"

# game/day 3.rpy:743
translate chinese_simplified shun03_ccb671ec:

    # "If I were ever to take him to an amusement park he\nwould have to promise to shake his ahoge and tail."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 272)
    "如果带他去游乐园的话，"

# game/day 3.rpy:747
translate chinese_simplified shun03_d3cebc32:

    # "Besides that, he's short too.{p}He hasn't stopped growing,{w=.3} has he?"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 278)
    "话说回来他还是那么矮。是停止成长了吗？"

# game/day 3.rpy:748
translate chinese_simplified shun03_35cef5a7:

    # "Is he eating right?"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 280)
    "有好好的吃东西吗？"

# game/day 3.rpy:749
translate chinese_simplified shun03_67db7169:

    # "Isn't it bad for him if he's just\neating things like noodles?{p}Properly adding blanched meat and sashimi..."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 281)
    "只吃素面的话对身体成长不好啊。"

# game/day 3.rpy:750
translate chinese_simplified shun03_b8c6f30b:

    # su "「[fn]-san?」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 285)
    su "「[博行]桑？」"

# game/day 3.rpy:751
translate chinese_simplified shun03_26e546c0:

    # "Delirious with heat,{w=.3}\nmy thoughts completely change to the trip scene."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 287)
    "被酷热弄得意乱神迷的[漏れ]完全陷入了不着边际的思考。"

# game/day 3.rpy:752
translate chinese_simplified shun03_66aebdcc:

    # "Around the time I'm about to check his\neating habits, {w=.3}he calls out my name a second time."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 288)
    "正当[漏れ]考虑峻的饮食习惯时，"

# game/day 3.rpy:753
translate chinese_simplified shun03_fd9d6358:

    # su "「Is it cooler out here than it is at home?」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 294)
    su "「在外面比家里凉快吗？」"

# game/day 3.rpy:754
translate chinese_simplified shun03_c27ca488:

    # "Dazedly ignoring him,\nI think about the wind of the air conditioner.{p}Anyways, rather than having gone out..."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 296)
    "是呢，喫茶店啦便利店啦神马的非常凉爽呢。"

# game/day 3.rpy:758
translate chinese_simplified shun03_c383fcc0:

    # su "「I know! {w=.3} How about we go to the river?」"
    # [旧版翻译] 来源: 峻_m_01.ks (KS 308)
    su "「对了！　河边，一起去吧？」"

# game/day 3.rpy:759
translate chinese_simplified shun03_ce875465:

    # "River?{p}He said the river... oh, that's right."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 310)
    "河？"

# game/day 3.rpy:764
translate chinese_simplified shun03_5b3e1566:

    # "There's one here in Minasato.{p}Suddenly, memories from my childhood come to mind."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 327)
    "这里是，水乡村呢。"

# game/day 3.rpy:765
translate chinese_simplified shun03_db523f1f:

    # "The nostalgic, light sound of the stream."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 328)
    "突然间，年幼时的记忆流淌而出。"

# game/day 3.rpy:766
translate chinese_simplified shun03_f6090272:

    # "I know what he means now,\nnot the stagnated water of the city."
    # [旧版翻译] 来源: 峻_m_01.ks (KS 329)
