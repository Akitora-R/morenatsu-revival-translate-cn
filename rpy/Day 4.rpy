# game/Day 4.rpy:1436
translate chinese_simplified juuichi04_ece94e5f:

    # boy "「Ahaha.{p} {nw}"
    # [旧版翻译]
    boy "「啊哈哈。{p}{nw}"

# game/Day 4.rpy:1438
translate chinese_simplified juuichi04_b49e9eb4:

