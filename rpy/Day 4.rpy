# game/Day 4.rpy:1487
translate chinese_simplified juuichi04_rideback_13f24952:

    # fn "「Seems like it...」"
    # [旧版翻译]
    fn "「好像是这样……」"

# game/Day 4.rpy:1491
translate chinese_simplified juuichi04_rideback_4e341d57:

    # ju "「...You're hopless.」"
    # [旧版翻译]
    ju "「……真是的。」"

# game/Day 4.rpy:1495
