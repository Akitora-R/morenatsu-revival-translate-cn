    ju "「……？{w=.3}奇怪的家伙。\n哎算了。」"

# game/Day 4.rpy:1479
translate chinese_simplified juuichi04_rideback_3fea9dae:

    # ju "「...If you sit on the grass like that for too long,\n your pants are going to be soaked with dew.」"
    ju "「……好啦，{w=.3}一直那样坐在草地上，\n露水会把裤子弄湿的。」"

# game/Day 4.rpy:1480
translate chinese_simplified juuichi04_rideback_24a2ea2c:

    # "Saying that,{w=.3} he offers me his hand.{p}I grab it, and he pulls me upright."
    "说完后，{w=.3}柔一对着我伸出了手。\n我握住柔一的手，{w=.3}\n在有些倾斜的地面上奋力想要站起。"

# game/Day 4.rpy:1481
translate chinese_simplified juuichi04_rideback_fff12769:

    # fn "「...Huh?」"
    # [旧版翻译]
    fn "「……咦？」"

