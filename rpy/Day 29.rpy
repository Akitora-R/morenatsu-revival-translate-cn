# game/Day 29.rpy:2283
translate chinese_simplified kouya29_587d5458:

    # ka "「...」"
    ka ""

# game/Day 29.rpy:2284
translate chinese_simplified kouya29_ee889091:

    # "The combined weight of these feelings gave me pause."
