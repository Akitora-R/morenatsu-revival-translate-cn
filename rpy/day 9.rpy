# game/day 9.rpy:1886
translate chinese_simplified shin09_shout_2ca802c5:

    # fn "「Shin-kun! Shin-kun!」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 1123)
    fn "【主人公】「深君！　深君！」"

