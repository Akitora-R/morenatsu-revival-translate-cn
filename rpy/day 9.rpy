    # [旧版翻译] 来源: 峻_s_07.ks (KS 153)
    extend "extend \"金色涂装相当的魄力。\""

# game/day 9.rpy:965
translate chinese_simplified shun09_60e81ed1:

    # fn "「When you said there were things connected to it,\n I imagined things like a gun controller or a mouse\n connected to a relatively smaller machine.」"
    # [旧版翻译] 来源: 峻_s_07.ks (KS 155)
    fn "【fn】「跟游戏机连在一起的那些东西，{p}是枪型的遥控器啦，鼠标啦，{p}还有其他的小机器，是这样子吧。」"

# game/day 9.rpy:966
translate chinese_simplified shun09_9862d266:

    # su "「Like this?」"
    # [旧版翻译] 来源: 峻_s_07.ks (KS 161)
    su "【su】「是指这个吗？」"

# game/day 9.rpy:967
translate chinese_simplified shun09_b96cfcf3:

    # "Shun-kun takes out a mouse with blue buttons."
    # [旧版翻译] 来源: 峻_s_07.ks (KS 163)
    "峻君拿出一个蓝色按钮的鼠标。"

# game/day 9.rpy:968
translate chinese_simplified shun09_f2957479:

    # fn "「Yeah, needed for something like drawing software,\n or a miniature garden simulator.」"
    # [旧版翻译] 来源: 峻_s_07.ks (KS 165)
    fn "【fn】「对对，像是画画的软件啊，{p}或是迷你世界模型的游戏会需要的对吧。」"

# game/day 9.rpy:972
translate chinese_simplified shun09_d53c38cf:

    # su "「It can also be used turned upside down.」"
    # [旧版翻译] 来源: 峻_s_07.ks (KS 172)
    su "【su】「反过来也能用。」"

# game/day 9.rpy:973
translate chinese_simplified shun09_b03ca5e8:

    # fn "「!{w=.3} It, it changed into a trackball!」"
    # [旧版翻译] 来源: 峻_s_07.ks (KS 176)
    fn "【fn】！「{w=.3}　变、变成轨迹球了啊！」"

# game/day 9.rpy:974
translate chinese_simplified shun09_d3c2cc1a:

    # "Now then,{w} after thoroughly enjoying the\ngame space in Shun-kun's house for a while,\nI sit myself down."
    # [旧版翻译] 来源: 峻_s_07.ks (KS 178)
    "好了。{w}稍微逛了一下峻君家中的游戏空间后，{p}两个人坐了下来。"

# game/day 9.rpy:975
translate chinese_simplified shun09_bc0650ec:

    # "Well, every little thing must be inserted\ninto the source of the electricity\njust so we can have fun."
    # [旧版翻译] 来源: 峻_s_07.ks (KS 182)
    "哎呀，只是单单地把电源打开{p}就很快乐了啊。"

# game/day 9.rpy:979
translate chinese_simplified shun09_15c0e480:

    # su "「[fn]-san, which game should we play?」"
    # [旧版翻译] 来源: 峻_s_07.ks (KS 188)
    su "【su】「[fn]-san，是要一起玩什么样的游戏呢？」"

# game/day 9.rpy:995
translate chinese_simplified shun09_fighting_0508ef23:

    # su "「Well then, I'll call Torahiko-san too.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 219)
    su "【su】「那么，把虎彦一起叫来吧。」"

# game/day 9.rpy:996
translate chinese_simplified shun09_fighting_e9adcc85:

    # fn "「Torahiko? He likes fighting games?」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 221)
    fn "【fn】「虎彦？他喜欢格斗游戏吗？」"

# game/day 9.rpy:1000
translate chinese_simplified shun09_fighting_2a8b256f:

    # su "「Yeah. He wanted me to call him\n the next time I play one.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 226)
    su "【su】「是啊。下次玩格斗游戏时希望一定要叫他一起来。」"

# game/day 9.rpy:1017
translate chinese_simplified shun09_fighting_e8db4398:

    # to "「Heheheh, I've come to get payback\n for the other day!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 260)
    to "【to】「嘿嘿嘿，前几天的那些一次还给你啦！」"

# game/day 9.rpy:1021
translate chinese_simplified shun09_fighting_aa2c2a5a:

    # su "「I accept your challenge!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 264)
    su "【su】「我接受挑战！」"

# game/day 9.rpy:1022
translate chinese_simplified shun09_fighting_2d7a9001:

    # "Shun-kun must have done beyond repairable damage\nto him last time, so he's probably chomping\nat the bit for revenge."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 267)
    "应该是在之前，输给峻君输得很惨，一直等待着复仇的时候吧。"

# game/day 9.rpy:1023
translate chinese_simplified shun09_fighting_65f1f634:

    # "With one phone call, a tiger dripping\nwith rain immediately appeared."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 269)
    "只拨了一通电话，被雨淋湿的虎人立刻就出现了。"

# game/day 9.rpy:1027
translate chinese_simplified shun09_fighting_0e5a0086:

    # "He wipes his head dry with a borrowed bath towel,{p}{nw}"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 271)
    "借了浴巾把头给擦干后，{p}{nw}"

# game/day 9.rpy:1030
translate chinese_simplified shun09_fighting_e7ca8d33:

    # extend "then sits with a thump on the 2nd player's side."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 274)
    extend "然后就扑通一声坐到了2P的位子。"

# game/day 9.rpy:1031
translate chinese_simplified shun09_fighting_ed73324b:

    # "There is a controller with 6 buttons and a stick,\nmodeled after the ones in arcades."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 276)
    "虎彦似乎很爱用的，那种有如游乐中心的游戏机台面板上六个按钮跟摇杆的控制器，"

# game/day 9.rpy:1032
translate chinese_simplified shun09_fighting_a17dbefb:

    # "It seems to be Torahiko's favorite.\nShun-kun probably has it prepared\nwhenever he comes over."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 278)
    "峻君在每次虎彦来时都会准备。"

# game/day 9.rpy:1038
translate chinese_simplified shun09_fighting_8864aba0:

    # to "「UOOOOOOH!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 289)
    to "【to】「呜喔喔喔喔！」"

# game/day 9.rpy:1039
translate chinese_simplified shun09_fighting_8bd97340:

    # su "「...」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 292)
    su "【su】「……」"

# game/day 9.rpy:1040
translate chinese_simplified shun09_fighting_530140f4:

    # "Torahiko's play style is to excitedly yell\nwhile mashing the buttons.{w} In stark contrast,\nShun-kun follows the screen in silence."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 295)
    "一边豪迈地大叫，一边压下控制器按钮的就是虎彦的游戏方式。跟完全不讲一句话看着屏幕的峻君形成鲜明的对比。"

# game/day 9.rpy:1041
translate chinese_simplified shun09_fighting_cc0d95eb:

    # "A military-style character with huge muscles,{p}and a petite, oriental martial artist.{p}Their selections are projections of their appearances."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 299)
    "身材壮硕有军队风格的角色，与身材娇小有着东方风格的格斗家。就好像是把两人的身形投影到画面上一样。"

# game/day 9.rpy:1042
translate chinese_simplified shun09_fighting_41cc727f:

    # "The lever violently clatters in the yellow hand.{p}The brown fingers precisely trace the arrow buttons.{p}"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 303)
    "那双黄色的手正相当粗暴地操纵着控制器。茶色的手指则是正确地按压着方向键。"

# game/day 9.rpy:1043
translate chinese_simplified shun09_fighting_01092cdb:

    # "Brute force is just toyed around with\nby effective tight turns."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 305)
    "相对于用力量压制对手的方式，这里则是用技巧巧妙地捉弄着对手。"

# game/day 9.rpy:1047
translate chinese_simplified shun09_fighting_9b2071ad:

    # to "「Uoh!!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 310)
    to "【to】「呜喔！！」"

# game/day 9.rpy:1052
translate chinese_simplified shun09_fighting_9c46a1c6:

    # "Just as I thought.{p}Torahiko leans back and yells simultaneously\nwith the loser on the screen."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 317)
    "果然。画面上响起败者悲鸣的同时，虎彦也向后仰倒。"

# game/day 9.rpy:1056
translate chinese_simplified shun09_fighting_c84df733:

    # to "「A-again! Again!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 324)
    to "【to】「再、再一次！　再一次！」"

# game/day 9.rpy:1060
translate chinese_simplified shun09_fighting_f13f080e:

    # su "「Hehe, I'm looking forward to it♪」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 330)
    su "【su】「嘿嘿，请多指教。」"

# game/day 9.rpy:1061
translate chinese_simplified shun09_fighting_e938cb1a:

    # "Then Torahiko continues to receive a beating,{p}which is expanded to 2 people whenever I rush in."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 333)
    "接下来虎彦持续着猛烈的挑战，接着连我也加入一起，最后，今天也是由峻君大胜来做结束。"

# game/day 9.rpy:1062
translate chinese_simplified shun09_fighting_1cc949fa:

    # "The result ended with a landslide victory\nfor Shun-kun today."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 335)
    "结果，在今天也是由峻君获得大胜。"

# game/day 9.rpy:1071
translate chinese_simplified shun09_puzzle_21711df3:

    # fn "「This won't be too hard. I should be able\n to learn the rules fairly quickly.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 345)
    fn "【fn】「不是很难的，能够很快地就想起该怎么玩比较好啊。」"

# game/day 9.rpy:1075
translate chinese_simplified shun09_puzzle_9947d81a:

    # su "「Well then, here.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 351)
    su "【su】「那么，这个。」"

# game/day 9.rpy:1076
translate chinese_simplified shun09_puzzle_e185235a:

    # fn "「Ooh!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 354)
    fn "【fn」「喔喔！」"

# game/day 9.rpy:1077
translate chinese_simplified shun09_puzzle_bdf25303:

    # "Make a nice gap, casually insert a stick,\nand clear a line.{w} Loved throughout the world,\nthis is Falling Mono Block Puzzle."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 357)
    "依据自己的喜好做出洞穴后，将棒子插入来将整列消除。世界中广为众人喜爱的，俄罗斯方块就这么登场了。"

# game/day 9.rpy:1081
translate chinese_simplified shun09_puzzle_b50dbb59:

    # su "「Let's battle!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 363)
    su "【su】「让我们来对战吧！」"

# game/day 9.rpy:1082
translate chinese_simplified shun09_puzzle_5eccf00f:

    # fn "「Huh?{w=.3} You play against each other in this?」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 366)
    fn "【fn」「咦？{w=.3}　这种游戏可以对战吗？」"

# game/day 9.rpy:1083
translate chinese_simplified shun09_puzzle_8a73400e:

    # "I was under the impression that this was a game\nwhere you challenge your own limits alone."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 369)
    "这游戏完全就是给人一种，设计给自己一个人玩挑战自我极限的游戏啊。"

# game/day 9.rpy:1087
translate chinese_simplified shun09_puzzle_1072b4c4:

    # su "「Yeah!{w=.3} You send blocks into your\n opponent's field and use techniques.{p} Whoever's stack fills up first loses.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 375)
    su "【su】【可以啊！{w=.3}　可以使用技能，把方块送入对方的区域内。被堆满的那一方就输了。」"

# game/day 9.rpy:1088
translate chinese_simplified shun09_puzzle_188320fd:

    # "Huh.{p}I didn't think that the era where you use\nspecial techniques in puzzle games had come."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 380)
    "这样啊。完全没有想到益智游戏也到了可以使用必杀技的时代了啊。"

# game/day 9.rpy:1089
translate chinese_simplified shun09_puzzle_611312f5:

    # fn "「Alright. Now that I know the rules,\n I feel safe even if we're starting right away.{p} I won't lose!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 384)
    fn "【fn」「好。因为已经知道规则了所以马上开始也没关系。我是不会输的喔！」"

# game/day 9.rpy:1093
translate chinese_simplified shun09_puzzle_02222463:

    # su "「I won't lose either!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 390)
    su "【su】「我也是不会输的！」"

# game/day 9.rpy:1104
translate chinese_simplified shun09_puzzle_c99ddd3e:

    # "Utter defeat.{p}More blocks rose up and I had lost."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 416)
    "惨败。整理方块的速度完全跟不上掉落的速度。"

# game/day 9.rpy:1108
translate chinese_simplified shun09_puzzle_c489ab4d:

    # su "「Victory!」{nw}"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 424)
    su "【su】【我赢了！」{nw}"

# game/day 9.rpy:1109
translate chinese_simplified shun09_puzzle_f6a3f372:

    # "Some time ago, I took a quick side glance\nat Shun-kun's button handling.{p}It wasn't natural."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 427)
    "在刚才偷偷地看了一眼峻君的操作，完全不正常啊。"

# game/day 9.rpy:1110
translate chinese_simplified shun09_puzzle_771d5587:

    # "The moment he pushed the up button,\nthe blocks fell."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 429)
    "都是在一瞬间就将方块落下。"

# game/day 9.rpy:1111
translate chinese_simplified shun09_puzzle_373347a3:

    # fn "「Sh{w=.3}-Shun-kun, you're good at this, aren't you?{p} I didn't stand a chance...{p} Isn't there an opponent that can beat you?」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 431)
    fn "【fn】【峻君，还真是熟练啊，我完全没有胜算啊……话说回来，这附近应该没有人能赢得了峻吧？」"

# game/day 9.rpy:1112
translate chinese_simplified shun09_puzzle_593365ed:

    # "I think through all of my childhood friends.{p}Somebody better than Shun-kun... hmm.{p}Kounosuke might be unexpectedly strong."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 436)
    "就算依序地回想了每一位幼驯染，但是比峻君还要厉害的人啊……嗯。孝之助意外的是很厉害的吧。"

# game/day 9.rpy:1116
translate chinese_simplified shun09_puzzle_d4745866:

    # su "「Father is better than me.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 443)
    su "【su】【父亲比我还要更加厉害。」"

# game/day 9.rpy:1117
translate chinese_simplified shun09_puzzle_7bd31c4e:

    # "What!? A nearby ambush!"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 446)
    "什么！　居然是在这么近的地方吗！"

# game/day 9.rpy:1121
translate chinese_simplified shun09_puzzle_74e00297:

    # su "「He pretty much only plays this game though.\n I've never been able to beat him.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 451)
    su "【su】【父亲的操作方式，速度一直都是这么快，我完全没有赢过啊。」"

# game/day 9.rpy:1125
translate chinese_simplified shun09_puzzle_1e16f7fe:

    # su "「I asked him about it.\n When the first machine was put in the arcade,\n he was really addicted to it」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 458)
    su "【su】【有听父亲说过，第一代的电玩机台出现在游戏中心时，就喜欢上这种游戏了。」"

# game/day 9.rpy:1126
translate chinese_simplified shun09_puzzle_ae21b8c4:

    # "Wow.{p}He was shown the experience of an old gamer?"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 463)
    "呜哇。没想到是老练的老玩家了啊。"

# game/day 9.rpy:1127
translate chinese_simplified shun09_puzzle_9873e948:

    # "Shun-kun has inherited the spirit of the blocks.{p}It was a crappy day for me in the end,\nI couldn't compete with him at all."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 466)
    "峻君也遗传了这俄罗斯方块之魂吧。结果在那一天，我始终没有任何获胜的机会。"

# game/day 9.rpy:1136
translate chinese_simplified shun09_oldgame_c914f677:

    # fn "「Back then there was a game\n I'd come to your house to play,\n I want to see if it might be here.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 477)
    fn "【fn】【在以前，我在你家玩的那个游戏，如果游戏还在的话想看看啊。」"

# game/day 9.rpy:1137
translate chinese_simplified shun09_oldgame_c428aad4:

    # su "「Alright.\n Please wait a minute♪」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 484)
    su "【su】【我知道了。请稍等一下。」"

# game/day 9.rpy:1141
translate chinese_simplified shun09_oldgame_16341899:

    # "He exits the living room,\nand seems to go to his room upstairs."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 491)
    "峻君离开了客厅，看样子是去二楼的自己房间的样子。"

# game/day 9.rpy:1145
translate chinese_simplified shun09_oldgame_367f2c83:

    # su "「Do you remember this?」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 497)
    su "【su】【你还记得这个吗？」"

# game/day 9.rpy:1146
translate chinese_simplified shun09_oldgame_1eb281c3:

    # "He shows me the thing he brought.{p}I think it's a retro paper box. There are characters\nlike medieval knights and wizards printed on it."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 500)
    "我看了看峻君所拿来的东西。从包装相当复古的箱子中取出来的东西，上面描绘有中世纪的骑士和魔法使般的角色。"

# game/day 9.rpy:1147
translate chinese_simplified shun09_oldgame_cbc46135:

    # "Hmm?{p}Although I do recall something like this\nin the corner of my head,{w} I can't remember."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 504)
    "晤晤？在记忆的角落，似乎有看过这个东西的记忆在。但是想不起来啊。"

# game/day 9.rpy:1148
translate chinese_simplified shun09_oldgame_34067c31:

    # su "「Back then I couldn't find my way\n through the dungeons.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 508)
    su "【su】【以前，有一个完全不知道该怎么走的迷宫在。」"

# game/day 9.rpy:1152
translate chinese_simplified shun09_oldgame_303317c5:

    # su "「When I asked you for help,\n you said 『Let's do it together!』\n and did the mapping for me.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 514)
    su "【su】【我把这件事和你说了之后，你对我说『那我们一起玩吧』。然后你帮我画了地图。」"

# game/day 9.rpy:1153
translate chinese_simplified shun09_oldgame_9d832064:

    # "Oh yeah, if I'm not mistaken I'd sit next\nto Shun-kun and copy the way through the caves\nwith a pencil while watching the screen."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 519)
    "是啊，自己确实在峻君的旁边，看着画面并且把洞窟内的道路用铅笔画了下来。"

# game/day 9.rpy:1154
translate chinese_simplified shun09_oldgame_4a96c487:

    # su "「Here's this.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 522)
    su "【su】【就是这个。」"

# game/day 9.rpy:1155
translate chinese_simplified shun09_oldgame_1b5566cf:

    # "A large, colorful insert that comes out\nof the box with the instructions.{p}If you gently open the folded up back side,"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 525)
    "跟着说明书从箱子中一起拿出来的是，颜色已经变了的超市的宣传单。打开了折叠了的宣传单，"

# game/day 9.rpy:1156
translate chinese_simplified shun09_oldgame_2acb0fb9:

    # "there are poorly-written characters,\nand things like maps and charts with pictures."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 529)
    "里面是用丑丑的文字，跟称不上是画或是图的图案所构成的地图。"

# game/day 9.rpy:1157
translate chinese_simplified shun09_oldgame_fe14ebe6:

    # "After that, there are pictures\nof monsters where the layout collapsed."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 531)
    "然后是画得乱七八糟的怪物配置图。"

# game/day 9.rpy:1158
translate chinese_simplified shun09_oldgame_0b387992:

    # "I remember!"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 533)
    "想起来了啊！"

# game/day 9.rpy:1159
translate chinese_simplified shun09_oldgame_1dfc07dd:

    # fn "「You kept that?{p} This is kind of embarrassing...\n Ah, I made a mistake with that character.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 535)
    fn "【fn】【你还留着吗？这个，有点让人不好意思啊……啊，这个字，还写错了。」"

# game/day 9.rpy:1163
translate chinese_simplified shun09_oldgame_a16b1b27:

    # su "「[fn]-san...{p} {nw}"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 540)
    su "【su】【[fn]-san...{p} {nw}"

# game/day 9.rpy:1165
translate chinese_simplified shun09_oldgame_e691c394:

    # extend "You remembered this game for me, I'm so happy♪」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 543)
    extend "【su】【你能记得这个游戏我真的很高兴啊。」"

# game/day 9.rpy:1169
translate chinese_simplified shun09_oldgame_c27edacd:

    # su "「We got lost in the end.\n When it was time to stop playing, we couldn't save.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 549)
    su "【su】【最后我们还是迷路了，在没有办法储存的状态下游戏的时间就结束了。」"

# game/day 9.rpy:1170
translate chinese_simplified shun09_oldgame_f974e7a8:

    # "An hour a day game."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 553)
    "玩游戏一天是一个小时。"

# game/day 9.rpy:1171
translate chinese_simplified shun09_oldgame_3d451276:

    # "I look and see \"entrance\" there, but no \"exit\".{p}Looks like we got really confused."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 555)
    "看那张地图，上面有写「入口」可是却没有写「出口」。看来我和峻君最后还是迷了路的样子。"

# game/day 9.rpy:1172
translate chinese_simplified shun09_oldgame_8471b62e:

    # "The same path had been drawn 5 or 6 times\nin overlapping black lines."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 557)
    "同样的道路上，黑色的线重复画了五六次。"

# game/day 9.rpy:1173
translate chinese_simplified shun09_oldgame_3814f234:

    # fn "「We did that?」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 559)
    fn "【fn】【是这样吗？」"

# game/day 9.rpy:1177
translate chinese_simplified shun09_oldgame_2e031fa0:

    # su "「Yeah. Both of us got sad and cried.{p} When father came to see what happened,\n he asked us, 『Are you fighting?』」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 565)
    su "【su】【是的。然后，因为很伤心的关系我们两个人都哭了。过来看我们怎么样的父亲还问了我们『是吵架了吗？』」"

# game/day 9.rpy:1178
translate chinese_simplified shun09_oldgame_73a70b08:

    # fn "「Hahaha, that's embarrassing too.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 570)
    fn "【fn】【哈哈哈，那真是让人不好意思啊。」"

# game/day 9.rpy:1182
translate chinese_simplified shun09_oldgame_26901d2f:

    # su "「After that I didn't play it for a while.{p} It stayed in the back of a drawer for a long time,{p} but after you left I started it again.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 576)
    su "【su】【在那之后，有一段时间都没有把它拿出来玩，就只是一直放在抽屉里面。不过，从你搬离水乡村之后，就又把它拿出来玩。」"

# game/day 9.rpy:1186
translate chinese_simplified shun09_oldgame_d1e2d828:

    # su "「I made it out of the dungeon and cleared it.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 583)
    su "【su】【那时就有好好的，通过那个迷宫，顺利地全破了。」"

# game/day 9.rpy:1187
translate chinese_simplified shun09_oldgame_9fcef45e:

    # fn "「Really?{w} Didn't you want to throw away\n these sloppy notes that weren't helpful at all?」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 586)
    fn "【fn】【这样啊。不过，这么破旧的地图，一点帮助也没有，扔了不是比较好吗？」"

# game/day 9.rpy:1188
translate chinese_simplified shun09_oldgame_bb07f125:

    # "These crude characters and lopsided pictures\nare evidence of myself in those days.{p}It feels half charming, half embarrassing."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 591)
    "难看的字和糟糕的图画，是那个时候我的存在的证明。愉快的心情跟不好意思的感觉是参半的。"

# game/day 9.rpy:1192
translate chinese_simplified shun09_oldgame_0accdf39:

    # su "「N-{w=.3}no way!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 598)
    su "【su】【[fn]-san... 不行！」"

# game/day 9.rpy:1196
translate chinese_simplified shun09_oldgame_2cc43601:

    # su "「It's a memory. Of you and me.」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 600)
    su "【su】【这是一个回忆。是属于你跟我的回忆。」"

# game/day 9.rpy:1197
translate chinese_simplified shun09_oldgame_7cd3b7bf:

    # "He places it on his lap and lovingly gazes\nat the scrap of paper."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 602)
    "他把那张纸放在膝上，用充满爱意的眼神凝视着那张纸片。"

# game/day 9.rpy:1198
translate chinese_simplified shun09_oldgame_b1a74a9d:

    # "That scrap of paper distracts him for a short time\nwhenever he feels sad about me being gone."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 604)
    "那张纸片每当因为我不在而感到悲伤时，都能给他短暂的慰藉。"

# game/day 9.rpy:1199
translate chinese_simplified shun09_oldgame_c6a31135:

    # "Even those poor illustrations\nwere helpful to him..."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 606)
    "即使是那些糟糕的插图，对他来说都有帮助啊......"

# game/day 9.rpy:1200
translate chinese_simplified shun09_oldgame_d643b79f:

    # fn "「Hey, do you want to play that game?」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 608)
    fn "【fn】【喂，你想玩那个游戏吗？」"

# game/day 9.rpy:1204
translate chinese_simplified shun09_oldgame_697c64c7:

    # su "「Yes!」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 610)
    su "【su】【好！」"

# game/day 9.rpy:1205
translate chinese_simplified shun09_oldgame_db33eeb3:

    # "A small cartridge connected us here on that day.{p}In the time we were separated,\nthe switch is turn on."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 612)
    "在那一天，一盘小小的卡带将我们连接在一起。在我们分开的时间里，开关被打开了。"

# game/day 9.rpy:1211
translate chinese_simplified shun09_oldgame_3e636d72:

    # "{cps=15}Journal 1 has been lost{p}{nw}"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 614)
    "{cps=15}日志1已遗失{p}{nw}"

# game/day 9.rpy:1213
translate chinese_simplified shun09_oldgame_2ee746eb:

    # extend "{cps=15}Journal 2 has been lost{p}{nw}"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 616)
    extend "【日志2已遗失{p}{nw}"

# game/day 9.rpy:1215
translate chinese_simplified shun09_oldgame_a2aa5bf5:

    # extend "{cps=15}Journal 3 has been lost"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 618)
    extend "【日志3已遗失"

# game/day 9.rpy:1216
translate chinese_simplified shun09_oldgame_7b3eeaf9:

    # "{cps=15}Sorry."
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 620)
    "{cps=15}抱歉。"

# game/day 9.rpy:1220
translate chinese_simplified shun09_oldgame_8bd97340:

    # su "「...」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 622)
    su "【su】【……」"

# game/day 9.rpy:1221
translate chinese_simplified shun09_oldgame_00b00233:

    # fn "「...」"
    # [旧版翻译] 来源: extract/orig/峻_s_07.ks (KS 624)
    fn "【fn】【……」"

# game/day 9.rpy:1238
translate chinese_simplified shin09_793049a1:

    # "So I was out on another walk in the village\nwhen I noticed a figure entering into the forest."
    # [旧版翻译] 来源: 深_m_03.ks (KS 12-13)
    "闲着没事在村子里散步的时候，突然看到有人影走进了森林里。"

# game/day 9.rpy:1251
translate chinese_simplified shin09_e874d884:

    # "Shin-kun?{p}Well, I think so at least..."
    # [旧版翻译] 来源: 深_m_03.ks (KS 29-30)
    "深君？[l]虽、虽然看到他了……"

# game/day 9.rpy:1252
translate chinese_simplified shin09_6916d87c:

    # "I didn't even have time to call out\nas a backpack-carrying little figure\ndisappeared inside."
    # [旧版翻译] 来源: 深_m_03.ks (KS 32-34)
    "还没时间出声叫他，那个背着小小的背包的某人就走进森林里消失了。"

# game/day 9.rpy:1256
translate chinese_simplified shin09_833df2e3:

    # "What could there be to do in the woods?{p}Foraging for edibles...?{w} That can't be.{p}But still, is it okay for them to go in alone?"
    # [旧版翻译] 来源: 深_m_03.ks (KS 38-40)
    "为什么会跑进森林里啊？[l]去采野菜……？[l] 不可能吧。[l]而且一个人进去，这样没问题吗？"

# game/day 9.rpy:1268
translate chinese_simplified shin09_follow_41816aea:

    # "I guess I should go after them.{p}I don't know if it really was Shin-kun,\nbut if it is him, it's dangerous to go alone."
    # [旧版翻译] 来源: 深_m_03.ks (KS 57-59)
    "还是追上去看看吧。[l]虽然不太确定刚刚看到的是不是深君，但如果是深君的话让他一个人进去森林也很危险。"

# game/day 9.rpy:1277
translate chinese_simplified shin09_follow_0cfab08f:

    # "At any rate, the weeds here are amazing."
    # [旧版翻译] 来源: 深_m_03.ks (KS 70-70)
    "这里的杂草长得还真高耶。[l]"

# game/day 9.rpy:1278
translate chinese_simplified shin09_follow_f592da6a:

    # "There's probably enough to keep people out,\nbut I slowly pushed my way in through\nthe animal trail into the forest."
    # [旧版翻译] 来源: 深_m_03.ks (KS 72-72)
    "慢慢地向森林的深处前进。"

# game/day 9.rpy:1279
translate chinese_simplified shin09_follow_1673d07a:

    # "I never came in here back in the days,\nbut it still feels like I got lost in a new place."
    # [旧版翻译] 来源: 深_m_03.ks (KS 74-75)
    "虽然以前很常跑进这个森林来玩，但现在感觉起来简直就是在不同的地方迷路了似的。"

# game/day 9.rpy:1280
translate chinese_simplified shin09_follow_d423b270:

    # "No wait,{w=.3} I think I *am*\ncompletely lost in a new place."
    # [旧版翻译] 来源: 深_m_03.ks (KS 77-77)
    "不，应该确实就是不同的地方吧。[l]"

# game/day 9.rpy:1281
translate chinese_simplified shin09_follow_18255485:

    # "When we played in the forest\nwe entered from somewhere else\nso I'm stuck relying on the animal trail alone."
    # [旧版翻译] 来源: 深_m_03.ks (KS 79-79)
    "是沿着不同的兽径进去的。"

# game/day 9.rpy:1282
translate chinese_simplified shin09_follow_0df95cdf:

    # "...{w} even so, it's pretty hot.{p}The trees' foliage blocked some of the sunlight's\nwarmth, but on the other hand it's humid."
    # [旧版翻译] 来源: 深_m_03.ks (KS 81-83)
    "……[l]而且真的好热。[l]虽然夏日的烈阳被树叶给遮住了，但取而代之的是异常的闷热感。"

# game/day 9.rpy:1283
translate chinese_simplified shin09_follow_755aa110:

    # "With that in the rustic air,\nthe moisture is killing me."
    # [旧版翻译] 来源: 深_m_03.ks (KS 85-87)
    "带著土臭又很潮湿的空气让人感觉相当不舒服。[l]再加上，老是被杂草绊到脚啦、踩到小石头啦、道路也很凹凸不平，有时候还会差点滑倒。"

# game/day 9.rpy:1284
translate chinese_simplified shin09_follow_bebe7f8c:

    # "So far, I'm buried in the weeds,\ntripping on rocks, walking on an uneven path,\nand sometimes sliding in mud."
    # [旧版翻译] 来源: 深_m_03.ks (KS 89-90)
    "奇差无比的道路，还有这不舒服的空气，让[漏れ]的体力以比想像中快得多的速度在流失。"

# game/day 9.rpy:1285
translate chinese_simplified shin09_follow_62bb5f01:

    # "The merciless path and the heavy uncomfortable\natmosphere have steadily been cutting\naway at my stamina."
    # [旧版翻译] 来源: 深_m_03.ks (KS 92-94)
    "森林的味道明明应该多少有些怀念的，会只觉得不舒服，到底是因为疲劳的关系，[wdt]还是因为[漏れ]已经习惯了都市的空气的关系呢。"

# game/day 9.rpy:1286
translate chinese_simplified shin09_follow_3bc26eec:

    # "This is supposed to be a nostalgic scent for me,\nso maybe it's because of the fatigue I'm hating it,{w=.3}\nor maybe it's because I'm used to the city air now."
    # [旧版翻译] 来源: 深_m_03.ks (KS 97-97)
    "「[wds]呼……呼……[rd]」"

# game/day 9.rpy:1287
translate chinese_simplified shin09_follow_b6ac0ae8:

    # fn "「{cps=10}*huff*... *huff*...」"
    # [原版缩写] 来源: 深_m_03.ks (KS 99-101)
    fn "就连呼吸都觉得很郁闷。[l]衣服因为汗跟湿气而黏在身体上的感觉也很让人不舒服。[l]丛生的杂草味道也超臭的。"

# game/day 9.rpy:1288
translate chinese_simplified shin09_follow_853af8a4:

    # "I could feel how heavy each breath was.{p}Between the sweat and humidity my clothes\nwere so uncomfortable."
    # [旧版翻译] 来源: 深_m_03.ks (KS 103-103)
    "这种凹凸不平的路面实在让人生气。[l]"

# game/day 9.rpy:1289
translate chinese_simplified shin09_follow_b8d7d372:

    # "I'm fighting with the overgrown weeds in every way.\nI only remember the uneven ground\nas being a pain in the ass."
    # [旧版翻译] 来源: 深_m_03.ks (KS 105-105)
    "拔断杂草再丢掉的动作，正巧成了足以支撑身体的前进方式。"

# game/day 9.rpy:1290
translate chinese_simplified shin09_follow_24f37802:

    # "I grabbed the weeds trying to vent my anger out,\nand somehow it supported me as I tore off on ahead."
    # [旧版翻译] 来源: 深_m_03.ks (KS 107-109)
    "……那个，真的是深君吗？[l]深君平常应该也没怎么运动，这种道路，一般人是没办法走的。"

# game/day 9.rpy:1291
translate chinese_simplified shin09_follow_5c2d484c:

    # "...I wonder if it really was Shin-kun?{p}He's not really the type to exercise much,\nand this isn't a path any normal person would take."
    # [旧版翻译] 来源: 深_m_03.ks (KS 111-113)
    "而且，那种不知道能不能称为入口的杂草缺口，如果不是很熟悉这森林的人，也不会从那种地方进来吧。"

# game/day 9.rpy:1292
translate chinese_simplified shin09_follow_95e8c14d:

    # "For starters, that gap in the grass isn't a real\nentrance, and no one who doesn't really know this\nforest in and out would really go in{w=.3}, right?"
    # [旧版翻译] 来源: 深_m_03.ks (KS 120-120)
    "「唔哇！」"

# game/day 9.rpy:1297
translate chinese_simplified shin09_follow_c761931e:

    # fn "「Wah!」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 120)
    fn "【主人公】\n「哇！」"

# game/day 9.rpy:1298
translate chinese_simplified shin09_follow_d86d82a9:

    # "It seems like I slipped on the ground."
    # [旧版翻译] 来源: 深_m_03.ks (KS 126-126)
    "该怎么办。"

# game/day 9.rpy:1299
translate chinese_simplified shin09_follow_2f173a15:

    # "Even though there was a tree to keep me\nfrom falling, I'm just about tapped out,\nand a break is sounding good."
    # [旧版翻译] 来源: 深_m_03.ks (KS 170-170)
    "总、总之，真的撑不住了。[l]"

# game/day 9.rpy:1300
translate chinese_simplified shin09_follow_ec012af7:

    # "What should I do?"
    # [旧版翻译] 来源: 深_m_03.ks (KS 172-172)
    "就地坐了下来。"

# game/day 9.rpy:1331
translate chinese_simplified shin09_rest_876314b9:

    # "W-well, it's useless to continue now.{p}I tried looking for a nice looking place\nand settled on the loose ground."
    # [旧版翻译] 来源: 深_m_03.ks (KS 176-176)
    "这、这种路，深君应该是不可能走得了吧。[l]"

# game/day 9.rpy:1335
translate chinese_simplified shin09_rest_08ca32ab:

    # "T-there's no way Shin-kun could be here.{p}Since I'm almost at my limit,\nI don't know how he could ever go down this way."
    # [旧版翻译] 来源: 深_m_03.ks (KS 178-178)
    "要说那个深君能够在这种路上走实在很难想像。"

# game/day 9.rpy:1336
translate chinese_simplified shin09_rest_0ec46105:

    # "In that case,\ndid I really mistake my eyes earlier?"
    # [旧版翻译] 来源: 深_m_03.ks (KS 180-181)
    "也就是说，刚刚真的是看错了吗？[l]不，应该说也只能这样想了。"

# game/day 9.rpy:1337
translate chinese_simplified shin09_rest_f118e824:

    # "No,{w=.3} I can't think of any other possibility.\nBesides, if someone came here\nwouldn't they leave a better trail?"
    # [旧版翻译] 来源: 深_m_03.ks (KS 183-185)
    "而且，如果这是平常会有人走的路的话，应该肯定会留下点痕迹才对吧？[l]但是这里怎么看，都只是称不上道路的兽径。"

# game/day 9.rpy:1338
translate chinese_simplified shin09_rest_b71f7116:

    # "If there was something like that,\nthis path couldn't even be an animal trail."
    # [旧版翻译] 来源: 深_m_03.ks (KS 187-188)
    "不管怎么想都不可能。[l]不可能就是不可能。"

# game/day 9.rpy:1339
translate chinese_simplified shin09_rest_cf0f0b50:

    # "It's impossible no matter how I think about it.{p}Impossible, completely impossible."
    # [旧版翻译] 来源: 深_m_03.ks (KS 190-192)
    "虽然多少还是会担心深君会不会[wdt]真的跑进森林里迷路了，[漏れ]还是一直跟自己说这不可能，然后往回走了回去。"

# game/day 9.rpy:1340
translate chinese_simplified shin09_rest_115236da:

    # "If Shin-kun was lost in this forest,{w=.3}\nor so I reluctantly thought,\nI would constantly warn myself about it."
    # [旧版翻译] 来源: 深_m_03.ks (KS 201-203)
    "回去的路，[l]毫无悬念地找不到了。好不容易穿过森林出来后，全身都酸痛疲劳到快瘫在地上了。"

# game/day 9.rpy:1348
translate chinese_simplified shin09_rest_f3529c21:

    # "The way back,{w} and the way I made by getting here,\nI've lost track of both. And when I was taken out\nof the forest I was completely exhausted."
    # [旧版翻译] 来源: 深_m_03.ks (KS 205-207)
    "明天肯定会全身酸痛而痛苦不堪吧。[l]为了保险，回家打了电话给深君，结果他说他没有去过森林。"

# game/day 9.rpy:1349
translate chinese_simplified shin09_rest_a74ae075:

    # "I'll probably have terrible muscle aches tomorrow."
    # [旧版翻译] 来源: 深_m_03.ks (KS 209-211)
    "……身上被蚊子叮了一堆包，鞋子沾满了泥巴，被草刮伤的地方痛得要死，全身都肌肉酸痛，今天怎么能这么惨啊――！！"

# game/day 9.rpy:1350
translate chinese_simplified shin09_rest_2cc29dca:

    # "I will also definitely try calling\nShin-kun's house later, and I'm sure I'll\nget an answer saying he didn't go in."
    # [旧版翻译] 来源: 深_m_03.ks (KS 223-224)
    "「深君――！[l]喂――！ 在的话就回答一下――！」"

# game/day 9.rpy:1351
translate chinese_simplified shin09_rest_0c725d7f:

    # "...between all the mosquito bites, my muddy shoes,\nsoreness where the grass brushed against me,\nand all the soreness, today has been the worst!"
    # [旧版翻译] 来源: 深_m_03.ks (KS 227-227)
    "……但是，却没有人回应。"

# game/day 9.rpy:1360
translate chinese_simplified shin09_call_3bc496e6:

    # fn "「Shin-kuuun!{p} If you're here, answer me!」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 1123)
    fn "【主人公】「深君！　深君！」"

# game/day 9.rpy:1361
translate chinese_simplified shin09_call_84f99e4f:

    # "I yelled out as loud as I could into the forest.{p}...however, there was no answer."
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 226-227)
    "[漏れ]尽可能地在森林里大声喊着深君的名字。[l]……但是，却没有人回应。"

# game/day 9.rpy:1362
translate chinese_simplified shin09_call_d6506ba8:

    # "N-{w=.3}...no more...{p}{nw}"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 229)
    "不……不行了……[l]"

# game/day 9.rpy:1364
translate chinese_simplified shin09_call_7fa2898d:

    # extend "I dragged myself over."
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 230)
    extend "没办法，最后[漏れ]还是忍不住就地坐了下来。"

# game/day 9.rpy:1369
translate chinese_simplified shin09_call_467a3b7b:

    # "The stirring of the trees,{p}the buzzing of the insects,{p}the cries of the birds and animals."
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 235-237)
    "树叶的飒飒声、虫鸣声、鸟和小动物的叫声。[l]除此之外就没有别的声音了。[l]忽然觉得不安了起来。"

# game/day 9.rpy:1370
translate chinese_simplified shin09_call_4a7b1e61:

    # "I could hear nothing else.{p}Suddenly, I felt so anxious."
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 241-243)
    "虽然印象中以前常常来森林玩，但是这个地方，好像完全没印象。[l]该不会跑到森林的深处去了吧？"

# game/day 9.rpy:1374
translate chinese_simplified shin09_call_dd606954:

    # "I've always made light of the place\nI played in back then, but do I\nhave any memories of this place?"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 247-249)
    "沿着这种完全没道理的小路走来的，要是回去时迷了路的话……？[l]不，该不会，其实已经迷路了吧？"

# game/day 9.rpy:1375
translate chinese_simplified shin09_call_111fa5e8:

    # "Or maybe memories of coming in this deep?"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 254-256)
    "森林里安静到让人紧张，害[漏れ]渐渐不安了起来。[l]在不断想着该怎么办的同时，不小心就忍不住一直往不好的方向去想了。"

# game/day 9.rpy:1379
translate chinese_simplified shin09_call_e005a4a5:

    # "I followed this inscrutable path,\nbut could I have lost the way back...?{p}No wait, aren't I lost already?"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 260-262)
    "只是散步到一半就跑来的，手边什么都没有。[l]水跟食物都没有，也没有什么可以当武器的东西。[l][bgm stop=2000]该怎么办。[l]要是受到野生动物的攻击的话……"

# game/day 9.rpy:1384
translate chinese_simplified shin09_call_f1e3b65b:

    # "My agitation was worsening in this eerie forest."
    # [旧版翻译] 来源: 深_m_03.ks (KS 283-283)
    "「[wdm]深……[rd]君[wdm]……？[rd]」"

# game/day 9.rpy:1385
translate chinese_simplified shin09_call_c2b98508:

    # "I tried not to think about it\nas best I could, but whenever I strayed\nto the negative it got worse."
    # [旧版翻译] 来源: 深_m_03.ks (KS 293-293)
    "「你在做什么啊？ 跑来这种地方。」"

# game/day 9.rpy:1389
translate chinese_simplified shin09_call_c571909f:

    # "Since I went on a random walk,\nI have nothing on hand.{p}Food and water of course,"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 312)
    "【深】「追过来？[l] 为什么？」"

# game/day 9.rpy:1390
translate chinese_simplified shin09_call_5c53b0be:

    # "but I need something I could wield.{p}{nw}"
    # [旧版翻译] 来源: 深_m_03.ks (KS 302-303)
    "所、所以说这里不是很危险的地方吗！[l]深君这个笨蛋！"

# game/day 9.rpy:1392
translate chinese_simplified shin09_call_8ad24ae9:

    # extend "What should I do?{p}If I was attacked by a wild animal..."
    # [旧版翻译] 来源: 深_m_03.ks (KS 306-307)
    extend "「看到你进入森林所以就追着过来了，但是找不到深君，道路又很差，结果就迷路了。」"

# game/day 9.rpy:1400
translate chinese_simplified shin09_call_163c6e20:

    # "{size=+15}Hiee-!"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 269-269)
    "「哇！！」"

# game/day 9.rpy:1401
translate chinese_simplified shin09_call_94e58688:

    # "Suddenly I heard sounds from the side,\nand I felt completely afraid.{p}As I instinctually back away I saw..."
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 271-272)
    "「突然间草丛间传出声音，害[漏れ]整个人被吓得全身僵直。[l]连忙退后几步之后，出现在[漏れ]眼前的却是，」"

# game/day 9.rpy:1405
translate chinese_simplified shin09_call_56822605:

    # si "「...{p}[fn]?」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 322)
    si "「……{p}[fn]？」"

# game/day 9.rpy:1406
translate chinese_simplified shin09_call_c7d659a4:

    # "What...?"
    # [旧版翻译] 来源: 深_m_03.ks (KS 325-325)
    "「这不是当然的吗！」"

# game/day 9.rpy:1407
translate chinese_simplified shin09_call_437d9c1f:

    # fn "「{cps=10}Shin...{cps=40}kun{cps=10}...?」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 278-278)
    fn "「[博行]……？」"

# game/day 9.rpy:1415
translate chinese_simplified shin09_call_4f4ca500:

    # si "「What are you doing in a place like this?」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 341-341)
    si "「诶……[l]不，这个是。」"

# game/day 9.rpy:1416
translate chinese_simplified shin09_call_4d20e7c1:

    # fn "{size=+15}「THAT'S WHAT I WANTED TO\n ASK！」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 296)
    fn "【主人公】「[fbig]「这是[漏れ]该说的话吧！」"

# game/day 9.rpy:1417
translate chinese_simplified shin09_call_82d93b7b:

    # "Out coming from the grass was the figure\nI saw earlier for a moment going into the forest,\nthe backpack-carrying Shin."
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 337-338)
    "【深】「可是，要是你自己迷路了的话，不就没意义了吗？」"

# game/day 9.rpy:1418
translate chinese_simplified shin09_call_62824914:

    # "I-I was almost about to cry!{p}Stupid Shin-kun!"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 306-307)
    "【主人公】「看到你进入森林所以就追着过来了，但是找不到深君，道路又很差，结果就迷路了。」"

# game/day 9.rpy:1419
translate chinese_simplified shin09_call_63b61e37:

    # fn "「Even after I thought I saw and came after you,\n I couldn't find you, the path was rocky,\n and I got lost.」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 322)
    fn "【深】「你、你是在担心我吗？」"

# game/day 9.rpy:1423
translate chinese_simplified shin09_call_0f30ab4b:

    # si "「You came after me?{w} Why?」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 325)
    si "【主人公】「这不是当然的吗！」"

# game/day 9.rpy:1424
translate chinese_simplified shin09_call_768faacd:

    # fn "「Well, isn't it dangerous to go\n into the forest alone!?」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 312)
    fn "【深】「追过来？[l] 为什么？」"

# game/day 9.rpy:1428
translate chinese_simplified shin09_call_9f4f782d:

    # si "「You... were worried about me?」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 315-316)
    si "【主人公】「这个，一个人跑进森林里来不是很危险的吗！」"

# game/day 9.rpy:1429
translate chinese_simplified shin09_call_4a19c7fe:

    # fn "「Of course I was!」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 331)
    fn "【深】「……」"

# game/day 9.rpy:1433
translate chinese_simplified shin09_call_bef95801:

    # si "「...」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 378-380)
    si "【深】\n「……」"

# game/day 9.rpy:1437
translate chinese_simplified shin09_call_fcf8b282:

    # si "「But if you get lost yourself,\n then what's the point?」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 382-384)
    si "【深】\n「可是如果你自己迷路了的话，不就没意义了吗？」"

# game/day 9.rpy:1438
translate chinese_simplified shin09_call_291fc528:

    # fn "「Ugh...{w} no, that's...」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 389)
    fn "【fn】\n「呃……不、这个是……」"

# game/day 9.rpy:1439
translate chinese_simplified shin09_call_b1e7d108:

    # "He's hitting where it hurts.{p}It's true, so I can't argue against that."
    # [旧版翻译] 来源: 深_m_03.ks (KS 392)
    "【fn】\n「诶？ 嗯、嗯。」"

# game/day 9.rpy:1443
translate chinese_simplified shin09_call_c331adc7:

    # si "「So I was right?{w} Anyway, from the look of things\n you didn't bring any insect spray?{p} They bite you know.」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 397)
    si "【深】\n「所以我说的对吗？」"

# game/day 9.rpy:1444
translate chinese_simplified shin09_call_948022f0:

    # "Shin-kun pointed at his slim neck\nwith his finger as he said that.{p}When I touched the same area, it was true."
    # [旧版翻译] 来源: 深_m_03.ks (KS 402)
    "【fn】\n「这样？」"

# game/day 9.rpy:1445
translate chinese_simplified shin09_call_565e0434:

    # "There was a bite.\nWait, it's not just there,\nit's all over."
    # [旧版翻译] 来源: 深_m_03.ks (KS 407-408)
    "有被蚊子叮的痕迹。[l]不只这里，到处都是。"

# game/day 9.rpy:1449
translate chinese_simplified shin09_call_4f3562c8:

    # si "「Oh well then.{p} I have some ointment, so wait there.」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 362-363)
    si "【深】\n「真拿你没办法。[l]我有带止痒药膏，别动喔。」"

# game/day 9.rpy:1454
translate chinese_simplified shin09_call_c5c1dfc0:

    # "As he talked, he put down his backpack\nand pulled it out."
    # [旧版翻译] 来源: 深_m_03.ks (KS 427)
    "他放下背包，从里面拿出药膏。"

# game/day 9.rpy:1455
translate chinese_simplified shin09_call_c06ecb51:

    # "He took off the cap,\nsqueezed some onto his fingertip,\nthen rubbed the back of my neck."
    # [旧版翻译] 来源: 深_m_03.ks (KS 430)
    "【fn】\n「谢谢。」"

# game/day 9.rpy:1456
translate chinese_simplified shin09_call_522c4c95:

    # fn "「T-thanks.」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 433)
    fn "【fn】\n「谢、谢谢。」"

# game/day 9.rpy:1457
translate chinese_simplified shin09_call_0f776a6d:

    # "My neck was rubbed by a soft paw pad.{p}That warm gentle feeling was\naccompanied by a ticklish feeling from the fur."
    # [旧版翻译] 来源: 深_m_03.ks (KS 437)
    "【fn】\n「可是因为很痒嘛。」"

# game/day 9.rpy:1458
translate chinese_simplified shin09_call_a4bff3c7:

    # "He was touching my neck,\nbut I got a shiver from just that,\nso if he keeps touching me like this..."
    # [旧版翻译] 来源: 深_m_03.ks (KS 439-441)
    "被摸脖子和背部本来就很容易痒了，而且被那和人不同带着细毛的手指摸，感觉更是痒到不行，光是忍着不出声就很痛苦了。"

# game/day 9.rpy:1462
translate chinese_simplified shin09_call_90957a41:

    # si "「Would you mind standing for a bit?」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 450)
    si "【深】\n「稍微站起来一下好吗？」"

# game/day 9.rpy:1463
translate chinese_simplified shin09_call_77c9d46e:

    # fn "「Huh? O-okay.」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 452-455)
    fn "「对对。[l]而且深君的毛很柔软，所以感觉起来就更痒了。」"

# game/day 9.rpy:1467
translate chinese_simplified shin09_call_998a10a3:

    # si "「Face that way.」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 461)
    si "【深】\n「转过去一下。」"

# game/day 9.rpy:1471
translate chinese_simplified shin09_call_08baf5f8:

    # fn "「Like this?」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 464)
    fn "【fn】\n「这样？」"

# game/day 9.rpy:1475
translate chinese_simplified shin09_call_8d0675ed:

    # si "「Wow, they really did get your back too.{p} Pull up your shirt for me?」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 471)
    si "【深】\n「啊，果然背后也被叮了呢。[l]可以把衣服拉起来吗？」"

# game/day 9.rpy:1476
translate chinese_simplified shin09_call_2e86a80a:

    # "No, you're so bold to do that here\nwhile we're alone Shin-kun..."
    # [旧版翻译] 来源: 深_m_03.ks (KS 475)
    "【fn】\n「啊。」"

# game/day 9.rpy:1479
translate chinese_simplified shin09_call_9085dc97:

    # "Ah, that's-{p}{nw}"
    # [旧版翻译] 来源: 深_m_03.ks (KS 482)
