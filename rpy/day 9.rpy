translate chinese_simplified shin09_shout_0053ed40:

    # extend "yes.」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 1223-1223)
    extend "这个，也就是说，[wdt]深君只是在这里睡午觉而已吗？"

# game/day 9.rpy:1937
translate chinese_simplified shin09_shout_69944d9a:

    # "Uh, then,{w=.3} so Shin-kun was napping?"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 1226-1226)
    "「可是，怎么会把那个背包当成枕头……」"

# game/day 9.rpy:1938
