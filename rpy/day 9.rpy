# game/day 9.rpy:1642
translate chinese_simplified shin09_continue_989e2e33:

    # "Why am I taking this so seriously?{p}I still don't know for sure if it was\nShin-kun I saw before."
    # [旧版翻译] 来源: 深_m_03.ks (KS 830-831)
