    si "【深】\n「……」"

# game/day 9.rpy:1922
translate chinese_simplified shin09_shout_6f2792be:

    # si "「It seems like you misunderstood things\n from the very start.」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 1202-1202)
