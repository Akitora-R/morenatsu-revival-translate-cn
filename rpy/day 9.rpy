# game/day 9.rpy:630
translate chinese_simplified kouya09_37d25cda:

    # "But that was all I took into account.{p}In my haste, I carelessly ignored the forecast."
    # [旧版翻译] 来源: extract/orig/洸哉_s_04.ks (KS 47)
