    fn "【fn】\n「……」"

# game/day 9.rpy:1641
translate chinese_simplified shin09_continue_53ff5c06:

    # "I got up in silence.{w} Yeah,\nI'm really reaching my limit.{w} As I stood up,\nI had to smile a bit when I looked at myself."
