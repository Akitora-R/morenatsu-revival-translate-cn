translate chinese_simplified shin09_shout_1a13f503:

    # "He might have fallen and hit his head.{p}I tried shaking him as best I could without\nmoving his head, and called out to Shin-kun."
    # [旧版翻译] 来源: 深_m_03.ks (KS 1323-1325)
    "简单来说，[l]就是虽然想睡午觉，但是在村子里睡怕会被孝之助给拍下来，所以才特地到这种不会有人的森林中来睡，[wdt]这样。"

# game/day 9.rpy:1888
translate chinese_simplified shin09_shout_b43d2cec:

    # si "「Mm...」"
    # [旧版翻译] 来源: extract/orig/深_m_03.ks (KS 1196)
    si "【深】「……」"

# game/day 9.rpy:1893
translate chinese_simplified shin09_shout_e58456bc:

    # si "「[fn]...?」"
    # [旧版翻译] 来源: 深_m_03.ks (KS 1336-1336)
